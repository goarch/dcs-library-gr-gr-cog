lemcLI.Epistle.title = "Κυριακῇ Πρώτῃ, τῶν Ἁγίων Πάντων"
lemcLI.Epistle.title_abbr = "Κυριακῇ τῶν Ἁγ. Πάντων"
lemcLI.Epistle.version = properties_gr_GR_cog.version.designation
