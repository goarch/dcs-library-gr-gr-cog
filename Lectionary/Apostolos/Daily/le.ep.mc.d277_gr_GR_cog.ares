lemcLI.Epistle.title = "Τῇ Τετάρτῃ τῆς ΚΓʹ Ἑβδομάδος"
lemcLI.Epistle.title_abbr = "Τετάρτῃ τῆς ΚΓʹ Ἑβδομάδος"
