lemcLI.Epistle.title = "Τῇ Τετάρτῃ τῆς ΙϚʹ Ἑβδομάδος"
lemcLI.Epistle.title_abbr = "Τετάρτῃ τῆς ΙϚʹ Ἑβδομάδος"
lemcLI.Epistle.version = properties_gr_GR_cog.version.designation
