lemcLI.Epistle.title = "Τῇ Πέμτῃ τῆς ΚΘʹ Ἑβδομάδος"
lemcLI.Epistle.title_abbr = "Πέμτῃ τῆς ΚΘʹ Ἑβδομάδος"
