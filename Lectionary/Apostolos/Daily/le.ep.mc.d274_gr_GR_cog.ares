lemcLI.Epistle.title = "Κυριακῇ Εἰκοστῇ Δευτέρᾳ"
lemcLI.Epistle.title_abbr = "Κυριακῇ ΚΒʹ"
lemcLI.Epistle.version = properties_gr_GR_cog.version.designation
