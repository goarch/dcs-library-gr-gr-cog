lemcLI.Epistle.title = "Τῇ Δευτέρᾳ τῆς ΙΒʹ Ἑβδομάδος"
lemcLI.Epistle.title_abbr = "Δευτέρᾳ τῆς ΙΒʹ Ἑβδομάδος"
