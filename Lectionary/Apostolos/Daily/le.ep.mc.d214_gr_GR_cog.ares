lemcLI.Epistle.title = "Τῇ Τετάρτῃ τῆς ΙΔʹ Ἑβδομάδος"
lemcLI.Epistle.title_abbr = "Τετάρτῃ τῆς ΙΔʹ Ἑβδομάδος"
