lemcLI.Epistle.title = "Τῇ Δευτέρᾳ τῆς ΚϚʹ Ἑβδομάδος"
lemcLI.Epistle.title_abbr = "Δευτέρᾳ τῆς ΚϚʹ Ἑβδομάδος"
