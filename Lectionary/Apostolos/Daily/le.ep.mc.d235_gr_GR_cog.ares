lemcLI.Epistle.title = "Τῇ Τετάρτῃ τῆς ΙΖʹ Ἑβδομάδος"
lemcLI.Epistle.title_abbr = "Τετάρτῃ τῆς ΙΖʹ Ἑβδομάδος"
lemcLI.Epistle.version = properties_gr_GR_cog.version.designation
