lemcLI.Epistle.title = "Τῷ Σαββάτῳ τῆς ΙΕʹ Ἑβδομάδος"
lemcLI.Epistle.title_abbr = "Σαββάτῳ τῆς ΙΕʹ Ἑβδομάδος"
