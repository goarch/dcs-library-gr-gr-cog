lemcLI.Epistle.title = "Τῇ Τετάρτῃ τῆς ΚϚʹ Ἑβδομάδος"
lemcLI.Epistle.title_abbr = "Τετάρτῃ τῆς ΚϚʹ Ἑβδομάδος"
