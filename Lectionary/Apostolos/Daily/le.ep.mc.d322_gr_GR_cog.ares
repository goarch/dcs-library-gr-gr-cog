lemcLI.Epistle.title = "Τῷ Σαββάτῳ τῆς ΚΘʹ Ἑβδομάδος"
lemcLI.Epistle.title_abbr = "Σαββάτῳ τῆς ΚΘʹ Ἑβδομάδος"
