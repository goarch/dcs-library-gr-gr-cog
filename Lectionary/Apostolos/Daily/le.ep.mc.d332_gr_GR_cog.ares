lemcLI.Epistle.title = "Τῇ Τρίτῃ τῆς ΛΑʹ Ἑβδομάδος"
lemcLI.Epistle.title_abbr = "Τρίτῃ τῆς ΛΑʹ Ἑβδομάδος"
