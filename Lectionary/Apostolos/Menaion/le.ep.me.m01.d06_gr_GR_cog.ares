lemeVE.Epistle.title = "Τῆς Ἑορτῆς."
lemeVE.Epistle.title_abbr = "Τῆς Ἑορτῆς"
lemeVE.Epistle.version = properties_gr_GR_cog.version.designation
lemeVE.Epistle.book_string = bible_gr_GR_cog.Corinthians1.text
lemeVE.Epistle.book_abbr = bible_gr_GR_cog.Corinthians1.abbr
lemeVE.Epistle.chapverse = "9:19 – 27"
lemeVE.Epistle.incipit = "Ἐλεύθερος ὢν ἐκ πάντων πᾶσιν ἐμαυτὸν ἐδούλωσα…"
lemeVE.Epistle.text = "Ἀδελφοί, ἐλεύθερος ὢν ἐκ πάντων πᾶσιν ἐμαυτὸν ἐδούλωσα, ἵνα τοὺς πλείονας κερδήσω· καὶ ἐγενόμην τοῖς Ἰουδαίοις ὡς Ἰουδαῖος, ἵνα Ἰουδαίους κερδήσω· τοῖς ὑπὸ νόμον ὡς ὑπὸ νόμον, ἵνα τοὺς ὑπὸ νόμον κερδήσω· τοῖς ἀνόμοις ὡς ἄνομος, μὴ ὢν ἄνομος Θεῷ, ἀλλ᾿ ἔννομος Χριστῷ, ἵνα κερδήσω ἀνόμους· ἐγενόμην τοῖς ἀσθενέσιν ὡς ἀσθενής, ἵνα τοὺς ἀσθενεῖς κερδήσω· τοῖς πᾶσι γέγονα τὰ πάντα, ἵνα πάντως τινὰς σώσω. Τοῦτο δὲ ποιῶ διὰ τὸ εὐαγγέλιον, ἵνα συγκοινωνὸς αὐτοῦ γένωμαι. Οὐκ οἴδατε ὅτι οἱ ἐν σταδίῳ τρέχοντες πάντες μὲν τρέχουσιν, εἷς δὲ λαμβάνει τὸ βραβεῖον; οὕτω τρέχετε, ἵνα καταλάβητε. πᾶς δὲ ὁ ἀγωνιζόμενος πάντα ἐγκρατεύεται, ἐκεῖνοι μὲν οὖν ἵνα φθαρτὸν στέφανον λάβωσιν, ἡμεῖς δὲ ἄφθαρτον. ἐγὼ τοίνυν οὕτω τρέχω, ὡς οὐκ ἀδήλως, οὕτω πυκτεύω, ὡς οὐκ ἀέρα δέρων, ἀλλ᾿ ὑποπιάζω μου τὸ σῶμα καὶ δουλαγωγῶ, μήπως ἄλλοις κηρύξας αὐτὸς ἀδόκιμος γένωμαι."

lemeGW.Epistle.title = "Εἰς τὸν Ἁγιασμόν."
lemeGW.Epistle.title_abbr = "Εἰς τὸν Ἁγιασμόν"
lemeGW.Epistle.version = properties_gr_GR_cog.version.designation
lemeGW.Epistle.book_string = bible_gr_GR_cog.Corinthians1.text
lemeGW.Epistle.book_abbr = bible_gr_GR_cog.Corinthians1.abbr
lemeGW.Epistle.chapverse = "10:1 – 4"
lemeGW.Epistle.incipit = "Οὐ θέλω ὑμᾶς ἀγνοεῖν, ὅτι οἱ πατέρες ἡμῶν πάντες…"
lemeGW.Epistle.text = "Ἀδελφοί, οὐ θέλω ὑμᾶς ἀγνοεῖν, ὅτι οἱ πατέρες ἡμῶν πάντες ὑπὸ τὴν νεφέλην ἦσαν, καὶ πάντες διὰ τῆς θαλάσσης διῆλθον, καὶ πάντες εἰς τὸν Μωϋσῆν ἐβαπτίσαντο ἐν τῇ νεφέλῃ καὶ ἐν τῇ θαλάσσῃ, καὶ πάντες τὸ αὐτὸ βρῶμα πνευματικὸν ἔφαγον, καὶ πάντες τὸ αὐτὸ πόμα πνευματικὸν ἔπιον· ἔπινον γὰρ ἐκ πνευματικῆς ἀκολουθούσης πέτρας, ἡ δὲ πέτρα ἦν ὁ Χριστός."

