leluLI.Gospel.title = "Τῷ Σαββάτῳ τῆς Γʹ Ἑβδομάδος τοῦ Λουκᾶ"
leluLI.Gospel.title_abbr = "Τῷ Σαββάτῳ τῆς Γʹ Ἑβδομάδος τοῦ Λουκᾶ"
