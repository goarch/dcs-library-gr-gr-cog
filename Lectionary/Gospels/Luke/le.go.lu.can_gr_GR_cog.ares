leluLI.Gospel.title = "Κυριακῇ τῆς Χαναναίας"
leluLI.Gospel.title_abbr = "Κυριακῇ τῆς Χαναναίας"
leluLI.Gospel.version = properties_gr_GR_cog.version.designation
