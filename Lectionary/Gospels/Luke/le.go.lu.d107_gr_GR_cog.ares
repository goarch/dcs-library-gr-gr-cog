leluLI.Gospel.title = "Τῇ Τρίτῃ τῆς ΙϚʹ Ἑβδομάδος τοῦ Λουκᾶ"
leluLI.Gospel.title_abbr = "Τῇ Τρίτῃ τῆς ΙϚʹ Ἑβδομάδος τοῦ Λουκᾶ"
