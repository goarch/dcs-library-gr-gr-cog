leluLI.Gospel.title = "Τῷ Σαββάτῳ τῆς Ϛʹ Ἑβδομάδος τοῦ Λουκᾶ"
leluLI.Gospel.title_abbr = "Τῷ Σαββάτῳ τῆς Ϛʹ Ἑβδομάδος τοῦ Λουκᾶ"
