leluLI.Gospel.title = "Τῇ Δευτέρᾳ τῆς ΙΖʹ Ἑβδομάδος τοῦ Λουκᾶ"
leluLI.Gospel.title_abbr = "Τῇ Δευτέρᾳ τῆς ΙΖʹ Ἑβδομάδος τοῦ Λουκᾶ"
