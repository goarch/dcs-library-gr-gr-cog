leluLI.Gospel.title = "Τῇ Παρασκευῇ τῆς Γʹ Ἑβδομάδος τοῦ Λουκᾶ"
leluLI.Gospel.title_abbr = "Τῇ Παρασκευῇ τῆς Γʹ Ἑβδομάδος τοῦ Λουκᾶ"
