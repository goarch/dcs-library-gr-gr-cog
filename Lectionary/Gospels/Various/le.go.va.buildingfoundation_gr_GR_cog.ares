levaLI.Gospel.title = "Ἐπὶ τῇ Θεμελιώσει Σχολείου καὶ Παντὸς Κτίσματος"
levaLI.Gospel.title_abbr = "Ἐπὶ τῇ Θεμελιώσει Σχολείου καὶ Παντὸς Κτίσματος"
