lemeLI.Gospel.title = "Τοῦ Ἀποστόλου"
lemeLI.Gospel.title_abbr = "Τοῦ Ἀποστόλου"
lemeLI.Gospel.version = properties_gr_GR_cog.version.designation
lemeLI.Gospel.book_string = bible_gr_GR_cog.John.text
