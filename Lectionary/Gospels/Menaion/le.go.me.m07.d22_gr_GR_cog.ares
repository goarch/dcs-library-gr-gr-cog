lemeLI.Gospel.title = "Τῆς Ἁγίας"
lemeLI.Gospel.title_abbr = "Τῆς Ἁγίας"
lemeLI.Gospel.version = properties_gr_GR_cog.version.designation
lemeLI.Gospel.book_string = bible_gr_GR_cog.Luke.text
