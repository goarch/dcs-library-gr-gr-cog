lemcLI.Gospel.title = "Τῇ Τετάρτῃ τῆς Ϛʹ Ἑβδομάδος"
lemcLI.Gospel.title_abbr = "Τετάρτῃ τῆς Ϛʹ Ἑβδομάδος"
