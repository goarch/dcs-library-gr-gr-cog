lemcLI.Gospel.title = "Τῇ Δευτέρᾳ τῆς Βʹ Ἑβδομάδος τοῦ Ματθαίου"
lemcLI.Gospel.title_abbr = "Δευτέρᾳ τῆς Βʹ Ἑβδομάδος"
