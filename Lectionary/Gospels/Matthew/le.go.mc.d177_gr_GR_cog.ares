lemcLI.Gospel.title = "Τῇ Δευτέρᾳ τῆς Θʹ Ἑβδομάδος τοῦ Ματθαίου"
lemcLI.Gospel.title_abbr = "Δευτέρᾳ τῆς Θʹ Ἑβδομάδος"
