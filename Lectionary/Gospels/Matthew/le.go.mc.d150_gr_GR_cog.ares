lemcLI.Gospel.title = "Τῇ Τρίτῃ τῆς Εʹ Ἑβδομάδος τοῦ Ματθαίου"
lemcLI.Gospel.title_abbr = "Τρίτῃ τῆς Εʹ Ἑβδομάδος"
