lemcLI.Gospel.title = "Τῇ Δευτέρᾳ τῆς Ϛʹ Ἑβδομάδος τοῦ Ματθαίου"
lemcLI.Gospel.title_abbr = "Δευτέρᾳ τῆς Ϛʹ Ἑβδομάδος"
