lemcLI.Gospel.title = "Τῇ Τετάρτῃ τῆς Εʹ Ἑβδομάδος τοῦ Ματθαίου"
lemcLI.Gospel.title_abbr = "Τετάρτῃ τῆς Εʹ Ἑβδομάδος"
