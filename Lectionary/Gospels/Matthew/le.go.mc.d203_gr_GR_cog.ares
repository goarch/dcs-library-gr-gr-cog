lemcLI.Gospel.title = "Τῷ Σαββάτῳ τῆς ΙΒʹ Ἑβδομάδος τοῦ Ματθαίου"
lemcLI.Gospel.title_abbr = "Σαββάτῳ τῆς ΙΒʹ Ἑβδομάδος"
