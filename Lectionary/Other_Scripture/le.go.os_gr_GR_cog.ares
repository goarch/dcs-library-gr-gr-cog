leosVE.Prayer_NynApolyeis.title = "ᾨδὴν τοῦ Θεοδόχου Συμεών"
leosVE.Prayer_NynApolyeis.title_abbr = "ᾨδὴν τοῦ Θεοδόχου Συμεών"
leosVE.Prayer_NynApolyeis.version = properties_gr_GR_cog.version.designation
leosVE.Prayer_NynApolyeis.book_string = bible_gr_GR_cog.Luke.text
leosVE.Prayer_NynApolyeis.book_abbr = bible_gr_GR_cog.Luke.abbr
leosVE.Prayer_NynApolyeis.chapverse = "2:29 – 32"
leosVE.Prayer_NynApolyeis.text = "Νῦν ἀπολύεις τον δοῦλόν σου, Δέσποτα, κατὰ τὸ ῥῆμά σου, ἐν εἰρήνῃ· ὅτι εἶδον οἱ ὀφθαλμοί μου τὸ σωτήριόν σου, ὃ ἡτοίμασας κατὰ πρόσωπον πάντων τῶν λαῶν· φῶς εἰς ἀποκάλυψιν ἐθνῶν, καὶ δόξαν λαοῦ σου Ἰσραήλ."
leosVE.Prayer_NynApolyeis1.text = "Νῦν ἀπολύεις τον δοῦλόν σου, Δέσποτα, κατὰ τὸ ῥῆμά σου, ἐν εἰρήνῃ· ὅτι εἶδον οἱ ὀφθαλμοί μου τὸ σωτήριόν σου, ὃ ἡτοίμασας κατὰ πρόσωπον πάντων τῶν λαῶν."
leosVE.Prayer_NynApolyeis2.text = "Φῶς εἰς ἀποκάλυψιν ἐθνῶν, καὶ δόξαν λαοῦ σου Ἰσραήλ."

leosMA.SixPsalmsIntro1.title = ""
leosMA.SixPsalmsIntro1.title_abbr = ""
leosMA.SixPsalmsIntro1.version = properties_gr_GR_cog.version.designation
leosMA.SixPsalmsIntro1.book_string = bible_gr_GR_cog.Luke.text
leosMA.SixPsalmsIntro1.book_abbr = bible_gr_GR_cog.Luke.abbr
leosMA.SixPsalmsIntro1.chapverse = "2:14"
leosMA.SixPsalmsIntro1.text = "Δόξα ἐν ὑψίστοις Θεῷ καὶ ἐπὶ γῆς εἰρήνη, ἐν ἀνθρώποις εὐδοκία."

leosMA.magnificat.title = ""
leosMA.magnificat.v1.info = ps_gr_GR_cog.bode9_mag.v1.number
leosMA.magnificat.v1.text = "Μεγαλύνει ἡ ψυχή μου τὸν Κύριον, καὶ ἠγαλλίασε τὸ πνεῦμά μου ἐπὶ τῷ Θεῷ τῷ σωτῆρί μου."
leosMA.magnificat.v2.info = ps_gr_GR_cog.bode9_mag.v2.number
leosMA.magnificat.v2.text = "Ὅτι ἐπέβλεψεν ἐπὶ τὴν ταπείνωσιν τῆς δούλης αὐτοῦ· ἰδού γάρ, ἀπὸ τοῦ νῦν μακαριοῦσί με πᾶσαι αἱ γενεαί."
leosMA.magnificat.v3.info = ps_gr_GR_cog.bode9_mag.v3.number
leosMA.magnificat.v3.text = "Ὅτι ἐποίησέ μοι μεγαλεῖα ὁ Δυνατός, καὶ ἅγιον τὸ ὄνομα αὐτοῦ, καί το ἔλεος αὐτοῦ εἰς γενεάν, καὶ γενεὰν τοῖς φοβουμένοις αὐτόν."
leosMA.magnificat.v4.info = ps_gr_GR_cog.bode9_mag.v4.number
leosMA.magnificat.v4.text = "Ἐποίησε κράτος ἐν βραχίονι αὐτοῦ, διεσκόρπισεν ὑπερηφάνους διανοίᾳ καρδίας αὐτῶν."
leosMA.magnificat.v5.info = ps_gr_GR_cog.bode9_mag.v5.number
leosMA.magnificat.v5.text = "Καθεῖλε δυνάστας ἀπὸ θρόνων, καὶ ὕψωσε ταπεινούς, πεινῶντας ἐνέπλησεν ἀγαθῶν, καὶ πλουτοῦντας ἐξαπέστειλε κενούς."
leosMA.magnificat.v6.info = ps_gr_GR_cog.bode9_mag.v6.number
leosMA.magnificat.v6.text = "Ἀντελάβετο Ἰσραὴλ παιδὸς αὐτοῦ, μνησθῆναι ἐλέους, καθὼς ἐλάλησε πρὸς τοὺς Πατέρας ἡμῶν, τῷ Ἀβραάμ, καὶ τῷ σπέρματι αὐτοῦ ἕως αἰῶνος."

leosMA.bode9.title = ""
leosMA.bode9.refrain.text = ""
leosMA.bode9.verse03.info = ps_gr_GR_cog.bode9.v1.number
leosMA.bode9.verse03.text = "Εὐλογητὸς Κύριος ὁ Θεὸς τοῦ Ἰσραήλ, ὅτι ἐπεσκέψατο καὶ ἐποίησε λύτρωσιν τῷ λαῷ αὐτοῦ."
leosMA.bode9.verse04.info = ps_gr_GR_cog.bode9.v2.number
leosMA.bode9.verse04.text = "Καὶ ἤγειρε κέρας σωτηρίας ἡμῖν, ἐν οἴκῳ Δαυῒδ τοῦ παιδὸς αὐτοῦ."
leosMA.bode9.verse05.info = ps_gr_GR_cog.bode9.v3.number
leosMA.bode9.verse05.text = "Καθὼς ἐλάλησε διὰ στόματος τῶν ἁγίων, τῶν ἀπʼ αἰῶνος Προφητῶν αὐτοῦ, σωτηρίαν ἐξ ἐχθρῶν ἡμῶν, καὶ ἐκ χειρὸς πάντων τῶν μισούντων ἡμᾶς."
leosMA.bode9.verse06.info = ps_gr_GR_cog.bode9.v5.number
leosMA.bode9.verse06.text = "Ποιῆσαι ἔλεος μετὰ τῶν Πατέρων ἡμῶν, καὶ μνησθῆναι διαθήκης ἁγίας αὐτοῦ."
leosMA.bode9.verse07.info = ps_gr_GR_cog.bode9.v6.number
leosMA.bode9.verse07.text = "Ὅρκον, ὃν ὤμοσε πρὸς Ἀβραὰμ τὸν πατέρα ἡμῶν, τοῦ δοῦναι ἡμῖν ἀφόβως, ἐκ χειρὸς τῶν ἐχθρῶν ἡμῶν ῥυσθέντας."
leosMA.bode9.verse08.info = ps_gr_GR_cog.bode9.v7.number
leosMA.bode9.verse08.text = "Λατρεύειν αὐτῷ ἐν ὁσιότητι καὶ δικαιοσύνῃ ἐνώπιον αὐτοῦ, πάσας τὰς ἡμέρας τῆς ζωῆς ἡμῶν."
leosMA.bode9.verse09.info = ps_gr_GR_cog.bode9.v8.number
leosMA.bode9.verse09.text = "Καὶ σύ, Παιδίον, Προφήτης Ὑψίστου κληθήσῃ· προπορεύσῃ γὰρ πρὸ προσώπου Κυρίου ἑτοιμάσαι ὁδοὺς αὐτοῦ."
leosMA.bode9.verse10.info = ps_gr_GR_cog.bode9.v9.number
leosMA.bode9.verse10.text = "Τοῦ δοῦναι γνῶσιν σωτηρίας τῷ λαῷ αὐτοῦ, ἐν ἀφέσει ἁμαρτιῶν αὐτῶν, διὰ σπλάγχνα ἐλέους Θεοῦ ἡμῶν."
leosMA.bode9.verse11.info = ps_gr_GR_cog.bode9.v10.number
leosMA.bode9.verse11.text = "Ἐν οἷς ἐπεσκέψατο ἡμᾶς ἀνατολὴ ἐξ ὕψους, ἐπιφᾶναι τοῖς ἐν σκότει καὶ σκιᾷ θανάτου καθημένοις."
leosMA.bode9.verse12.info = ps_gr_GR_cog.bode9.v11.number
leosMA.bode9.verse12.text = "Τοῦ κατευθῦναι τοὺς πόδας ἡμῶν εἰς ὁδὸν εἰρήνης."

leosLIPR.prothesis.v6.version = properties_gr_GR_cog.version.designation
leosLIPR.prothesis.v6.book_string = bible_gr_GR_cog.John.text
leosLIPR.prothesis.v6.book_abbr = bible_gr_GR_cog.John.abbr
leosLIPR.prothesis.v6.chapverse = "19:34-35"
leosLIPR.prothesis.v6.text = "Εἷς τῶν στρατιωτῶν λόγχῃ τὴν πλευρὰν αὐτοῦ ἔνυξε, καὶ εὐθέως ἐξῆλθεν αἷμα καὶ ὕδωρ· καὶ ὁ ἑωρακὼς μεμαρτύρηκε καὶ ἀληθινή ἐστιν ἡ μαρτυρία αὐτοῦ."

leosLIPR.preliminary.v1.version = properties_gr_GR_cog.version.designation
leosLIPR.preliminary.v1.book_string = bible_gr_GR_cog.Luke.text
leosLIPR.preliminary.v1.book_abbr = bible_gr_GR_cog.Luke.abbr
leosLIPR.preliminary.vchapverse = "2:14"
leosLIPR.preliminary.v1.text = "Δόξα ἐν ὑψίστοις Θεῷ καὶ ἐπὶ γῆς εἰρήνη, ἐν ἀνθρώποις εὐδοκία."

leosLI.pe.d095.CommunionHymn.title = ""
leosLI.pe.d095.CommunionHymn.title_abbr = ""
leosLI.pe.d095.CommunionHymn.version = properties_gr_GR_cog.version.designation
leosLI.pe.d095.CommunionHymn.book_string = bible_gr_GR_cog.John.text
leosLI.pe.d095.CommunionHymn.book_abbr = bible_gr_GR_cog.John.abbr
leosLI.pe.d095.CommunionHymn.chapverse = "6:56"
leosLI.pe.d095.CommunionHymn.text = "Ὁ τρώγων μου τὴν Σάρκα, καὶ πίνων μου τὸ Αἷμα, ἐν ἐμοὶ μένει, κἀγὼ ἐν αὐτῷ, εἶπεν ὁ Κύριος."

leosTY.Beatitudes.title = "ΟΙ ΜΑΚΑΡΙΣΜΟΙ"
leosTY.Beatitudes.title_abbr = "ΟΙ ΜΑΚΑΡΙΣΜΟΙ"
leosTY.Beatitudes.version = properties_gr_GR_cog.version.designation
leosTY.Beatitudes.book_string = bible_gr_GR_cog.Matthew.text
leosTY.Beatitudes.book_abbr = bible_gr_GR_cog.Matthew.abbr
leosTY.Beatitudes.chapverse = ""
leosTY.Beatitudes_Intro.text = "Ἐν τῇ Βασιλείᾳ σου μνήσθητι ἡμῶν Κύριε, ὅταν ἔλθῃς ἐν τῇ Βασιλείᾳ σου."
leosTY.Beatitudes_v01.text = "Μακάριοι οἱ πτωχοὶ τῷ πνεύματι, ὅτι αὐτῶν ἐστιν ἡ Βασιλεία τῶν οὐρανῶν."
leosTY.Beatitudes_v02.text = "Μακάριοι οἱ πενθοῦντες, ὅτι αὐτοὶ παρακληθήσονται."
leosTY.Beatitudes_v03.text = "Μακάριοι οἱ πρᾳεῖς, ὅτι αὐτοὶ κληρονομήσουσι τὴν γῆν."
leosTY.Beatitudes_v04.text = "Μακάριοι οἱ πεινῶντες καὶ διψῶντες τὴν δικαιοσύνην, ὅτι αὐτοὶ χορτασθήσονται."
leosTY.Beatitudes_v05.text = "Μακάριοι οἱ ἐλεήμονες, ὅτι αὐτοὶ ἐλεηθήσονται."
leosTY.Beatitudes_v06.text = "Μακάριοι οἱ καθαροὶ τῇ καρδίᾳ, ὅτι αὐτοὶ τὸν Θεὸν ὄψονται."
leosTY.Beatitudes_v07.text = "Μακάριοι οἱ εἰρηνοποιοί, ὅτι αὐτοὶ Υἱοὶ Θεοῦ κληθήσονται."
leosTY.Beatitudes_v08.text = "Μακάριοι οἱ δεδιωγμένοι ἕνεκεν δικαιοσύνης, ὅτι αὐτῶν ἐστιν ἡ Βασιλεία τῶν οὐρανῶν."
leosTY.Beatitudes_v09.text = "Μακάριοι ἐστὲ ὅταν ὀνειδίσωσιν ὑμᾶς, καὶ διώξωσι, καὶ εἴπωσι πᾶν πονηρὸν ῥῆμα καθʼ ὑμῶν, ψευδόμενοι ἕνεκεν ἐμοῦ."
leosTY.Beatitudes_v10.text = "Χαίρετε καὶ ἀγαλλιᾶσθε, ὅτι ὁ μισθὸς ὑμῶν πολὺς ἐν τοῖς οὐρανοῖς."
leosTY.Beatitudes_Refrain1.text = "Μνήσθητι ἡμῶν Κύριε, ὅταν ἔλθῃς ἐν τῇ Βασιλείᾳ σου."
leosTY.Beatitudes_Refrain2.text = "Μνήσθητι ἡμῶν Δέσποτα, ὅταν ἔλθῃς ἐν τῇ Βασιλείᾳ σου."
leosTY.Beatitudes_Refrain3.text = "Μνήσθητι ἡμῶν Ἅγιε, ὅταν ἔλθῃς ἐν τῇ Βασιλείᾳ σου."

leos.prokeimenon.MM.ode92v8v1.text = properties_gr_GR_cog.media.key

leosCA.ParaklesisPandemic.Gospel.title = ""
leosCA.ParaklesisPandemic.Gospel.version = properties_gr_GR_cog.version.designation
leosCA.ParaklesisPandemic.Gospel.book_string = bible_gr_GR_cog.Matthew.text
leosCA.ParaklesisPandemic.Gospel.book_abbr = bible_gr_GR_cog.Matthew.abbr
leosCA.ParaklesisPandemic.Gospel.chapverse = "8:1 – 4"
leosCA.ParaklesisPandemic.Gospel.text = "Τῷ καιρῷ ἐκείνῳ, καταβάντι τῷ Ἰησοῦ ἀπὸ τοῦ ὄρους ἠκολούθησαν αὐτῷ ὄχλοι πολλοί. καὶ ἰδοὺ λεπρὸς ἐλθὼν προσεκύνει αὐτῷ λέγων· Κύριε, ἐὰν θέλῃς δύνασαί με καθαρίσαι. καὶ ἐκτείνας τὴν χεῖρα ἥψατο αὐτοῦ ὁ Ἰησοῦς λέγων· Θέλω, καθαρίσθητι· καὶ εὐθέως ἐκαθαρίσθη αὐτοῦ ἡ λέπρα. καὶ λέγει αὐτῷ ὁ Ἰησοῦς· Ὅρα μηδενὶ εἴπῃς, ἀλλὰ ὕπαγε σεαυτὸν δεῖξον τῷ ἱερεῖ, καὶ προσένεγκε τὸ δῶρον ὃ προσέταξεν Μωσῆς, εἰς μαρτύριον αὐτοῖς."
