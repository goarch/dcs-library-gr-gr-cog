meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera01.greekmelody = he.a.m6_gr_GR_cog.heAU.IApegnosmeni.greekname
meVE.Stichera01.melody = he.a.m6_gr_GR_cog.heAU.IApegnosmeni.name
meVE.Stichera01.incipit = "Τὰς ἑπτὰ Συνόδους…"
meVE.Stichera01.text = "Τὰς ἑπτὰ Συνόδους τὰς τῶν Πατέρων, κατὰ διαφόρους καιροὺς συστάσας, εἰς ἕνα συνήθροισεν ἑνὶ Κανόνι τῷδε, μάλα καλῶς ὁ Πατριάρχης, ὁ Γερμανὸς ὁ νέος, γράφων ὁμοῦ τε καὶ κρατύνων, τὰ δόγματα τὰ τούτων· ὃς καὶ πρέσβεας αὐτοὺς ἀγρύπνους, τῆς σωτηρίας τῷ Κυρίῳ προβάλλεται, καὶ τοῦ ποιμνίου συμποίμενας."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera02.melody = he.a.m6_gr_GR_cog.heAU.IApegnosmeni.name
meVE.Stichera02.incipit = "Τὸ τοῦ Νόμου γράμμα…"
meVE.Stichera02.text = "Τὸ τοῦ Νόμου γράμμα παισὶν Ἑβραίων, ἔθετο τιμίαν τὴν ἑβδομάδα, σκιᾷ προσανέχουσι, καὶ λατρεύουσι ταύτῃ· ἥν περ Πατέρες συνδραμόντες, ἐν ἑπτάδι Συνόδων, νεύσει Θεοῦ τοῦ ἐν ἑξάδι, ἡμερῶν σύμπαν τόδε, ἀπαρτίσαντος, καὶ τὴν ἑβδόμην εὐλογήσαντος, σεμνοτέραν εἰργάσασθε, ὅρον ἐκθέμενοι Πίστεως."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera03.melody = he.a.m6_gr_GR_cog.heAU.IApegnosmeni.name
meVE.Stichera03.incipit = "Τὴν Τριάδα πᾶσιν…"
meVE.Stichera03.text = "Τὴν Τριάδα πᾶσιν ἐκ τῶν πραγμάτων, τῆς κοσμογενείας οὖσαν αἰτίαν, τρανῶς παρεδώκατε, τρισόλβιοι Πατέρες· τρεῖς γὰρ καὶ τέσσαρας Συνόδους, μυστικωτάτῳ λόγῳ θέντες, καὶ ἔκδικοι φανέντες, τοῦ ὀρθοδόξου λόγου, τὰ στοιχεῖα τὰ τέσσαρα ὄντα, καὶ τὴν Τριάδα ἐνεφήνατε, κτίσασαν ταῦτα, καὶ κόσμον ποιήσασαν."

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera04.greekmelody = he.a.m6_gr_GR_cog.heAU.IApegnosmeni.greekname
meVE.Stichera04.melody = he.a.m6_gr_GR_cog.heAU.IApegnosmeni.name
meVE.Stichera04.incipit = "Ἤρκεσε καὶ μία…"
meVE.Stichera04.text = "Ἤρκεσε καὶ μία ζωὴν ἐμπνεῦσαι, τῷ κειμένῳ γόνῳ τῆς ὑπουργούσης, Προφήτου ἀνάκαμψις Ἐλισσαιὲ τοῦ πάνυ· ὅμως ἀνέκαμψεν ἑπτάκις, καὶ συνέκυψε τούτῳ, οἷα προόπτης προαγγέλλων, τὰς ὑμῶν συνελεύσεις· αἷς τὴν νέκρωσιν τοῦ Θεοῦ Λόγου ἐψυχώσατε, θανατώσαντες Ἄρειον, καὶ τοὺς ἐκείνῳ συγκάμνοντας."

meVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera05.melody = he.a.m6_gr_GR_cog.heAU.IApegnosmeni.name
meVE.Stichera05.incipit = "Τὸν διῃρημένον Χριστοῦ…"
meVE.Stichera05.text = "Τὸν διῃρημένον Χριστοῦ χιτῶνα, καὶ διεῤῥηγμένον κυσὶν ὑλάκταις, σοφῶς συνεῤῥάψατε σεβάσμιοι Πατέρες, βλέπειν τὴν γύμνωσιν τὴν τούτου, μηδαμῶς ἐνεγκόντες, ὥς περ ὁ Σήμ τε καὶ Ἰάφεθ, τὴν πατρῴαν τὸ πάλαι, καταισχύναντες τὸν πατραλοίαν, καὶ τοὺς ἐκείνῳ συμφρονήσαντας Ἄρειον, τὸν τῆς μανίας ἐπώνυμον."

meVE.Stichera06.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera06.melody = he.a.m6_gr_GR_cog.heAU.IApegnosmeni.name
meVE.Stichera06.incipit = "Τοὺς Μακεδονίους…"
meVE.Stichera06.text = "Τοὺς Μακεδονίους καὶ Νεστορίους, καὶ τοὺς Εὐτυχέας καὶ Διοσκόρους, Ἀπολλιναρίους τε Σαβελλιοσεβήρους, λύκους βαρεῖς ἀποδειχθέντας, ἐν δέρμασι προβάτων, πόῤῥω τῆς ποίμνης τοῦ Σωτῆρος, ὡς ἀληθεῖς ποιμένες, ἀπηλάσατε γυμνοὺς κωδίων, τοὺς τρισαθλίους καταστήσαντας ἄριστα· ὅθεν ὑμᾶς μακαρίζομεν."

meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Τὰς μυστικὰς σήμερον…"
meVE.SticGlory.text = "Τὰς μυστικὰς σήμερον τοῦ Πνεύματος σάλπιγγας, τοὺς θεοφόρους Πατέρας ἀνευφημήσωμεν· τοὺς μελῳδήσαντας ἐν μέσῳ τῆς Ἐκκλησίας, μέλος ἐναρμόνιον θεολογίας, Τριάδα μίαν ἀπαράλλακτον, οὐσίαν τε καὶ θεότητα· τοὺς καθαιρέτας Ἀρείου, καὶ Ὀρθοδόξων προμάχους· τοὺς πρεσβεύοντας πάντοτε Κυρίῳ, ἐλεηθῆναι τὰς ψυχάς ἡμῶν."

meVE.LityGlory.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.LityGlory.melody = ""
meVE.LityGlory.incipit = me.m07.dHF_gr_GR_cog.meVE.AposGlory.incipit
meVE.LityGlory.text = me.m07.dHF_gr_GR_cog.meVE.AposGlory.text

meVE.LityBoth.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.LityBoth.melody = ""
meVE.LityBoth.incipit = "Θεοτόκε ἡ προστασία…"
meVE.LityBoth.text = "Θεοτόκε ἡ προστασία πάντων τῶν δεομένων, εἰς σὲ θαῤῥοῦμεν, εἰς σὲ καυχώμεθα, ἐν σοὶ πᾶσα ἡ ἐλπὶς ἡμῶν ἐστι. Πρέσβευε τῷ ἐκ σοῦ τεχθέντι, ὑπὲρ ἀχρείων δούλων σου."

meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Τὴν ἐτήσιον μνήμην…"
meVE.AposGlory.text = "Τὴν ἐτήσιον μνήμην σήμερον, τῶν θεοφόρων Πατέρων, τῶν ἐκ πάσης τῆς οἰκουμένης συναθροισθέντων, ἐν τῇ λαμπρᾷ πόλει Νικαέων, τῶν ὀρθοδόξων τὰ συστήματα, εὐσεβοῦντες πιστῶς ἑορτάσωμεν. Οὗτοι γὰρ τοῦ δεινοῦ Ἀρείου τὸ ἄθεον δόγμα, εὐσεβοφρόνως καθεῖλον, καὶ τῆς Καθολικῆς Ἐκκλησίας, συνοδικῶς τοῦτον ἐξωστράκισαν· καὶ τρανῶς τὸν Υἱὸν τοῦ Θεοῦ, ὁμοούσιον καὶ συναΐδιον, πρὸ τῶν αἰώνων ὄντα, τοῖς πᾶσιν ἐδίδαξαν ὁμολογεῖν, ἐν τῷ τῆς πίστεως Συμβόλῳ, ἀκριβῶς καὶ εὐσεβῶς τοῦτο ἐκθέμενοι. Ὅθεν καὶ ἡμεῖς τοῖς θείοις αὐτῶν δόγμασιν ἑπόμενοι, βεβαίως πιστεύοντες λατρεύομεν, σὺν Πατρὶ τὸν Υἱόν, καὶ τὸ Πνεῦμα τὸ Πανάγιον, ἐν μιᾷ Θεότητι, Τριάδα ὁμοούσιον."

meVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.AposTheotokion.melody = ""
meVE.AposTheotokion.incipit = oc.m4.d1_gr_GR_cog.ocVE.AposTheotokion.incipit
meVE.AposTheotokion.text = oc.m4.d1_gr_GR_cog.ocVE.AposTheotokion.text

meVE.Apolytikion1.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Apolytikion1.melody = ""
meVE.Apolytikion1.incipit = me.m07.dHF_gr_GR_cog.meVE.Apolytikion1.incipit
meVE.Apolytikion1.text = me.m07.dHF_gr_GR_cog.meVE.Apolytikion1.text

meMA.C1.acrostic.title = "Ὁ Κανὼν τῶν Ἁγίων,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Ὑμνῶ μακάρων συνδρομὴν τὴν ἑβδόμην."
meMA.C1.poet = poets_gr_GR_cog.po.Theofanous
meMA.C1.title = titles_gr_GR_cog.ti.CanonFathers
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintsM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C11.greekmelody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.greekname
meMA.Ode1C11.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C11.incipit = "Ὑμνολογῆσαι τὴν ἑβδόμην ἄθροισιν…"
meMA.Ode1C11.text = "Ὑμνολογῆσαι τὴν ἑβδόμην ἄθροισιν, ἐφιεμένῳ μοι νῦν, τὴν τῶν ἑπτὰ δίδου, χαρισμάτων σύνοδον, τοῦ Παρακλήτου Κύριε, τὴν σοφίσασαν ταύτην, γλωσσοπυρσεύτως, καὶ βλάσφημον, πᾶσαν γλωσσαλγίαν σιγήσασαν."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C12.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C12.incipit = "Μείζων ἀρχῆθεν ἀριθμῶν…"
meMA.Ode1C12.text = "Μείζων ἀρχῆθεν ἀριθμῶν ὁ ἕβδομος· δημιουργίας καὶ γάρ, τῆς τοῦ Θεοῦ πάσης, πρωτοτύπως γέγονεν, ἡ παντελὴς κατάπαυσις, εἰς ἑβδόμην ἡμέραν· καὶ νῦν πασῶν τῶν αἱρέσεων, λῆξις εἰς ἰσάριθμον Σύνοδον."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C13.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C13.incipit = "Νενικηκὼς τὸν θεομάχον Ἄρειον…"
meMA.Ode1C13.text = "Νενικηκὼς τὸν θεομάχον Ἄρειον, ἐν τῇ Νικαίᾳ τὸ πρίν, ποιμαντικῇ ῥάβδῳ ὀρθοδόξοις ἴθυνε, τὴν Ἐκκλησίαν δόγμασιν, ὁ χορὸς τῶν Πατέρων· καὶ νῦν ἐν ταύτῃ κατῄσχυνε, τοὺς Εἰκονομάχους ὁ σύμμαχος."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C1T.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C1T.incipit = "Ὡς οἱ Πατέρες εὐσεβῶς…"
meMA.Ode1C1T.text = "Ὡς οἱ Πατέρες εὐσεβῶς ἐδίδαξαν, ὁμολογοῦμεν πιστῶς, Παρθενικὴν μήτραν, ἀνωδίνως τέξασαν, μετὰ σαρκὸς τὸν ἄσαρκον· προσκυνοῦμέν τε τούτου, στηλογραφοῦντες τὴν μόρφωσιν, καὶ τιμητικῶς ἀσπαζόμεθα."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C11.greekmelody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.greekname
meMA.Ode3C11.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C11.incipit = "Μὴ σαλευθῆναι τοῦ Χριστοῦ…"
meMA.Ode3C11.text = "Μὴ σαλευθῆναι τοῦ Χριστοῦ, τὴν ἀῤῥαγῆ Ἐκκλησίαν, ὑπʼ αὐτοῦ μυσταγωγούμενοι θεῖοι, Ποιμενάρχαι τοὺς αὐτήν, παρασαλεῦσαι θέλοντας, ὡς Ἀντιχρίστου μοίρας, τῶν εὐσεβῶν παρεσάλευσαν."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C12.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C12.incipit = "Ἀνακαθαίρει θολεῤῥούς…"
meMA.Ode3C12.text = "Ἀνακαθαίρει θολεῤῥούς, καὶ βορβορώδεις χειμάῤῥους, ἐκ πηγῶν τοῦ σωτηρίου ἀντλήσας, καὶ διψῶντα τὸν λαόν, τὸν τοῦ Χριστοῦ κορέννυσι, τῶν διδαχῶν τοῖς ῥείθροις, ὁ τῶν Πατέρων κατάλογος."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C13.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C13.incipit = "Κατὰ τῶν ὄντως μισητῶν…"
meMA.Ode3C13.text = "Κατὰ τῶν ὄντως μισητῶν, χριστιανοκατηγόρων, συνδρομὴ τῶν φιλοχρίστων ἑβδόμῃ, ἐν τῇ πόλει τῇ λαμπρᾷ, τῶν Νικαέων γέγονεν, ἧς βασιλεῖς Εἰρήνη, καὶ Κωνσταντῖνος συνήγοροι."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C1T.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C1T.incipit = "Ἅπας ἀπέστω δυσσεβής…"
meMA.Ode3C1T.text = "Ἅπας ἀπέστω δυσσεβής, ὁ τὴν εἰκόνα μὴ σέβων, τὴν σεπτὴν τῆς Θεοτόκου καὶ ταύτην, μὴ κηρύττων τὸν Χριστόν, θεανδρικῶς κυήσασαν, καὶ τῷ πυρὶ πεμπέσθω, κατακαιόμενος ἄπαυστα."

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3Kathisma1.greekmelody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.greekname
meMA.Ode3Kathisma1.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
meMA.Ode3Kathisma1.incipit = "Φωστῆρες ὑπέρλαμπροι…"
meMA.Ode3Kathisma1.text = "Φωστῆρες ὑπέρλαμπροι, τῆς ἀληθείας σαφῶς, τῷ κόσμῳ ἐδείχθητε, μακαριώτατοι, Πατέρες θεόφθογγοι· τήξαντες τὰς αἱρέσεις, τῶν βλασφήμων γλωσσάλγων· σβέσαντες τὰς φλογώδεις, τῶν δυσφήμων συγχύσεις· διὸ ὡς Ἱεράρχαι Χριστοῦ, πρεσβεύσατε σωθῆναι ἡμᾶς."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaT.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
meMA.Ode3KathismaT.incipit = "Ταχὺ ἡμᾶς πρόφθασον…"
meMA.Ode3KathismaT.text = "Ταχὺ ἡμᾶς πρόφθασον, Παρθενομῆτορ ἁγνή· ἐχθρῶν ἡμᾶς λύτρωσαι, τῶν βλασφημούντων εἰς σέ, καὶ μὴ προσκυνούντων σε· θραῦσον τὰς γλωσσαλγίας, τῶν αἱρέσεων πάσας· γνώτωσαν ὅτι μόνη, Θεομήτωρ ὑπάρχεις, πρεσβείαις σου Ὀρθοδόξων, τὸ σύστημα σῴζουσα."

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C11.greekmelody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.greekname
meMA.Ode4C11.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C11.incipit = "Ῥῆμα Θεοῦ, ἔχοντες βέλος…"
meMA.Ode4C11.text = "Ῥῆμα Θεοῦ, ἔχοντες βέλος καὶ μάχαιραν, πάντας ἄρδην, τούτους κατασφάττουσι, τοὺς δυσμενεῖς, τύπῳ σταυρικῷ, τοὺς μὴ σεβομένους, ἐπίσης τὰ ἐκτυπώματα, Χριστοῦ τῆς Θεοτόκου, τῶν Ἁγίων τε πάντων, οἱ Πατέρες οἱ θεοειδέστατοι."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C12.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C12.incipit = "Ὥσπερ ἑπτά, σάλπιγγες Ἱεριχούντια…"
meMA.Ode4C12.text = "Ὥσπερ ἑπτά, σάλπιγγες Ἱεριχούντια, εἰς ἑβδόμην, τείχη κατηδάφισαν, περιδρομήν· οὕτως αἱ ἑπτά, Σύνοδοι πᾶν στῖφος, κατὰ Θεοῦ ἐπαιρόμενον, κατήγαγον εἰς χάος, συνδρομὴν εἰς ἑβδόμην, τῶν εὐήχων σαλπίγγων τοῦ Πνεύματος."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C13.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C13.incipit = "Νεανικήν, ἔνστασιν ἐπιδεικνύμενος…"
meMA.Ode4C13.text = "Νεανικήν, ἔνστασιν ἐπιδεικνύμενος, καὶ τῷ θείῳ, ζήλῳ πυρπολούμενος, ὁ Πατρικὸς δῆμος Ἠλιού, οἷα τῆς αἰσχύνης, τοὺς ἱερεῖς ἐθανάτωσε· διὸ σὺν παῤῥησίᾳ, τοῦ Χριστοῦ τὴν εἰκόνα, σχετικῶς προσκυνεῖν ἐδογμάτισε."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C1T.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C1T.incipit = "Σύ μου ἐλπίς, Πάναγνε…"
meMA.Ode4C1T.text = "Σύ μου ἐλπίς, Πάναγνε σύ μου καὶ ὕμνησις, σὺ λιμήν μου, σύ μου καὶ κυβέρνησις, ἡ τὸν Θεόν, Λόγον τοῦ Πατρός, σεσωματωμένον, ἀσυνδυάστως κυήσασα· διό σου ἀδιστάκτως, προσκυνῶ τὴν εἰκόνα, τῇ ἰσχύϊ σου ἐνδυναμούμενος."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C11.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
meMA.Ode5C11.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C11.incipit = "Ὑψηλῇ διανοίᾳ…"
meMA.Ode5C11.text = "Ὑψηλῇ διανοίᾳ, συνδιασκεψάμενοι ἀνεθεμάτισαν, τοὺς Εἰκονομάχους, ὡς ἀλλόκοτα τούτους φρονήσαντας, οἱ σεπτοὶ Πατέρες· καὶ τὴν τιμὴν Χριστοῦ τῷ τύπῳ, ὡς εἰκὸς ἀπονέμειν ἐθέσπισαν."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C12.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C12.incipit = "Νῦν καιρὸς εὐφροσύνης…"
meMA.Ode5C12.text = "Νῦν καιρὸς εὐφροσύνης, ἄρτι σωτηρίας ἡμέρα ἐπέφανεν· εὐφρανθῶμεν τοίνυν, καὶ Χριστῷ εὐφροσύνως βοήσωμεν· Τὴν εἰρήνην δίδου, τὴν σὴν ἡμῖν λιταῖς Πατέρων, τῆς ἑβδόμης Συνόδου φιλάνθρωπε."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C1T.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C1T.incipit = "Διὰ σπλάγχνα ἐλέους…"
meMA.Ode5C1T.text = "Διὰ σπλάγχνα ἐλέους, ἀπὸ τῆς Παρθένου ὁ Υἱὸς γεγέννηται, τοῦ Θεοῦ ἀτρέπτως, τὸ ἀλλότριον φέρων ὡς ἴδιον· καὶ μορφῇ τῇ τούτου, περιγραπτὸς ὁρᾶται θέλων, κατʼ οὐσίαν ὁ ὢν ἀπερίγραπτος."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C11.greekmelody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.greekname
meMA.Ode6C11.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C11.incipit = "Ῥανάτωσαν γλυκασμόν…"
meMA.Ode6C11.text = "Ῥανάτωσαν γλυκασμόν, τὰ ὄρη καὶ ἀγαλλίασιν· αἱρετικῶν ἡ πληθύς, ἀπεσκορακίσθη γάρ, πικρὸν ἡ προχέουσα, ἰὸν τῶν εἰκόνων, τῶν ἁγίων τὴν ἀθέτησιν."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C12.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C12.incipit = "Ὁ οὐρανὸς καὶ ἡ γῆ…"
meMA.Ode6C12.text = "Ὁ οὐρανὸς καὶ ἡ γῆ, συμφώνως ἑορταζέτωσαν, τῆς θυγατρὸς τοῦ Θεοῦ, τὴν μεγαλειότητα· καὶ γὰρ μεγαλύνεται, καταβαλλομένη, τοὺς αὐτὴν κατασμικρύνοντας."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C1T.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C1T.incipit = "Μητρὸς Υἱὸς ὁ Πατρός…"
meMA.Ode6C1T.text = "Μητρὸς Υἱὸς ὁ Πατρός, ἀμήτωρ τὸ πρὶν ἀπάτωρ δέ, θεοπρεπῶς γεννηθείς, καὶ ἀναγεννήσας με· διὸ τὴν γεννήσασαν, σὺν τῷ γεννηθέντι, εἰκονίζων κατασπάζομαι."

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Kontakion1.melody = "Χειρόγραφον εἰκόνα."
meMA.Kontakion1.incipit = "Ὁ ἐκ Πατρὸς ἐκλάμψας Υἱὸς…"
meMA.Kontakion1.text = "Ὁ ἐκ Πατρὸς ἐκλάμψας Υἱὸς ἀῤῥήτως, ἐκ γυναικὸς ἐτέχθη διπλοῦς τῇ φύσει· ὃν εἰδότες, οὐκ ἀρνούμεθα τῆς μορφῆς τὸ ἐκτύπωμα· αὐτὸ δὲ εὐσεβῶς ἀνιστοροῦντες, σέβομεν πιστῶς· καὶ διὰ τοῦτο τὴν ἀληθινὴν πίστιν κρατοῦσα ἡ Ἐκκλησία, ἀσπάζεται τὴν εἰκόνα τῆς Χριστοῦ ἐνανθρωπήσεως."

meMA.Oikos1.text = "Θέλων ὁ πανοικτίρμων Θεὸς ἡμᾶς διεγείρειν ἀεί, πρὸς μνήμην τελείαν τῆς αὑτοῦ ἐνανθρωπήσεως, τὴν ὑπόθεσιν ταύτην παρέδωκε τοῖς ἀνθρώποις, διὰ τῆς χρωματουργίας τῶν εἰκόνων, τὴν σεβάσμιον ἀνατυποῦσθαι μορφήν· ὅπως ταύτην ἐπʼ ὄψεσιν ὁρῶντες, πιστεύωμεν, ἅπερ λόγῳ ἀκηκόαμεν, γνωρίζοντες σαφῶς τὴν πρᾶξιν καὶ τὸ ὄνομα, τὸ σχῆμα καὶ τοὺς ἄθλους τῶν Ἁγίων ἀνδρῶν· καὶ Χριστὸν τὸν στεφοδότην στεφάνους παρεχόμενον τοῖς Ἁγίοις ἀθληταῖς τε καὶ μάρτυσι, διʼ ὧν ἄρτι τρανότερον τὴν ἀληθινὴν πίστιν κρατοῦσα ἡ Ἐκκλησία, ἀσπάζεται τὴν εἰκόνα τῆς Χριστοῦ ἐνανθρωπήσεως."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C11.greekmelody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.greekname
meMA.Ode7C11.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C11.incipit = "Ἡττῶνται τοῖς δόγμασιν…"
meMA.Ode7C11.text = "Ἡττῶνται τοῖς δόγμασιν, αἱρεσιάρχαι τῶν θεηγόρων ἀνδρῶν, τῶν τὸ σέβας τῶν τύπων, τοῖς ἀρχετύποις μεθαρμοζόντων ὀρθῶς, καθάπερ ἔφη ὁ Μέγας Βασίλειος. Εὐλογητός ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C12.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C12.incipit = "Ναοὶ καλλωπίζονται…"
meMA.Ode7C12.text = "Ναοὶ καλλωπίζονται, φαιδραῖς εἰκόσι κατακοσμούμενοι νῦν· διὰ τοῦτο ὁ κόσμος, ἐν ἐκκλησίαις, τῷ ὑπὲρ πάντας βροτούς, ὡραίῳ κάλλει, συμψάλλει τοῖς ψάλλουσιν· Εὐλογητὸς ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C13.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C13.incipit = "Τὸ φῶς ἀνατέταλκε…"
meMA.Ode7C13.text = "Τὸ φῶς ἀνατέταλκε, μακρὰν τὸ σκότος, οἱ δυσσεβεῖς ἐκποδών· διὰ τοῦτο τὰ πάντα, φωτὸς πλησθέντα, τὸν φωτοδότην Χριστόν, μετʼ εὐθυμίας ὑμνοῦσι καὶ λέγουσιν· Εὐλογητὸς ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C1T.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C1T.incipit = "Ἡ πάναγνος Δέσποινα…"
meMA.Ode7C1T.text = "Ἡ πάναγνος Δέσποινα, ἡ μόνη πάντων τῆς σωτηρίας ἐλπίς, ἡ φρικτῶς τετοκυῖα, τὸν Βασιλέα τῶν βασιλέων Χριστόν, ἐν ταῖς ὠλέναις αὐτὸν βρέφος φέρουσα, συμπροσκυνεῖται γραπτῶς, ὡς οἱ Πατέρες φασίν."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C11.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
meMA.Ode8C11.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C11.incipit = "Νομοθετεῖ μὲν ἄριστα…"
meMA.Ode8C11.text = "Νομοθετεῖ μὲν ἄριστα, τῶν Πατέρων ὁ σύλλογος, τοῖς θεοσεβέσι, σχετικὴν προσκύνησιν, καὶ τὴν ἀναστήλωσιν, τῆς ἱερᾶς εἰκόνος Χριστοῦ· οἱ φιλευσεβεῖς δέ, τὴν ἐτήσιον μνήμην, ὡς παῖδες ἐκτελοῦμεν, εὐπειθεῖς τὴν ἐκείνων, καὶ πόθῳ τὴν εἰκόνα, Χριστοῦ καταφιλοῦμεν."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C12.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C12.incipit = "Ἑπταπλασίως ἔκαμπτον…"
meMA.Ode8C12.text = "Ἑπταπλασίως ἔκαμπτον, ταπεινοὺς ὑψηλόφρονες, καὶ τῶν φιλαρέτων, τὰς ὁρμὰς ἀνέκοπτον· διʼ ὧν ἐνδιέβαλλον, εἰς τὰς ἐνθέους πράξεις αὐτῶν· ἀλλʼ οἱ τῆς ἑβδόμης, συνελθόντες Συνόδου, Πατέρες ἐν Νικαίᾳ, τὴν ὀφρὺν τὴν ἐκείνων, αὐτίκα κατασπῶσιν, ἑπταπλασιωτέρως."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C13.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C13.incipit = "Βέλη νηπίων γίνονται…"
meMA.Ode8C13.text = "Βέλη νηπίων γίνονται, ψαλμικῶς γηραιόφροσι, τῶν νηπιοφρόνων, αἱ πληγαὶ καὶ μάστιγες· τῇ θείᾳ δυνάμει δέ, ἐξασθενοῦσι γλῶσσαι πολλαί, τῶν τὰς βλασφημίας, εἰς τὸ ὕψος λαλούντων· καὶ πᾶς τις τὸν Πατέρα, τὸν Υἱὸν καὶ τὸ Πνεῦμα, Θεὸν ἕνα γινώσκει, πανταίτιον καὶ μόνον."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C1T.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C1T.incipit = "Δημιουργεῖται νήπιος…"
meMA.Ode8C1T.text = "Δημιουργεῖται νήπιος, ἑκοντὶ διὰ ἔλεος, ὁ Δημιουργὸς ἐκ τῶν ἁγνῶν αἱμάτων σου, τηρῶν μετὰ τόκον σε, κεκαθαρμένην ὅλην Ἁγνή, καὶ τὴν ῥυπωθεῖσαν, ἐκκαθαίρων εἰκόνα· διό περ ἐν εἰκόσι, συμμορφοῦταί σοι φύσει, βροτὸς γεγενημένος, Θεὸς ὑπάρχων φύσει."

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C11.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9C11.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C11.incipit = "Ὁ μέγας τῇ ἰσχὺϊ…"
meMA.Ode9C11.text = "Ὁ μέγας τῇ ἰσχὺϊ καὶ τῇ βουλῇ, ὁ τὸ πᾶν συγκρατῶν ἀκατάληπτε, μόνε Θεέ, κράτιστε παντάρχα Παμβασιλεῦ, τὴν Ἐκκλησίαν κράτυνον, τῇ ὀρθοδοξίᾳ σου συντηρῶν, Πατέρων πανενδόξων, παραδειγματισάντων, κακοδοξίαν παρακλήσεσι."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C12.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C12.incipit = "Μεγάλων ἠξιώθητε…"
meMA.Ode9C12.text = "Μεγάλων ἠξιώθητε τῶν τιμῶν, ἐπὶ γῆς οὐρανόφρονες Ἅγιοι, ὅτι Χριστοῦ, τύπον ἐτιμήσατε σχετικῶς· καὶ νῦν σκιὰν ἐκθέμενοι, καὶ τὸ περικάλυμμα τῆς σαρκός, αὐτὸν αὐτοπροσώπως, εἰς πρόσωπον ὁρᾶτε, καὶ τῶν μειζόνων ἀξιούμενοι."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C13.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C13.incipit = "Ἣν ἵνα παιδευθῶμεν…"
meMA.Ode9C13.text = "Ἣν ἵνα παιδευθῶμεν πανστρατιάς, βαρβαρώδους ἱππείας ἠρέθισας, ῥύμην αὐτός, θραῦσον καὶ τὸ θράσος τὸ καθʼ ἡμῶν· καὶ βασιλεῖ συμμάχησον, τῷ τεθαῤῥηκότι σοι Παντουργέ, ταῖς εὐπαῤῥησιάστοις, πρεσβείαις τῶν Πατέρων, ὧν ἐκτελοῦμεν τὸ μνημόσυνον."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C1T.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C1T.incipit = "Νοῆσαι τὸ μυστήριον…"
meMA.Ode9C1T.text = "Νοῆσαι τὸ μυστήριον οὐδαμῶς, τῆς φρικτῆς σου λοχείας, δεδύνηται, βρότειος νοῦς, ἀλλʼ οὐδʼ ὑψηλόνους ἀγγελικός, ὅτι Θεὸν ἐγέννησας, σὺ σεσαρκωμένον ὑπερφυῶς· διό σε Θεοτόκον, εἰδότες σὺν ἐκείνῳ, καθιστοροῦντες μεγαλύνομεν."

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_gr_GR_cog.heAU.EnPnevmatiToIero.greekname
meMA.Exaposteilarion1.melody = he.a.m3_gr_GR_cog.heAU.EnPnevmatiToIero.name
meMA.Exaposteilarion1.incipit = "Πατέρες οὐρανόφρονες…"
meMA.Exaposteilarion1.text = "Πατέρες οὐρανόφρονες, οἱ Συνόδῳ ἑβδόμῃ, συναθροισθέντες δέησιν, ἐκτενῆ τῇ Τριάδι, προσάξατε τοῦ ῥυσθῆναι, ἐκ πάσης αἱρέσεως, καὶ κρίσεως αἰωνίου, Βασιλείας τε τυχεῖν, οὐρανῶν τοὺς τὴν ὑμῶν, σύναξιν θείαν ὑμνοῦντας."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.ExapTheotokion.melody = he.a.m3_gr_GR_cog.heAU.EnPnevmatiToIero.name
meMA.ExapTheotokion.incipit = "Πρεσβείαις ὑπεράγαθε…"
meMA.ExapTheotokion.text = "Πρεσβείαις ὑπεράγαθε, Κύριε τῆς Μητρός σου, καὶ τῶν ἐν ἑπτὰ Συνόδοις, ἀθροισθέντων Πατέρων, τὴν Ἐκκλησίαν στήριξον, καὶ τὴν Πίστιν κράτυνον. καὶ οὐρανῶν Βασιλείας, δεῖξον πάντας κοινωνούς, ὅταν ἔλθῃς ἐπὶ γῆς, τοῦ κρῖναι πᾶσαν τὴν κτίσιν."

meMA.Lauds1.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Lauds1.greekmelody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.greekname
meMA.Lauds1.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meMA.Lauds1.incipit = me.m07.dHF_gr_GR_cog.meMA.Lauds1.incipit
meMA.Lauds1.text = me.m07.dHF_gr_GR_cog.meMA.Lauds1.text

meMA.Lauds2.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Lauds2.melody = ""
meMA.Lauds2.incipit = me.m07.dHF_gr_GR_cog.meMA.Lauds2.incipit
meMA.Lauds2.text = me.m07.dHF_gr_GR_cog.meMA.Lauds2.text

meMA.Lauds3.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Lauds3.melody = ""
meMA.Lauds3.incipit = me.m07.dHF_gr_GR_cog.meMA.Lauds3.incipit
meMA.Lauds3.text = me.m07.dHF_gr_GR_cog.meMA.Lauds3.text

meMA.LaudsGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.LaudsGlory.melody = ""
meMA.LaudsGlory.incipit = "Τῶν ἁγίων Πατέρων ὁ χορός…"
meMA.LaudsGlory.text = "Τῶν ἁγίων Πατέρων ὁ χορός, ἐκ τῶν τῆς οἰκουμένης περάτων συνδραμών, Πατρὸς καὶ Υἱοῦ καὶ Πνεύματος Ἁγίου, μίαν οὐσίαν ἐδογμάτισε καὶ φύσιν· καὶ τὸ μυστήριον τῆς θεολογίας, τρανῶς παρέδωκε τῇ Ἐκκλησίᾳ. Οὓς εὐφημοῦντες ἐν πίστει, μακαρίσωμεν λέγοντες· Ὦ θεία παρεμβολή, θεηγόροι ὁπλῖται, παρατάξεως Κυρίου· ἀστέρες πολύφωτοι, τοῦ νοητοῦ στερεώματος· τῆς μυστικῆς Σιών, οἱ ἀκαθαίρετοι πύργοι· τὰ μυρίπνοα ἄνθη τοῦ Παραδείσου· τὰ πάγχρυσα στόματα τοῦ Λόγου· Νικαίας τὸ καύχημα, οἰκουμένης ἀγλάϊσμα· ἐκτενῶς πρεσβεύσατε, ὑπὲρ τῶν ψυχῶν ἡμῶν."

meLI.Kontakion1.mode = me.m10.dHF_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.melody = me.m10.dHF_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m10.dHF_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m10.dHF_gr_GR_cog.meMA.Kontakion1.text

meLI.MM.CommunionHymn.text = properties_gr_GR_cog.media.key

meLI.Megalynarion.text = "Ἐπὶ τὸ πρωτότυπον ἡ τιμή, τῶν σεπτῶν Εἰκόνων, διαβαίνει ὡς ἀληθῶς, ὥσπερ οἱ Πατέρες, Συνόδου τῆς ἑβδόμης, ἐτράνωσαν πανσόφως· οὓς μεγαλύνομεν."
