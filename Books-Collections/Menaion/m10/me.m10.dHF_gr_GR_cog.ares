meDA.commemoration.full = "Ἀκολουθία τῶν Ἁγίων Πατέρων τῆς Ζʹ Οἰκουμενικῆς Συνόδου" // full title of day
meDA.commemoration.first = "Τῶν Ἁγίων Πατέρων τῆς Ζʹ Συνόδου"
meDA.commemoration.first_short = "Τῶν Ἁγίων Πατέρων τῆς Ζʹ Συνόδου"
