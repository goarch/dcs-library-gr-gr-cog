meDA.fordate = "διὰ τὴν 14ην Αὐγούστου"
meLE.commemoration1 = "Προεόρτια τῆς Κοιμήσεως τῆς Ὑπεραγίας Θεοτόκου καὶ ἀειπαρθένου Μαρίας, καὶ μνήμη τοῦ Ἁγίου Προφήτου Μιχαίου."
meLE.commemoration2 = ""
