A_Resource_Whose_Name = me.m08.d14_gr_GR_cog

meDA.date = "Τῌ ΙΔʹ ΑΥΓΟΥΣΤΟΥ"
meDA.commemoration.full = "Προεόρτια τῆς Κοιμήσεως τῆς Ὑπεραγίας Θεοτόκου καὶ ἀειπαρθένου Μαρίας, καὶ μνήμη τοῦ Ἁγίου Προφήτου Μιχαίου." //full title of day
meDA.commemoration.first = "Προεόρτια τῆς Κοιμήσεως τῆς Θεοτόκου"
meDA.commemoration.first_short = "Προεόρτια τῆς Κοιμήσεως τῆς Θεοτόκου"
