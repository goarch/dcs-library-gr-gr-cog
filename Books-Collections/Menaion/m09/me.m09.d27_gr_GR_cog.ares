meDA.pdfheaderdate = "τῆς 27ης Σεπτεμβρίου"
meDA.fordate = "διὰ τὴν 27ην Σεπτεμβρίου"
meLE.commemoration1 = "Μνήμη τοῦ Ἁγίου Μάρτυρος Καλλιστράτου, καὶ τῶν σὺν αὐτῷ."
meLE.commemoration2 = ""
