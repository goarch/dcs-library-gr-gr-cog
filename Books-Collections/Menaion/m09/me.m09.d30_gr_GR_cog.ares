meDA.date = "Τῌ Λʹ ΣΕΠΤΕΜΒΡΙΟΥ"
meDA.commemoration.full = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Γρηγορίου τῆς Μεγάλης Ἀρμενίας" // full title of day
meDA.commemoration.first = "Μνήμη τοῦ Ἁγίου Γρηγορίου τῆς Μεγάλης Ἀρμενίας"
meDA.commemoration.first_short = "Μνήμη τοῦ Ἁγίου Γρηγορίου τῆς Μεγάλης Ἀρμενίας"
