meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera01.greekmelody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.greekname
meVE.Stichera01.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meVE.Stichera01.incipit = "Μαρτύρων ἐν αἵματι…"
meVE.Stichera01.text = "Μαρτύρων ἐν αἵματι, τὴν ἱερὰν διπλοΐδα, φοινίξας εἰσέδραμες, εἰς Ἁγίων Ἅγια, ἀξιάγαστε, ἔνθα φῶς ἄῤῥητον, ἔνθα θεία δόξα, ὅπου ἦχος ἑορτάζοντος, ἐν ᾧ τῶν πόνων σου, Μάρτυς ἀποδέχῃ τὰ ἔπαθλα, καὶ στέφος τὸ ἀμάραντον, καὶ τὴν αἰωνίζουσαν εὔκλειαν, καὶ τοῦ Παραδείσου, τὴν οἴκησιν Γρηγόριε σοφέ, ἐν παῤῥησίᾳ δεόμενος, ὑπὲρ τῶν ψυχῶν ἡμῶν."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera02.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meVE.Stichera02.incipit = "Βασάνων οὐκ ἔσεισε…"
meVE.Stichera02.text = "Βασάνων οὐκ ἔσεισε, σοῦ τὴν ψυχὴν τρικυμία, οὐ κάθειρξις χρόνιος, ἐν ζοφώδει λάκκῳ σε κατακρύπτουσα, Ἀθλητὰ ἔνδοξε· ἀλλʼ ὡς φῶς ἤστραψας, τοῖς ἐν σκότει κινδυνεύουσι, τῆς ματαιότητος, οὓς υἱοὺς ἡμέρας ἀνέδειξας, λουτροῦ διὰ Βαπτίσματος, καὶ ἀναγεννήσεως κρείττονος, καὶ σωτηριώδους, καὶ θείας ἀληθῶς διαγωγῆς, ὡς ἱεράρχης θεόληπτος, πάνσοφε Γρηγόριε."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera03.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meVE.Stichera03.incipit = "Νυμφίον ἀθάνατον…"
meVE.Stichera03.text = "Νυμφίον ἀθάνατον, σὲ τὸν ἁπάντων Δεσπότην, Ῥιψιμία στέργουσα, τὴν δορὰν ἀφῄρηται, τὴν τοῦ σώματος, τῶν παθῶν πρότερον, τὸν ζοφώδη σάκκον, ἐγκρατείᾳ διαῤῥήξασα· μεθʼ ἧς ἠγώνισται, καὶ Γαϊανὴ ἡ ἀοίδιμος, παρθένων ἐπιφέρουσα, ὅμιλον στεῤῥῶς ἐναθλήσαντα, καὶ καταβαλόντα, τῆς Εὔας τὸν ἀρχαῖον πτερνιστήν· ἃς ἐπαξίως γεραίροντες, σὲ Χριστὲ δοξάζομεν."

meVE.SticGlory.poet = poets_gr_GR_cog.po.Sergiou
meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Τίς ἐπαξίως τῶν ἀρετῶν…"
meVE.SticGlory.text = "Τίς ἐπαξίως τῶν ἀρετῶν σου διηγήσεται τὰ τρόπαια; ποῖον στόμα τοῦ μαρτυρίου τὴν καρτερίαν ἀποφθέγξεται; ἐν ἀμφοτέροις γὰρ ἠρίστευσας Γρηγόριε. Ἀλλὰ μὴ παύσῃ δυσωπῶν, εὐαρεστήσας Χριστῷ, σωθῆναι τὰς ψυχὰς ἡμῶν, ὡς ἔχων Ἱερομάρτυς παῤῥησίαν πολλήν."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticTheotokion.greekmelody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.greekname
meVE.SticTheotokion.melody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.name
meVE.SticTheotokion.incipit = "Τὴν πᾶσάν μου ἐλπίδα…"
meVE.SticTheotokion.text = "Τὴν πᾶσάν μου ἐλπίδα εἰς σέ, Παρθένε ἀνατίθημι· μὴ παρίδῃς, ἀλλὰ σπεῦσον ἀγαθή, ῥυσθῆναί με ἐν τάχει, παθῶν τῶν ἐνοχλούντων, καὶ καθʼ ἑκάστην πολεμούντων με."

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticStavrotheotokion.greekmelody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.greekname
meVE.SticStavrotheotokion.melody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.name
meVE.SticStavrotheotokion.incipit = "Ὁ ἥλιος ἐσκότασεν…"
meVE.SticStavrotheotokion.text = "Ὁ ἥλιος ἐσκότασεν, Υἱέ μου προσηλούμενον, φωτοδότα, καθορῶν σε καὶ ἡ γῆ, τῷ φόβῳ ἐκλονεῖτο· λαὸς δὲ Ἰουδαίων, οὐδόλως ᾤκτειρε παμφίλτατε."

meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Εἰς τὸν ἄδυτον γνόφον…"
meVE.AposGlory.text = "Εἰς τὸν ἄδυτον γνόφον τοῦ ἀφράστου φωτός, εἰσδύσας νοητῶς ὁ Μάρτυς καὶ Ποιμήν, ἐμυήθη τὰ ἀπόῤῥητα τῶν μυστηρίων Θεοῦ, ὡς Μάρτυς μὲν φωτιζόμενος, ὡς ποιμὴν δὲ μυσταγωγούμενος· διὸ διπλοῦς καὶ τοὺς στεφάνους, ἐκ τῆς ἄνω δόξης ἀνεδήσατο, πρεσβεύων πάντοτε Χριστῷ ὑπὲρ τῶν ψυχῶν ἡμῶν."

meVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.AposTheotokion.melody = he.o_gr_GR_cog.heOT.TheotokeSyEi.name
meVE.AposTheotokion.incipit = he.o_gr_GR_cog.heOT.TheotokeSyEi.incipit
meVE.AposTheotokion.text = he.o_gr_GR_cog.heOT.TheotokeSyEiAthloforou.text

meVE.AposStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.AposStavrotheotokion.greekmelody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.greekname
meVE.AposStavrotheotokion.melody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.name
meVE.AposStavrotheotokion.incipit = oc.m6.d6_gr_GR_cog.ocVE.AposTheotokion.incipit
meVE.AposStavrotheotokion.text = oc.m6.d6_gr_GR_cog.ocVE.AposTheotokion.text

meVE.GeneralApolytikion1.name = "Γρηγόριε·"
meVE.MM.GeneralApolytikion1.text = properties_gr_GR_cog.media.key

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.Apolytikion1ger.greekmelody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.greekname
meVE.Apolytikion1ger.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meVE.Apolytikion1ger.incipit = "Θείας πίστεως…"
meVE.Apolytikion1ger.text = "Θείας πίστεως, τῇ γεωργίᾳ, ἐνεούργησας, βροτῶν καρδίας, κατασπείρας τὴν τοῦ Λόγου ἐπίγνωσιν, καὶ λαμπρυνθεὶς μαρτυρίου τοῖς στίγμασιν, ἱεραρχίᾳ Γρηγόριε ἔφανας. Πάτερ Ὅσιε, Χριστὸν τὸν Θεὸν ἱκέτευε, δωρήσασθαι ἡμῖν τὸ μέγα ἔλεος."

meMA.C1.acrostic.title = "Κανὼν τοῦ Ἁγίου,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Τὸν γρήγορον μέλπω σε, Μάρτυς, ποιμένα. Ὁ Ἰωσήφ."
meMA.C1.title = titles_gr_GR_cog.ti.CanonHieromartyr
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.greekname
meMA.Ode1C11.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C11.incipit = "Τριάδι τῇ σεπτῇ παρεστὼς στεφηφόρος…"
meMA.Ode1C11.text = "Τριάδι τῇ σεπτῇ παρεστὼς στεφηφόρος, ὡς γρήγορος ποιμήν, ὡς Μάρτυς ἱερός, ἱεραῖς σου δεήσεσι, κοίμισον τὰ τῶν παθῶν μου, ἀχλυώδη ἰνδάλματα, εὐφημοῦντος σε, Μάκαρ Γρηγόριε."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C12.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C12.incipit = "Ὁ ἄδυτος λαμπτήρ, Ἱεράρχης ὁ…"
meMA.Ode1C12.text = "Ὁ ἄδυτος λαμπτήρ, Ἱεράρχης ὁ μέγας, ὁ πολύαθλος ποιμήν, ἀγώνων ἡ τριβή, Ἀρμενίας τὸ καύχημα, σήμερον πρὸς εὐωχίαν, τοὺς πιστοὺς συνεκάλεσε, συνελθόντες αὐτὸν μακαρίσωμεν."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C13.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C13.incipit = "Ναμάτων ζωηρῶν, τῶν τοῦ Πνεύματος…"
meMA.Ode1C13.text = "Ναμάτων ζωηρῶν, τῶν τοῦ Πνεύματος Μάκαρ, ἐμπλησθεὶς ὡς ποταμός, Ἐδὲμ τῆς νοητῆς, ἐκπεπόρευσαι πρόσωπον, ἄρδων τὸ τῆς Ἐκκλησίας, καὶ ξηραίνων τὸ πέλαγος, τῆς εἰδωλομανίας Γρηγόριε."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C1T.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C1T.incipit = "Γυναῖκες τῷ Σταυρῷ, τοῦ ἐκ…"
meMA.Ode1C1T.text = "Γυναῖκες τῷ Σταυρῷ, τοῦ ἐκ σοῦ σαρκωθέντος, κραταιούμεναι Ἁγνή, ἐνήθλησαν στεῤῥῶς, καὶ αὐτῷ προσηνέχθησαν, ὄπισθέν σου τῆς Παρθένου, παρθενίας λαμπρότησι, καὶ Μαρτύρων ἐν αἵματι λάμπουσαι."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OtiSteiraEteken.greekname
meMA.Ode3C11.melody = he.h.m4_gr_GR_cog.heHE.OtiSteiraEteken.name
meMA.Ode3C11.incipit = "Ῥαπισμοῖς σιαγόνων σου, μύλας συντρίβεις…"
meMA.Ode3C11.text = "Ῥαπισμοῖς σιαγόνων σου, μύλας συντρίβεις λεόντων, καὶ ὀχετοῖς αἱμάτων, δαιμόνων λύθρον ἐκμειοῖς, εἰδωλικὰς προῤῥίζους τε, καταστρέφεις στήλας, Ἀξιάγαστε."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C12.melody = he.h.m4_gr_GR_cog.heHE.OtiSteiraEteken.name
meMA.Ode3C12.incipit = "Οὐ δεινῶν ἐπίτασις, οὐ χαλεπαὶ…"
meMA.Ode3C12.text = "Οὐ δεινῶν ἐπίτασις, οὐ χαλεπαὶ τιμωρίαι, οὐ ζοφωτάτη λάκκου, κάθειρξις χρόνιος τὴν σήν, ἀδαμαντίνην ἔτρεψε διάνοιαν Μάρτυς Ἀξιάγαστε."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C13.melody = he.h.m4_gr_GR_cog.heHE.OtiSteiraEteken.name
meMA.Ode3C13.incipit = "Νυσταγμὸν σοῖς ὄμμασι, Μάρτυς οὐκ…"
meMA.Ode3C13.text = "Νυσταγμὸν σοῖς ὄμμασι, Μάρτυς οὐκ ἔδωκας ἕως, τοὺς νυσταγμῷ κακίας, κεκρατημένους δυσσεβῶς, υἱοὺς ἡμέρας ἔδειξας κραυγάζοντας, Ἅγιος εἶ Κύριε."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C1T.melody = he.h.m4_gr_GR_cog.heHE.OtiSteiraEteken.name
meMA.Ode3C1T.incipit = "Μητροπάρθενον Κόρην, σὲ Ῥιψιμία ἡ…"
meMA.Ode3C1T.text = "Μητροπάρθενον Κόρην, σὲ Ῥιψιμία ἡ Μάρτυς, ἐπισταμένη μόνην, ἐθέλχθη σοῦ ταῖς καλλοναῖς, καὶ τῷ Χριστῷ ὀπίσω σου προσήνεκται, ἄθλοις διαλάμπουσα."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3H.greekmelody = he.h.m4_gr_GR_cog.heHE.OtiSteiraEteken.greekname
meMA.Ode3H.melody = he.h.m4_gr_GR_cog.heHE.OtiSteiraEteken.melody
meMA.Ode3H.incipit = he.h.m4_gr_GR_cog.heHE.OtiSteiraEteken.incipit
meMA.Ode3H.text = he.h.m4_gr_GR_cog.heHE.OtiSteiraEteken.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3Kathisma1.greekmelody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.greekname
meMA.Ode3Kathisma1.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meMA.Ode3Kathisma1.incipit = "Βλέμμα γρήγορον τῆς διανοίας, Μάρτυς…"
meMA.Ode3Kathisma1.text = "Βλέμμα γρήγορον τῆς διανοίας, Μάρτυς ἔνδοξε προκεκτημένος, ὁμωνύμως καὶ καταλλήλως διέπρεψας, ὑπὲρ Χριστοῦ τῇ ἀθλήσει στρεβλούμενος, ἐν προσευχαῖς ἀνενδότως ἠγρύπνησες ὅθεν εἴληφας, ἱεραρχικῶς διʼ αἵματος, βραβεῖον κατʼ ἄμφω παμμάκαρ Γρηγόριε."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3KathismaT.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meMA.Ode3KathismaT.incipit = oc.m3.d2_gr_GR_cog.ocMA.Kathisma23.incipit
meMA.Ode3KathismaT.text = oc.m3.d2_gr_GR_cog.ocMA.Kathisma23.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3KathismaSt.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meMA.Ode3KathismaSt.incipit = me.m01.d29_gr_GR_cog.meMA.Ode3KathismaSt.incipit
meMA.Ode3KathismaSt.text = me.m01.d29_gr_GR_cog.meMA.Ode3KathismaSt.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.greekname
meMA.Ode4C11.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C11.incipit = "Εἰς περίβλεπτον σε ὕψος, μαρτυρίου…"
meMA.Ode4C11.text = "Εἰς περίβλεπτον σε ὕψος, μαρτυρίου ἀνήνεγκεν, ὑψηλὸς ἐν δόξῃ, Κύριος Ὕψιστος ἔνδοξε, οὗ τὰ παθήματα χαίρων ἐξεικόνισας, Ἱερομάρτυς, δόξα βοῶν τῇ δυνάμει σου."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C12.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C12.incipit = "Λυμαινόμενον ἀθέως, τὸν ἐχθρὸν χώραν…"
meMA.Ode4C12.text = "Λυμαινόμενον ἀθέως, τὸν ἐχθρὸν χώραν ἅπασαν, τὴν τῶν Ἀρμενίων, θείᾳ δυναστείᾳ κατέβαλες, καὶ ὡς πυρσὸς ἀναλάμψας κατεφώτισας, τοὺς ἐν σκότει, κειμένους σοφὲ ματαιότητος."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C13.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C13.incipit = "Πολυπλάσιον τῷ Κτίστῃ, σοῦ τὸ…"
meMA.Ode4C13.text = "Πολυπλάσιον τῷ Κτίστῃ, σοῦ τὸ τάλαντον ἤνεγκας, τῶν ἀνασωθέντων, θείαις διδαχαῖς σου Γρηγόριε, καὶ πρὸς αὐτοῦ τὸν ἀγήρω κλῆρον εἴληφας, βασιλείαν, τὴν τῶν οὐρανῶν καὶ λαμπρότητα."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C1T.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C1T.incipit = "Ὡς καλὴν ὡς ἐκλεκτὴν σε…"
meMA.Ode4C1T.text = "Ὡς καλὴν ὡς ἐκλεκτήν σε, ὡς ὡραίαν ἠγάπησαν, νεάνιδες κόραι, μετὰ Ῥιψιμίας ἀθλήσασαι, παρθενομῆτορ Μαρία, καὶ ὀπίσω σου, προσηνέχθησαν, τῷ σῷ Υἱῷ εὐφραινόμεναι."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TonFotismonSouKyrie.greekname
meMA.Ode5C11.melody = he.h.m4_gr_GR_cog.heHE.TonFotismonSouKyrie.name
meMA.Ode5C11.incipit = "Σταυροφανὲς ἑώρακας, σημεῖον ἐμφανῶς, φωτὶ…"
meMA.Ode5C11.text = "Σταυροφανὲς ἑώρακας, σημεῖον ἐμφανῶς, φωτὶ ἐκλάμπον, καὶ λῦον τὴν νύκτα τὴν εἰδωλικήν, φωτός τε τέκνα, τοὺς πιστοὺς ἐργαζόμενον."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C12.melody = he.h.m4_gr_GR_cog.heHE.TonFotismonSouKyrie.name
meMA.Ode5C12.incipit = "Ἐν κατωτάτῳ λάκκῳ σε, διέσωσε…"
meMA.Ode5C12.text = "Ἐν κατωτάτῳ λάκκῳ σε, διέσωσε Θεός, θηρσὶ συνόντα ἐτῶν περιόδους, μέλλοντα φωτὶ τοῦ θείου Λόγου, καταυγάζειν τοὺς ἄφρονας."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C13.melody = he.h.m4_gr_GR_cog.heHE.TonFotismonSouKyrie.name
meMA.Ode5C13.incipit = "Μαρτυρικῶς ἠγώνισαι, καὶ στεφθεὶς ὡς…"
meMA.Ode5C13.text = "Μαρτυρικῶς ἠγώνισαι, καὶ στεφθεὶς ὡς νικητής· χρισθεὶς δὲ μύρῳ ἱερωσύνης, ἔχρισας λαούς, δυσώδους πλάνης, ἀπαλλάξας Γρηγόριε."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C1T.melody = he.h.m4_gr_GR_cog.heHE.TonFotismonSouKyrie.name
meMA.Ode5C1T.incipit = "Οἱ τῆς ὀσμῆς αἰσθόμεναι, τοῦ…"
meMA.Ode5C1T.text = "Οἱ τῆς ὀσμῆς αἰσθόμεναι, τοῦ μύρου τοῦ ἐκ σοῦ ἁγνή, Παρθένε ἐκλάμψαντος Λόγου, διʼ ἀθλητικῶν, αὐτῷ ἀγώνων, εὐηρέστησαν χαίρουσαι."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C11.greekmelody = he.h.m4_gr_GR_cog.heHE.EvoiseProtypon.greekname
meMA.Ode6C11.melody = he.h.m4_gr_GR_cog.heHE.EvoiseProtypon.name
meMA.Ode6C11.incipit = "Ῥημάτων σου, δυναστείᾳ ναοὶ κατεῤῥάγησαν…"
meMA.Ode6C11.text = "Ῥημάτων σου, δυναστείᾳ ναοὶ κατεῤῥάγησαν, καὶ δαιμόνων κατεβλήθη, ἀνίδρυτα ξόανα, καὶ πιστῶν καρδίαι, θεϊκῷ ἐνιδρύθησαν ἔρωτι."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C12.melody = he.h.m4_gr_GR_cog.heHE.EvoiseProtypon.name
meMA.Ode6C12.incipit = "Τηριδάτην, ὥσπερ συνδεδεμένον προσήγαγες, τῷ…"
meMA.Ode6C12.text = "Τηριδάτην, ὥσπερ συνδεδεμένον προσήγαγες, τῷ Κυρίῳ, ὥσπερ ἄρνα τὸν πρὶν λύκον ἄγριον, διὰ μέγαν πλοῦτον, εὐσπλαγχνίας Θεοῦ νῦν σῳζόμενον."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C13.melody = he.h.m4_gr_GR_cog.heHE.EvoiseProtypon.name
meMA.Ode6C13.incipit = "Ὑπέδειξας, πλανηθεῖσι τὴν τρίβον τὴν…"
meMA.Ode6C13.text = "Ὑπέδειξας, πλανηθεῖσι τὴν τρίβον τὴν ἔνθεον, ἀπλανέσι διδαχαῖς, Ἱεράρχα χρησάμενος, ὡς ποιμὴν Ποιμένος, ἀληθοῦς μιμητὴς ὦ Γρηγόριε."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C1T.melody = he.h.m4_gr_GR_cog.heHE.EvoiseProtypon.name
meMA.Ode6C1T.incipit = "Σταυρωθέντα, τὸν ἐκ σοῦ ὡς…"
meMA.Ode6C1T.text = "Σταυρωθέντα, τὸν ἐκ σοῦ ὡς ἐπέγνω σαρκούμενον, Θεοτόκε, Ῥιψιμία αὐτῷ συνεσταύρωται, ὡς ἀμνὰς ποιμένι, ἱερεῖον Θεοῦ ὡς ἀμώμητον."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6H.greekmelody = he.h.m4_gr_GR_cog.heHE.EvoiseProtypon.greekname
meMA.Ode6H.melody = he.h.m4_gr_GR_cog.heHE.EvoiseProtypon.melody
meMA.Ode6H.incipit = he.h.m4_gr_GR_cog.heHE.EvoiseProtypon.incipit
meMA.Ode6H.text = he.h.m4_gr_GR_cog.heHE.EvoiseProtypon.text

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Kontakion1.greekmelody = he.a.m2_gr_GR_cog.heAU.TousAsfaleis.greekname
meMA.Kontakion1.melody = he.a.m2_gr_GR_cog.heAU.TousAsfaleis.name
meMA.Kontakion1.incipit = "Τὸν εὐκλεῆ…"
meMA.Kontakion1.text = "Τὸν εὐκλεῆ καὶ Ἱεράρχην ἅπαντες, ὡς ἀθλητὴν τῆς ἀληθείας σήμερον, οἱ πιστοὶ θείοις ἐν ᾄσμασι, καὶ ὑμνῳδίαις εὐφημήσωμεν· τὸν γρήγορον ποιμένα καὶ διδάσκαλον, Γρηγόριον, φωστῆρα τὸν παγκόσμιον· Χριστῷ γὰρ πρεσβεύει τοῦ σωθῆναι ἡμᾶς."

meMA.Oikos1.text = "Τοῦτον τὸν μέγαν ἐν Ἀθλοφόροις, τὸν φωστῆρα τὸν θεῖον, Ἀρμενίας πιστοὶ ποιμένα τε καὶ πρόμαχον, ἐν ὑμνῳδίαις εὐφημοῦμεν καὶ ᾄσμασιν ἐνθέοις αὐτοῦ τὴν μνήμην· τὴν γὰρ ἀχλὺν τῶν ματαίων εἰδώλων ἠφάνισε, σὺν τούτοις καὶ τῶν δαιμόνων τὴν ἐνέργειαν ἐνέκρωσε· διὸ τοὺς πόνους ὑπήνεγκε, σταθερᾷ διανοίᾳ καὶ χάριτι, καὶ πρεσβεύει Χριστῷ τοῦ σωθῆναι ἡμᾶς."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C11.greekmelody = he.h.m4_gr_GR_cog.heHE.AvramiaioiPote.greekname
meMA.Ode7C11.melody = he.h.m4_gr_GR_cog.heHE.AvramiaioiPote.name
meMA.Ode7C11.incipit = "Πολυειδεῖς βασάνους, καθυπομείνας Μάρτυς, πολλοὺς…"
meMA.Ode7C11.text = "Πολυειδεῖς βασάνους, καθυπομείνας Μάρτυς, πολλοὺς βασάνων ἠλευθέρωσας, μελλούσης ἐτάσεως, ὁ τῶν Πατέρων βοῶν, Θεὸς εὐλογητὸς εἶ."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C12.melody = he.h.m4_gr_GR_cog.heHE.AvramiaioiPote.name
meMA.Ode7C12.incipit = "Οἶκον Τριάδος σαυτόν, ἀποτελέσας Μάρτυς…"
meMA.Ode7C12.text = "Οἶκον Τριάδος σαυτόν, ἀποτελέσας Μάρτυς, ναοὺς εἰδώλων κατηδάφισας, ναοὺς δὲ ἀνήγειρας, τῷ παντεπόπτῃ Λόγῳ, λαοῦ εἰς σωτηρίαν."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C13.melody = he.h.m4_gr_GR_cog.heHE.AvramiaioiPote.name
meMA.Ode7C13.incipit = "Ἱερουργὸς ἐδείχθης, σαυτὸν θυσίαν πρώην…"
meMA.Ode7C13.text = "Ἱερουργὸς ἐδείχθης, σαυτὸν θυσίαν πρώην, θερμῶς προσάγων τῷ Δεσπότῃ σου· ὃν θύων μετέπειτα, τοῖς εὐσεβέσι νέμεις, ψυχῶν εἰς σωτηρίαν."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C1T.melody = he.h.m4_gr_GR_cog.heHE.AvramiaioiPote.name
meMA.Ode7C1T.incipit = "Μαρτυρικοῖς στεφάνοις, κεκοσμημέναι Κόραι, τῷ…"
meMA.Ode7C1T.text = "Μαρτυρικοῖς στεφάνοις, κεκοσμημέναι Κόραι, τῷ ἐκ Παρθένου ἀνατείλαντι, Θεῷ προσηνέχθησαν, μελῳδικῶς βοῶσαι· Χριστέ, εὐλογητὸς εἶ."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C11.greekmelody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.greekname
meMA.Ode8C11.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C11.incipit = "Ἐναθλήσας νομίμως κατῄσχυνας, τοὺς ἀνόμους…"
meMA.Ode8C11.text = "Ἐναθλήσας νομίμως κατῄσχυνας, τοὺς ἀνόμους ἐχθροὺς κραταιότατα, ἱερουργὲ Γρηγόριε, καὶ Θεῷ προσηγάγω μέλποντα δῆμον· Εὐλογεῖτε ὑμνεῖτε τὸν Κύριον."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C12.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C12.incipit = "Νεουργήσας τὴν ἄκαρπον ἄρουραν, κατεβάλου…"
meMA.Ode8C12.text = "Νεουργήσας τὴν ἄκαρπον ἄρουραν, κατεβάλου τοῦ λόγου τὰ σπέρματα, εἰς ἑκατὸν δρεψάμενος, λογικῶν ἀσταχύων τὴν εὐκαρπίαν, γεωργῷ τῶν ψυχῶν εὐφορήσασαν."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C13.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C13.incipit = "Ἀστραπαῖς σου τῶν λόγων ἐφώτισας…"
meMA.Ode8C13.text = "Ἀστραπαῖς σου τῶν λόγων ἐφώτισας, καὶ πολλὰς μυριάδας προσήγαγες, τῷ διʼ ἡμᾶς ἑκούσια, ὑπομείναντι πάθη, ᾧ μελωδοῦμεν· Εὐλογεῖτε ὑμνεῖτε τὸν Κύριον."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C1T.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C1T.incipit = "Οὐ βασάνων πληθὺν δειλιάσασα, οὐ…"
meMA.Ode8C1T.text = "Οὐ βασάνων πληθὺν δειλιάσασα, οὐ σαρκὸς ἡδοναῖς ὑποκύψασα, τὸν ἐκ Παρθένου Κύριον, ὡμολόγει βοῶσα ἡ Ῥιψιμία· Εὐλογεῖτε ὑμνεῖτε τὸν Κύριον."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8H.greekmelody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.greekname
meMA.Ode8H.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.melody
meMA.Ode8H.incipit = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.incipit
meMA.Ode8H.text = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C11.greekmelody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.greekname
meMA.Ode9C11.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C11.incipit = "Ἰσχύϊ νευρούμενος Χριστοῦ ὑπήνεγκας, τῶν…"
meMA.Ode9C11.text = "Ἰσχύϊ νευρούμενος Χριστοῦ ὑπήνεγκας, τῶν βασάνων τὸ ἐπίπονον, στήλας κατέαξας δαιμόνων, ναοὺς εἰδωλικοὺς κατηδάφισας, λαούς τε τοὺς ἐν ἀγνοίᾳ ἐφώτισας, Ἱερομάρτυς πανσεβάσμιε."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C12.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C12.incipit = "Ὡς ὄρθρος ἀνέτειλεν ἡμῖν ἡ…"
meMA.Ode9C12.text = "Ὡς ὄρθρος ἀνέτειλεν ἡμῖν ἡ μνήμη σου, χαρισμάτων αἴγλην φέρουσα· σὺ γὰρ φωτὸς ὤφθης δοχεῖον, τοῦ θείου καὶ πρὸς φῶς ἐξεδήμησας, ἀνέσπερον πλουσίως λαμπόμενος, φωτοχυσίαις θείαις Ὅσιε."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C13.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C13.incipit = "Συνόμιλος ὤφθης Προφητῶν, Μαρτύρων τε…"
meMA.Ode9C13.text = "Συνόμιλος ὤφθης Προφητῶν, Μαρτύρων τε, Ἀποστόλων ὁμοδίαιτος, Ἀρχιερέων καὶ Ὁσιῶν, Ἀγγέλων Ἀρχαγγέλων ἰσόῤῥοπος· μεθʼ ὧν ὑπὲρ ἡμῶν τῶν ὑμνούντων σε, Πάτερ δυσώπει τὸν φιλάνθρωπον."

meMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C14.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C14.incipit = "Ἠρίστευσαν γύναια σεμνὰ τὴν ἔκπτωσιν…"
meMA.Ode9C14.text = "Ἠρίστευσαν γύναια σεμνὰ τὴν ἔκπτωσιν, τὴν τῆς Εὕας ἀνορθούμενα, ἤνεγκαν πόνων τρικυμίαν, μεγάλα τὸν εἰς ὕψος καυχώμενον, ποσὶν ὡραιοτάτοις συνέτριψαν· ἃς ἐπαξίως μακαρίζομεν."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C1T.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C1T.incipit = "Φωτὶ τοῦ προσώπου τοῦ ἐκ…"
meMA.Ode9C1T.text = "Φωτὶ τοῦ προσώπου τοῦ ἐκ σοῦ ἐκλάμψαντος, ἐλλαμφθεῖσα Ἀειπάρθενε, πόθῳ ἀσχέτῳ Ῥιψιμία, παθήματα αὐτοῦ καὶ τὸν θάνατον, οἰκείᾳ τῇ σαρκὶ ἐξεικόνισεν· ὅθεν σὺν σοὶ νῦν ἐπαγάλλεται."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9H.greekmelody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.greekname
meMA.Ode9H.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.melody
meMA.Ode9H.incipit = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.incipit
meMA.Ode9H.text = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.text

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Exaposteilarion1.greekmelody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.greekname
meMA.Exaposteilarion1.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
meMA.Exaposteilarion1.incipit = "Φρικτὸν ἰδόντες θέαμα…"
meMA.Exaposteilarion1.text = "Φρικτὸν ἰδόντες θέαμα, ἐξέστησαν οἱ ἄπιστοι· ὃν γὰρ ἐνόμιζον εἶναι, νεκρὸν ἐν λάκκῳ θηρίων, ζῶντα ἀναβιβάσαντες, προσπίπτουσι κραυγάζοντες· Μέγας Θεὸς Γρηγορίου, ὁ τοῦτον δείξας φωστῆρα."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.ExapTheotokion.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
meMA.ExapTheotokion.incipit = "Ὁ νώτοις ἐποχούμενος…"
meMA.ExapTheotokion.text = "Ὁ νώτοις ἐποχούμενος, χερουβικοῖς Πανάχραντε, ἐν ταῖς ἀγκάλαις σου θέλων, σάρκα λαβὼν ἀνεκλήθη, ὅπως ἡμᾶς ἐργάσηται, υἱοὺς Θεοῦ τῇ χάριτι, τοὺς εἰς αὐτὸν πιστεύοντας, καί σὲ ἀεὶ εὐφημοῦντας, τὴν πρόξενον σωτηρίας."

meLI.Kontakion1.mode = me.m09.d30_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.greekmelody = me.m09.d30_gr_GR_cog.meMA.Kontakion1.greekmelody
meLI.Kontakion1.melody = me.m09.d30_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m09.d30_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m09.d30_gr_GR_cog.meMA.Kontakion1.text

meLI.Megalynarion.text = ""

