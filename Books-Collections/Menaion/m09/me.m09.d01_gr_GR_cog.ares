meLI.MM.CommunionHymn.text = properties_gr_GR_cog.media.key

meLI.Megalynarion.text = "Ἄναρχε τρσήλιε Βασιλεῦ, ὁ καιρῶν καὶ χρόνων, τὰς ἑλίξεις περισκοπῶν, εὐλόγησον τὸν κύκλον, τῆς νέας περιόδου, τὰς ἀγαθάς σου δόσεις πᾶσι δωρούμενος."
meLI.Megalynarion2.text = "Στῦλος ἐναρέτου ὤφθης ζωῆς, ἐν στύλῳ βιώσας, ὑπὲρ ἄνθρωπον Συμεών· ἔνθεν ἀμοιβῶν σου, τὰς ὑπὲρ νοῦν ἐλλάμψεις, ἐκθάμβως ἐξαστράπτεις εἰς κόσμον ἅπαντα."
