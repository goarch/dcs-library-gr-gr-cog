meDA.commemoration.first = "Μνήμη τῶν Ἁγίων Μαρτύρων Μηνοδώρας, Μητροδώρας καὶ Νυμφοδώρας"
meDA.commemoration.first_short = "Μνήμη τῶν Ἁγίων Μαρτύρων Μηνοδώρας, Μητροδώρας καὶ Νυμφοδώρας"
