meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Stichera01.greekmelody = he.a.m2_gr_GR_cog.heAU.PoioisEffimionStemmasin.greekname
meVE.Stichera01.melody = he.a.m2_gr_GR_cog.heAU.PoioisEffimionStemmasin.name
meVE.Stichera01.incipit = "Ποίοις οἱ εὐτελεῖς…"
meVE.Stichera01.text = "Ποίοις οἱ εὐτελεῖς χείλεσιν, εὐφημήσωμεν νῦν τὴν τεχθεῖσαν; τὴν ἁγιωτέραν τῆς κτίσεως, καὶ τιμιωτέραν ὑπάρχουσαν, Χερουβίμ, καὶ πάντων τῶν Ἁγίων· τὸν θρόνον, τοῦ Βασιλέως τὸν ἀσάλευτον· τὸν οἶκον, ἐν ᾧ κατῴκησεν ὁ Ὕψιστος· τὴν σωτηρίαν τοῦ κόσμου· τὸ Θεοῦ ἁγίασμα· τὴν παρέχουσαν τοῖς πιστοῖς, ἐν τῇ θείᾳ γεννήσει αὐτῆς, τὸ μέγα ἔλεος."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Stichera02.melody = he.a.m2_gr_GR_cog.heAU.PoioisEffimionStemmasin.name
meVE.Stichera02.incipit = "Ποῖα πνευματικὰ ᾄσματα…"
meVE.Stichera02.text = "Ποῖα πνευματικὰ ᾄσματα, νῦν προσάξωμέν σοι Παναγία; τῇ γὰρ ἐκ τῆς στείρας κυήσει σου, ἅπαντα τὸν κόσμον ἡγίασας, καὶ Ἀδὰμ δεσμῶν ἀπελυτρώσω, καὶ Εὔαν, ἐκ τῶν ὠδίνων ἠλευθέρωσας· Ἀγγέλων, διὸ χοροὶ συνεορτάζουσιν· ὁ οὐρανὸς τῇ γῇ χαίρει, καὶ ἐπικροτοῦσιν, αἱ ψυχαὶ Δικαίων ᾠδάς, πιστῶς ἀνακράζουσαι, εἰς δόξαν τῶν γενεθλίων σου."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Stichera03.melody = he.a.m2_gr_GR_cog.heAU.PoioisEffimionStemmasin.name
meVE.Stichera03.incipit = "Τίνα τὰ φοβερὰ ᾄσματα…"
meVE.Stichera03.text = "Τίνα τὰ φοβερὰ ᾄσματα, ἃ προσῆξάν σοι τότε Παρθένε; κύκλῳ σου τεχθείσης ἱστάμεναι, κόραι χαρμοσύνως χορεύουσαι, καὶ θαμβητικῶς ἀναβοῶσαι· Ἐτέχθη, τοῦ Βασιλέως τὸ παλάτιον· ἐκλάμπει, ἡ κιβωτὸς τοῦ ἁγιάσματος· πύλαι ἠνοίχθησαν στεῖραι· τοῦ Θεοῦ γὰρ πύλη, εὐτεκνίαν τῶν ἀρετῶν, εἰσάγει βραβεύουσα, εἰρήνην καὶ μέγα ἔλεος."

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera04.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera04.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera04.incipit = "Ταῖς βαφαῖς…"
meVE.Stichera04.text = "Ταῖς βαφαῖς ταῖς ἐξ αἵματος, ἑαυτὰς ὡραΐσασαι, τῷ ὡραίῳ κάλλει, κόραι νεάνιδες, ἀδιαφθόρως συνήφθητε, Χριστῷ τῷ Θεῷ ἡμῶν, συντηροῦντι τὴν ὑμῶν, παρθενίαν ἀμόλυντον, εἰς ἀκήρατον, ἀφθαρσίας νυμφῶνα, εἰς θαλάμους, οὐρανίους εἰς παστάδα, ἀχειροποίητον Μάρτυρες."

meVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera05.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera05.incipit = "Ἀτελεῖ ἐν τῷ σώματι…"
meVE.Stichera05.text = "Ἀτελεῖ ἐν τῷ σώματι, καὶ τελείῳ φρονήματι, παλαμναῖον δράκοντα, τὸν ἀρχέκακον, κατεπαλαίσατε ἔνδοξοι, δυνάμει τοῦ Πνεύματος, καὶ ἀνίσχυρον αὐτοῦ, τὴν ἰσχὺν ἀπεδείξατε· ὅθεν ἤρατε, τοὺς στεφάνους τῆς νίκης, Μηνοδώρα, Μητροδώρα, Νυμφοδώρα, αἱ τῆς Τριάδος ὑπέρμαχοι."

meVE.Stichera06.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera06.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera06.incipit = "Καὶ τὰ μέλη…"
meVE.Stichera06.text = "Καὶ τὰ μέλη στρεβλούμεναι, καὶ πυρὶ δαπανώμεναι, σιδηροῖς τε ὄνυξι, σπαραττόμεναι, καὶ ἐπὶ ξύλου κρεμάμεναι, καὶ ξίφει τεμνόμεναι, οὐκ ἠρνήσασθε Χριστόν, ἀθληφόροι πανεύφημοι· ὅθεν εὕρατε, τοὺς στεφάνους τῆς νίκης, Μηνοδώρα, Μητροδώρα, Νυμφοδώρα, αἱ τῆς Τριάδος ἰσάριθμοι."

meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = me.m09.d08_gr_GR_cog.meVE.Aposticha2.incipit
meVE.SticGlory.text = me.m09.d08_gr_GR_cog.meVE.Aposticha2.text

meVE.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Aposticha1.greekmelody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.greekname
meVE.Aposticha1.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meVE.Aposticha1.incipit = "Χορὸς τῶν Προφητῶν…"
meVE.Aposticha1.text = "Χορὸς τῶν Προφητῶν, ἀγάλλεσθε· ἰδοὺ γάρ, στεῖρα καρπὸν ἐκφύει, ἐν ᾧ αἱ προφητεῖαι, ὑμῶν περαιωθήσονται."

meVE.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Aposticha2.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meVE.Aposticha2.incipit = "Σκίρτα Ἰωακείμ…"
meVE.Aposticha2.text = "Σκίρτα Ἰωακείμ, ὁρῶν Ἄνναν κοιλίας, καρπὸν ἐκφύουσάν σοι, ἐξ οὗ ζωὴ τῷ κόσμῳ, καὶ λύτρωσις τεχθήσεται."

meVE.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Aposticha3.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meVE.Aposticha3.incipit = "Γῆρας Ἰωακείμ…"
meVE.Aposticha3.text = "Γῆρας Ἰωακείμ, καὶ στείρωσις τῆς Ἄννης, σκιρτάτωσαν ὡς πάλαι, γηράσασαν τὴν φύσιν, τὴν βρότειον καινίζοντα."

meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.AposGlory.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meVE.AposGlory.incipit = "Ὕμνον ἐκ ῥυπαρῶν…"
meVE.AposGlory.text = "Ὕμνον ἐκ ῥυπαρῶν, χειλέων Θεοτόκε, προσδέχου καὶ τὴν λύσιν, δίδου μοι τῶν πταισμάτων, καὶ τῶν κακῶν διόρθωσιν."

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Apolytikion1ger.melody = "Τοὺς τρεῖς μεγίστους."
meVE.Apolytikion1ger.incipit = "Τὰς τρεῖς ἐνδόξους…"
meVE.Apolytikion1ger.text = "Τὰς τρεῖς ἐνδόξους Παρθένους καὶ Ἀθληφόρους θεόφρονας, τὰς συνδεδεμένας ἐνθέως, ἀδελφικῇ οίκειότητι, τὰς καλλιῤῥόους πηγὰς τῆς εὐσεβείας, τὰς ἀναβλυζούσας, μαρτυρικῶν ἀγώνων χάριν ἀέναον, τὴν θείαν Μηνοδώραν, καὶ τὴν Μητροδώραν τὴν ἔνδοξον, σὺν τῇ κλυτῇ Νυμφοδώρᾳ, τῇ ἐν πᾶσι καρτερόφρονι, πάντες οἱ τρυφῶντες τῶν ἄθλων αὐτῶν, συνδραμόντες ὕμνοις τιμήσωμεν· αὐταὶ γὰρ τῇ Τριάδι, ὑπὲρ ἡμῶν ἀεὶ πρεσβεύουσι."

meMA.Kathisma11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Kathisma11.greekmelody = he.a.m4_gr_GR_cog.heAU.KateplagiIosif.greekname
meMA.Kathisma11.melody = he.a.m4_gr_GR_cog.heAU.KateplagiIosif.name
meMA.Kathisma11.incipit = me.m09.d08_gr_GR_cog.meMA.Kathisma11.incipit
meMA.Kathisma11.text = me.m09.d08_gr_GR_cog.meMA.Kathisma11.text

meMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Kathisma21.greekmelody = he.a.m4_gr_GR_cog.heAU.KateplagiIosif.greekname
meMA.Kathisma21.melody = he.a.m4_gr_GR_cog.heAU.KateplagiIosif.name
meMA.Kathisma21.incipit = me.m09.d07_gr_GR_cog.meVE.Apolytikion1.incipit
meMA.Kathisma21.text = me.m09.d07_gr_GR_cog.meVE.Apolytikion1.text

meMA.C1.acrostic.title = "Κανὼν τῶν Ἁγίων,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Τριῶν ἀδελφῶν γνησίων ἄθλους σέβω. Ἰωσήφ."
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaints
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintsM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C11.greekmelody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.greekname
meMA.Ode1C11.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C11.incipit = "Τριάδα τὴν ἄκτιστον, ἣν εὐσεβῶς…"
meMA.Ode1C11.text = "Τριάδα τὴν ἄκτιστον, ἣν εὐσεβῶς ἐκηρύξατε, ἡμῖν ἱλεώσασθε, Μάρτυρες ἔνδοξοι, νῦν γεραίρουσιν, ὑμῶν τους θείους ἄθλους, καὶ τὰ κατορθώματα, θεομακάριστοι."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C12.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C12.incipit = "Ῥημάτων ἠλόγησαν, τοῦ δυσμενοῦς αἱ…"
meMA.Ode1C12.text = "Ῥημάτων ἠλόγησαν, τοῦ δυσμενοῦς αἱ Νεάνιδες, τῷ θείῳ φραττόμεναι, ὅπλῳ τῆς πίστεως, καὶ ὑπέστησαν, βασάνων τρικυμίαν, καὶ θάνατον ἄδικον, διὰ τὴν πάντων ζωήν."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C13.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C13.incipit = "Ἰσχὺϊ ῥωννύμεναι, παντοδυνάμῳ τοῦ κτίσαντος…"
meMA.Ode1C13.text = "Ἰσχὺϊ ῥωννύμεναι, παντοδυνάμῳ τοῦ κτίσαντος, ἀνδρείαν ἀνέλαβον, γνώμην αἱ πάνσεμνοι, καὶ τὸν δράκοντα, τὸν σκολιὸν τὸν μέγαν, ποσὶ κατεπάτησαν, καὶ κατηδάφισαν."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C1T.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C1T.incipit = "Ὡς ἔμψυχον θάλαμον, ὡς ἀδιάφθορον…"
meMA.Ode1C1T.text = "Ὡς ἔμψυχον θάλαμον, ὡς ἀδιάφθορον σκήνωμα, ὡς πύλην οὐράνιον, ὡς θείαν τράπεζαν, ὡς παλάτιον, καὶ θρόνον τοῦ Δεσπότου, Μαρίαν τὴν ἄχραντον, ὕμνοις τιμήσωμεν."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.greekname
meMA.Ode3C11.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C11.incipit = "Νενεκρωμένῳ, λογισμῷ ὁ παράνομος τύραννος…"
meMA.Ode3C11.text = "Νενεκρωμένῳ, λογισμῷ ὁ παράνομος τύραννος, τὴν ζωὴν ἡμῶν Χριστόν, δεινῶς ἀρνεῖσθαι ἠνάγκαζε, Μάρτυς Μηνοδώρα σε, καταικιζόμενος."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C12.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C12.incipit = "Ἀτενιζούσης, πρὸς Θεὸν δικαστὴς οὐκ…"
meMA.Ode3C12.text = "Ἀτενιζούσης, πρὸς Θεὸν δικαστὴς οὐκ ἐφείσατο, ἀλλὰ ῥάβδοις ἀπηνῶς, συνθλᾷ τὰ μέλη σου στέφος σοι, πλέκων ὡς οὐκ ᾤετο, Μάρτυς ἀμάραντον."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C13.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C13.incipit = "Διὰ βασάνων, αἱ τρισόλβιοι ἅγιαι…"
meMA.Ode3C13.text = "Διὰ βασάνων, αἱ τρισόλβιοι ἅγιαι Μάρτυρες, θησαυρὸν ἐν οὐρανοῖς, καὶ αἰωνίζουσαν εὔκλειαν, εὕραντο τρανότερον, Θεῷ ἐγγίζουσαι."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C1T.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C1T.incipit = "Ἐπιφανεῖσα, τῆς ψυχῆς μου τὸ…"
meMA.Ode3C1T.text = "Ἐπιφανεῖσα, τῆς ψυχῆς μου τὸ σκότος ἀπέλασον, ἁμαρτίας τὰς σειράς, ἁγνὴ Παρθένε διάῤῥηξον, σῶσόν με κυήσασα, τὸν πανοικτίρμονα."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3H.greekmelody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.greekname
meMA.Ode3H.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.melody
meMA.Ode3H.incipit = he.h.m4_gr_GR_cog.heHE.OukEnSofia.incipit
meMA.Ode3H.text = he.h.m4_gr_GR_cog.heHE.OukEnSofia.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3Kathisma1.greekmelody = he.a.m4_gr_GR_cog.heAU.KateplagiIosif.greekname
meMA.Ode3Kathisma1.melody = he.a.m4_gr_GR_cog.heAU.KateplagiIosif.name
meMA.Ode3Kathisma1.incipit = "Κατεπλάγησαν ὑμῶν, τὴν καρτερίαν τὴν…"
meMA.Ode3Kathisma1.text = "Κατεπλάγησαν ὑμῶν, τὴν καρτερίαν τὴν πολλήν, ἐπουράνιοι χοροί, τῶν ἀσωμάτων Λειτουργῶν, ὥς περ γὰρ ἄλλου πάσχοντος διέκεισθε, τὰ σκέλη τοῖς μοχλοῖς συντριβόμεναι, θάνατον πικρὸν ὑπομένουσαι, καὶ γυναικείῳ σώματι, τὸν δράκοντα τὸν ἀποστάτην συντρίβουσαι, παρθένοι Νύμφαι, τοῦ Ζωοδότου, πίστεως αἱ ὑπέρμαχοι."

meMA.Ode3Kathisma2.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3Kathisma2.greekmelody = he.a.m4_gr_GR_cog.heAU.KateplagiIosif.greekname
meMA.Ode3Kathisma2.melody = he.a.m4_gr_GR_cog.heAU.KateplagiIosif.name
meMA.Ode3Kathisma2.incipit = "Ἡ Παρθένος Μαριάμ, καὶ Θεοτόκος…"
meMA.Ode3Kathisma2.text = "Ἡ Παρθένος Μαριάμ, καὶ Θεοτόκος ἀληθῶς, ὡς νεφέλη τοῦ φωτός, σήμερον ἔλαμψεν ἡμῖν, καὶ ἐκ Δικαίων προέρχεται, εἰς δόξαν ἡμῶν. Οὐκ ἔτι ὁ Ἀδάμ, κατακρίνεται· ἡ Εὔα τῶν δεσμῶν, ἀπολέλυται· καὶ διὰ τοῦτο κράζομεν βοῶντες, ἐν παῤῥησίᾳ τῇ μόνῃ Ἁγνῇ· Χαρὰν μηνύει, ἡ γέννησίς σου, πάσῃ τῇ οἰκουμένῃ."

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.greekname
meMA.Ode4C11.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C11.incipit = "Λαμπομένη ταῖς ἀκτῖσι, τοῦ Σταυροῦ…"
meMA.Ode4C11.text = "Λαμπομένη ταῖς ἀκτῖσι, τοῦ Σταυροῦ ἡ ἀοίδιμος, Μητροδώρα ξύλῳ, ἀπαιωρουμένη ὑπέφερε, τὴν τοῦ πυρὸς τιμωρίαν, πλάνης ἄνθρακας, δροσισμῷ ἀγάπης, τοῦ Χριστοῦ ἀποσβέσασα."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C12.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C12.incipit = "Φανοτάτῃ θεωρίᾳ, λογισμῷ ἀτενίζουσα, καὶ…"
meMA.Ode4C12.text = "Φανοτάτῃ θεωρίᾳ, λογισμῷ ἀτενίζουσα, καὶ φανταζομένη, κάλλος τοῦ Νυμφίου ἀμήχανον, κατεαγεῖσα μοχλῷ τε ἡ ἀοίδιμος, Μηνοδώρα, φέρει καρτερῶς τὰ ἐπίπονα."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C13.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C13.incipit = "Ὡραιώθητε παρθένοι, καὶ φαιδρῶς ἐδοξάσθητε…"
meMA.Ode4C13.text = "Ὡραιώθητε παρθένοι, καὶ φαιδρῶς ἐδοξάσθητε, τὸν δεδοξασμένον, Λόγον ὁλικῶς ἀγαπήσασαι, οὗ τετρωμέναι τῷ πόθῳ ὑπεμείνατε, παθημάτων, τὰς ἐπαγωγὰς καρτερώτατα."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C1T.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C1T.incipit = "Νεκρωθέντα με κακίᾳ, τοῦ δολίου…"
meMA.Ode4C1T.text = "Νεκρωθέντα με κακίᾳ, τοῦ δολίου Πανάχραντε, ἡ ζωὴν τεκοῦσα, ζώωσον· πρὸς σὲ γὰρ κατέφυγον, καὶ ἐμπεσόντα εἰς βάθη παραπτώσεων, ἐπανάγαγε, ὡς συμπαθὴς Παναμώμητε."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C11.greekmelody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.greekname
meMA.Ode5C11.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C11.incipit = "Γνώμην καρτερικήν, καὶ ἀήττητον φρόνημα…"
meMA.Ode5C11.text = "Γνώμην καρτερικήν, καὶ ἀήττητον φρόνημα, αἱ Μάρτυρες πρὸ βημάτων, ἐνδεικνύμεναι νίκης, στεφάνους ἀνεπλέξαντο."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C12.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C12.incipit = "Νῦν φέρει σιδηρῶν, ἐξ ὀνύχων…"
meMA.Ode5C12.text = "Νῦν φέρει σιδηρῶν, ἐξ ὀνύχων σπαράγματα, στεῤῥότατα κρεμαμένη, Νυμφοδώρα Νυμφίον, ποθοῦσα τὸν ἀθάνατον."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C13.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C13.incipit = "Ἡ τρίφωτος λαμπάς, τὸ τριώροφον…"
meMA.Ode5C13.text = "Ἡ τρίφωτος λαμπάς, τὸ τριώροφον οἴκημα, τὸ σκήνωμα τῆς Τριάδος, εὐφημείσθωσαν ὕμνοις, Παρθένοι αἱ θεόφρονες."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C1T.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C1T.incipit = "Σὲ μόνην ἐκλεκτήν, καὶ καλὴν…"
meMA.Ode5C1T.text = "Σὲ μόνην ἐκλεκτήν, καὶ καλὴν καὶ ἀμώμητον, εὑράμενος σωματοῦται, ὁ ὑπέρθεος Λόγος, ἐκ σοῦ Θεοχαρίτωτε."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.greekname
meMA.Ode6C11.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C11.incipit = "Ἰδεῖν σου, ἐφιέμεναι κάλλος ἀμήχανον…"
meMA.Ode6C11.text = "Ἰδεῖν σου, ἐφιέμεναι κάλλος ἀμήχανον, αἱ τετρωμέναι τῷ πόθῳ, σοῦ τῷ γλυκυτάτῳ ἄναρχε Λόγε, τῶν βασάνων, τὴν πικρίαν γενναίως ὑπήνεγκαν."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C12.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C12.incipit = "Ὡς κρίνα, ἀθλητῶν ἐν λειμῶνι…"
meMA.Ode6C12.text = "Ὡς κρίνα, ἀθλητῶν ἐν λειμῶνι ἐξήνθησαν, αἱ πανοίδιμοι Κόραι, καὶ τὴν Ἐκκλησίαν πνοαῖς βασάνων, τῶν ποικίλων, εὐωδίασαν Πνεύματος χάριτι."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C13.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C13.incipit = "Νυμφίον, τὸν ἀθάνατον μόνον ποθήσασαι…"
meMA.Ode6C13.text = "Νυμφίον, τὸν ἀθάνατον μόνον ποθήσασαι, τοῦ ὀρωμένου θανάτου, ἀοράτῳ σθένει νευρούμεναι, ἀριδήλως, οὐκ ἐφρόντισαν Κόραι νεάνιδες."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C1T.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C1T.incipit = "Ἅγιος, ὁ σκηνώσας ἐν μήτρᾳ…"
meMA.Ode6C1T.text = "Ἅγιος, ὁ σκηνώσας ἐν μήτρᾳ σου Κύριος, ἁγιωτέραν εὑρών σε, καὶ καθαρωτέραν κτίσεως πάσης, Θεομῆτορ, κυριώνυμε ἄχραντε Δέσποινα."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6H.greekmelody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.greekname
meMA.Ode6H.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.melody
meMA.Ode6H.incipit = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.incipit
meMA.Ode6H.text = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.text

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Kontakion1.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
meMA.Kontakion1.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Kontakion1.incipit = "Ὑπὲρ Τριάδος καρτερῶς ἐναθλοῦσαι, τὸν…"
meMA.Kontakion1.text = "Ὑπὲρ Τριάδος καρτερῶς ἐναθλοῦσαι, τὸν πολυμήχανον ἐχθρὸν ἐτροπώσασθε, ἀδελφικῶς τῷ πνεύματι συνδούμεναι· ὅθεν εἰσῳκίσθητε, σὺν ταῖς πέντε Παρθένοις, πρός τὸν ἐπουράνιον, Ἀθληφόροι νυμφῶνα, καὶ σὺν Ἀγγέλοις τῷ παμβασιλεῖ, ἐν εὐφροσύνῃ ἀπαύστως παρίστασθε."

meMA.Oikos1.text = "Ἱερωτάτην συγκροτεῖ, πανήγυριν ἐν πίστει, ἡ Χριστοῦ Ἐκκλησία, αὐταδέλφων Μαρτύρων ἐπιτελοῦσα εὐσεβῶς, μνήμην ὑμῶν τὴν φωσφόρον, καὶ λαμπρὰν καὶ παμφαῆ, πανεύφημοι ὁμότροποι· στεῤῥῶς γὰρ ἐπὶ τῆς γῆς, τὸν ἀντίπαλον νοῦν καταπατήσασαι, ἀνεδήσασθε στεφάνους ἐκ χειρὸς τοῦ παμβασιλέως· παρʼ οὗ μοι φωτισμὸν αἰτήσασθε, ὄντως εὐφημῆσαι τὴν ὑμῶν μνήμην ἀξίως, καὶ τὰς θαυμαστὰς καὶ θείας ἀνδραγαθίας· ὑμεῖς γὰρ τῷ Παμβασιλεῖ, ἐν εὐφροσύνῃ ἀπαύστως παρίστασθε."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C11.greekmelody = he.h.m4_gr_GR_cog.heHE.AvramiaioiPote.greekname
meMA.Ode7C11.melody = he.h.m4_gr_GR_cog.heHE.AvramiaioiPote.name
meMA.Ode7C11.incipit = "Θύειν εἰδώλοις σαφῶς, τοῦ δυσσεβοῦς…"
meMA.Ode7C11.text = "Θύειν εἰδώλοις σαφῶς, τοῦ δυσσεβοῦς τυράννου, κελευομένου κατεπτύσατε, βοῶσαι Νεάνιδες, ὁ τῶν Πατέρων ἡμῶν Θεὸς εὐλογητὸς εἶ."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C12.melody = he.h.m4_gr_GR_cog.heHE.AvramiaioiPote.name
meMA.Ode7C12.incipit = "Λελαμπρυσμέναι τὸν νοῦν, θεαρχικαῖς ἀκτῖσιν…"
meMA.Ode7C12.text = "Λελαμπρυσμέναι τὸν νοῦν, θεαρχικαῖς ἀκτῖσιν, ἀχλὺν εἰδώλων ἠμαυρώσατε, βοῶσαι Πανεύφημοι, ὁ τῶν Πατέρων ἡμῶν Θεὸς εὐλογητὸς εἶ."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C13.melody = he.h.m4_gr_GR_cog.heHE.AvramiaioiPote.name
meMA.Ode7C13.incipit = "Οὐκ ἐκτομαὶ τῶν μελῶν, οὐ…"
meMA.Ode7C13.text = "Οὐκ ἐκτομαὶ τῶν μελῶν, οὐ διωγμὸς οὐ θλῖψις, Χριστοῦ χωρίσαι ὅλως, ἴσχυσαν, βοώσας τὰς Μάρτυρας· Ὁ τῶν Πατέρων ἡμῶν Θεὸς εὐλογητὸς εἶ."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C1T.melody = he.h.m4_gr_GR_cog.heHE.AvramiaioiPote.name
meMA.Ode7C1T.incipit = "Ὑπερφυῶς τὸν Θεόν, ἐν τῇ…"
meMA.Ode7C1T.text = "Ὑπερφυῶς τὸν Θεόν, ἐν τῇ γαστρί σου Κόρη, κυοφορῆσαι κατηξίωσαι, βροτοὺς ἀναπλάττοντα, τοὺς μελῳδοῦντας πιστῶς, Χριστὲ εὐλογητὸς εἶ."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C11.greekmelody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.greekname
meMA.Ode8C11.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C11.incipit = "Στομωθεῖσαι ἀγάπῃ τοῦ κτίσαντος, ἀπημβλύνατε…"
meMA.Ode8C11.text = "Στομωθεῖσαι ἀγάπῃ τοῦ κτίσαντος, ἀπημβλύνατε κέντρα τοῦ ὄφεως, ἐν γυναικείῳ σώματι, ἀνδρικοὺς διανύουσαι τοὺς ἀγῶνας, καὶ στεφάνοις ἐνθέοις στεφόμεναι."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C12.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C12.incipit = "Συμπλακεῖσαι ἐν μέσῳ τοῦ σκάμματος…"
meMA.Ode8C12.text = "Συμπλακεῖσαι ἐν μέσῳ τοῦ σκάμματος, ἀοράτοις ἐχθροῖς μετὰ σώματος, τοὺς ἀσωμάτους ἔτρεψαν, αἱ θεόφρονες Κόραι, ἀναβοῶσαι· Εὐλογεῖτε τὰ ἔργα τὸν Κύριον."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C13.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C13.incipit = "Ἐν Θεῷ τῷ Σωτῆρι νευρούμεναι…"
meMA.Ode8C13.text = "Ἐν Θεῷ τῷ Σωτῆρι νευρούμεναι, ἐν Χριστῷ Ἰησοῦ δυναμούμεναι, τὸ τοῦ ἐχθροῦ ἀνίσχυρον, διωλέσατε κράτος, ἀναβοῶσαι· Εὐλογεῖτε τὰ ἔργα τὸν Κύριον."

meMA.Ode8C14.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C14.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C14.incipit = "Βασιλείας τῆς ἄνω ἐτύχετε, σὺν…"
meMA.Ode8C14.text = "Βασιλείας τῆς ἄνω ἐτύχετε, σὺν Χριστῷ Ἰησοῦ βασιλεύουσαι, πεποικιλμέναι στίγμασι, τῶν βασάνων τῷ κάλλει διηνθισμέναι, ἀξιάγαστοι Κόραι νεάνιδες."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C1T.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C1T.incipit = "Ὡς Θεοῦ ἀκηλίδωτον τέμενος, ὑπεδέξω…"
meMA.Ode8C1T.text = "Ὡς Θεοῦ ἀκηλίδωτον τέμενος, ὑπεδέξω αὐτὸν σωματούμενον, καὶ ἐν δυσὶ ταῖς φύσεσι, γνωριζόμενον Κόρη, ᾧ μελῳδοῦμεν· Εὐλογεῖτε τὰ ἔργα τὸν Κύριον."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8H.greekmelody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.greekname
meMA.Ode8H.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.melody
meMA.Ode8H.incipit = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.incipit
meMA.Ode8H.text = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C11.greekmelody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.greekname
meMA.Ode9C11.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C11.incipit = "Ἰδεῖν ἐφιέμεναι κάλλος, τὸ τοῦ…"
meMA.Ode9C11.text = "Ἰδεῖν ἐφιέμεναι κάλλος, τὸ τοῦ Νυμφίου ὁλοτρόπῳ, νεύσει πρὸς αὐτὸν θεοφόροι, ἀθανασίαν ἐμελετήσατε, ἐν τῷ θνητῷ τοῦ σώματος· ὅθεν ἀξίως μακαρίζεσθε."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C12.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C12.incipit = "Ὤφθητε τυράννων ἐν μέσῳ, οἷά…"
meMA.Ode9C12.text = "Ὤφθητε τυράννων ἐν μέσῳ, οἷά περ λύκων ὠμοτάτων, ἄσπιλοι ἀμνάδες τὴν τούτων, θηριωδίαν καταπαλαίουσαι, καὶ τῷ Χριστῷ εὐπρόσδεκτα, ὡς Ἱερεῖα προσαγόμεναι."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C13.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C13.incipit = "Στέφος ἀνεπλέξασθε ἅμα, μὴ παλαιούμενον…"
meMA.Ode9C13.text = "Στέφος ἀνεπλέξασθε ἅμα, μὴ παλαιούμενον παρθένοι, θείας ἐπετύχετε δόξης, καὶ βασιλείαν ὄντως ἀσάλευτον, παραλαβεῖν ὡς Μάρτυρες, μετὰ Μαρτύρων ἠξιώθητε."

meMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C14.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C14.incipit = "Ἧς κατηξιώθητε δόξης, καὶ ἐπετύχετε…"
meMA.Ode9C14.text = "Ἧς κατηξιώθητε δόξης, καὶ ἐπετύχετε χορείαις, τοὺς ἐπιτελοῦντας ἐκ πόθου, ὑμῶν τὴν μνήμην τυχεῖν πρεσβεύσατε, ὡς παῤῥησίαν ἔχουσαι, πρὸς τὸν Δεσπότην Σεμνοπάρθενοι."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C1T.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C1T.incipit = "Φεῖσαί μου Χριστὲ ὅταν ἔλθῃς…"
meMA.Ode9C1T.text = "Φεῖσαί μου Χριστὲ ὅταν ἔλθῃς, κρῖναι τὸν κόσμον μετὰ δόξης, λῦσον τὴν ἀχλὺν τῶν παθῶν μου, ταῖς ἱκεσίαις τῆς κυησάσης σε, καὶ τῶν σεπτῶν Μαρτύρων σου, ὡς ἀγαθὸς καὶ πολυέλεος."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9H.greekmelody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.greekname
meMA.Ode9H.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.melody
meMA.Ode9H.incipit = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.incipit
meMA.Ode9H.text = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.text

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.greekname
meMA.Exaposteilarion1.melody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.name
meMA.Exaposteilarion1.incipit = "Αἱ τρεῖς παρθένοι Τριάδα, Θεὸν…"
meMA.Exaposteilarion1.text = "Αἱ τρεῖς παρθένοι Τριάδα, Θεὸν ἀφράστως ποθοῦσαι, κηρύττουσι τῶν τυράννων, ἐνώπιον· διὰ τοῦτο, βασανισθεῖσαι τοῦ στέφους, τυγχάνουσι τοῦ ἀφθάρτου."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.ExapTheotokion.melody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.name
meMA.ExapTheotokion.incipit = "Ὁ γλυκασμὸς τῶν Ἀγγέλων, ὁ…"
meMA.ExapTheotokion.text = "Ὁ γλυκασμὸς τῶν Ἀγγέλων, ὁ φωτισμὸς τῶν ἀνθρώπων, ἡ προστασία τοῦ κόσμου, Θεογεννῆτορ Μαρία, τοὺς σὲ ὑμνοῦντας ἐν πίστει, ῥῦσαι πταισμάτων Παρθένε."

meMA.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Aposticha1.greekmelody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.greekname
meMA.Aposticha1.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meMA.Aposticha1.incipit = "Γόνος Ἰωακείμ, καὶ Ἄννης ἡ…"
meMA.Aposticha1.text = "Γόνος Ἰωακείμ, καὶ Ἄννης ἡ Παρθένος, ἐφάνη τοῖς ἀνθρώποις, τῶν δεσμῶν ἀφιεῖσα, τῆς ἁμαρτίας ἅπαντας."

meMA.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Aposticha2.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meMA.Aposticha2.incipit = "Ὄρος ὡς ἀληθῶς, κατάσκιον ἐδείχθη…"
meMA.Aposticha2.text = "Ὄρος ὡς ἀληθῶς, κατάσκιον ἐδείχθη, ἡ στείρωσις τῆς Ἄννης, ἐξ οὗ ἡ σωτηρία, πᾶσι πιστοῖς δεδώρηται."

meMA.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Aposticha3.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meMA.Aposticha3.incipit = "Ῥήξασα τὰ δεσμά, στειρώσεως τῆς…"
meMA.Aposticha3.text = "Ῥήξασα τὰ δεσμά, στειρώσεως τῆς Ἄννης, ἡ πάναγνος Παρθένος, προῆλθε τοῖς ἀνθρώποις, τὴν ἄφεσιν βραβεύουσα."

meMA.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.AposGlory.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meMA.AposGlory.incipit = "Ἴωμεν οἱ πιστοί, δοξάζοντες τὴν…"
meMA.AposGlory.text = "Ἴωμεν οἱ πιστοί, δοξάζοντες τὴν Κόρην· ἐτέχθη γὰρ ἐκ στείρας, τὴν στειρωθεῖσαν φύσιν, ἡμῶν ἀνακαινίζουσα."

meLI.Kontakion1.mode = me.m09.d10_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.greekmelody = me.m09.d10_gr_GR_cog.meMA.Kontakion1.greekmelody
meLI.Kontakion1.melody = me.m09.d10_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m09.d10_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m09.d10_gr_GR_cog.meMA.Kontakion1.text

