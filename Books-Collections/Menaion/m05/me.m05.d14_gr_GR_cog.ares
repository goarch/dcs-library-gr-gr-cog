meHO.note2 = ""

meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.greekname
meVE.Stichera01.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera01.incipit = "Ζήλῳ πυρπολούμενος…"
meVE.Stichera01.text = "Ζήλῳ πυρπολούμενος, τῆς εὐσεβείας Ἰσίδωρε, ὑπεισῆλθες τὸ στάδιον, θερμῶς τῆς ἀθλήσεως, καὶ βραβεῖον νίκης, Μάρτυς ἀπηνέγκω, κατὰ τῆς πλάνης διδαχαῖς, θεοφιλέσιν ὡραϊζόμενος· Σταυροῦ δὲ κρατυνόμενος, τῇ πανοπλίᾳ κατέβαλες, τὸν ἀλάστορα τύραννον, νικηφόρος δεικνύμενος."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera02.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera02.incipit = "Μάστιξι ξεόμενος…"
meVE.Stichera02.text = "Μάστιξι ξεόμενος, τῆς δερματίνης νεκρώσεως, τοὺς χιτῶνας ἐνδέδυσαι· στολὴν ἀφθαρσίας δέ, καὶ λαμπρὰν ἐσθῆτα, περιβεβλημένος, θᾶττον τῷ ξύλῳ τῆς ζωῆς, ἀποκατέστης ζωὴν δρεψάμενος, τὴν ὄντως ἀκατάλυτον, καὶ ἀτελεύτητον ἔνδοξε, ἧς περ νῦν ἐμφορούμενος, τοὺς ὑμνοῦντάς σε εὔφρανον."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera03.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera03.incipit = "Ὄντως ὑπερβέβηκε…"
meVE.Stichera03.text = "Ὄντως ὑπερβέβηκε, τὰ τῶν Μαρτύρων παλαίσματα, τῶν ἐπαίνων τὴν σύνθεσιν, καὶ λόγον καὶ ἔννοιαν· οἱ στεῤῥοὶ γὰρ πύργοι, τῆς θεοσεβείας, σῶμα θνητὸν καὶ παθητόν, ὡς τὸ ἡμέτερον περικείμενοι, πυρός τε κατετόλμησαν, καὶ τῶν πληγῶν κατεφρόνησαν, ὡς ἐν σώματι πάσχοντες, ἀλλοτρίῳ οἱ ἔνδοξοι."

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Apolytikion1ger.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
meVE.Apolytikion1ger.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meVE.Apolytikion1ger.incipit = "Ὣς στρατευθεὶς τῷ Βασιλεῖ…"
meVE.Apolytikion1ger.text = "Ὣς στρατευθεὶς τῷ Βασιλεῖ τῶν αἰώνων, τῶν ἐπιγείων τὴν στρατείαν ἀπώσω, καὶ εὐθαρσῶς ἐκήρυξας Χριστὸν τὸν Θεόν· ὅθεν τὸν ἀγῶνά σου, τὸν καλὸν ἐκτελέσας, Μάρτυς θεοδόξαστος, τοῦ Σωτῆρος ἐδείχθης· ὃν ἐκδυσώπει σῴζεσθαι ἡμᾶς, τοὺς σὲ τιμῶντας, παμμάκαρ Ἰσίδωρε."

meMA.C1.acrostic.title = "Κανὼν τοῦ Ἁγίου,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Τὸν κλεινὸν Ἰσίδωρον ὑμνῶ προφρόνως."
meMA.C1.poet = poets_gr_GR_cog.po.Theofanous
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaintM
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C11.greekmelody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.greekname
meMA.Ode1C11.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C11.incipit = "Ταῖς σαῖς ἱκεσίαις Μάρτυς Χριστοῦ…"
meMA.Ode1C11.text = "Ταῖς σαῖς ἱκεσίαις Μάρτυς Χριστοῦ, Ἰσίδωρε μάκαρ, οὐρανόθεν μοι φωτισμόν, παράσχου καὶ χάριν εὐφημῆσαι, τὴν ἑορτήν σου τὴν σεβάσμιον."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C12.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C12.incipit = "Ὁλόκληρον ἔχων πρὸς τὸν Θεόν…"
meMA.Ode1C12.text = "Ὁλόκληρον ἔχων πρὸς τὸν Θεόν, Ἰσίδωρε Μάρτυς, τὴν καρδίαν καὶ τὴν ψυχήν, πανάμωμον ἔσχες καὶ τὸν βίον, μαρτυρικῶς ἐγγυμναζόμενος."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C13.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C13.incipit = "Νομίμως ῥυθμίσας σου τὴν ζωήν…"
meMA.Ode1C13.text = "Νομίμως ῥυθμίσας σου τὴν ζωήν, Ἰσίδωρε μάκαρ, ὥσπερ ἄσυλον θησαυρόν, τὴν πίστιν ἐκράτεις, ἄτρεπτόν τε τὴν σωτηρίαν παμμακάριστε."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C1T.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C1T.incipit = "Κυρίως τεκοῦσα φύσει Θεόν, κυρίως…"
meMA.Ode1C1T.text = "Κυρίως τεκοῦσα φύσει Θεόν, κυρίως ἀκούεις, Θεοτόκος καὶ ἀληθῶς, τὴν προσηγορίαν καταλλήλως, τῷ θείῳ Λόγῳ Ἁγνὴ περιφέρουσα."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C11.greekmelody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.greekname
meMA.Ode3C11.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C11.incipit = "Λόγῳ κυβερνώμενος, τὰς τῶν παθῶν…"
meMA.Ode3C11.text = "Λόγῳ κυβερνώμενος, τὰς τῶν παθῶν ὁρμὰς ἔνδοξε, Μάρτυς Χριστοῦ, ἀρετῶν ἀσκήσει, ἀθλοφόρε ἠμαύρωσας."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C12.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C12.incipit = "Ἔχων ἀκατάπληκτον, τὴν τῆς ψυχῆς…"
meMA.Ode3C12.text = "Ἔχων ἀκατάπληκτον, τὴν τῆς ψυχῆς ὁρμὴν ἔνδοξε, πανευσεβῶς, τὴν ὁμολογίαν, ἀῤῥαγῆ διετήρησας."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C13.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C13.incipit = "Ἵλεων πρεσβείαις σου, τὸν τοῦ…"
meMA.Ode3C13.text = "Ἵλεων πρεσβείαις σου, τὸν τοῦ παντὸς Κριτὴν ἔργασαι, τοῖς εὐλαβῶς, τὴν σὴν εὐφημοῦσιν, Ἀθλοφόρε πανήγυριν."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C1T.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C1T.incipit = "Νέκρωσον τὸ φρόνημα, τὸ τῆς…"
meMA.Ode3C1T.text = "Νέκρωσον τὸ φρόνημα, τὸ τῆς σαρκὸς ἡμῶν Δέσποινα, καὶ τὴν ψυχήν, ζώωσον Παρθένε, τῶν ἐν πίστει ὑμνούντων σε."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3H.greekmelody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.greekname
meMA.Ode3H.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.melody
meMA.Ode3H.incipit = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.incipit
meMA.Ode3H.text = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3Kathisma1.greekmelody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.greekname
meMA.Ode3Kathisma1.melody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.name
meMA.Ode3Kathisma1.incipit = "Ἀγωνισάμενος, κατὰ τοῦ ὄφεως, ἔστησας…"
meMA.Ode3Kathisma1.text = "Ἀγωνισάμενος, κατὰ τοῦ ὄφεως, ἔστησας τρόπαιον, Μάρτυς Ἰσίδωρε· ἐκ τῆς Αἰγύπτου γὰρ φωστήρ, αὐγάζων τὴν ὑφήλιον, πᾶσιν ἐξανέτειλας, τὰς κινήσεις ποιούμενος, πρὸς τὸν ἀνατείλαντα, ἐκ Παρθένου θεόπαιδος, διʼ ὃν σφαγιασθεὶς ἀθλοφόρε, θῦμα εὐῶδες γεγένησαι."

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C11.greekmelody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.greekname
meMA.Ode4C11.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C11.incipit = "Ὅλον ἐν σοί, τὸν λόγον…"
meMA.Ode4C11.text = "Ὅλον ἐν σοί, τὸν λόγον εἰσοικισάμενος, στρατιώτης, ὡς ἀκαταγώνιστος, τυραννικὴν ᾔσχυνας ὀφρύν, καὶ τροπαιοφόρος, ἐντεῦθεν μάκαρ γενόμενος, στεφάνους ἀμαράντους, ἐκ Θεοῦ ἐκομίσω, παναοίδιμε Μάρτυς, Ἰσίδωρε."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C12.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C12.incipit = "Νεανικῶς, καταδιώξας, Ἰσίδωρε, τοὺς ἐχθρούς…"
meMA.Ode4C12.text = "Νεανικῶς, καταδιώξας, Ἰσίδωρε, τοὺς ἐχθρούς σου, τούτους κατελέανας, τῷ φοβερῷ ὅπλῳ τοῦ Σταυροῦ, περιπεφραγμένος, ἰσχύν τε περιζωσάμενος, καὶ τοὺς μισήσαντάς σε, ἐξωλόθρευσας κράζων· τῇ δυνάμει σου δόξα Φιλάνθρωπε."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C13.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C13.incipit = "Ἰχνηλατῶν, τὰ τοῦ Δεσπότου παθήματα…"
meMA.Ode4C13.text = "Ἰχνηλατῶν, τὰ τοῦ Δεσπότου παθήματα, ἐμιμήσω, θάνατον ἑκούσιον, τὸ διʼ αὐτόν, θέλων ὑποστάς· ὅθεν ἀκηράτου, ζωῆς σε Μάρτυς ἠξίωσεν, ὁ Κύριος τῆς δόξης, οὗ χερσὶν ἐναπέθου, τὴν ψυχήν σου παμμάκαρ, Ἰσίδωρε."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C1T.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C1T.incipit = "Σωματωθείς, ἀνακαινίζει τὸν ἄνθρωπον, ὅλως…"
meMA.Ode4C1T.text = "Σωματωθείς, ἀνακαινίζει τὸν ἄνθρωπον, ὅλως ὅλῳ, Πάναγνε ἑνούμενος, ὁ πατρικούς, κόλπους μὴ λιπών, καὶ τὴν σὴν γαστέρα, οἰκῆσαι καταδεξάμενος, ὁ πλούτῳ εὐσπλαγχνίας, ἑκουσίως πτωχεύσας, καὶ πλουτίσας τὸν κόσμον Θεότητι."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C11.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
meMA.Ode5C11.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C11.incipit = "Ἱερεῖον προσήχθης, ἄμωμον καὶ τέλειον…"
meMA.Ode5C11.text = "Ἱερεῖον προσήχθης, ἄμωμον καὶ τέλειον τῷ σῷ Δεσπότῃ Χριστῷ, καὶ τυθεὶς προθύμως, καὶ τὸ αἷμά σου ῥάνας Ἰσίδωρε, κοινωνὸς τοῦ πάθους, καὶ τῆς αὐτοῦ νῦν βασιλείας, χρηματίζεις ἀξίως συμμέτοχος."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C12.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C12.incipit = "Δυναμούμενος Σῶτερ, τῷ παντοδυνάμῳ σου…"
meMA.Ode5C12.text = "Δυναμούμενος Σῶτερ, τῷ παντοδυνάμῳ σου σθένει κατέσβεσε, τὴν ἀχλὺν τῆς πλάνης, ὁ καλλίνικος Μάρτυς Ἰσίδωρος, καὶ τμηθεὶς τὴν κάραν, σοὶ τὴν ψυχὴν τῷ ζωοδότῃ, εὐκλεῶς ἐναπέθετο Δέσποτα."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C13.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C13.incipit = "Ὡραΐζεται μάκαρ, τοῖς σοῖς προτερήμασιν…"
meMA.Ode5C13.text = "Ὡραΐζεται μάκαρ, τοῖς σοῖς προτερήμασιν ἡ Ἐκκλησία Χριστοῦ, καὶ φαιδρύνεταί σου, ταῖς τῶν ἄθλων ἐνστάσεσιν ἔνδοξε πρὸς τὴν ἁμαρτίαν· σὺ γὰρ στεῤῥῶς μέχρις αἱμάτων, ἀνθιστάμενος ὤφθης Ἰσίδωρε."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C1T.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C1T.incipit = "Ῥυπωθεῖσαν τὴν φύσιν, τὴν τῆς…"
meMA.Ode5C1T.text = "Ῥυπωθεῖσαν τὴν φύσιν, τὴν τῆς ἀνθρωπότητος τῇ παραβάσει τῇ πρίν, καὶ δεινῶς φθαρεῖσαν, καὶ θνητὴν γενομένην ἀνέστησας, τὴν πηγὴν τεκοῦσα, τῆς ὑπὲρ νοῦν ἀθανασίας, Θεοτόκε πανάμωμε Δέσποινα."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C11.greekmelody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.greekname
meMA.Ode6C11.melody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.name
meMA.Ode6C11.incipit = "Ὁλόκληρον πρὸς Θεὸν τὴν ἔφεσιν…"
meMA.Ode6C11.text = "Ὁλόκληρον πρὸς Θεὸν τὴν ἔφεσιν, κεκτημένος ἀθλοφόρε παμμάκαρ, τῶν ἀγαθῶν, τὸ ἀκήρατον ὄντως, τῶν ἐπιγείων τὸν πόθον ἠμαύρωσας, καὶ ἔδραμες ἀναβοῶν· Ἐκολλήθην ὀπίσω σου Δέσποτα."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C12.melody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.name
meMA.Ode6C12.incipit = "Νυμφίος ὡς εὐπρεπὴς Ἰσίδωρε, καλλοναῖς…"
meMA.Ode6C12.text = "Νυμφίος ὡς εὐπρεπὴς Ἰσίδωρε, καλλοναῖς μαρτυρικαῖς διαπρέπων, πρὸς οὐρανούς, ἀνελήλυθας χαίρων, καλλοποιῷ λαμπηδόνι παρίστασθαι, δεόμενος, διαπαντός, ὑπὲρ τῶν ἐκτελούντων τὴν μνήμην σου."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C13.melody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.name
meMA.Ode6C13.incipit = "Ὑπέφερες ἀθλητὰ σφαττόμενος, προορῶν τὴν…"
meMA.Ode6C13.text = "Ὑπέφερες ἀθλητὰ σφαττόμενος, προορῶν τὴν διʼ αἰῶνος δόξαν, καὶ τὴν τρυφήν, τὴν ἀΐδιον ὄντως, μετὰ Μαρτύρων, ὡς Μάρτυς ἀήττητος, ἀπείληφας παναληθῶς, στεφηφόρε παμμάκαρ, Ἰσίδωρε."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C1T.melody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.name
meMA.Ode6C1T.incipit = "Μαρία τὸ τοῦ Δεσπότου σκήνωμα…"
meMA.Ode6C1T.text = "Μαρία τὸ τοῦ Δεσπότου σκήνωμα, τὸ λαμπραῖς τῆς παρθενίας ἀκτῖσι, φωτοειδῶς, ὥσπερ κρίνον ἐκλάμψαν, τῆς ἀκανθώδους ἐν μέσῳ συγχύσεως, σοῦ δέομαι τῆς ἀγαθῆς, τῶν πταισμάτων παράσχου μοι ἄφεσιν."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6H.greekmelody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.greekname
meMA.Ode6H.melody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.melody
meMA.Ode6H.incipit = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.incipit
meMA.Ode6H.text = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.text

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Kontakion1.greekmelody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.greekname
meMA.Kontakion1.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
meMA.Kontakion1.incipit = "Κυβερνήτης μέγιστος τῇ οἰκουμένῃ, σὺ…"
meMA.Kontakion1.text = "Κυβερνήτης μέγιστος τῇ οἰκουμένῃ, σὺ ἐφάνης Ἅγιε, ταῖς πρὸς Θεόν σου προσευχαῖς· διὸ ὑμνοῦμέν σε σήμερον, Μάρτυς θεόφρον, Ἰσίδωρε ἔνδοξε."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C11.greekmelody = he.h.m8_gr_GR_cog.heHE.PaidesEvraion.greekname
meMA.Ode7C11.melody = he.h.m8_gr_GR_cog.heHE.PaidesEvraion.name
meMA.Ode7C11.incipit = "Νῦν ἐλλαμπόμενος Τρισμάκαρ, τῇ τοῦ…"
meMA.Ode7C11.text = "Νῦν ἐλλαμπόμενος Τρισμάκαρ, τῇ τοῦ πνεύματος αὐγῇ τοὺς σὲ ὑμνοῦντας, ἐλλαμφθῆναι σὸν σοὶ εὐδόκησον βοῶντας· Εὐλογητὸς εἶ Κύριε, ὁ Θεὸς εἰς τοὺς αἰῶνας."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C12.melody = he.h.m8_gr_GR_cog.heHE.PaidesEvraion.name
meMA.Ode7C12.incipit = "Ὢ τῶν καλλίστων σου ἀγώνων…"
meMA.Ode7C12.text = "Ὢ τῶν καλλίστων σου ἀγώνων, διʼ ὧν ἔλυσας τὴν πλάνην τῶν εἰδώλων καὶ τυράννους δεινούς, κατῄσχυνας κραυγάζων· Εὐλογητὸς εἶ Κύριε, ὁ Θεὸς εἰς τοὺς αἰῶνας."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C1T.melody = he.h.m8_gr_GR_cog.heHE.PaidesEvraion.name
meMA.Ode7C1T.incipit = "Πάναγνε Δέσποινα Παρθένε, τῶν πταισμάτων…"
meMA.Ode7C1T.text = "Πάναγνε Δέσποινα Παρθένε, τῶν πταισμάτων μου τοὺς μώλωπας ἐλαίῳ, συμπαθείας τῆς σῆς, θεράπευσον βοῶντος· Εὐλογημένος Δέσποινα, ὁ καρπὸς τῆς σῆς κοιλίας."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C11.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
meMA.Ode8C11.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C11.incipit = "Ῥᾳδιουργίαις ᾤετο, ὑποκλέπτειν ὁ τύραννος…"
meMA.Ode8C11.text = "Ῥᾳδιουργίαις ᾤετο, ὑποκλέπτειν ὁ τύραννος, τῆς σῆς καρτερίας, τὸ στεῤῥὸν καὶ εὔτονον, παμμάκαρ, Ἰσίδωρε, πρὸς τὴν αὐτοῦ κακόνοιαν· ἀλλὰ σὺ θεόφρον, τὸν Χριστὸν ἀνεβόας· φοβοῦμαι, ᾧ λατρεύω, προσκυνῶ τε καὶ μέλπω· λαὸς ὑπερυψοῦτε, αὐτὸν εἰς τοὺς αἰῶνας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C12.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C12.incipit = "Ὁλολαμπὲς ὡς ἥλιος, ἱλαρόν σου…"
meMA.Ode8C12.text = "Ὁλολαμπὲς ὡς ἥλιος, ἱλαρόν σου τὸ πρόσωπον, τῇ τοῦ μαρτυρίου χαρμονῇ ἐφαίνετο· ἀμνὸς γὰρ ὡς ἄμωμος σφαγιασθεὶς προσήχθης Θεῷ, ὃν ὡς πλαστουργόν, μελῳδικῶς ἀνεβόας· οἱ Παῖδες εὐλογεῖτε, ἱερεῖς ἀνυμνεῖτε, λαὸς ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C13.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C13.incipit = "Φωτοειδὲς τὸ σῶμά σου, τοῖς…"
meMA.Ode8C13.text = "Φωτοειδὲς τὸ σῶμά σου, τοῖς ποθοῦσιν ἐδείκνυτο, τῆς Ἀγγελικῆς δορυφορούσης τάξεως, ἀστράπτον Ἰσίδωρε, μαρμαρυγαῖς τῆς χάριτος, θαυματοποιΐαις τε ποικίλαις ἐμπρέπον, δωρούμενον ἑκάστῳ, τὰς ἰάσεις ἀφθόνως, καὶ σάλου ἐξαρπάζων, σαφῶς καὶ ἐκ κινδύνων."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C1T.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C1T.incipit = "Ῥητορευόντων γλῶσσαί σε, εὐφημῆσαι οὐ…"
meMA.Ode8C1T.text = "Ῥητορευόντων γλῶσσαί σε, εὐφημῆσαι οὐ σθένουσιν, ὦ Θεογεννῆτορ, Μαριὰμ Θεόνυμφε· Θεὸν γὰρ ἐγέννησας, τὸν ἐπὶ πάντων Κόρη ἁγνή, ἐκ παρθενικῆς, ἀπειρογάμου νηδύος· ὃν Παῖδες εὐλογοῦσιν, ἱερεῖς ἀνυμνοῦσι, λαοὶ ὑπερυψοῦσιν, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8H.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
meMA.Ode8H.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.melody
meMA.Ode8H.incipit = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.incipit
meMA.Ode8H.text = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C11.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9C11.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C11.incipit = "Ὁ πλούτῳ εὐσπλαγχνίας συγκαταβάς, καὶ…"
meMA.Ode9C11.text = "Ὁ πλούτῳ εὐσπλαγχνίας συγκαταβάς, καὶ πτωχεύσας, σταυρόν τε καὶ θάνατον ὑπὲρ ἡμῶν, θέλων ὑπομείνας ὡς ἀγαθός, τὸν διʼ αὐτόν σε θάνατον, βλέπων ὑπομείναντα καρτερῶς, αὐτοῦ τῆς βασιλείας, Ἰσίδωρε τρισμάκαρ, συγκληρονόμον ἀπειργάσατο."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C12.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C12.incipit = "Νομίμως σῶν αἱμάτων ἐπὶ τῆς…"
meMA.Ode9C12.text = "Νομίμως σῶν αἱμάτων ἐπὶ τῆς γῆς, οἱ κρουνοὶ ἐκχυθέντες Ἰσίδωρε, ἐν οὐρανοῖς χλαῖνάν σοι ἐφοίνιξαν εὐπρεπῶς, ἐξυφασμένην χάριτι, ἣν νῦν ἐνδυσάμενος τῷ Χριστῷ, παρέστης ἐν θαλάμοις, παμμάκαρ οὐρανίοις, στεφανηφόρε Μάρτυς ἔνδοξε."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C13.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C13.incipit = "Ὡς ἔχων παῤῥησίαν πρὸς τὸν…"
meMA.Ode9C13.text = "Ὡς ἔχων παῤῥησίαν πρὸς τὸν Χριστόν, ἱκετεύων μὴ παύσῃ Ἰσίδωρε, ἐκ πειρασμῶν, ζάλης τε καὶ θλίψεως καὶ παθῶν, τοὺς ἐκτελοῦντας ῥύσασθαι, μνήμην σου ἀξίως τὴν ἱεράν, ψυχῶν τε σωτηρίαν, αἰτούμενος τρισμάκαρ, σῆς κληρουχίας καταξίωσον."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C1T.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C1T.incipit = "Σωτῆρα ὡς τεκοῦσα καὶ λυτρωτήν…"
meMA.Ode9C1T.text = "Σωτῆρα ὡς τεκοῦσα καὶ λυτρωτήν, σωτηρίας με Κόρη ἀξίωσον, ἐπιτυχεῖν, πάναγνε πταισμάτων μου τὰς σειράς, ταῖς σαῖς πρεσβείαις λύουσα· πάντα γὰρ ὡς θέλεις σὺ κατορθοῖς, ὡς φέρουσα ἐν κόλποις, τὸν πάντων Βασιλέα, τὸν ἀγαθότητι ἀσύγκριτον."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9H.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9H.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.melody
meMA.Ode9H.incipit = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.incipit
meMA.Ode9H.text = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.text

meLI.Kontakion1.mode = me.m05.d14_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.greekmelody = me.m05.d14_gr_GR_cog.meMA.Kontakion1.greekmelody
meLI.Kontakion1.melody = me.m05.d14_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m05.d14_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m05.d14_gr_GR_cog.meMA.Kontakion1.text

meLI.MM.CommunionHymn.text = properties_gr_GR_cog.media.key

meLI.Megalynarion.text = "Ξίφει ἐκτμηθείς σου τὴν κεφαλήν, ἔτεμες τῆς πλάνης, Ἀθλοφόρε τὰς μηχανάς, καὶ Χριστῷ ἡνώθης, τῇ κεφαλῇ τῶν ὅλων, ὡς κοινωνὸς τοῦ πάθους, τούτου Ἰσίδωρε."
