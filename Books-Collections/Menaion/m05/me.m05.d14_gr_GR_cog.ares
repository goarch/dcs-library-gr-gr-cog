A_Resource_Whose_Name = me.m05.d14_gr_GR_cog

meDA.date = "Τῌ ΙΔʹ ΜΑΪΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
meDA.commemoration.full = "Μνήμη τοῦ Ἁγίου Μάρτυρος Ἰσιδώρου τοῦ ἐν τῇ Χίῳ" //full title of day
meDA.commemoration.first = "Μνήμη τοῦ Ἁγίου Μάρτυρος Ἰσιδώρου τοῦ ἐν τῇ Χίῳ"
meDA.commemoration.first_short = "Μνήμη τοῦ Ἁγίου Μάρτυρος Ἰσιδώρου τοῦ ἐν τῇ Χίῳ"
meDA.commemoration.first_title = titles_gr_GR_cog.ti.SaintM
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = ""
meDA.commemoration.second_name = ""
meDA.insert1 = "καὶ τοῦ Ἁγίου Μάρτυρος Ἰσιδώρου τοῦ ἐν τῇ Χίῳ," //for use in petitions and dismissal
meDA.insert2 = "οὗ καὶ τὴν μνήμην ἐπιτελοῦμεν·" //for use in petitions and dismissal
meDA.note = ""
meDA.pdfcoverdate = "τῆς 14ης Μαΐου,"
meDA.pdfdatebefore = "τῆς 13ης Μαΐου"
meDA.pdfheaderdate = "τῆς 14ης Μαΐου"
meDA.fordate = "διὰ τὴν 14ην Μαΐου"
meLE.commemoration1 = "Μνήμη τοῦ Ἁγίου Μάρτυρος Ἰσιδώρου τοῦ ἐν τῇ Χίῳ."
meLE.commemoration2 = ""
meHO.number = ""
meHO.rank = ""
meHO.commemorations = ""
