meDA.date = "Τῌ ΚΓʹ ΜΑΡΤΙΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
meDA.commemoration.full = "Μνήμη τοῦ Ὁσίου πατρὸς ἡμῶν Νίκωνος καὶ τῶν αὐτοῦ Μαθητῶν ἑκατὸν ἐνενήκοντα ἐννέα." //full title of day
meDA.commemoration.first = "Μνήμη τοῦ Ὁσίου πατρὸς ἡμῶν Νίκωνος"
meDA.commemoration.first_short = "Μνήμη τοῦ Ὁσίου πατρὸς ἡμῶν Νίκωνος"
meDA.commemoration.first_title = titles_gr_GR_cog.ti.Saints
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = ""
meDA.commemoration.second_name = ""
meDA.insert1 = "καὶ τοῦ Ὁσίου πατρὸς ἡμῶν Νίκωνος καὶ τῶν αὐτοῦ Μαθητῶν ἑκατὸν ἐνενήκοντα ἐννέα," //for use in petitions and dismissal
meDA.insert2 = "ὧν καὶ τὴν μνήμην ἐπιτελοῦμεν·" //for use in petitions and dismissal
meDA.note = ""
meDA.pdfcoverdate = "τῆς 23ης Μαρτίου,"
meDA.pdfdatebefore = "τῆς 22ας Μαρτίου"
meDA.pdfheaderdate = "τῆς 23ης Μαρτίου"
meDA.fordate = "διὰ τὴν 23ην Μαρτίου"
meLE.commemoration1 = "Μνήμη τοῦ Ὁσίου πατρὸς ἡμῶν Νίκωνος καὶ τῶν αὐτοῦ Μαθητῶν ἑκατὸν ἐνενήκοντα ἐννέα."
meLE.commemoration2 = ""
meHO.number = ""
meHO.rank = ""
