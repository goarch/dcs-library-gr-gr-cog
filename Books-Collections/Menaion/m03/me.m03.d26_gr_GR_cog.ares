meDA.commemoration.first = "Σύναξις τοῦ Ἀρχιστρατήγου Γαβριήλ"
meDA.commemoration.first_short = "Σύναξις τοῦ Ἀρχιστρατήγου Γαβριήλ"
meDA.commemoration.second_short = "Ἀπόδοσις τοῦ Εὐαγγελισμοῦ"
