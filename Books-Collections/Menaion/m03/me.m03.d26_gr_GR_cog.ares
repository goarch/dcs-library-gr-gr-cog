meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera01.greekmelody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.greekname
meVE.Stichera01.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
meVE.Stichera01.incipit = "Γαβριὴλ ὁ μέγιστος…"
meVE.Stichera01.text = "Γαβριὴλ ὁ μέγιστος νοῦς, ὁ θεοειδέστατος, ὁ φωταυγὴς καὶ οὐράνιος, φῶς τὸ τρισήλιον, καθορῶν καὶ βλέπων, σὺν ταῖς ἄνω τάξεσι, τὸ θεῖον καὶ φρικῶδες μυστήριον, εὐηγγελίσατο, τῇ Παρθένῳ ἀφικόμενος, καὶ πρεσβεύει, ὑπὲρ τῶν ψυχῶν ἡμῶν."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera02.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
meVE.Stichera02.incipit = "Τὸ μέγα μυστήριον…"
meVE.Stichera02.text = "Τὸ μέγα μυστήριον τὸ πρίν, τοῖς Ἀγγέλοις ἄγνωστον, καὶ πρὸ αἰώνων ἀπόκρυφον, μόνος πεπίστευσαι, Γαβριὴλ καὶ τοῦτο, τῇ μόνῃ τεθάῤῥηκας, Ἁγνῇ εἰς Ναζαρέτ ἀφικόμενος· μεθʼ ἧς ἱκέτευε, δωρηθῆναι ταῖς ψυχαῖς ἡμῶν, τὴν εἰρήνην, καὶ τὸ μέγα ἔλεος."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera03.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
meVE.Stichera03.incipit = "Φωτὸς ὢν ἀνάπλεως…"
meVE.Stichera03.text = "Φωτὸς ὢν ἀνάπλεως ἀεί, καὶ ποιῶν τὸ θέλημα, καὶ ἐκτελῶν τὰ προστάγματα, τοῦ Παντοκράτορος, ἀρχηγὲ Ἀγγέλων, Γαβριὴλ πανάριστε, τοὺς πόθῳ σε τιμῶντας περίσῳζε, ἀεὶ αἰτούμενος, δωρηθῆναι ταῖς ψυχαῖς ἡμῶν, τὴν εἰρήνην, καὶ τὸ μέγα ἔλεος."

meVE.SticGlory.poet = poets_gr_GR_cog.po.IoannouMonachou
meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = me.m03.d25_gr_GR_cog.meVE.SticGlory.incipit
meVE.SticGlory.text = me.m03.d25_gr_GR_cog.meVE.SticGlory.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Apolytikion1ger.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
meVE.Apolytikion1ger.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meVE.Apolytikion1ger.incipit = "Φερωνυμίᾳ καταλλήλῳ ἐμπρέπων, καθυπουργεῖς ἐν…"
meVE.Apolytikion1ger.text = "Φερωνυμίᾳ καταλλήλῳ ἐμπρέπων, καθυπουργεῖς ἐν τῇ τοῦ Λόγου σαρκώσει, ὡς στρατηγὸς τῶν Ἀσωμάτων τάξεων· ὅθεν εὐηγγέλισαι, τῇ Παρθένῳ Μαρίᾳ, χαῖρε προσφωνῶν αύτῇ, τὸν Θεὸν γὰρ συλλήψῃ· ὃν ἐκδυσώπει σῴζεσθαι ἡμᾶς, τοὺς σὲ ὑμνοῦντας, Γαρβιὴλ Ἀρχάγγελε."

meMA.C1.acrostic.title = "Ὁ Κανὼν τοῦ Ἀρχαγγέλου,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Ὡς παμμέγιστον τὸν Γαβριὴλ αἰνέσω. Ἰωσήφ."
meMA.C1.title = titles_gr_GR_cog.ti.CanonArchangel
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_Archangel.text

meMA.Ode1C1H.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.greekname
meMA.Ode1C1H.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.melody
meMA.Ode1C1H.incipit = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.incipit
meMA.Ode1C1H.text = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C11.greekmelody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.greekname
meMA.Ode1C11.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C11.incipit = "Ὡς φῶς χρηματίζοντα, ταῖς πρὸς…"
meMA.Ode1C11.text = "Ὡς φῶς χρηματίζοντα, ταῖς πρὸς τὸ φῶς τὸ ἀκρότατον, ἀΰλοις μεθέξεσι, θεῖον καὶ ἄϋλον, ἱκετεύω σε, Ἀρχάγγελε τὸν νοῦν μου, φώτισον πρεσβείαις σου, ὅπως ὑμνήσω σε."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C12.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C12.incipit = "Στησώμεθα σήμερον, χοροὺς ἐνθέους γηθόμενοι…"
meMA.Ode1C12.text = "Στησώμεθα σήμερον, χοροὺς ἐνθέους γηθόμενοι, τὸν πρῶτον γεραίροντες, τῶν ἀσωμάτων Νοῶν, τὸν τὴν ἄῤῥητον, χαρὰν μεμηνυκότα, ἐν κόσμῳ φοιτήσασαν διʼ ἀγαθότητα."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C13.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C13.incipit = "Προστάτην σε μέγιστον, καὶ πρὸς…"
meMA.Ode1C13.text = "Προστάτην σε μέγιστον, καὶ πρὸς Θεὸν ἀντιλήπτορα, καὶ τεῖχος καὶ στήριγμα, Γαβριὴλ ἔχοντες, οἱ ποθοῦντές σε, ῥυόμεθα κινδύνων, καὶ βλάβης τοῦ ὄφεως ἀνευφημοῦντές σε."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C1T.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C1T.incipit = "Ἁγνήν σε πανάμωμον, ὁ Γαβριὴλ…"
meMA.Ode1C1T.text = "Ἁγνήν σε πανάμωμον, ὁ Γαβριὴλ ὡς ἑώρακε, τὸ Χαῖρέ σοι Δέσποινα, λαμπρῶς ἐβόησεν, ἀπειρόγαμε, βροτῶν ἡ σωτηρία, Ἀγγέλων τὸ καύχημα, καὶ σεμνολόγημα."

meMA.Ode3C1H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.greekname
meMA.Ode3C1H.melody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.melody
meMA.Ode3C1H.incipit = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.incipit
meMA.Ode3C1H.text = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.text

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.greekname
meMA.Ode3C11.melody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.name
meMA.Ode3C11.incipit = "Μεθέξει φωτὸς ἀϋλοτάτου, ὡς ἄϋλος…"
meMA.Ode3C11.text = "Μεθέξει φωτὸς ἀϋλοτάτου, ὡς ἄϋλος ὄντως Γαβριήλ, ἀΰλως φωτιζόμενος, φῶς καθωράθης δεύτερον, τοὺς ὑλικοὺς ἑκάστοτε, βροτοὺς φωτίζων ὑμνοῦντάς σε."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C12.melody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.name
meMA.Ode3C12.incipit = "Μεγίστης εὐκλείας ἠξιώθης, τὸ μέγα…"
meMA.Ode3C12.text = "Μεγίστης εὐκλείας ἠξιώθης, τὸ μέγα μυστήριον ἡμῖν, ἀνακαλύψας μέγιστε, Ἀγγέλων διʼ οὗ ἤρθημεν, οἱ ἀπὸ γῆς πρὸς μέγιστον, ὕψος μεγάλως τιμῶντές σε."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C13.melody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.name
meMA.Ode3C13.incipit = "Ἐπίφανον πᾶσιν οὐρανόθεν, τοῖς πόθῳ…"
meMA.Ode3C13.text = "Ἐπίφανον πᾶσιν οὐρανόθεν, τοῖς πόθῳ ζητοῦσί σε ἀεί, καὶ παῦσον τὸ κλυδώνιον, καθʼ ἡμῶν κινούμενον, τῶν πειρασμῶν καὶ θλίψεων, ὦ Γαβριὴλ Ἀρχιστράτηγε."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C1T.melody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.name
meMA.Ode3C1T.incipit = "Γνωρίζων τὸ πάλαι κεκρυμμένον, Μυστήριον…"
meMA.Ode3C1T.text = "Γνωρίζων τὸ πάλαι κεκρυμμένον, Μυστήριον Κόρη σοι ποτέ, ὁ Γαβριὴλ ἐκραύγαζε· Χαῖρε Θεοῦ παλάτιον, ἐν ᾧ οἰκήσας ἅπαντας, βροτοὺς θεώσει ὡς εὔσπλαγχνος."

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3Kathisma1.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meMA.Ode3Kathisma1.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Ode3Kathisma1.incipit = "Ὁ μέγας Γαβριήλ, Ἀρχηγὸς τῶν…"
meMA.Ode3Kathisma1.text = "Ὁ μέγας Γαβριήλ, Ἀρχηγὸς τῶν Ἀγγέλων, δεικνύμενος ἀεί, σὺν αὐτοῖς ἀνακράζει, τὸ θεῖον μελῴδημα, τῇ Τριάδι γηθόμενος. Τοῦτον ἅπαντες, μεγαλοφώνως ἐν πίστει, ἀνυμνήσωμεν, καὶ καθαρᾷ διανοίᾳ, αἰσίως δοξάσωμεν."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaT.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Ode3KathismaT.incipit = "Τῶν ἀσωμάτων Λειτουργῶν ὡς πρωτεύων…"
meMA.Ode3KathismaT.text = "Τῶν ἀσωμάτων Λειτουργῶν ὡς πρωτεύων, τὸ πρὸ αἰώνων ὁρισθὲν φρικτὸν ὄντως, σοὶ Γαβριὴλ πεπίστευται Μυστήριον, τόκον τὸν ἀπόῤῥητον, τῆς Ἁγίας Παρθένου· Χαῖρε προσφωνῶν αὐτῇ, ἡ Κεχαριτωμένη· χρεωστικῶς σὲ ὅθεν οἱ πιστοί, ἐν εὐφροσύνῃ ἀεὶ μακαρίζομεν."

meMA.Ode4C1H.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.greekname
meMA.Ode4C1H.melody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.melody
meMA.Ode4C1H.incipit = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.incipit
meMA.Ode4C1H.text = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.greekname
meMA.Ode4C11.melody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.name
meMA.Ode4C11.incipit = "Ἵστασο μεθέξεσι θεαρχικαῖς, πάλαι Γαβριὴλ…"
meMA.Ode4C11.text = "Ἵστασο μεθέξεσι θεαρχικαῖς, πάλαι Γαβριὴλ ἀξιάγαστε, καταφαιδρύνων, τὸν Προφήτην Δανιήλ, καὶ ἐντιθεὶς τὴν δήλωσιν, τῶν ἀγνοουμένων ἐν πνεύματι."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C12.melody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.name
meMA.Ode4C12.incipit = "Στόμασι πηλίνοις σε χαρμονικῶς, πύρινον…"
meMA.Ode4C12.text = "Στόμασι πηλίνοις σε χαρμονικῶς, πύρινον τῇ φύσει ὑπάρχοντα, ἀνευφημοῦμεν, ἐξελοῦ ἡμᾶς πυρός, διηνεκῶς φλογίζοντος, θείαις Γαβριὴλ μεσιτείαις σου."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C13.melody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.name
meMA.Ode4C13.incipit = "Τὴν ὑπὲρ τὸν ἥλιον θείαν…"
meMA.Ode4C13.text = "Τὴν ὑπὲρ τὸν ἥλιον θείαν στολήν, δόξῃ ἀποῤῥήτῳ ἀστράπτουσαν, ἠμφιεσμένος, Στρατηγὲ τῶν Λειτουργῶν, τῷ Βασιλεῖ παρίστασαι, τῷ ἐπουρανίῳ γηθόμενος."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C1T.melody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.name
meMA.Ode4C1T.incipit = "Ὅλην σε τῷ Πνεύματι ὁ…"
meMA.Ode4C1T.text = "Ὅλην σε τῷ Πνεύματι ὁ Γαβριήλ, περιηγνισμένην Πανάμωμε, κατανοήσας, ἐκβοᾷ σοι ἐμφανῶς· Χαῖρε ἀρᾶς ἡ λύτρωσις, καὶ τῶν Προπατόρων ἀνάκλησις."

meMA.Ode5C1H.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.greekname
meMA.Ode5C1H.melody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.melody
meMA.Ode5C1H.incipit = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.incipit
meMA.Ode5C1H.text = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.text

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.greekname
meMA.Ode5C11.melody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.name
meMA.Ode5C11.incipit = "Νοὸς κατὰ μέθεξιν, τοῦ πρώτου…"
meMA.Ode5C11.text = "Νοὸς κατὰ μέθεξιν, τοῦ πρώτου φωτιζόμενος, δεύτερον ὡράθης φῶς κραυγάζων, σὺν ταῖς ἀπείροις Ἀγγέλων τάξεσιν· Ἅγιος ὁ Θεὸς ὁ παντουργός, Υἱὸς ὁ συνάναρχος, καὶ τὸ Πνεῦμα τὸ σύνθρονον."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C12.melody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.name
meMA.Ode5C12.incipit = "Τὸ εἶδός σου πύρινον, τὸ…"
meMA.Ode5C12.text = "Τὸ εἶδός σου πύρινον, τὸ κάλλος ὑπερθαύμαστον, ἅπασαν διάνοιαν ἐκπλῆττον, μέγα τὸ κλέος Γαβριὴλ μέγιστε, θείων Ἀσωμάτων ἀρχηγέ, πάντων ἐγκαλλώπισμα, τῶν πιστῶς ἀνυμνούντων σε."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C13.melody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.name
meMA.Ode5C13.incipit = "Ὁ θεῖος ὡς εἶδὲ σε…"
meMA.Ode5C13.text = "Ὁ θεῖος ὡς εἶδέ σε, καιρῷ τοῦ θυμιάματος, πάλαι συνεστῶτα Ζαχαρίας, μένει κωφεύων· οὐ γὰρ ἐπίστευσε, σοῦ τῇ ἀγγελία τῇ φρικτῇ, ἣν περ ἐξεφώνησας, Γαβριήλ Ἀρχιστράτηγε."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C1T.melody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.name
meMA.Ode5C1T.incipit = "Ναὸς ἁγιάσματος, ὑπάρχουσα Πανάμωμε, φωνῇ…"
meMA.Ode5C1T.text = "Ναὸς ἁγιάσματος, ὑπάρχουσα Πανάμωμε, φωνῇ Γαβριὴλ τοῦ Ἀρχαγγέλου, τὸν ἐν Ἁγίοις ἀναπαυόμενον, τέτοκας πανάγιον Θεόν, πάντας ἁγιάζοντα, καὶ δεινῶν ἐξαιρούμενον."

meMA.Ode6C1H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.greekname
meMA.Ode6C1H.melody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.melody
meMA.Ode6C1H.incipit = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.incipit
meMA.Ode6C1H.text = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.text

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.greekname
meMA.Ode6C11.melody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.name
meMA.Ode6C11.incipit = "Γεώδεις γλῶσσαι γεραίρειν σε, τὸν…"
meMA.Ode6C11.text = "Γεώδεις γλῶσσαι γεραίρειν σε, τὸν νοῦν τὸν φωταυγῆ καὶ οὐράνιον, οὐκ ἐξισχύουσι, περιφανῶς λαμπρυνόμενον, ταῖς ὑπὲρ νοῦν καὶ λόγον, θείαις λαμπρότησιν."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C12.melody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.name
meMA.Ode6C12.incipit = "Ἀκτίς Ἡλίου πολύφωτε, πυρίνων Λειτουργῶν…"
meMA.Ode6C12.text = "Ἀκτίς Ἡλίου πολύφωτε, πυρίνων Λειτουργῶν Ἀρχιστράτηγε, ταῖς σελασφόροις σου, πρὸς τὸν Δεσπότην δεήσεσι, τοὺς ὑμνητάς σου σκότους, παθῶν ἐξάρπασον."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C13.melody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.name
meMA.Ode6C13.incipit = "Βουλὰς ἐθνῶν διασκέδασον, τὴν Πίστιν…"
meMA.Ode6C13.text = "Βουλὰς ἐθνῶν διασκέδασον, τὴν Πίστιν τὴν ὀρθόδοξον κράτυνον, παῦσον τὰ σχίσματα, τῆς Ἐκκλησίας, Ἀρχάγγελε, ταῖς πρὸς τὸν Κτίστην πάντων, σοῦ παρακλήσεσι."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C1T.melody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.name
meMA.Ode6C1T.incipit = "Ῥημάτων θείων ὑπήκοος, Ἁγνὴ τοῦ…"
meMA.Ode6C1T.text = "Ῥημάτων θείων ὑπήκοος, Ἁγνὴ τοῦ Γαβριὴλ ἐχρημάτισας, καὶ τὸν προάναρχον, Λόγον σαρκὶ ἀπεκύησας, τῆς ἀλογίας κόσμον ἀπολυτρούμενον."

meMA.Ode7C1H.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.greekname
meMA.Ode7C1H.melody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.melody
meMA.Ode7C1H.incipit = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.incipit
meMA.Ode7C1H.text = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.text

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.greekname
meMA.Ode7C11.melody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.name
meMA.Ode7C11.incipit = "Ἰωάννου τόκον Ἔνδοξε ἐμήνυσας, τῷ…"
meMA.Ode7C11.text = "Ἰωάννου τόκον Ἔνδοξε ἐμήνυσας, τῷ Ζαχαρία ποτέ, ἔνδον τοῦ θείου Ναοῦ, ἑστῶτι καὶ ψάλλοντι, τῷ λυτρωτῇ καὶ Θεῷ· Ὑπερύμνητε, ὁ τῶν Πατέρων Κύριος, καὶ Θεός εὐλογητὸς εἶ."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C12.melody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.name
meMA.Ode7C12.incipit = "Ἡ περίδοξος τοῦ οἴκου σου…"
meMA.Ode7C12.text = "Ἡ περίδοξος τοῦ οἴκου σου εὐπρέπεια, περιφανῶς Γαβριήλ, καθαγιάζει ψυχὰς πιστῶν, καὶ προτρέπεται μεγαλοφώνως βοᾶν· Ὑπερύμνητε, ὁ τῶν Πατέρων Κύριος, καὶ Θεὸς εὐλογητὸς εἶ."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C13.melody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.name
meMA.Ode7C13.incipit = "Λαμπρυνόμενος μεθέξει Ἀρχιστράτηγε, πρώτου φωτὸς…"
meMA.Ode7C13.text = "Λαμπρυνόμενος μεθέξει Ἀρχιστράτηγε, πρώτου φωτὸς μυστικῶς, δεύτερον φῶς ἀληθῶς, ὡράθης τοὺς μέλποντας, φωτίζων πάντοτε· Ὑπερύμνητε, ὁ τῶν Πατέρων Κύριος, καὶ Θεὸς εὐλογητὸς εἶ."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C1T.melody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.name
meMA.Ode7C1T.incipit = "Ἀπεστάλη Γαβριὴλ ὁ Ἀρχιστράτηγος, χαρὰν…"
meMA.Ode7C1T.text = "Ἀπεστάλη Γαβριὴλ ὁ Ἀρχιστράτηγος, χαρὰν μηνύων σοι, Παρθενομῆτορ ἁγνή, διʼ ἧς λύπη πέπαυται, καὶ ἡ ἀρὰ ἀληθῶς, ἀπεστείρωται, καὶ εὐλογία ἤνθησε, τοῖς πιστοῖς εἰς τοὺς αἰῶνας."

meMA.Ode8C1H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.greekname
meMA.Ode8C1H.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.melody
meMA.Ode8C1H.incipit = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.incipit
meMA.Ode8C1H.text = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.text

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C11.greekmelody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.greekname
meMA.Ode8C11.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
meMA.Ode8C11.incipit = "Ἱερολογίαις ἱεραῖς σε, λαὸς ἱερὸς…"
meMA.Ode8C11.text = "Ἱερολογίαις ἱεραῖς σε, λαὸς ἱερὸς ὑμνεῖ γηθόμενος· σὺ γὰρ τὸν παναίτιον, Λόγον σωματούμενον, τὸ καθʼ ἡμᾶς Ἀρχάγγελε, τῇ ἐξ ἡμῶν προσφωνεῖς, Παρθένῳ ὑπὲρ νοῦν τε καὶ λόγον· ὅθεν σε τιμῶμεν, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C12.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
meMA.Ode8C12.incipit = "Νοΐ τῷ μεγάλῳ τε καὶ…"
meMA.Ode8C12.text = "Νοΐ τῷ μεγάλῳ τε καὶ πρώτῳ, ἀΰλως Ἀρχάγγελε ἑνούμενος, στόματι πυρίνῳ σου, μέλπεις τὸ μελῴδημα, τὸ φοβερόν, ὃ μέλπουσι, πάντων Ἀγγέλων χοροί· Τὸν Κύριον ὑμνεῖτε τὰ ἔργα, καὶ ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C13.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
meMA.Ode8C13.incipit = "Εὐκλείαις σαφῶς πεποικιλμένος, ταῖς θείαις…"
meMA.Ode8C13.text = "Εὐκλείαις σαφῶς πεποικιλμένος, ταῖς θείαις διέρχῃ τὰ οὐράνια, εἶτα τὰ ἐπίγεια, ἐκπληρῶν ὡς ἄϋλος, τὰ ἱερὰ θελήματα, Χριστοῦ τοῦ πάντων Θεοῦ, Ἀγγέλων Γαβριήλ Ἀρχηγέτα, κλέος τῶν ἐν πίστει, ἀεί σε εὐφημούντων."

meMA.Ode8C14.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C14.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
meMA.Ode8C14.incipit = "Σαρκὶ καθʼ ὑπόστασιν ὁ Λόγος…"
meMA.Ode8C14.text = "Σαρκὶ καθʼ ὑπόστασιν ὁ Λόγος, ἀνθρώποις προσομιλῆσαι προελόμενος, ἔσχε σε προτρέχοντα, καὶ προετοιμάζοντα τὸ ἱερὸν παλάτιον, ὦ Ἱερὲ Γαβριήλ, καὶ Κύριον ὑμνεῖτε βοῶντα, καὶ ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C1T.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
meMA.Ode8C1T.incipit = "Ὡς θρόνον τερπνὸν τοῦ Βασιλέως…"
meMA.Ode8C1T.text = "Ὡς θρόνον τερπνὸν τοῦ Βασιλέως, ὡς πάντων τῶν ποιημάτων ὑπερέχουσαν, ὡς τὸν ὑπερούσιον, μόνην οὐσιώσασαν, τὸν τοὺς βροτοὺς θεώσαντα, ἑνώσει κρείττονι, γεννήσεως ἀῤῥήτου καὶ ξένης, τὴν εὐλογημένην, ὑμνήσωμεν Παρθένον."

meMA.Ode9C1H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.greekname
meMA.Ode9C1H.melody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.melody
meMA.Ode9C1H.incipit = he.h.m4_gr_GR_cog.heHE.ApasGigenis.incipit
meMA.Ode9C1H.text = he.h.m4_gr_GR_cog.heHE.ApasGigenis.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.greekname
meMA.Ode9C11.melody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.name
meMA.Ode9C11.incipit = "Ἵσταται φρικτῶς, τῷ θρόνῳ τῆς…"
meMA.Ode9C11.text = "Ἵσταται φρικτῶς, τῷ θρόνῳ τῆς χάριτος διακονούμενος, καὶ καταστραπτόμενος, φωτοχυσίαις ταῖς ὑπὲρ ἔννοιαν, καὶ ἱερῶς θεούμενος, καὶ φῶς ὁρώμενος, καὶ φωτίζων, πίστει τοὺς τιμῶντάς σε, ἱερὲ Γαβριὴλ Ἀρχιστράτηγε."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C12.melody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.name
meMA.Ode9C12.incipit = "Ὥσπερ οὐρανός, ὑπάρχεις κατάστερος, θείαις…"
meMA.Ode9C12.text = "Ὥσπερ οὐρανός, ὑπάρχεις κατάστερος, θείαις λαμπρότησιν, ὥσπερ Στρατηγέτης δέ, χερσὶ κατέχεις σκῆπτρον ὑπέρλαμπρον, καὶ διαθέεις ἅπασαν τὴν γῆν, τὸ βούλημα τοῦ Δεσπότου, πάντοτε ποιούμενος, καὶ δεινῶν τοὺς πιστοὺς ἐξαιρούμενος."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C13.melody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.name
meMA.Ode9C13.incipit = "Στῆσον τὸ δεινόν, βαρβάρων κλυδώνιον…"
meMA.Ode9C13.text = "Στῆσον τὸ δεινόν, βαρβάρων κλυδώνιον, ἐπεγειρόμενον, πάντοτε τοῖς δούλοις σου, τῆς Ἐκκλησίας παῦσον τὰ σχίσματα, τοῖς ὑμνηταῖς σου βράβευσον πταισμάτων λύτρωσιν, Βασιλεῖ τε, δώρησαι τὰ τρόπαια, Γαβριὴλ τῇ θερμῇ προστασίᾳ σου."

meMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C14.melody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.name
meMA.Ode9C14.incipit = "Ἡ περικαλής, δυὰς καὶ περίδοξος…"
meMA.Ode9C14.text = "Ἡ περικαλής, δυὰς καὶ περίδοξος Μιχαὴλ καὶ Γαβριήλ, θρόνῳ παριστάμενοι, τῆς θείας δόξης, πᾶσιν αἰτήσασθε, ἁμαρτιῶν συγχώρησιν, ἀπαλλαγὴν τῶν δεινῶν, ὡς προστάται, ὡς τὴν ἀγαθότητα, τοῦ Δεσπότου ἐν πᾶσι μιμούμενοι."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C1T.melody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.name
meMA.Ode9C1T.incipit = "Φέγγος ἀστραπῆς, τοῦ τόκου σου…"
meMA.Ode9C1T.text = "Φέγγος ἀστραπῆς, τοῦ τόκου σου ἔλαμψε καὶ κατεφαίδρυνε, πᾶσαν τὴν ὑφήλιον, καὶ τὸν προστάτην τοῦ σκότους ὤλεσε, Θεογεννῆτορ Πάναγνε, Ἀγγέλων καύχημα, καὶ ἀνθρώπων, πάντων τὸ διάσωσμα, τῶν ἀπαύστοις φωναῖς εὐφημούντων σε."

meMA.MM.Ve1123as5678.text = properties_gr_GR_cog.media.key

meLI.MM.CommunionHymn.text = properties_gr_GR_cog.media.key

meLI.Megalynarion.text = ""

