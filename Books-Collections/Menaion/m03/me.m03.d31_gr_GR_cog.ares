meLE.commemoration1 = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος καὶ θαυματουργοῦ Ὑπατίου, Ἐπισκόπου Γαγγρῶν."
meLE.commemoration2 = ""
