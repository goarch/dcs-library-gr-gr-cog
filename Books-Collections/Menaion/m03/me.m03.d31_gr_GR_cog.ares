meDA.insert1 = "καὶ τοῦ Ἁγίου Ἱερομάρτυρος καὶ θαυματουργοῦ Ὑπατίου, Ἐπισκόπου Γαγγρῶν," //for use in petitions and dismissal
meDA.insert2 = "οὗ καὶ τὴν μνήμην ἐπιτελοῦμεν·" //for use in petitions and dismissal
