meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera01.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
meVE.Stichera01.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.Stichera01.incipit = "Πάτερ θεόφρον Ὑπάτιε, ἐν ἐγκρατείᾳ…"
meVE.Stichera01.text = "Πάτερ θεόφρον Ὑπάτιε, ἐν ἐγκρατείᾳ καλῶς, ἐκτραφεὶς εἰς περίδοξον, ἀρετῶν ἐπηύξησαι, ὕψος ἀνατεινόμενος, πρὸς θεωρίαν μυστικωτάτην σαφῶς, Χριστοῦ τὸ κάλλος κατοπτριζόμενος, οὗ ταῖς ἐλλάμψεσι, νοῦν τε καὶ διάνοιαν, καταυγασθείς, πᾶσιν ἐναπήστραψας, τὰς τῶν θαυμάτων αὐγάς."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera02.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.Stichera02.incipit = "Πάτερ πατέρων Ὑπάτιε, Ὀρθοδοξίας φωτί…"
meVE.Stichera02.text = "Πάτερ πατέρων Ὑπάτιε, Ὀρθοδοξίας φωτί, ἀπαστράψας κατηύγασας, διανοίας Ὅσιε, τῶν πιστῶς προστρεχόντων σοι, καὶ τὰς Ἀρείου κόρας ἠμαύρωσας, ἀποκηρύξας τῆς Ἐκκλησίας Χριστοῦ· ὅθεν φωστῆρά σε, κεκτημένοι ἅπαντες, τὴν ἱεράν, μνήμην σου γεραίρομεν, καὶ μακαρίζομεν."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera03.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.Stichera03.incipit = "Πάτερ ἱερὲ Ὑπάτιε, τὸν Βασιλέα…"
meVE.Stichera03.text = "Πάτερ ἱερὲ Ὑπάτιε, τὸν Βασιλέα Χριστόν, ὃν τρανῶς ἀνεκήρυξας, Πατρὶ ὁμοούσιον, ἔχων ἐν τῇ καρδίᾳ σου, τὰς τῶν θαυμάτων ἀκτῖνας ἔλαμψας, φωταγωγήσας πᾶσαν ὑφήλιον· δράκοντα ἔκτεινας, καὶ θερμῶν ἀνάβλυσιν, σαῖς προσευχαῖς, ὑδάτων ἐξέβλυσας εἰς ἰατρείαν παθῶν."

meVE.MM.Stichera1123as78910.text = properties_gr_GR_cog.media.key

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.SticTheotokion.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
meVE.SticTheotokion.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
