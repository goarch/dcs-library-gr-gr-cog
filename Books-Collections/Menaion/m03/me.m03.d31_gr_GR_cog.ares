meVE.SticStavrotheotokion.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.SticStavrotheotokion.incipit = me.m03.d13_gr_GR_cog.meVE.SticStavrotheotokion.incipit
meVE.SticStavrotheotokion.text = me.m03.d13_gr_GR_cog.meVE.SticStavrotheotokion.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Apolytikion1ger.greekmelody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.greekname
meVE.Apolytikion1ger.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
meVE.Apolytikion1ger.incipit = "Ὁσίως ἱέρευσας, τῷ ἐπὶ πάντων…"
meVE.Apolytikion1ger.text = "Ὁσίως ἱέρευσας, τῷ ἐπὶ πάντων Θεῷ, καὶ πρόεδρος ἔνθεος, τῆς Ἐκκλησίας Γαγγρῶν, ἐδείχθης Ὑπάτιε· ὅθεν θαυματουργίαις, διαλάμπων ποικίλαις, σύνθρονον τῷ Τεκόντι, τὸν Υἱὸν ὡμολόγεις, διʼ ὃν καὶ χαίρων ἤθλησας, Ἱερομάρτυς ἔνδοξε."

meMA.C1.title = titles_gr_GR_cog.ti.CanonHieromartyr
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.Ode1C1H.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.greekname
meMA.Ode1C1H.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.melody
meMA.Ode1C1H.incipit = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.incipit
meMA.Ode1C1H.text = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C11.greekmelody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.greekname
meMA.Ode1C11.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C11.incipit = "Φωτί της Τριάδος καταυγασθείς, ἐκ…"
meMA.Ode1C11.text = "Φωτί της Τριάδος καταυγασθείς, ἐκ βρέφους θεόφρον, Ἱεράρχα τῷ ζωηρῷ τῆς πίστεως γάλακτι ἐτράφης, ταῖς ἀρεταῖς καταυγαζόμενος."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C12.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C12.incipit = "Συνέσει καὶ χάριτι κοσμηθείς, νηστείαις…"
meMA.Ode1C12.text = "Συνέσει καὶ χάριτι κοσμηθείς, νηστείαις καὶ πόνοις, ἐχαλίνωσας τῆς σαρκός, θεόφρον παμμάκαρ τὰς ὀρέξεις, καὶ τὴν ψυχὴν ἀρεταῖς κατεκόσμησας."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C13.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C13.incipit = "Ἀστράψας τῷ βίῳ τῷ φαεινῶ…"
meMA.Ode1C13.text = "Ἀστράψας τῷ βίῳ τῷ φαεινῶ, ὡς ἥλιος πᾶσαν, Ἱεράρχα τὴν τοῦ Χριστοῦ, ἐφαίδρυνας Πάτερ Ἐκκλησίαν, ἐν ταῖς ἀκτῖσι τῶν θαυμάτων σου."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C1T.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C1T.incipit = "Ἰδοὺ αἱ προῤῥήσεις τῶν προφητῶν…"
meMA.Ode1C1T.text = "Ἰδοὺ αἱ προῤῥήσεις τῶν προφητῶν, ἐπὶ σοὶ τὸ πέρας, ἀπειλήφασιν ἀληθῶς· Λόγον γὰρ ἀσπόρως συλλαβοῦσα, Θεογεννῆτορ ἁγνὴ ἀπεκήυσας."

meMA.Ode3C1H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.greekname
meMA.Ode3C1H.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.melody
meMA.Ode3C1H.incipit = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.incipit
meMA.Ode3C1H.text = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.text

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C11.greekmelody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.greekname
meMA.Ode3C11.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C11.incipit = "Ξύλον ζωῆς πέφυκας, καταρδευόμενος πάνσοφε…"
meMA.Ode3C11.text = "Ξύλον ζωῆς πέφυκας, καταρδευόμενος πάνσοφε, ἐκ τῶν Γραφῶν, οὗ περ οὐ προστρέχει, τῷ καρπῷ ὁ τῆς Εὔας ἐχθρός."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C12.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C12.incipit = "Στόματα ἐνέφραξας, τὰ δυσσεβῆ συσχὼν…"
meMA.Ode3C12.text = "Στόματα ἐνέφραξας, τὰ δυσσεβῆ συσχὼν ᾄσματα, προφητικῶς, ταῖς θεοπειθέσι, πρὸς Χριστὸν παρακλήσεσι."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C13.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C13.incipit = "Γύναια βακχεύοντα, σὺ τῇ πηγῇ…"
meMA.Ode3C13.text = "Γύναια βακχεύοντα, σὺ τῇ πηγῇ σοφῶς ἔθραυσας, σωφρονισμόν, τοῖς ἀγνωμονοῦσι, παραδόξως ποιούμενος."

meMA.Ode3C14.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C14.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C14.incipit = "Οἶκος θείου Πνεύματος, καὶ προσευχῆς…"
meMA.Ode3C14.text = "Οἶκος θείου Πνεύματος, καὶ προσευχῆς εἰκὼν γέγονας, Ἱεραρχῶν, καύχημα καὶ κλέος, τῶν Μαρτύρων Ὑπάτιε."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C1T.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C1T.incipit = "Νόμοις οὐ δουλεύσασα, τοῖς μητρικοῖς…"
meMA.Ode3C1T.text = "Νόμοις οὐ δουλεύσασα, τοῖς μητρικοῖς Σεμνὴ τέτοκας, τὸν Λυτρωτήν, φύσεως οἱ νόμοι, ἐπὶ σοὶ καινίζονται."

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3Kathisma1.greekmelody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.greekname
meMA.Ode3Kathisma1.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
meMA.Ode3Kathisma1.incipit = "Τῆς πίστεως δόγματα, κρατύνων Ὅσιε…"
meMA.Ode3Kathisma1.text = "Τῆς πίστεως δόγματα, κρατύνων Ὅσιε, Πατρὶ συναΐδιον, καὶ ὁμοούσιον, τὸν Λόγον ἐκήρυξας· ὅθεν ὀρθοδόξως, τὴν σὴν ποίμνην ποιμάνας, ᾔσχυνας τοῦ Ἀρείου, τὴν κακόφρονα γνώμην· διὸ νῦν μεταβὰς πρὸς τὸν Χριστόν, πρέσβευε ὑπὲρ πάντων ἡμῶν."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaT.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
meMA.Ode3KathismaT.incipit = me.m01.d22_gr_GR_cog.meMA.Ode3KathismaT.incipit
meMA.Ode3KathismaT.text = me.m01.d22_gr_GR_cog.meMA.Ode3KathismaT.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaSt.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
meMA.Ode3KathismaSt.incipit = oc.m4.d6_gr_GR_cog.ocMA.Kathisma23.incipit
meMA.Ode3KathismaSt.text = oc.m4.d6_gr_GR_cog.ocMA.Kathisma23.text

meMA.Ode4C1H.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.greekname
meMA.Ode4C1H.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.melody
meMA.Ode4C1H.incipit = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.incipit
meMA.Ode4C1H.text = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C11.greekmelody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.greekname
meMA.Ode4C11.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C11.incipit = "Ἡ τοῦ Πνεύματος ἔλλαμψις, Πάτερ…"
meMA.Ode4C11.text = "Ἡ τοῦ Πνεύματος ἔλλαμψις, Πάτερ ἐπὶ σοὶ πλουσίως σκηνώσασα, φωτοφόρον στῦλον ἔδειξε, δᾳδουχοῦντα κόσμον θείοις δόγμασι."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C12.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C12.incipit = "Τῇ γαλήνῃ τῶν λόγων σου…"
meMA.Ode4C12.text = "Τῇ γαλήνῃ τῶν λόγων σου, τὸν εἰδωλικὸν χειμῶνα ἠμαύρωσας, καὶ τροπαίοις ταπεινώσεως, ἀσεβείας θράσος κατεμάρανας."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C13.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C13.incipit = "Ἀκηλίδωτον ἔσοπτρον, Πάτερ τῆς Τριάδος…"
meMA.Ode4C13.text = "Ἀκηλίδωτον ἔσοπτρον, Πάτερ τῆς Τριάδος ὤφθης Ὑπάτιε· κατοπτεύειν γὰρ ἠγάπησας, καθαρῶς τὴν γνῶσιν τοῦ Θεοῦ ἡμῶν."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C1T.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C1T.incipit = "Ὡς φρικτὸν καὶ παράδοξον, τῆς…"
meMA.Ode4C1T.text = "Ὡς φρικτὸν καὶ παράδοξον, τῆς ἁγνῆς λοχείας σου τὸ Μυστήριον! ὑπὲρ φύσιν γὰρ Πανάμωμε, τὸν Δημιουργόν σου ἀπεκύησας."

meMA.Ode5C1H.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
meMA.Ode5C1H.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.melody
meMA.Ode5C1H.incipit = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.incipit
meMA.Ode5C1H.text = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.text

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C11.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
meMA.Ode5C11.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C11.incipit = "Ἐπὶ ὕδωρ τῆς θείας, Πάτερ…"
meMA.Ode5C11.text = "Ἐπὶ ὕδωρ τῆς θείας, Πάτερ, ἀναβάσεως ἔχων τὴν ἔφεσιν, καὶ τοῦ Παραδείσου, τοῦ ἀΰλου τὸ κάλλος γλιχόμενος, εὐανθέσι τόποις, συμβολικῶς ἐπαναπαύου, τὰς ἐκεῖθεν μονὰς τεκμαιρόμενος."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C12.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C12.incipit = "Ταῖς ἀΰλοις γυμνάζων, Πάτερ σεαυτὸν…"
meMA.Ode5C12.text = "Ταῖς ἀΰλοις γυμνάζων, Πάτερ σεαυτὸν θεωρίαις καὶ πράξεσιν, ὑλικὰς φροντίδας, ὥσπερ βάρος ψυχῆς καταλέλοιπας, καὶ ἐν ταῖς ἐρήμοις, χοροβατῶν ὡς ἐν λιμῶνι, ἐπλουτίσθης τὴν χάριν τοῦ Πνεύματος."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C13.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C13.incipit = "Ἐπαυξήσας τὴν ποίμνην, Πάτερ ἐν…"
meMA.Ode5C13.text = "Ἐπαυξήσας τὴν ποίμνην, Πάτερ ἐν τῇ πόᾳ τῶν θείων δογμάτων σου, ὥσπερ μάνδρας οἴκους, σεβασμίους παμμάκαρ καθίδρυσας, ἐν οἷς εἰσελαύνων, τὰ λογικὰ θρέμματα Πάτερ, ἐλυτρώσω θηρῶν ἐξ αἱρέσεων."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C1T.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C1T.incipit = "Μόνη τίκτεις Παρθένος, μόνη καὶ…"
meMA.Ode5C1T.text = "Μόνη τίκτεις Παρθένος, μόνη καὶ ἀπείρανδρος ὤφθης Πανάμωμε· ἐν γαστρὶ γὰρ Λόγον, τοῦ Πατρὸς δεξαμένη τὸν ἄναρχον, γαλουχεῖς Παρθένε, θαῦμα φρικτόν! καὶ παρθενεύεις, καὶ τοὺς ὅρους καινίζεις τῆς φύσεως."

meMA.Ode6C1H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.greekname
meMA.Ode6C1H.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.melody
meMA.Ode6C1H.incipit = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.incipit
meMA.Ode6C1H.text = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.text

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C11.greekmelody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.greekname
meMA.Ode6C11.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C11.incipit = "Φλογώδη ῥεῖθρα φωτός, Ἱερομάρτυς Ὑπάτιε…"
meMA.Ode6C11.text = "Φλογώδη ῥεῖθρα φωτός, Ἱερομάρτυς Ὑπάτιε, ἀνάψας ὁ ποταμός, νυκτὶ διαβαίνοντι, τὴν τρίβον ἐδείκνυεν, ὑποφαίνων πᾶσι, τῆς ψυχῆς σου τὴν λαμπρότητα."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C12.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C12.incipit = "Τερατουργῶν διὰ σοῦ, ὁ ζωοδότης…"
meMA.Ode6C12.text = "Τερατουργῶν διὰ σοῦ, ὁ ζωοδότης Χριστὸς ὁ Θεός, ἰάσεων θησαυρόν, τὸ ὕδωρ ἀνέδειξεν, εὐχαῖς σου Ὑπάτιε, γλυκασμὸν θαυμάτων, τὸ πικρὸν ἀπεργασάμενος."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C13.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C13.incipit = "Θαυμάτων ὑπερφυῶν, ἐργάτης ὤφθης Ὑπάτιε…"
meMA.Ode6C13.text = "Θαυμάτων ὑπερφυῶν, ἐργάτης ὤφθης Ὑπάτιε, λαβὼν δὲ παρὰ Θεοῦ, χάριν τῶν ἰάσεων, πηγὴ ἐχρημάτισας, δαψιλεύων πᾶσι, σωτηρίας θείας νάματα."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C1T.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C1T.incipit = "Ταῖς σαῖς πρεσβείαις Ἁγνή, κινδύνων…"
meMA.Ode6C1T.text = "Ταῖς σαῖς πρεσβείαις Ἁγνή, κινδύνων καὶ περιστάσεων, ἐξάρπασόν με δεινῶν, καὶ ῥῦσαί με δέομαι· σὺ γὰρ τεῖχος ἄῤῥηκτον, καὶ λιμὴν καὶ σκέπη καὶ ἀπόρθητον ὀχύρωμα."

meMA.Ode7C1H.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.greekname
meMA.Ode7C1H.melody = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.melody
meMA.Ode7C1H.incipit = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.incipit
meMA.Ode7C1H.text = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.text

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C11.greekmelody = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.greekname
meMA.Ode7C11.melody = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.name
meMA.Ode7C11.incipit = "Ἀποῤῥήτων θαυμάτων, αὐτουργὸς Ἱεράρχα παρὰ…"
meMA.Ode7C11.text = "Ἀποῤῥήτων θαυμάτων, αὐτουργὸς Ἱεράρχα παρὰ Χριστοῦ γεγονώς, ἐφώτισας τὸν κόσμον, τῇ πράξει καὶ τῷ λόγῳ, ἐκδιδάξας βοᾶν εὐσεβῶς· ὁ τῶν Πατέρων ἡμῶν, Θεός εὐλογητὸς εἶ."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C12.melody = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.name
meMA.Ode7C12.incipit = "Ἀπογνώσεως βρόχους, ἐν βυθῷ ἀπιστίας…"
meMA.Ode7C12.text = "Ἀπογνώσεως βρόχους, ἐν βυθῷ ἀπιστίας ἀποπνιγόμενος, προσάπτων τοῖς πεσοῦσιν, εἰς πάθη ἀτιμίας, τὴν μετάνοιαν ἔσβεσεν· ἣν περ ἀστράψας πιστοῖς, κατέφλεξας Ναβάτον."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C1T.melody = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.name
meMA.Ode7C1T.incipit = "Τὴν Μητέρα τοῦ Λόγου, τὴν…"
meMA.Ode7C1T.text = "Τὴν Μητέρα τοῦ Λόγου, τὴν Ἁγνὴν Θεοτόκον καὶ προστασίαν ἡμῶν, διʼ ἧς τὰς ἐπηρείας, ἐχθρῶν καταπατοῦμεν, ἀνυμνοῦμεν καὶ λέγομεν· Εὐλογημένη Θεόν, σαρκὶ ἀποτεκοῦσα."

meMA.Ode8C1H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.greekname
meMA.Ode8C1H.melody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.melody
meMA.Ode8C1H.incipit = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.incipit
meMA.Ode8C1H.text = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.text

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C11.greekmelody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.greekname
meMA.Ode8C11.melody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.name
meMA.Ode8C11.incipit = "Τὰς ἀναιμάκτους εἰλικρινῶς τῇ Τριάδι…"
meMA.Ode8C11.text = "Τὰς ἀναιμάκτους εἰλικρινῶς τῇ Τριάδι, ἀναφέρων θυσίας Παμμάκαρ, γέγονας Κυρίῳ σφάγιον Μαρτυρίου."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C12.melody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.name
meMA.Ode8C12.incipit = "Τὴν ἱεράν σου βάψας στολὴν…"
meMA.Ode8C12.text = "Τὴν ἱεράν σου βάψας στολὴν τῷ οἰκείῳ, Θεοφόρε αἵματι προθύμως, στέφανον ἐδέξω διπλοῦν Ἱερομάρτυς."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C13.melody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.name
meMA.Ode8C13.incipit = "Ὡς Μαθητὴς οἷά περ Χριστοῦ…"
meMA.Ode8C13.text = "Ὡς Μαθητὴς οἷά περ Χριστοῦ ἐκμιμήσει, συμπαθείας θνῄσκων ὑπερηύχου, σοῦ τοὺς ἀνδροφόνους τεύξασθαι σωτηρίας."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C1T.melody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.name
meMA.Ode8C1T.incipit = "Λόγον συνείληφας ἐν γαστρὶ ὑπὲρ…"
meMA.Ode8C1T.text = "Λόγον συνείληφας ἐν γαστρὶ ὑπὲρ λόγον, καὶ τεκοῦσα πάλιν παρθενεύεις πάντα ὑπὲρ φύσιν τὰ σὰ Θεογεννῆτορ."

meMA.Ode9C1H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9C1H.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.melody
meMA.Ode9C1H.incipit = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.incipit
meMA.Ode9C1H.text = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C11.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9C11.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C11.incipit = "Μωσέα εἰκονίζων ταῖς ἀρεταῖς, ὑπερήλασας…"
meMA.Ode9C11.text = "Μωσέα εἰκονίζων ταῖς ἀρεταῖς, ὑπερήλασας τοῦτον τῷ θαύματι, ῥάβδῳ τῇ σῇ· πλήξας γὰρ τὸν δράκοντα εὐθαρσῶς, ὡς ἐν ἀγκίστρῳ εἵλκυσας, Πάτερ ἐκ ταμείων Βασιλικῶν, πυρὶ καταναλώσας, ὡς ὄργανον κακίας Ὀρθοδοξίᾳ κραταιούμενος."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C12.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C12.incipit = "Χωννύμενος τοῖς λίθοις διὰ Χριστόν…"
meMA.Ode9C12.text = "Χωννύμενος τοῖς λίθοις διὰ Χριστόν, ὑπὸ τῶν μιαιφόνων Ὑπάτιε, ῥείθροις τῶν σῶν, ἔπνιξας αἱμάτων τοῦ ἀσεβοῦς, Ναβάτου τὰ ἀντίθεα, δόγματα κηρύξας Πάτερ σοφέ, τοῖς πταίουσι συγγνώμην, διὰ τῆς μετανοίας τῶν ὀφλημάτων προσπορίζεσθαι."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C13.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C13.incipit = "Μὴ παύσῃ ἱκετεύων ὑπὲρ ἡμῶν…"
meMA.Ode9C13.text = "Μὴ παύσῃ ἱκετεύων ὑπὲρ ἡμῶν, Ἱεράρχα καὶ Μάρτυς Ὑπάτιε, τῷ Ποιητῇ, πάντων καὶ Δεσπότῃ παρεστηκώς, ἐκ πειρασμῶν καὶ θλίψεων, ῥύσασθαι τοὺς πόθῳ εἰλικρινεῖ, τελοῦντας τὴν σὴν μνήμην, καὶ θείαις μελῳδίαις, ἀνευφημοῦντάς σε πανεύφημε."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C1T.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C1T.incipit = "Ὀφρὺν καὶ θράσος ἅμα τῶν…"
meMA.Ode9C1T.text = "Ὀφρὺν καὶ θράσος ἅμα τῶν δυσμενῶν, ὁ τεχθεὶς ἐκ Παρθένου κατάβαλε, καὶ τὰς βουλάς, τῶν κακοδοξουντων Δημιουργέ, τῶν δὲ πιστῶν τὸ σύστημα στήριξον ἀκράδαντον ὡς Θεός, τὸ κέρας ἀνυψώσας, καὶ πίστει κραταιώσας, ἵνα σε πάντες μεγαλύνωμεν."

meLI.Megalynarion.text = ""
