meDA.pdfdatebefore = "τῆς 22ας Ἰουνίου"
meDA.pdfheaderdate = "τῆς 23ης Ἰουνίου"
meDA.fordate = "διὰ τὴν 23ην Ἰουνίου"
meLE.commemoration1 = "Μνήμη τῆς Ἁγίας Μάρτυρος Ἀγριππίνης."
meLE.commemoration2 = ""
meHO.number = ""
meHO.rank = ""
meHO.commemorations = ""
