meHO.note2 = ""
meDA.dismissal = ""
meDA.dismissal.incipit = ""

meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.greekname
meVE.Stichera01.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera01.incipit = "Ῥώμη σε προβάλλεται…"
meVE.Stichera01.text = "Ῥώμη σε προβάλλεται, ὥσπερ λειμὼν ῥόδον εὔοσμον, Ἀγριππίνα πολύαθλε, πιστῶν τὴν διάνοιαν, κατευωδιάζον, ὀδμαῖς ἐναρέτοις, καὶ τὸ δυσῶδες τῶν παθῶν, ἀποδιῶκον χάριτι πάντιμε, Μαρτύρων ἐγκαλλώπισμα, τῆς Ἐκκλησίας ἑδραίωμα, τῶν παρθένων τὸ καύχημα, τῶν θαυμάτων τὸ πέλαγος."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera02.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera02.incipit = "Ὄλβον ὡς πολύτιμον…"
meVE.Stichera02.text = "Ὄλβον ὡς πολύτιμον, τῇ Σικελίᾳ σε δίδωσιν, ἐν τῇ Ῥώμῃ ἀθλήσασαν, Χριστὸς ὁ Θεὸς ἡμῶν· ἔνθα γενομένη, ἀοίδιμε Μάρτυς, τὴν τῶν δαιμόνων πονηράν, πληθὺν διώκεις ἐπιστασίᾳ σου· διό σε μακαρίζομεν, καὶ τὴν ἁγίαν σου σήμερον, ἑορτάζομεν ἄθλησιν, Ἀγριππίνα πολύαθλε."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera03.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera03.incipit = "Ἔφερον ἐπʼ ὤμων…"
meVE.Stichera03.text = "Ἔφερον ἐπʼ ὤμων σε, Βάσσα καὶ Παῦλα προστάξεσι, τοῦ τὰ σύμπαντα φέροντος, τόπους διαμείβουσαι, καὶ μακρὰ πελάγη, Μάρτυς Ἀγριππίνα, θαυματουργίας φοβεράς, ἐπιτελοῦσα τῇ θείᾳ χάριτι· κατέπαυσας ἐν τόπῳ δέ, ἐν ᾧ Θεὸς ᾠκονόμησε, κεκμηκότων ἀνάπαυσις, γενομένη πανεύφημε."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticTheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.greekname
meVE.SticTheotokion.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.SticTheotokion.incipit = "Σὲ τὸ καθαρώτατον…"
meVE.SticTheotokion.text = "Σὲ τὸ καθαρώτατον, τοῦ Βασιλέως παλάτιον, δυσωπῶ πολυΰμνητε· Τὸν νοῦν μου καθάρισον, τὸν ἐσπιλωμένον, πάσαις ἁμαρτίαις, καὶ καταγώγιον τερπνόν, τῆς ὑπερθέου Τριάδος ποίησον, ὅπως τὴν μεσιτείαν σου, καὶ τὸ ἀμέτρητον ἔλεος, μεγαλύνω σῳζόμενος, ὁ ἀχρεῖος ἱκέτης σου."

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticStavrotheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.greekname
meVE.SticStavrotheotokion.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.SticStavrotheotokion.incipit = me.m06.d06_gr_GR_cog.meVE.SticStavrotheotokion.incipit
meVE.SticStavrotheotokion.text = me.m06.d06_gr_GR_cog.meVE.SticStavrotheotokion.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.Apolytikion1ger.greekmelody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.greekname
meVE.Apolytikion1ger.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meVE.Apolytikion1ger.incipit = "Θείῳ Πνεύματι…"
meVE.Apolytikion1ger.text = "Θείῳ Πνεύματι, κραταιωθεῖσα, ἠνδραγάθησας, γενναιοφρόνως, Ἀγριππίνα παρθενίας ὀσφράδιον· ὅθεν Χριστοῦ δοξασθεῖσα τῇ χάριτι, πηγὰς θαυμάτων βλυστάνεις τοῖς πέρασι. Μάρτυς ἔνδοξε, Χριστὸν τὸν Θεὸν ἱκέτευε, δωρήσασθαι ἡμῖν τὸ μέγα ἔλεος."

meMA.C1.acrostic.title = "Ὁ Κανὼν τῆς Ἁγίας,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς, ἄνευ τῶν Θεοτοκίων·"
meMA.C1.acrostic.text = "Τὴν Χριστονύμφην Ἀγριππίνην αἰνέσω."
meMA.C1.poet = poets_gr_GR_cog.po.Theofanous
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaintW
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintW.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C11.greekmelody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.greekname
meMA.Ode1C11.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C11.incipit = "Τῷ φέγγει τῆς χάριτος, τῆς…"
meMA.Ode1C11.text = "Τῷ φέγγει τῆς χάριτος, τῆς ἀστραψάσης σοι ἄνωθεν, τὸν ζόφον ἀπέλασον τῆς ἀγνωσίας μου, καὶ παράσχου μοι, εὐχαῖς σου Ἀγριππίνα, χάριν ἀνυμνῆσαί σου, Μάρτυς τὰ θαύματα."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C12.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C12.incipit = "Ἡλίου φαιδρότερον, ὡς ἀληθῶς ἐξανέτειλας…"
meMA.Ode1C12.text = "Ἡλίου φαιδρότερον, ὡς ἀληθῶς ἐξανέτειλας, ἐν τῷ στερεώματι τῆς Ἐκκλησίας Χριστοῦ, καὶ κατηύγασας, ἀκτῖσι τῶν ἀγώνων, Μάρτυς καὶ θαυμάτων σου, κόσμου τὰ πέρατα."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C13.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C13.incipit = "Νυμφίον ἀθάνατον, τὸν ζωοδότην ποθήσασα…"
meMA.Ode1C13.text = "Νυμφίον ἀθάνατον, τὸν ζωοδότην ποθήσασα, ὡς μνῆστρα τὴν ἄθλησιν, τούτῳ προσήνεγκας, καὶ ἀντέλαβες, οὐρανῶν Βασιλείαν, καὶ στέφανον ἄφθαρτον, Μάρτυς ἀοίδιμε."

meMA.Ode1C14.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C14.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C14.incipit = "Χειρὶ τοῦ Δεσπότου σου, κυβερνωμένη…"
meMA.Ode1C14.text = "Χειρὶ τοῦ Δεσπότου σου, κυβερνωμένη διέπλευσας, τὴν ἄστατον θάλασσαν, τῆς ἀσεβείας σεμνή, καὶ προσώρμισας, λιμένι Ἀγριππίνα, τῆς ἄνω λαμπρότητος, θεομακάριστε."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C1T.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
meMA.Ode1C1T.incipit = "Παρθένε πανάμωμε, ἡ τὸν Σωτῆρα…"
meMA.Ode1C1T.text = "Παρθένε πανάμωμε, ἡ τὸν Σωτῆρα κυήσασα, καὶ τοῦτον ἀγκάλαις σου, θείαις κατέχουσα, κυριώνυμε, διάλυσον τὸν γνόφον, ψυχῆς μου καὶ φώτισον, ταύτην γεραίρειν σε."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.greekname
meMA.Ode3C11.melody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.name
meMA.Ode3C11.incipit = "Ῥάβδοις τυπτομένη ἔχαιρε, τούτοις τὰ…"
meMA.Ode3C11.text = "Ῥάβδοις τυπτομένη ἔχαιρε, τούτοις τὰ ὀστᾶ τῆς ἀσεβείας συντρίβουσα, καὶ βοῶσα· Τῆς σῆς οὐδέν με, ἀγαπήσεως χωρίσει Χριστέ."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C12.melody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.name
meMA.Ode3C12.incipit = "Ἵνα τῶν ἐχθρῶν τὴν γύμνωσιν…"
meMA.Ode3C12.text = "Ἵνα τῶν ἐχθρῶν τὴν γύμνωσιν, Μάρτυς στηλιτεύσης, τοῦ χιτῶνος γεγύμνωσαι· διὰ τοῦτο τῆς ἀφθαρσίας, τὴν στολὴν Χριστός σοι δίδωσι."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C13.melody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.name
meMA.Ode3C13.incipit = "Στόμα τὸ λαλοῦν παράνομα, τῆς…"
meMA.Ode3C13.text = "Στόμα τὸ λαλοῦν παράνομα, τῆς εὐνομωτάτης, κατὰ σοῦ Χριστομάρτυρος, ἐνεφράγη, τὰ μεγαλεῖα τοῦ Σωτῆρος κηρυττούσης σου."

meMA.Ode3C14.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C14.melody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.name
meMA.Ode3C14.incipit = "Τείνας ἐπὶ γῆς τὸ σῶμά…"
meMA.Ode3C14.text = "Τείνας ἐπὶ γῆς τὸ σῶμά σου, ὁ τῆς ἀσεβείας ὑπουργὸς μεματαίωται, τεταμένην πρὸς τὸν Δεσπότην, τὴν διάνοιαν ἐχούσης σου."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C1T.melody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.name
meMA.Ode3C1T.incipit = "Ῥῆσις εὐσεβὴς πεπλήρωται, ἡ τοῦ…"
meMA.Ode3C1T.text = "Ῥῆσις εὐσεβὴς πεπλήρωται, ἡ τοῦ Ἠσαΐου· Παρθένος γὰρ τέτοκε, σαρκωθέντα τὸν ζωοδότην, καὶ Σωτῆρα τῶν ψυχῶν ἡμῶν."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3H.greekmelody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.greekname
meMA.Ode3H.melody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.melody
meMA.Ode3H.incipit = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.incipit
meMA.Ode3H.text = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3Kathisma1.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
meMA.Ode3Kathisma1.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Ode3Kathisma1.incipit = "Τὸν ὡραιότατον Χριστὸν ἀγαπήσασα, καὶ…"
meMA.Ode3Kathisma1.text = "Τὸν ὡραιότατον Χριστὸν ἀγαπήσασα, καὶ παρθενίᾳ τὴν ψυχὴν ὡραΐσασα, διὰ παντοίων πόνων τε καὶ θλίψεων, τούτῳ κατηγγύησαι, ὡς Παρθένος καὶ Μάρτυς· ὅθεν σε ἠξίωσεν, οὐρανίων θαλάμων, ὑπὲρ ἡμῶν πρεσβεύουσαν αὐτῷ, τῶν σὲ τιμώντων, σεμνὴ παμμακάριστε."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaT.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Ode3KathismaT.incipit = ho.ho23_gr_GR_cog.hoCA.Apolytikion1.incipit
meMA.Ode3KathismaT.text = ho.ho23_gr_GR_cog.hoCA.Apolytikion1.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaSt.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Ode3KathismaSt.incipit = "Τὸν ἐξ ἀνάρχου τοῦ Πατρὸς…"
meMA.Ode3KathismaSt.text = "Τὸν ἐξ ἀνάρχου τοῦ Πατρὸς γεννηθέντα, ἡ ἐπʼ ἐσχάτων σε σαρκὶ τετοκυῖα, ἐπὶ Σταυροῦ κρεμάμενον ὁρῶσά σε Χριστέ. Οἴμοι! ποθεινότατε, Ἰησοῦ ἀνεβόα· πῶς ὁ δοξαζόμενος, ὡς Θεὸς ὑπʼ Ἀγγέλων, ὑπὸ ἀνόμων νῦν βροτῶν Υἱέ, θέλων σταυροῦσαι; Ὑμνῶ σε μακρόθυμε."

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.greekname
meMA.Ode4C11.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C11.incipit = "Ὁ τὸ θέλημα τῶν τοῦτον…"
meMA.Ode4C11.text = "Ὁ τὸ θέλημα τῶν τοῦτον, φοβουμένων ποιούμενος, διʼ Ἀγγέλου Μάρτυς, λύει σε δεσμῶν καὶ στρεβλώσεων, τὴν διαλύσασαν πᾶσαν τὴν ἀσέβειαν, τῷ δεσμῷ τῆς ἀγάπης Χριστοῦ τοῦ νυμφίου σου."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C12.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C12.incipit = "Νεκρωθεῖσα διʼ ἀγάπην, τοῦ νεκρώσαντος…"
meMA.Ode4C12.text = "Νεκρωθεῖσα διʼ ἀγάπην, τοῦ νεκρώσαντος ἅπασαν, τὴν ἰσχὺν θανάτου, χάριν ἀναβλύζεις ἀείζωον, τοὺς ἐκ παθῶν νεκρωθέντας θεραπεύουσα, Ἀγριππίνα, Μαρτύρων Χριστοῦ ἐγκαλλώπισμα."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C13.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C13.incipit = "Ὑπερβᾶσα τῇ ἀγάπῃ, τοῦ νυμφίου…"
meMA.Ode4C13.text = "Ὑπερβᾶσα τῇ ἀγάπῃ, τοῦ νυμφίου σου ἅπαντα, τῆς σαρκὸς τὸν πόθον, ἔφερες στεῤῥῶς ἐν τῷ τύπτεσθαι, τὰς ἀλγηδόνας βοῶσα· Οὐ χωρίσει με, τῆς στοργῆς σου Χριστέ, τῶν παθῶν ἡ ἐπίτασις."

meMA.Ode4C14.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C14.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C14.incipit = "Μακαρίας ξυνωρίδος, τῆς Τριάδος τῷ…"
meMA.Ode4C14.text = "Μακαρίας ξυνωρίδος, τῆς Τριάδος τῷ ἔρωτι, ὑπεραθλησάσης, Βάσσης Ἀγριππίνης τε σώφρονος, τίς τὴν ἀνδρείαν ἐξείποι; ὅπως ἔδειξαν, ἀδρανῆ τῶν εἰδώλων ἰσχύν κραταιότατα."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C1T.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C1T.incipit = "Ἡ Βασίλισσα Παρθένος, διαχρύσῳ στολίσματι…"
meMA.Ode4C1T.text = "Ἡ Βασίλισσα Παρθένος, διαχρύσῳ στολίσματι, ὡραϊζομένη, Υἱῷ Βασιλεῖ νῦν παρίσταται, ἡ ἀσυγκρίτως Ἀγγέλους ὑπερέχουσα, τοὺς κραυγάζοντας· Δόξα Χριστὲ τῇ δυνάμει σου."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C11.greekmelody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.greekname
meMA.Ode5C11.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C11.incipit = "Φῶς ἄδυτον τῷ σῷ, ἐνσκηνῶσαν…"
meMA.Ode5C11.text = "Φῶς ἄδυτον τῷ σῷ, ἐνσκηνῶσαν σκηνώματι, ἐδείκνυ σε τοῖς ὁρῶσιν, ἐν νυκτὶ ὡς ἡμέραν, βολὰς θαυμάτων πέμπουσαν."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C12.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C12.incipit = "Ἡ ἄσπιλος ἀμνάς, τοῦ ποιμένος…"
meMA.Ode5C12.text = "Ἡ ἄσπιλος ἀμνάς, τοῦ ποιμένος τοῖς ἴχνεσι, βαδίζουσα ἱερεῖον, ὥσπερ ἄμωμον τούτῳ, ἐνθέως προσενήνεκται."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C13.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C13.incipit = "Νοῦν ἔχουσα φωτός, προφητείας ἀνάπλεων…"
meMA.Ode5C13.text = "Νοῦν ἔχουσα φωτός, προφητείας ἀνάπλεων, τὰ μέλλοντα, ὡς παρόντα, ἡ ἀοίδιμος Βάσσα, προλέγειν κατηξίωται."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C1T.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C1T.incipit = "Ὦ Μῆτερ τοῦ Θεοῦ, τῆς…"
meMA.Ode5C1T.text = "Ὦ Μῆτερ τοῦ Θεοῦ, τῆς ψυχῆς μου τὴν κάκωσιν, θεράπευσον ἡ τεκοῦσα, τὸν πανάγαθον Λόγον, τὸν πάντας ἀγαθύνοντα."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.greekname
meMA.Ode6C11.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C11.incipit = "Ἀστράψαν, ἐκ τῆς Ῥώμης ὡς…"
meMA.Ode6C11.text = "Ἀστράψαν, ἐκ τῆς Ῥώμης ὡς ἄδυτον ἥλιον, ἡ Σικελία τὸ σῶμα, τῆς Ἁγίας Μάρτυρος δεξαμένη, τῆς ζοφώδους, τῶν δαιμόνων λυτροῦται δεινότητος."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C12.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C12.incipit = "Γενναίως, αἱ τρισόλβιοι Ἅγιαι Μαρτυρες…"
meMA.Ode6C12.text = "Γενναίως, αἱ τρισόλβιοι Ἅγιαι Μαρτυρες, αἱ πρὸ θανάτου θανοῦσαι, ἐν τῇ προσδοκίᾳ τοῦ μαρτυρίου, νεκρωθέν σου, ζωηφόρον τὸ σῶμα κομίζουσι."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C13.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C13.incipit = "Ῥομφαῖαι, τοῦ ἐχθροῦ ἐπὶ σὲ…"
meMA.Ode6C13.text = "Ῥομφαῖαι, τοῦ ἐχθροῦ ἐπὶ σὲ ἐξησθένησαν· καὶ γὰρ ὡς πόλεις καθεῖλες, ἀθεμελιώτους τούτου τὰ θράση, Ἀγριππίνα, τῷ μοχλῷ τῶν ἐνδόξων ἀγώνων σου."

meMA.Ode6C14.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C14.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C14.incipit = "Ἰᾶται, τῇ προσψαύσει αἱμόῤῥους τοῦ…"
meMA.Ode6C14.text = "Ἰᾶται, τῇ προσψαύσει αἱμόῤῥους τοῦ, σκήνους σου, λεπροὶ καθαίρονται πίστει· δραπετεύει ἄλλη δὲ πᾶσα νόσος, τῇ προσκλήσει, τοῦ Ἁγίου σου Μάρτυς ὀνόματος."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C1T.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C1T.incipit = "Ῥήμασι, τοῦ Γαβριὴλ Παρθένε πανάμωμε…"
meMA.Ode6C1T.text = "Ῥήμασι, τοῦ Γαβριὴλ Παρθένε πανάμωμε, νῦν κεχρημένοι βοῶμεν· Χαῖρε Μήτηρ μόνη εὐλογημένη, Χαῖρε πύλη, δικαιοσύνης ἥλιον ἔχουσα."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6H.greekmelody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.greekname
meMA.Ode6H.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.melody
meMA.Ode6H.incipit = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.incipit
meMA.Ode6H.text = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.text

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ODiasosasEnPyri.greekname
meMA.Ode7C11.melody = he.h.m4_gr_GR_cog.heHE.ODiasosasEnPyri.name
meMA.Ode7C11.incipit = "Περιστερὰ οἷα χρυσῆ, ὅπλῳ τοῦ…"
meMA.Ode7C11.text = "Περιστερὰ οἷα χρυσῆ, ὅπλῳ τοῦ Σταυροῦ φραττομένη, Ἀγαρηνοὺς τοὺς ἐν νυκτί, τῷ φρουρίῳ τῷ σῷ προσεγγίσαντας, ἐξηφάνισας σώσασα, τοὺς πιστοὺς μιαιφονίας, τῆς τούτων Μάρτυς."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C12.melody = he.h.m4_gr_GR_cog.heHE.ODiasosasEnPyri.name
meMA.Ode7C12.incipit = "Πολυειδεῖς διά, Χριστόν, πόνους ὑπομείνασα…"
meMA.Ode7C12.text = "Πολυειδεῖς διά, Χριστόν, πόνους ὑπομείνασα Μάρτυς, ἄπονον εὗρες ἐν αὐτῷ, καὶ ἀθάνατον λῆξιν κραυγάζουσα· Ὑπερύμνητε Κύριε, ὁ Θεὸς ὁ τῶν Πατέρων εὐλογητός εἶ."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C13.melody = he.h.m4_gr_GR_cog.heHE.ODiasosasEnPyri.name
meMA.Ode7C13.incipit = "Ἱερουργὸς ὁ θαυμαστός, καὶ θαυματουργίαις…"
meMA.Ode7C13.text = "Ἱερουργὸς ὁ θαυμαστός, καὶ θαυματουργίαις ἐκλάμπων, σοῦ τὰ θαυμάσια ὁρῶν, Ἀγριππίνα Θεὸν ἐμεγάλυνε, καὶ γηθόμενος ἔψαλλεν· ὁ Θεὸς ὁ τῶν Πατέρων εὐλογητός εἶ."

meMA.Ode7C14.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C14.melody = he.h.m4_gr_GR_cog.heHE.ODiasosasEnPyri.name
meMA.Ode7C14.incipit = "Νενευρωμένῳ λογισμῷ, σοῦ τὸ ῥωστικὸν…"
meMA.Ode7C14.text = "Νενευρωμένῳ λογισμῷ, σοῦ τὸ ῥωστικὸν παθημάτων, διακομίζουσαι σῶμα, γυναικείας οὐδόλως ᾐσθάνοντο, ἀσθενείας κραυγάζουσαι, αἱ παρθένοι τῷ Δεσπότῃ· Εὐλογητός εἶ."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C1T.melody = he.h.m4_gr_GR_cog.heHE.ODiasosasEnPyri.name
meMA.Ode7C1T.incipit = "Κυοφορήσασα Θεόν, μένεις μετὰ τόκον…"
meMA.Ode7C1T.text = "Κυοφορήσασα Θεόν, μένεις μετὰ τόκον παρθένος, καὶ γαλουχεῖς μητροπρεπῶς, τὸν τροφέα τοῦ κόσμου Πανάμωμε, ὃν ὑμνοῦντες κραυγάζομεν· ὁ Θεὸς ὁ τῶν Πατέρων εὐλογητὸς εἶ."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C11.greekmelody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.greekname
meMA.Ode8C11.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
meMA.Ode8C11.incipit = "Ἡ νὺξ ὡς ἡμέρα καθωρᾶτο…"
meMA.Ode8C11.text = "Ἡ νὺξ ὡς ἡμέρα καθωρᾶτο, τοῖς φέρουσι Μάρτυς σου τὸ λείψανον, τόπος εὐωδίαστος, ἅπας σε δεχόμενος, δαιμονικὴ παράταξις, σφοδρῶς ἠλαύνετο, ἰάσεων ἀπέῤῥει πλημμύρα, τοῖς ὑπερυψοῦσι, Χριστὸν εἰς τοὺς αἰῶνας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C12.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
meMA.Ode8C12.incipit = "Νυμφίον ἀθάνατον ποθοῦσα, ὀπίσω τῶν…"
meMA.Ode8C12.text = "Νυμφίον ἀθάνατον ποθοῦσα, ὀπίσω τῶν μύρων τούτου ἔδραμες, τούτου τὰ παθήματα, Μάρτυς καὶ τὸν θάνατον, ἐκμιμουμένη ἔνδοξε, καὶ ἀνακράζουσα· Τὸν Κύριον ὑμνεῖτε τὰ ἔργα, καὶ ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C13.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
meMA.Ode8C13.incipit = "Ἀνύστακτον ἔχουσα τὴν πίστιν, ἐλαίῳ…"
meMA.Ode8C13.text = "Ἀνύστακτον ἔχουσα τὴν πίστιν, ἐλαίῳ τε φαιδρυνθεῖσαν τῶν αἱμάτων σου, Μάρτυς τὴν λαμπάδα σου, ἔνδον εἰσελήλυθας, εἰς τὸν νυμφῶνα χαίρουσα, τῆς οὐρανίου χαρᾶς. Τὸν Κύριον ὑμνεῖτε βοῶσα, καὶ ὑπερυψοῦτε, αὐτὸν εἰς τοὺς αἰῶνας."

meMA.Ode8C14.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C14.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
meMA.Ode8C14.incipit = "Ἰδεῖν τὴν τερπνότητα Κυρίου, τὸν…"
meMA.Ode8C14.text = "Ἰδεῖν τὴν τερπνότητα Κυρίου, τὸν τούτου ναόν τε ἐπισκέψασθαι, ποθοῦσα ὡς ἅρματι, αἵματι οἰκείῳ σύ, ἐποχουμένη ψάλλουσα πρὸς τοῦτον ἔφθασας· Τὸν Κύριον ὑμνεῖτε τὰ ἔργα, καὶ ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C1T.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
meMA.Ode8C1T.incipit = "Ἡ βάτος τὸ πρὶν προδιετύπου…"
meMA.Ode8C1T.text = "Ἡ βάτος τὸ πρὶν προδιετύπου, τὸ ξένον τοῦ τόκου σου μυστήριον, ἄκαυστος τῷ φλέγεσθαι, μένουσα πανάμωμε· καὶ γὰρ τὸ πῦρ ἐκύησας, τὸ τῆς Θεότητος, καὶ ἄφλεκτος διέμεινας Κόρη· ὅθεν σε ὑμνοῦμεν, πιστοὶ εἰς τοὺς αἰῶνας."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8H.greekmelody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.greekname
meMA.Ode8H.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.melody
meMA.Ode8H.incipit = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.incipit
meMA.Ode8H.text = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C11.greekmelody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.greekname
meMA.Ode9C11.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C11.incipit = "Νεύσει τοῦ τὰ πάντα ποιοῦντος…"
meMA.Ode9C11.text = "Νεύσει τοῦ τὰ πάντα ποιοῦντος, τοῦ μαρτυρίου πρὸς τὸ πέρας, ἡ Ἀγαθονίκη σὺν Βάσσᾳ, ὁμοῦ καὶ Παῦλα προθύμως σπεύδουσαι, ὡς ἀληθῶς κατάλληλον, εὗρον τοῦ πόθου τὸ συμπέρασμα."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C12.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C12.incipit = "Ἐν ἐπουρανίοις θαλάμοις, κατασκηνώσασα Παρθένε…"
meMA.Ode9C12.text = "Ἐν ἐπουρανίοις θαλάμοις, κατασκηνώσασα Παρθένε, καὶ τῶν ἀθεάτων τὰ κάλλη, κατανοοῦσα καὶ ἀπολαύουσα, τῆς τοῦ Θεοῦ λαμπρότητος, τοὺς σὲ ὑμνοῦντας καταφαίδρυνον."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C13.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C13.incipit = "Στέφανος ἐτέθη χαρίτων, τῇ κορυφῇ…"
meMA.Ode9C13.text = "Στέφανος ἐτέθη χαρίτων, τῇ κορυφῇ σου Ἀγριππίνα, ὡς τελειωσάσης τὸν δρόμον, καὶ τηρησάσης τὴν πίστην ἄσυλον, καὶ τῶν δικαίων τάγματα, περιχαρῶς σε ὑπεδέξαντο."

meMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C14.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C14.incipit = "Ὡς παρισταμένη τῷ θρόνῳ, ἐν…"
meMA.Ode9C14.text = "Ὡς παρισταμένη τῷ θρόνῳ, ἐν παῤῥησίᾳ τοῦ Δεσπότου, μάρτυς Ἀγριππίνα σὺν πᾶσι, τοῖς ἀπʼ αἰῶνος Ἁγίοις αἴτησαι, ἁμαρτιῶν τὴν λύτρωσιν, τοῖς σὲ ὑμνοῦσι καλλιπάρθενε."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C1T.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C1T.incipit = "Ὡς τὸν τοῦ παντὸς δεδραγμένον…"
meMA.Ode9C1T.text = "Ὡς τὸν τοῦ παντὸς δεδραγμένον, μητροπρεπῶς ταῖς σαῖς ἀγκάλαις, φέρουσα Παρθένε Μαρία, χειρός με ῥῦσαι τοῦ πολεμήτορος, ὅπως τὴν σὴν σῳζόμενος, ἀνευφημῶ μεγαλειότητα."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9H.greekmelody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.greekname
meMA.Ode9H.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.melody
meMA.Ode9H.incipit = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.incipit
meMA.Ode9H.text = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.text

meLI.MM.CommunionHymn.text = properties_gr_GR_cog.media.key

meLI.Megalynarion.text = ""

