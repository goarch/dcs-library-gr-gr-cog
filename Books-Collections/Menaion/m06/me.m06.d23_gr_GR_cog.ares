A_Resource_Whose_Name = me.m06.d23_gr_GR_cog

meDA.date = "Τῌ ΚΓʹ ΙΟΥΝΙΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
meDA.commemoration.full = "Μνήμη τῆς Ἁγίας Μάρτυρος Ἀγριππίνης" //full title of day
meDA.commemoration.first = "Μνήμη τῆς Ἁγίας Μάρτυρος Ἀγριππίνης"
meDA.commemoration.first_short = "Μνήμη τῆς Ἁγίας Μάρτυρος Ἀγριππίνης"
meDA.commemoration.first_title = titles_gr_GR_cog.ti.SaintW
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = ""
meDA.commemoration.second_name = ""
