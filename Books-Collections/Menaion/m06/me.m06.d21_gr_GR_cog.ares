meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera01.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera01.incipit = "Φωταυγῆ σε ὡς ἥλιον…"
meVE.Stichera01.text = "Φωταυγῆ σε ὡς ἥλιον, τὰ τοῦ κόσμου πληρώματα, νοηταῖς λαμπρότησι καταυγάζοντα, καὶ ἀθεΐας ἐξαίροντα, τὴν νύκτα μακάριε, Μάρτυς Ἰουλιανέ, ἐγνωκότες τὴν μνήμην σου, ἑορτάζομεν, τὴν φωσφόρον καὶ θείαν· καὶ τὴν κόνιν, τῶν λειψάνων προσκυνοῦμεν, ῥῶσιν ψυχῶν ἀρυόμενοι."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera02.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera02.incipit = "Καὶ τυπτόμενος…"
meVE.Stichera02.text = "Καὶ τυπτόμενος μάστιξι, καὶ δεινῶς πτερνιζόμενος, καὶ φρουρᾷ μακάριε καθειργνύμενος, τόπους ἀμείβων θλιβόμενος, θηρσὶ συγκλειόμενος, καὶ βυθῷ προσομιλῶν, καὶ θαλάσσῃ ποντούμενος, καὶ δεξάμενος, τὸ μακάριον τέλος, οὐκ ἠρνήσω, τὸν Δεσπότην τῶν ἁπάντων, κλέος Μαρτύρων πανόλβιε."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera03.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera03.incipit = "Θαλαττίων ἐκ κόλπων…"
meVE.Stichera03.text = "Θαλαττίων ἐκ κόλπων σε, πρὸς τῇ χέρσῳ γενόμενον, κυβερνήσει Πνεύματος ὡς ἑώρακε, τὸ ἱερώτατον γύναιον, πιστῶς ὑπεδέξατο, Μάρτυς Ἰουλιανέ, καὶ ταφῇ παραδέδωκε, σοῦ τὸ ἄμωμον, καὶ πολύαθλον σῶμα, τὸ νικῆσαν, διαβόλου τυραννίδα, τῇ συνεργίᾳ τῆς χάριτος."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticTheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.SticTheotokion.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.SticTheotokion.incipit = me.m06.d09_gr_GR_cog.meVE.SticTheotokion.incipit
meVE.SticTheotokion.text = me.m06.d09_gr_GR_cog.meVE.SticTheotokion.text

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticStavrotheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.SticStavrotheotokion.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.SticStavrotheotokion.incipit = me.m02.d11_gr_GR_cog.meVE.AposStavrotheotokion.incipit
meVE.SticStavrotheotokion.text = me.m02.d11_gr_GR_cog.meVE.AposStavrotheotokion.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Apolytikion1ger.greekmelody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.greekname
meVE.Apolytikion1ger.melody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.name
meVE.Apolytikion1ger.incipit = "Μητρικαῖς ὑποθήκαις…"
meVE.Apolytikion1ger.text = "Μητρικαῖς ὑποθήκαις μυσταγωγούμενος, πανευκλεὴς στρατιώτης ὤφθης Χριστοῦ τοῦ Θεοῦ, παντευχίαν μυστικὴν περιζωσάμενος· ὅθεν καθεῖλες τὸν ἐχθρόν, ὡς γενναῖος ἀριεστεύς, καὶ ἤθλησας θεοφρόνως, Ἰουλιανὲ θεόφρον, ὑπὲρ ἡμῶν ἀεὶ πρεσβεύων Θεῷ."

meMA.C1.acrostic.title = "Ὁ Κανὼν τοῦ Ἁγίου,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς, ἄνευ τῶν Θεοτοκίων·"
meMA.C1.acrostic.text = "Ἰουλιανὸν ὕμνοισι Μάρτυρα στέφω."
meMA.C1.poet = poets_gr_GR_cog.po.IoannouMonachou
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaintM
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C11.greekmelody = he.h.m8_gr_GR_cog.heHE.AsomenToKyrio.greekname
meMA.Ode1C11.melody = he.h.m8_gr_GR_cog.heHE.AsomenToKyrio.name
meMA.Ode1C11.incipit = "Ἱεροῖς εὐφημείσθω…"
meMA.Ode1C11.text = "Ἱεροῖς εὐφημείσθω, ὕμνοις Ἀθλητά σου ἡ ἀοίδιμος, καὶ ὑπέρτιμος μνήμη· ἀπροσίτῳ γὰρ δόξῃ δεδόξασται."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C12.melody = he.h.m8_gr_GR_cog.heHE.AsomenToKyrio.name
meMA.Ode1C12.incipit = "Ὄλισθον οὐχ ὑπέστης…"
meMA.Ode1C12.text = "Ὄλισθον οὐχ ὑπέστης, διηγωνισμένος τὸ μαρτύριον, τοῦ Χριστοῦ στρατιῶτα, ἀσθενείᾳ σαρκὸς μέχρις αἵματος."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C13.melody = he.h.m8_gr_GR_cog.heHE.AsomenToKyrio.name
meMA.Ode1C13.incipit = "Ὑπὲρ αἴγλην χρυσίου…"
meMA.Ode1C13.text = "Ὑπὲρ αἴγλην χρυσίου, τοῖς μαρτυρικοῖς ἐναγλαΐζεται, αἰκισμοῖς ἀπαστράπτων, καὶ πολύτιμον λίθον ὁ Ἅγιος."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C1T.melody = he.h.m8_gr_GR_cog.heHE.AsomenToKyrio.name
meMA.Ode1C1T.incipit = "Ἄχραντε Θεοτόκε…"
meMA.Ode1C1T.text = "Ἄχραντε Θεοτόκε, ἡ σεσαρκωμένον τὸν ἀΐδιον, καὶ ὑπέρθεον Λόγον, ὑπὲρ φύσιν τεκοῦσα, ὑμνοῦμέν σε."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C11.greekmelody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.greekname
meMA.Ode3C11.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C11.incipit = "Λίθοις οὐ προστέταγμαι…"
meMA.Ode3C11.text = "Λίθοις οὐ προστέταγμαι, θεολατρεῖν χειρῶν ἔργοις, Ἰουλιανός, τῷ φρενοβλαβούντι, δικαστῇ ἀπεφθέγγετο."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C12.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C12.incipit = "Ἵστασο πρὸ βήματος…"
meMA.Ode3C12.text = "Ἵστασο πρὸ βήματος, τυραννικοῦ Χριστοῦ Μάρτυς, Ἰουλιανέ, ὡς Κριτῇ τῶν ζώντων, καὶ νεκρῶν παριστάμενος."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C13.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C13.incipit = "Ἄφρων οὐ γεγένημαι…"
meMA.Ode3C13.text = "Ἄφρων οὐ γεγένημαι, ὁμολογῶν Θεὸν ἔφη, Ἰουλιανός, ἕνα ἐν Τριάδι, ἀμερίστως ὑμνούμενον."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C1T.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C1T.incipit = "Δὸς ἡμῖν βοήθειαν…"
meMA.Ode3C1T.text = "Δὸς ἡμῖν βοήθειαν, ταῖς ἱκεσίαις σου Πάναγνε, τὰς προσβολάς, ἀποκρουομένη, τῶν δεινῶν περιστάσεων."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3H.greekmelody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.greekname
meMA.Ode3H.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.melody
meMA.Ode3H.incipit = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.incipit
meMA.Ode3H.text = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3Kathisma1.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meMA.Ode3Kathisma1.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Ode3Kathisma1.incipit = "Ὑδάτων πνιγμονῇ…"
meMA.Ode3Kathisma1.text = "Ὑδάτων πνιγμονῇ, τὸ μακάριον τέλος, δεξάμενος σοφέ, τὸν πολύμορφον ὄφιν, ἐν τούτοις ἐναπέπνιξας, καὶ τὴν νίκην ἀπείληφας· ὅθεν πόθῳ σου, τὴν ἀξιέπαινον μνήμην, ἑορτάζοντες, ὑπὲρ ἡμῶν σε πρεσβεύειν, Χριστῷ ἱκετεύομεν."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3KathismaT.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Ode3KathismaT.incipit = me.m03.d03_gr_GR_cog.meMA.Ode3KathismaT.incipit
meMA.Ode3KathismaT.text = me.m03.d03_gr_GR_cog.meMA.Ode3KathismaT.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3KathismaSt.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Ode3KathismaSt.incipit = me.m01.d19_gr_GR_cog.meMA.Ode3KathismaSt.incipit
meMA.Ode3KathismaSt.text = me.m01.d19_gr_GR_cog.meMA.Ode3KathismaSt.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C11.greekmelody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.greekname
meMA.Ode4C11.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C11.incipit = "Νιφετώδεσι μάστιξιν…"
meMA.Ode4C11.text = "Νιφετώδεσι μάστιξιν, Ἰουλιανὸς τὸ σῶμα προδίδωσιν· ἀνεπαίσθητος τῶν πόνων γάρ, τοῦ Χριστοῦ τῷ πόθῳ ἐφυλάττετο."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C12.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C12.incipit = "Οὐρανίου ὑπέρτιμε…"
meMA.Ode4C12.text = "Οὐρανίου ὑπέρτιμε, Ἰουλιανὲ χλιδῆς ἐφιέμενος, τοῖς διώκταις τὴν ἐπίγειον, ὡς Χριστοῦ θεράπων καταλέλοιπας."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C13.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C13.incipit = "Νικητὴν δεισιδαίμονος…"
meMA.Ode4C13.text = "Νικητὴν δεισιδαίμονος, πλάνης οὐ σαρκὸς ἡ ῥώμη πανέντιμε, ἀλλὰ πόθος ὁ ἀήττητος, τῶν Χριστοῦ παθῶν σε ἀπειργάσατο."

meMA.Ode4C14.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C14.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C14.incipit = "Ὑπερέπτης ὡς πτέρυξι…"
meMA.Ode4C14.text = "Ὑπερέπτης ὡς πτέρυξι, τοὺς τῆς ἀσεβείας βρόχους στεῤῥότητι, καὶ τοῦ Πνεύματος τῇ χάριτι, πρὸς σκηνὰς Μαρτύρων ἐπαγόμενος."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C1T.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C1T.incipit = "Θεοτόκον σε Πάναγνε…"
meMA.Ode4C1T.text = "Θεοτόκον σε Πάναγνε, οἱ πεφωτισμένοι πάντες κηρύττομεν· τὸν γὰρ Ἥλιον ἐκύησας, τῆς δικαιοσύνης ἀειπάρθενε."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C11.greekmelody = he.h.m8_gr_GR_cog.heHE.OrthrizontesVoomenSoi.greekname
meMA.Ode5C11.melody = he.h.m8_gr_GR_cog.heHE.OrthrizontesVoomenSoi.name
meMA.Ode5C11.incipit = "Μιμούμενος ἐν πᾶσι…"
meMA.Ode5C11.text = "Μιμούμενος ἐν πᾶσι πανεύφημε, τὸν Δεσπότην, ἔστης ἐπὶ βήματος, παρανομούντων κρινόμενος."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C12.melody = he.h.m8_gr_GR_cog.heHE.OrthrizontesVoomenSoi.name
meMA.Ode5C12.incipit = "Νομίμως ἠγωνίσω…"
meMA.Ode5C12.text = "Νομίμως ἠγωνίσω καὶ τέθυσαι, τῷ Δεσπότῃ, ὡς ἀρνίον ἄκακον, χερσὶν ἀνόμων μακάριε."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C13.melody = he.h.m8_gr_GR_cog.heHE.OrthrizontesVoomenSoi.name
meMA.Ode5C13.incipit = "Ὁσίως μαρτυρήσας…"
meMA.Ode5C13.text = "Ὁσίως μαρτυρήσας ἀοίδιμε, ἐπεγνώσθης, Ἰουλιανὲ μακάριε, ὑπὸ Θεοῦ παντοκράτορος."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C1T.melody = he.h.m8_gr_GR_cog.heHE.OrthrizontesVoomenSoi.name
meMA.Ode5C1T.incipit = "Παρθένον μετὰ τόκον…"
meMA.Ode5C1T.text = "Παρθένον μετὰ τόκον ὑμνοῦμέν σε, Θεοτόκε· σὺ γὰρ τὸν Θεὸν Λόγον, σαρκὶ τῷ κόσμῳ ἐκύησας."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C11.greekmelody = he.h.m8_gr_GR_cog.heHE.ChitonaMoiParaschou.greekname
meMA.Ode6C11.melody = he.h.m8_gr_GR_cog.heHE.ChitonaMoiParaschou.name
meMA.Ode6C11.incipit = "Ἰκρίῳ προσπαγέντος σου…"
meMA.Ode6C11.text = "Ἰκρίῳ προσπαγέντος σου Χριστέ, ὁ κλεινὸς θεράπων σου, οὐκ ἐπαισχύνεται, ἀλλʼ ὡς δόξης κοινωνὸς ἐναβρύνεται."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C12.melody = he.h.m8_gr_GR_cog.heHE.ChitonaMoiParaschou.name
meMA.Ode6C12.incipit = "Σεσίγηται τῆς πλάνης…"
meMA.Ode6C12.text = "Σεσίγηται τῆς πλάνης τὰ αἰσχρά, θεηγόρων γλώσσῃ δέ, θεῖα μυστήρια, τῶν Μαρτύρων τοῦ Χριστοῦ ἐκκαλύπτεται."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C13.melody = he.h.m8_gr_GR_cog.heHE.ChitonaMoiParaschou.name
meMA.Ode6C13.incipit = "Ἰάματα παθῶν…"
meMA.Ode6C13.text = "Ἰάματα παθῶν παντοδαπῶν, καὶ πταισμάτων ἄφεσιν, αἴτησαι ἔνδοξε, Ἀθλητὰ τοῦ Σωτῆρος τοῖς ὑμνοῦσί σε."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C1T.melody = he.h.m8_gr_GR_cog.heHE.ChitonaMoiParaschou.name
meMA.Ode6C1T.incipit = "Ὁ Λόγος τοῦ Θεοῦ…"
meMA.Ode6C1T.text = "Ὁ Λόγος τοῦ Θεοῦ σε τοῖς βροτοῖς, Θεοτόκε ἔδειξεν, οὐράνιον κλίμακα· διὰ σοῦ γὰρ πρὸς ἡμᾶς καταβέβηκε."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6H.greekmelody = he.h.m8_gr_GR_cog.heHE.ChitonaMoiParaschou.greekname
meMA.Ode6H.melody = he.h.m8_gr_GR_cog.heHE.ChitonaMoiParaschou.melody
meMA.Ode6H.incipit = he.h.m8_gr_GR_cog.heHE.ChitonaMoiParaschou.incipit
meMA.Ode6H.text = he.h.m8_gr_GR_cog.heHE.ChitonaMoiParaschou.text

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C11.greekmelody = he.h.m8_gr_GR_cog.heHE.PaidesEvraion.greekname
meMA.Ode7C11.melody = he.h.m8_gr_GR_cog.heHE.PaidesEvraion.name
meMA.Ode7C11.incipit = "Μύρον εὐῶδες…"
meMA.Ode7C11.text = "Μύρον εὐῶδες ἀποστάζει, ἡ ἀοίδιμος καὶ ἔνδοξός σου μνήμη, στρατιῶτα Χριστοῦ, τοῖς ψάλλουσιν ἀπαύστως· Εὐλογητὸς εἶ Κύριε, ὁ Θεὸς εἰς τοὺς αἰῶνας."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C12.melody = he.h.m8_gr_GR_cog.heHE.PaidesEvraion.name
meMA.Ode7C12.incipit = "Ἄῤῥητος δόξα…"
meMA.Ode7C12.text = "Ἄῤῥητος δόξα περιστέφει, τοὺς πρὸς αἴνεσιν τὴν σὴν συνειλεγμένους, στρατιῶτα Χριστοῦ, καὶ ψάλλοντας ἀπαύστως· Εὐλογητὸς εἶ Κύριε, ὁ Θεὸς εἰς τοὺς αἰῶνας."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C13.melody = he.h.m8_gr_GR_cog.heHE.PaidesEvraion.name
meMA.Ode7C13.incipit = "Ῥήσει τυράννου…"
meMA.Ode7C13.text = "Ῥήσει τυράννου ἀπειθήσας, οὐκ ἐλάτρευσας ἀοίδιμε τῇ κτίσει, ἀλλʼ ἢ μόνῳ Θεῷ, τῷ ζῶντι ἀναμέλπων· Εὐλογητὸς εἶ Κύριε, ὁ Θεὸς εἰς τοὺς αἰῶνας."

meMA.Ode7C14.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C14.melody = he.h.m8_gr_GR_cog.heHE.PaidesEvraion.name
meMA.Ode7C14.incipit = "Τῦφον κατέβαλες…"
meMA.Ode7C14.text = "Τῦφον κατέβαλες τυράννου, στηλιτεύσας τὴν ἀνόμων ἀφροσύνην, καὶ τὴν δόξαν Χριστοῦ, ἐκήρυττες κραυγάζων· Εὐλογητὸς εἶ Κύριε, ὁ Θεὸς εἰς τοὺς αἰῶνας."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C1T.melody = he.h.m8_gr_GR_cog.heHE.PaidesEvraion.name
meMA.Ode7C1T.incipit = "Χαίροις πανάμωμε…"
meMA.Ode7C1T.text = "Χαίροις πανάμωμε Παρθένε, ὅτι ἔτεκες Θεὸν σαρκὶ τῷ κόσμῳ, τὸν ἐκ πλάνης ἁγνή, λυτρούμενον τοὺς πίστει, σὲ Θεοτόκον Δέσποινα, ἀληθῆ δοξολογοῦντας."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C11.greekmelody = he.h.m8_gr_GR_cog.heHE.MousikonOrganon.greekname
meMA.Ode8C11.melody = he.h.m8_gr_GR_cog.heHE.MousikonOrganon.name
meMA.Ode8C11.incipit = "Ὑπεθώπευε μὲν ὁ ἀλάστωρ…"
meMA.Ode8C11.text = "Ὑπεθώπευε μὲν ὁ ἀλάστωρ, καὶ βασάνοις σε ἐξεκαλεῖτο, πρὸς πλάνην Ἰουλιανέ· αὐτὸς δὲ ἀνεβόας· Τὸν Κύριον ὑμνεῖτε, καὶ ὑπερυψοῦτε εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C12.melody = he.h.m8_gr_GR_cog.heHE.MousikonOrganon.name
meMA.Ode8C12.incipit = "Ῥωμαλεωτέρως ὥσπερ…"
meMA.Ode8C12.text = "Ῥωμαλεωτέρως ὥσπερ λέων, μετὰ τὰς αἰκίας τοῖς τυράννοις, προσβάλλεις Ἰουλιανέ, κραυγάζων νηφαλέως· Τὸν Κύριον ὑμνεῖτε, καὶ ὑπερυψοῦτε εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C13.melody = he.h.m8_gr_GR_cog.heHE.MousikonOrganon.name
meMA.Ode8C13.incipit = "Ἀρετῆς ἁπάσης…"
meMA.Ode8C13.text = "Ἀρετῆς ἁπάσης ἔμπνους στήλη, ἀσεβείας θρίαμβος ὡράθης, ἐν πόλεσι περιαχθείς, ἐβόας ἀναμέλπων· Τὸν Κύριον ὑμνεῖτε, καὶ ὑπερυψοῦτε εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C14.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C14.melody = he.h.m8_gr_GR_cog.heHE.MousikonOrganon.name
meMA.Ode8C14.incipit = "Σοβαροῦ πυρὸς…"
meMA.Ode8C14.text = "Σοβαροῦ πυρὸς οὐκ ἀπειλή με, ουδʼ ἀκμὴ τοῦ ξίφους ἀποστήσει, τοῦ πλαστουργήσαντος Θεοῦ, ἐβόας ἀναμέλπων· Τὸν Κύριον ὑμνεῖτε, καὶ ὑπερυψοῦτε εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C1T.melody = he.h.m8_gr_GR_cog.heHE.MousikonOrganon.name
meMA.Ode8C1T.incipit = "Ὡς τῶν ὅλων…"
meMA.Ode8C1T.text = "Ὡς τῶν ὅλων Κύριον τεκοῦσα, καὶ Παρθένος μείνασα Μαρία, καὶ μετὰ τόκον οἱ πιστοί, ἀξίως ἀνυμνοῦντες, τὸ Χαῖρε σοι βοῶμεν, καὶ ὑπερυψοῦμεν εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8H.greekmelody = he.h.m8_gr_GR_cog.heHE.MousikonOrganon.greekname
meMA.Ode8H.melody = he.h.m8_gr_GR_cog.heHE.MousikonOrganon.melody
meMA.Ode8H.incipit = he.h.m8_gr_GR_cog.heHE.MousikonOrganon.incipit
meMA.Ode8H.text = he.h.m8_gr_GR_cog.heHE.MousikonOrganon.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C11.greekmelody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.greekname
meMA.Ode9C11.melody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.name
meMA.Ode9C11.incipit = "Τοῦ τυράννου τύφον…"
meMA.Ode9C11.text = "Τοῦ τυράννου τύφον κατέβαλες, Χριστοῦ στρατιῶτα, καὶ ἀνδρείως ἠγώνισαι κατὰ κράτος, ἐκνευρίσας τοῦτον· διό σε μακαρίζομεν."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C12.melody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.name
meMA.Ode9C12.incipit = "Ἐπηρμένον ὄμμα…"
meMA.Ode9C12.text = "Ἐπηρμένον ὄμμα κατέβαλες, Θεοῦ στρατιῶτα, ἀσωμάτου ἀλάστορος, προσπαλαίσας μετὰ σαρκὸς ἀνδρείως, Χριστὸν μεγαλύνων ἀεί."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C13.melody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.name
meMA.Ode9C13.incipit = "Φωλεοὺς ἐξέφυγες…"
meMA.Ode9C13.text = "Φωλεοὺς ἐξέφυγες δράκοντος, ἐχθροῦ ἀρχεκάκου, θαλαττίοις μακάριε κενεῶσιν, ἐμβεβλημένος· ὅθεν σε ὕμνοις μεγαλύνομεν."

meMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C14.melody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.name
meMA.Ode9C14.incipit = "Ὡς καλῶς…"
meMA.Ode9C14.text = "Ὡς καλῶς τοῖς ἄθλοις ἠγώνισαι, ὑπὲρ τοῦ Δεσπότου! ὡς ὡραίως κατέστεψαι, δεξιᾷ δεσποτικῇ! διό σε ἀξίως μεγαλύνομεν."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C1T.melody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.name
meMA.Ode9C1T.incipit = "Ὁ Μωσῆς ἐν βάτῳ…"
meMA.Ode9C1T.text = "Ὁ Μωσῆς ἐν βάτῳ κατεῖδέ σε, Ἁγνὴ ἐν τῷ ὄρει, δεχομένην τὸ ἄστεκτον, τῆς Θεότητος πῦρ ἀφλέκτως· ὅθεν σε πάντες μεγαλύνομεν."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9H.greekmelody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.greekname
meMA.Ode9H.melody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.melody
meMA.Ode9H.incipit = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.incipit
meMA.Ode9H.text = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.text

