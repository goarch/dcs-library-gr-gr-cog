meDA.pdfheaderdate = "τῆς 21ης Ἰουνίου"
meDA.fordate = "διὰ τὴν 21ην Ἰουνίου"
meLE.commemoration1 = "Μνήμη τοῦ Ἁγίου Μάρτυρος Ἰουλιανοῦ τοῦ Ταρσέως."
meLE.commemoration2 = ""
