A_Resource_Whose_Name = me.m06.d17_gr_GR_cog

meDA.date = "Τῌ ΙΖʹ ΙΟΥΝΙΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
meDA.commemoration.full = "Μνήμη τῶν Ἁγίων Μαρτύρων, Ἰσαύρου, Βασιλείου, Ἰννοκεντίου, Ἑρμείου, Φήλικος καὶ Περεγρίνου· καὶ τῶν Ἁγίων Μαρτύρων, Μανουήλ, Σαβὲλ καὶ Ἰσμαήλ." // full title of day
meDA.commemoration.first = "Μνήμη τῶν Ἁγίων Μαρτύρων, Ἰσαύρου, Βασιλείου, Ἰννοκεντίου, Ἑρμείου, Φήλικος καὶ Περεγρίνου"
meDA.commemoration.first_short = "Μνήμη τῶν Ἁγίων Μαρτύρων, Ἰσαύρου, Βασιλείου, Ἰννοκεντίου, Ἑρμείου, Φήλικος καὶ Περεγρίνου"
meDA.commemoration.first_title = "Τοῦ Ἁγ. Ἰσαύρου καὶ τῶν σὺν αὐτῷ."
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = "Τῶν Ἁγ. Μανουὴλ καὶ τῶν σὺν αὐτῷ."
meDA.commemoration.second_name = ""
meDA.insert1 = "τῶν Ἁγίων Μαρτύρων, Ἰσαύρου καὶ Μανουήλ, καὶ τῶν σὺν αὐτοῖς," // for use in petitions and dismissal
meDA.insert2 = "ὧν καὶ τὴν μνήμην ἐπιτελοῦμεν·" // for use in petitions and dismissal
meDA.note = ""
meDA.pdfcoverdate = "τῆς 17ης Ἰουνίου,"
meDA.pdfdatebefore = "τῆς 16ης Ἰουνίου"
meDA.pdfheaderdate = "τῆς 17ης Ἰουνίου"
meDA.fordate = "διὰ τὴν 17ην Ἰουνίου"
meLE.commemoration1 = "Τῶν Ἁγίων Μαρτύρων Μανουήλ, Σαβὲλ καὶ Ἰσμαήλ."
meLE.commemoration2 = ""
meHO.number = ""
meHO.rank = ""
meHO.commemorations = ""
meHO.note1 = ""
meHO.note2 = ""
meDA.dismissal = ""
meDA.dismissal.incipit = ""

meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.greekname
meVE.Stichera01.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera01.incipit = "Πόνοις συντριβόμενοι…"
meVE.Stichera01.text = "Πόνοις συντριβόμενοι, καὶ κακουχίαις στενούμενοι, καὶ εἱρκτῇ συγκλειόμενοι, ξίφεσι κοπτόμενοι, καὶ βιαιοτάτῳ, θνῄσκοντες θανάτῳ, οὐκ ἀπηρνήσασθε Χριστόν, οὐ τοῖς ξοάνοις σέβας ἐνείματε· διὸ καὶ ἠξιώθητε, τῆς οὐρανίου λαμπρότητος, δυσωποῦντες τὸν Κύριον, ὑπὲρ πάντων μακάριοι."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera02.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera02.incipit = "Ἴσαυρος ὁ ἔνδοξος…"
meVE.Stichera02.text = "Ἴσαυρος ὁ ἔνδοξος, καὶ ὁ στεῤῥὸς Ἰννοκέντιος, καὶ ὁ θεῖος Βασίλειος, Φῆλιξ ὁ θαυμάσιος, ὁ κλεινὸς Ἑρμείας, καὶ ὁ Περεγρῖνος, οἱ οὐρανώσαντες τὴν γῆν, ταῖς τῶν θαυμάτων θείαις λαμπρότησι, πιστῶς μακαριζέσθωσαν, ὡς τοῦ Κυρίου θεράποντες, καὶ τὰ πάθη διώκοντες, τῶν ψυχῶν ἡμῶν πάντοτε."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera03.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera03.incipit = "Κρήνη ἀναβλύζουσα…"
meVE.Stichera03.text = "Κρήνη ἀναβλύζουσα, τῶν ἰαμάτων χαρίσματα, ἡ σορὸς ὑμῶν δέδεικται, ἐξ ἧς ἀρυόμεθα, τῶν παθῶν ὑγείαν, καὶ τῶν νοσημάτων, τὴν παντελῆ ἀπαλλαγήν, ἀνευφημοῦντες ὑμᾶς ἑκάστοτε, σεπτοὶ Μεγαλομάρτυρες, τῶν Ἀσωμάτων ἐφάμιλλοι, τοῦ Κυρίου θεράποντες, πρεσβευταὶ τῶν ψυχῶν ἡμῶν."

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera04.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera04.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera04.incipit = "Ὡς ἀστέρες πολύφωτοι…"
meVE.Stichera04.text = "Ὡς ἀστέρες πολύφωτοι, Ἀθλοφόροι πανεύφημοι, θεϊκαῖς λαμπρότησι καταυγάζετε, τῆς οἰκουμένης τὰ πέρατα, δαιμόνων σκοτόμαιναν, καὶ παθῶν φθοροποιῶν, καὶ κινδύνων ἐξαίροντες· ὅθεν σήμερον, τὴν φαιδρὰν καὶ φωσφόρον καὶ ἁγίαν, συνελθόντες ἐκτελοῦμεν, ὑμῶν πανήγυριν ἔνδοξοι."

meVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera05.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera05.incipit = "Μανουὴλ ὁ θαυμάσιος…"
meVE.Stichera05.text = "Μανουὴλ ὁ θαυμάσιος, καὶ Σαβὲλ ὁ μακάριος, Ἰσμαὴλ ὁ πάνσοφος μελῳδήμασιν, ἱερωτάτοις τιμάσθωσαν, Τριάδα τὴν ἄκτιστον, ἐναντίον τῶν ἐχθρῶν, ἱερῶς προκηρύξαντες, καὶ πολύθεον, ἀποσβέσαντες πλάνην, τῶν αἱμάτων, ταῖς προσχύσεσι καὶ δόξαν, ἀπειληφότες ἀμάραντον."

meVE.Stichera06.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera06.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera06.incipit = "Βασιλέα παράνομον…"
meVE.Stichera06.text = "Βασιλέα παράνομον, παρανόμως προστάττοντα, ὑποκύπτειν σέβας τε νέμειν ἄλογον, θεοῖς ἀψύχοις μακάριοι, ἐμφρόνως ᾐσχύνατε, Μανουὴλ καὶ Ἰσμαήλ, καὶ Σαβὲλ μεγαλώνυμοι· καὶ ἀθλήσαντες, καρτερῶς καὶ νομίμως τοὺς στεφάνους, ἀνεπλέξασθε τῆς νίκης, ὑπὲρ τοῦ κόσμου πρεσβεύοντες."

meVE.SticGlory.poet = poets_gr_GR_cog.po.Anatoliou
meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Εἰλικρινῶς ποθήσαντές σε…"
meVE.SticGlory.text = "Εἰλικρινῶς ποθήσαντές σε Λόγε Θεοῦ, οἱ ἔνδοξοι Μάρτυρες, τὸ πυρσολατρεῖν ἐάσαντες, λιπόντες καὶ τὴν τῶν Χαλδαίων χθόνα, τῷ σῷ φωτὶ κατηυγάσθησαν· θωρακισθέντες δὲ ὅπλοις τῆς πίστεως, ᾔσχυναν Ἰουλιανὸν τὸν τύραννον, Μανουὴλ ὁ ἔνδοξος, καὶ Σαβὲλ ὁ ἀείμνηστος, καὶ Ἰσμαὴλ ὁ τρισόλβιος, σὺν Πατρὶ καὶ τῷ Πνεύματι ὑμνοῦντές σε, καὶ πρεσβεύουσι τοῦ σωθῆναι τὰς ψυχὰς ὑμῶν."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.SticTheotokion.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
meVE.SticTheotokion.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.SticTheotokion.incipit = "Χαίροις οἰκουμένης…"
meVE.SticTheotokion.text = "Χαίροις οἰκουμένης καύχημα. Χαῖρε Κυρίου ναέ. Χαῖρε ὄρος κατάσκιον. Χαῖρε καταφύγιον. Χαῖρε λυχνία χρυσῆ. Χαῖρε τὸ κλέος τῶν ὀρθοδόξων σεμνή. Χαῖρε Μαρία Μήτηρ Χριστοῦ τοῦ Θεοῦ. Χαῖρε Παράδεισε. Χαῖρε θεία τράπεζα. Χαῖρε σκηνή. Χαῖρε στάμνε πάγχρυσε. Χαῖρε ἡ πάντων χαρά."

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.SticStavrotheotokion.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
meVE.SticStavrotheotokion.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.SticStavrotheotokion.incipit = me.m01.d15_gr_GR_cog.meMA.AposStavrotheotokion.incipit
meVE.SticStavrotheotokion.text = me.m01.d15_gr_GR_cog.meMA.AposStavrotheotokion.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.Apolytikion1ger.greekmelody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.greekname
meVE.Apolytikion1ger.melody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.name
meVE.Apolytikion1ger.incipit = "Ὡς ἐννεάριθμον…"
meVE.Apolytikion1ger.text = "Ὡς ἐννεάριθμον, τοῦ Λόγου σύνταγμα, ἐχθρῶν τὰς φάλαγγας, κατετροπώσαντο, Ἴσαυρος Φῆλιξ σὺν αὐτοῖς, Ἑρμείας καὶ Περεγρῖνος, ἅμα Ἰννοκέντιος, Μανουὴλ καὶ Βασίλειος, Ἰσμαὴλ ὁ ἔνδοξος, καὶ Σαβὲλ ὁ μακάριος· διὸ καὶ τὰ βραβεῖα τῆς νίκης, εὗρον ὡς Μάρτυρες Κυρίου."

meMA.C1.acrostic.title = "Ὁ Κανὼν τῶν Ἁγίων,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Ἴσαυ(ρε Μ)άρτυς, εὐμενὴς φάνηθί μοι."
meMA.C1.acrostic.notice2 = "Ἐν δὲ τοῖς Θεοτοκίοις· Γ(ρ)ηγορίου."
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaints
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintsM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C11.greekmelody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.greekname
meMA.Ode1C11.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C11.incipit = "Ἱλέωσαι Μάρτυς τὸν εὐμενῆ, Θεὸν…"
meMA.Ode1C11.text = "Ἱλέωσαι Μάρτυς τὸν εὐμενῆ, Θεὸν καὶ Σωτῆρα, ἐλεῆσαί με καὶ δεινῆς, ἐπηρείας μάκαρ ῥύσασθαί με, τὸν προσφυγόντα πιστῶς ἐν τῇ σκέπῃ σου."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C12.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C12.incipit = "Στενούμενος πταίσμασι χαλεποῖς, καὶ πλήθει…"
meMA.Ode1C12.text = "Στενούμενος πταίσμασι χαλεποῖς, καὶ πλήθει κινδύνων, πιεζόμενος ἐκβοῶ· Ἴσαυρε θεόφρον πρόστηθί μου, τῆς συνεχούσης ἀνάγκης καὶ λύτρωσαι."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C13.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C13.incipit = "Ἀθλήσας νομίμως ὑπὲρ Χριστοῦ, ἀνύστακτος…"
meMA.Ode1C13.text = "Ἀθλήσας νομίμως ὑπὲρ Χριστοῦ, ἀνύστακτος φύλαξ, ἐχαρίσθης πόλει τῇ σῇ, γενοῦ δὲ καὶ σκέπη καὶ προστάτης, τῶν προσφυγόντων σοι ἔνδοξε, Ἴσαυρε."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C1T.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
meMA.Ode1C1T.incipit = "Γυμνῶν ἀρετῶν με καταστολῆς, εὑρὼν…"
meMA.Ode1C1T.text = "Γυμνῶν ἀρετῶν με καταστολῆς, εὑρὼν ὁ Βελίαρ, βέλει ἔτρωσεν ἡδονῶν, ἡ τὸν ἰατρὸν Θεὸν τεκοῦσα, τὰ τῆς ψυχῆς μου θεράπευσον τραύματα."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C11.greekmelody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.greekname
meMA.Ode3C11.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C11.incipit = "Ἄνωθεν τοῖς δούλοις σου, τὴν…"
meMA.Ode3C11.text = "Ἄνωθεν τοῖς δούλοις σου, τὴν σὴν βοήθειαν δώρησαι, σῴζων ἡμᾶς, πάσης ἐπηρείας, καὶ κινδύνων καὶ θλίψεων."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C12.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C12.incipit = "Ῥεῖθρα τῶν ἰάσεων, ἡ σὴ…"
meMA.Ode3C12.text = "Ῥεῖθρα τῶν ἰάσεων, ἡ σὴ σορὸς ἀναβρύουσα, παντοδαπά, παύει τῶν ἀνθρώπων, ἀῤῥωστήματα, Ἴσαυρε."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C13.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C13.incipit = "Τίμιος γεγένησαι, τὸ τοῦ Χριστοῦ…"
meMA.Ode3C13.text = "Τίμιος γεγένησαι, τὸ τοῦ Χριστοῦ τιμῶν ὄνομα· διὸ βοῶ· λύτρωσαί με πάσης, ἀτιμίας πρεσβείαις σου."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C1T.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
meMA.Ode3C1T.incipit = "Ἥνωται ὁ Κτίστης μου, ὑπερφυῶς…"
meMA.Ode3C1T.text = "Ἥνωται ὁ Κτίστης μου, ὑπερφυῶς ἐν σοὶ Δέσποινα, ὅλον ἐμέ, θέλων ἀναπλάσαι, διὰ σοῦ ὡς ηὐδόκησεν."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3H.greekmelody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.greekname
meMA.Ode3H.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.melody
meMA.Ode3H.incipit = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.incipit
meMA.Ode3H.text = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3Kathisma1.greekmelody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.greekname
meMA.Ode3Kathisma1.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meMA.Ode3Kathisma1.incipit = "Θεῖον φρόνημα, ἀνειλημμένοι, ὦ ὑπέρμαχοι…"
meMA.Ode3Kathisma1.text = "Θεῖον φρόνημα, ἀνειλημμένοι, ὦ ὑπέρμαχοι τοῦ Δυῤῥαχίου, καὶ τοῦ Χριστοῦ ὁπλῖται στεῤῥόψυχοι, Ἀπολλωνίου τὸ θράσος καθείλετε, καὶ Τριποντίου τὸ σέβας ᾐσχύνατε, νίκης ἔπαθλα, φαιδρῶς ἐκ Θεοῦ δεξάμενοι, δωρεῖσθε τοῖς πιστοῖς παθῶν ἰάματα."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3KathismaT.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meMA.Ode3KathismaT.incipit = oc.m3.d2_gr_GR_cog.ocMA.Kathisma23.incipit
meMA.Ode3KathismaT.text = oc.m3.d2_gr_GR_cog.ocMA.Kathisma23.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3KathismaSt.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meMA.Ode3KathismaSt.incipit = "Ἡ ἀμίαντος, ἀμνὰς τοῦ Λόγου…"
meMA.Ode3KathismaSt.text = "Ἡ ἀμίαντος, ἀμνὰς τοῦ Λόγου, ἡ ἀκήρατος, Παρθενομῆτορ, ἐν τῷ Σταυρῷ θεασαμένη κρεμάμενον, τὸν ἐξ αὐτῆς ἀνωδίνως βλαστήσαντα, μητροπρεπῶς θρηνῳδοῦσα ἐκραύγαζεν· Οἴμοι! τέκνον μου, πῶς πάσχεις, θέλων ῥύσασθαι, παθῶν τῆς ἀτιμίας τὸν ἄνθρωπον;"

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C11.greekmelody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.greekname
meMA.Ode4C11.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C11.incipit = "Ὑψωθεὶς ἀπονοίᾳ μου, ὀλισθήσας πάθεσι…"
meMA.Ode4C11.text = "Ὑψωθεὶς ἀπονοίᾳ μου, ὀλισθήσας πάθεσι κατενήνεγμαι, ἔγειρόν με κατακείμενον, ἐν βυθῷ θεόφρον ἀπογνώσεως."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C12.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C12.incipit = "Σὲ πανένδοξε κέκτημαι, ἀσφαλῆ φρουρόν…"
meMA.Ode4C12.text = "Σὲ πανένδοξε κέκτημαι, ἀσφαλῆ φρουρόν μου καὶ καταφύγιον, πρόστηθί μου μὴ παρίδῃς με, ἐν ἡμέρᾳ θλίψεως καὶ σῶσόν με."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C13.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C13.incipit = "Ἐν ὀδύνῃ καρδίας μου, τὸν…"
meMA.Ode4C13.text = "Ἐν ὀδύνῃ καρδίας μου, τὸν ἐμὸν προστάτην σε τὸν θερμότατον, δυσωπῶ· Μὴ καταλίπῃς με, ἐχθρῶν ἐπηρείαις ἀπολλύμενον."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C1T.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C1T.incipit = "Γηγενῶν ἀκαταίσχυντε, σκέπη καὶ βοήθεια…"
meMA.Ode4C1T.text = "Γηγενῶν ἀκαταίσχυντε, σκέπη καὶ βοήθεια σύ μου πρόστηθι, καὶ παντοίας με ἐξάρπασον, συμφορᾶς Παρθένε τὸν οἰκέτην σου."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C11.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
meMA.Ode5C11.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C11.incipit = "Υἱὸς ὤφθης ἡμέρας, ἔχων ἐν…"
meMA.Ode5C11.text = "Υἱὸς ὤφθης ἡμέρας, ἔχων ἐν καρδίᾳ σου λάμπον φῶς ἄδυτον, διʼ οὗ σκοτομήνη, τῆς ἀπάτης μειοῦται καὶ ἅπασι, δᾳδουχεῖται γνῶσις, θείου φωτός· διὸ βοῶ σοι· Φώτισόν με τὸν γνώμῃ τυφλώττοντα."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C12.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C12.incipit = "Μὴ παρίδῃς με Μάρτυς, πίστει…"
meMA.Ode5C12.text = "Μὴ παρίδῃς με Μάρτυς, πίστει σοι προστρέχοντα, μηδὲ ἀπώσῃ με· γλώσσῃ γὰρ δολία, κατʼ ἐμοῦ οἱ μισοῦντές με φθέγγονται, πολεμοῦντες μάτην, τοῦ ἀπολέσαι τὸν σὸν δοῦλον, ἀλλὰ πρόφθασον σῶσόν με Ἅγιε."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C13.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C13.incipit = "Ἐν νυκτὶ καὶ ἡμέρᾳ, σὲ…"
meMA.Ode5C13.text = "Ἐν νυκτὶ καὶ ἡμέρᾳ, σὲ ἐπικαλοῦμαι τὸν μέγαν προστάτην μου, ἐν παντί με τόπῳ καὶ καιρῷ διαφύλαξον Ἅγιε, ἀπὸ πάσης βλάβης, καὶ ἐναντίων, τὸν εἰς σὲ τὴν ἐπηρείας ἐλπίδα μου θέμενον."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C1T.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C1T.incipit = "Ὅλον ἐμὲ μορφοῦται, ἐκ σοῦ…"
meMA.Ode5C1T.text = "Ὅλον ἐμὲ μορφοῦται, ἐκ σοῦ Ἀπειρόγαμε Θεὸς ὁ πλάστης μου, ὃν ἀεὶ δυσώπει, οἰκτιρῆσαι λαὸν ἁμαρτάνοντα, διασῶσαι κόσμον, δαιμονικῆς ἁπάσης βλάβης, τὸν εἰς σὲ Θεοτόκε ἐλπίζοντα."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C11.greekmelody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.greekname
meMA.Ode6C11.melody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.name
meMA.Ode6C11.incipit = "Νοός μου τὰς ἐκτροπὰς θεραπεύσας…"
meMA.Ode6C11.text = "Νοός μου τὰς ἐκτροπὰς θεραπεύσας, καὶ καρδίας μου τὰ πάθη θεόφρον, σωματικῶν, ἀλγηδόνων μὲ ῥῦσαι, καὶ ἐπηρείας ἁπάσης καὶ θλίψεως, καὶ δεῖξόν με ταῖς σαῖς λιταῖς, τοῦ ἐχθροῦ τῶν παγίδων ὑπέρτερον."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C12.melody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.name
meMA.Ode6C12.incipit = "Ἡγίασέ σε ἀθλήσαντα Μάρτυς, ὁ…"
meMA.Ode6C12.text = "Ἡγίασέ σε ἀθλήσαντα Μάρτυς, ὁ πανάγιος Θεὸς ὃν δυσώπει, ἁγιασμόν, τοῖς σοῖς δούλοις ἐκπέμψαι, καὶ φωτισμὸν καὶ πταισμάτων τὴν λύτρωσιν· προστάτης γὰρ παρὰ Θεοῦ, ἐχαρίσθης ἡμῖν ἀκαταίσχυντος."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C13.melody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.name
meMA.Ode6C13.incipit = "Συνεῖναί με τὸν πολλὰ σε…"
meMA.Ode6C13.text = "Συνεῖναί με τὸν πολλά σε ποθοῦντα, πολυπόθητε εὐδόκησον Μάρτυς, σὲ δυσωπῶ, τὸν καλόν μου προστάτην, καὶ πίστει κράζω σοι ἅγιε, Ἴσαυρε. Γενήθητί μοι βοηθός, καὶ παντοίας ἀνάγκης με λύτρωσαι."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C1T.melody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.name
meMA.Ode6C1T.incipit = "Ῥανίσι τῆς σωστικῆς σου πρεσβείας…"
meMA.Ode6C1T.text = "Ῥανίσι τῆς σωστικῆς σου πρεσβείας, κατασβέσασα παθῶν μου τὴν φλόγα, τὰς τοῦ νοός, ἐκτροπὰς σαῖς πρεσβείαις, ὑπεραγία Παρθένε θεράπευσον, καὶ κόπασον τὸ χαλεπόν, τῶν παθῶν μου κλυδώνιον πάναγνε."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6H.greekmelody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.greekname
meMA.Ode6H.melody = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.melody
meMA.Ode6H.incipit = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.incipit
meMA.Ode6H.text = he.h.m8_gr_GR_cog.heHE.TinDeisinEkcheo.text

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C11.greekmelody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.greekname
meMA.Ode7C11.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C11.incipit = "Φωτὶ ἀστραπτόμενος, τῷ τρισηλίῳ ἔνδοξε…"
meMA.Ode7C11.text = "Φωτὶ ἀστραπτόμενος, τῷ τρισηλίῳ ἔνδοξε Ἴσαυρε, Ἰννοκέντιε θεῖε, Φῆλιξ Ἑρμεία καὶ Περεγρῖνε σοφέ, σὺν Βασιλείῳ θαυμάτων λαμπρότησι, καταφωτίσατε τοὺς εὐφημοῦντας ἡμᾶς."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C12.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C12.incipit = "Ἀστέρες πολύφωτοι, ζόφον τῆς πλάνης…"
meMA.Ode7C12.text = "Ἀστέρες πολύφωτοι, ζόφον τῆς πλάνης μειοῦντες ὤφθητε, ἀθλοφόροι Κυρίου· διὸ ψυχήν μου γνώμῃ τυφλώττουσαν, θεογνωσίας φωτὶ καταλάμψατε, τῆς ἀγνωσίας ἀχλύν ἀποδιώκοντες."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C13.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C13.incipit = "Νοσοῦσαν ἀνίατα, τὴν ταπεινήν μου…"
meMA.Ode7C13.text = "Νοσοῦσαν ἀνίατα, τὴν ταπεινήν μου ψυχὴν ἰάσασθε, τὰ τοῦ σώματος πάθη, Μάρτυρες θεῖοι ἐξαφανίσατε, ὦ Περεγρῖνε Ἴσαυρε Βασίλειε, Φῆλιξ Ἑρμεία κλεινὲ καὶ Ἰννοκέντιε."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C1T.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C1T.incipit = "Ἰσχύς μου καὶ ὕμνησις, καὶ…"
meMA.Ode7C1T.text = "Ἰσχύς μου καὶ ὕμνησις, καὶ σωτηρία Χριστὸς ὁ Κύριος, ὁ ἐκ σοῦ ἀνατείλας, Παρθενομῆτορ διὰ χρηστότητα, ἐκ τῆς ἀρχαίας ἡμᾶς λυτρωσάμενος, προγονικῆς ἀπειλῆς καὶ ἀποφάσεως."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C11.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
meMA.Ode8C11.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C11.incipit = "Ἠγλαϊσμένος κάλλεσι, μαρτυρίου θεόληπτε, καὶ…"
meMA.Ode8C11.text = "Ἠγλαϊσμένος κάλλεσι, μαρτυρίου θεόληπτε, καὶ κεκοσμημένος, τοῖς ἐξ ἄθλων στίγμασι, πορφύραν ἐξ αἵματος, ἐνδεδυμένος τῆς σῆς σφαγῆς, καὶ Ἱερωσύνης, καλλυνόμενος δόξῃ, παρέστης τῷ Κυρίῳ, ὃν ἀεὶ ἐκδυσώπει, κοσμῆσαι σωτηρίου, ἡμᾶς περιβολαίῳ."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C12.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C12.incipit = "Θανατωθεὶς ὁ δείλαιος, ἡδονῶν τῷ…"
meMA.Ode8C12.text = "Θανατωθεὶς ὁ δείλαιος, ἡδονῶν τῷ ἐκπτώματι, ἔῤῥιμμαι εἰς γῆν, θέαμα θρήνων ἄξιον, πανένδοξε, Ἴσαυρε, νῦν ἐπʼ ἐμὲ ἐπίβλεψον, δεῖξον ἐν ἐμοί, τὴν τῶν θαυμάτων σου χάριν, βροτῶν ἰδέτω γένος, ὅτι σύ μου προστάτης, καὶ σῴζεις ἐκ θανάτου, τοὺς σοὺς ἀχρείους δούλους."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C13.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C13.incipit = "Ἱερωσύνῃ πρότερον, κοσμηθεὶς ἱερώτατε, καὶ…"
meMA.Ode8C13.text = "Ἱερωσύνῃ πρότερον, κοσμηθεὶς ἱερώτατε, καὶ διακονήσας, εὐλαβῶς εἰς ὕστερον, αὐθαίρετον γέγονας, σὺ ἱερεῖον ἄμωμον, ἱερουργηθείς, Χριστῷ διὰ μαρτυρίου· διὸ κἀμοῦ τὸν ὕμνον, ὡς θυμίαμα Μάρτυς, προσκόμισον τῷ Κτίστῃ, καὶ σῶσόν με λιταῖς σου."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C1T.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C1T.incipit = "Ὁ τῶν φωστήρων κάλλεσιν, οὐρανὸν…"
meMA.Ode8C1T.text = "Ὁ τῶν φωστήρων κάλλεσιν, οὐρανὸν καλλωπίσας Θεός, ἄλλον οὐρανόν σε, Θεοτόκε ἔδειξεν· ἐκ σοῦ γὰρ ὡς ἥλιος, ἐξανατείλας πᾶσαν τὴν γῆν, τῆς θεογνωσίας, κατελάμπρυνε φέγγει· διὸ οὐδεὶς προστρέχων, ἐν σοὶ κατῃσχυμμένος, πορεύεται τῶν θείων, μὴ τυχὼν δωρεῶν σου."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8H.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
meMA.Ode8H.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.melody
meMA.Ode8H.incipit = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.incipit
meMA.Ode8H.text = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C11.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9C11.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C11.incipit = "Μεγάλων χαρισμάτων ἀξιωθείς, ἐκ Θεοῦ…"
meMA.Ode9C11.text = "Μεγάλων χαρισμάτων ἀξιωθείς, ἐκ Θεοῦ παναοίδιμε Ἴσαυρε, ἀποσοβεῖς, δαίμονας καὶ νόσους παντοδαπάς, καὶ πειρασμοὺς καὶ θάνατον, πᾶσι τὰ αἰτήματα χορηγῶν· διὸ κἀμοὶ παράσχου, εἰρήνην καὶ ὑγείαν, καὶ τῶν πταισμάτων ἀπολύτρωσιν."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C12.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C12.incipit = "Ὁ θεῖος καὶ σεβάσμιός σου…"
meMA.Ode9C12.text = "Ὁ θεῖος καὶ σεβάσμιός σου ναός, τὸ πολύτιμον ἅγιον σῶμά σου, ὡς θησαυρόν, ἔχων ἀναφαίρετον τοὺς πιστούς, καταπλουτίζει πάντοτε, ταῖς τῶν χαρισμάτων διανομαῖς· διὸ κἀγὼ τῶν θείων, τύχοιμι δωρεῶν σου, ὁ προσφυγὼν τῷ θείῳ τάφῳ σου."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C13.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C13.incipit = "Ἰδοὺ Μάρτυς Κυρίου καλῶς καμών…"
meMA.Ode9C13.text = "Ἰδοὺ Μάρτυς Κυρίου καλῶς καμών, τὸν μισθὸν ἐκομίσω τῶν πόνων σου. Πρόστηθι οὖν, πάντοτε θεόφρον τοῦ σοῦ λαοῦ, τὴν σὴν πατρίδα φύλαττε, σῷζε τοὺς προστρέχοντάς σοι πιστῶς, καὶ βράβευσον εἰρήνην, πάσῃ τῇ οἰκουμένῃ, κἀμοῦ τοῦ σοῦ οἰκέτου μέμνησο."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C1T.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C1T.incipit = "Ὑπέρφωτε νεφέλη Μήτηρ Θεοῦ, τοὺς…"
meMA.Ode9C1T.text = "Ὑπέρφωτε νεφέλη Μήτηρ Θεοῦ, τοὺς ἡμῖν πολεμοῦντας πολέμησον, τῇ κραταιᾷ, καὶ παντοδυνάμῳ σου δεξιᾷ, τοῖς ἐν ἀνάγκαις πρόστηθι, τῶν ἀδικουμένων ἀντιλαβοῦ, πταισμάτων λυτρουμένη, ταῖς σαῖς ἱκετηρίαις· ὅσα γὰρ θέλεις πάντα δύνασαι."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9H.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9H.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.melody
meMA.Ode9H.incipit = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.incipit
meMA.Ode9H.text = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.text

meLI.MM.CommunionHymn.text = properties_gr_GR_cog.media.key

meLI.Megalynarion.text = ""

