A_Resource_Whose_Name = me.m01.d23_gr_GR_cog

meDA.date = "Τῌ ΚΓʹ ΙΑΝΟΥΑΡΙΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
meDA.commemoration.full = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Κλήμεντος Ἀγκύρας, καὶ τοῦ Ἁγίου Μάρτυρος Ἀγαθαγγέλου" //full title of day
meDA.commemoration.first = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Κλήμεντος Ἀγκύρας"
meDA.commemoration.first_short = "Μνήμη τοῦ Ἁγίου Κλήμεντος"
meDA.commemoration.first_title = "Τοῦ Ἁγ. Κλήμεντος."
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = "Τοῦ Ἁγ. Ἀγαθαγγέλου."
meDA.commemoration.second_name = ""
meDA.insert1 = "καὶ τοῦ Ἁγίου ἐνδόξου Ἱερομάρτυρος Κλήμεντος Ἀγκύρας," //for use in petitions and dismissal
meDA.insert2 = "οὗ καὶ τὴν μνήμην ἐπιτελοῦμεν·" //for use in petitions and dismissal
meDA.note = ""
meDA.pdfcoverdate = "τῆς 23ης Ἰανουαρίου,"
meDA.pdfdatebefore = "τῆς 22ας Ἰανουαρίου"
meDA.pdfheaderdate = "τῆς 23ης Ἰανουαρίου"
meDA.fordate = "διὰ τὴν 23ην Ἰανουαρίου"
meLE.commemoration1 = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Κλήμεντος Ἀγκύρας, καὶ τοῦ Ἁγίου Μάρτυρος Ἀγαθαγγέλου."
meLE.commemoration2 = ""
meHO.number = "23."
meHO.rank = ""
