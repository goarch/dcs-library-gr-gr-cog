meHO.note2 = ""

meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Stichera01.greekmelody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.greekname
meVE.Stichera01.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
meVE.Stichera01.incipit = "Κλῆμα τῆς ἀμπέλου τῆς ζωῆς…"
meVE.Stichera01.text = "Κλῆμα τῆς ἀμπέλου τῆς ζωῆς, ὤφθης μυστικῇ γεωργίᾳ, περισκαπτόμενον· πόνοις γὰρ ἀσκήσεως Πάτερ τεμνόμενος, τῷ δὲ ξίφει τρυγώμενος, τῷ τοῦ μαρτυρίου, οἶνον κατανύξεως, ἡμῖν ἐκέρασας· οὗ νῦν ἐμφορούμενοι πάντες, πίστει τὴν πανίερον μνήμην, τὴν σὴν ἑορτάζομεν μακάριε."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Stichera02.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
meVE.Stichera02.incipit = "Ὅτε ἱερούργεις τὴν φρικτήν, καὶ…"
meVE.Stichera02.text = "Ὅτε ἱερούργεις τὴν φρικτήν, καὶ τελειοτάτην θυσίαν, καὶ ὑπερκόσμιον, τότε προσενήνεξαι ἱερουργούμενος· τὸ σὸν αἷμα δὲ πάνσοφε, προθύμῳ καρδίᾳ, αἵματι προσέμιξας, τῷ τοῦ Δεσπότου σου· ᾧ σὺ ῥαντιζόμενος μάκαρ, ὅλος καθαρὸς ἀνεδείχθης, ὅλος ἱερώτατος θεσπέσιε."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Stichera03.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
meVE.Stichera03.incipit = "Θύων τὸν Ἀμνὸν τὸν τοῦ…"
meVE.Stichera03.text = "Θύων τὸν Ἀμνὸν τὸν τοῦ Θεοῦ, τὸν τῆς ἁμαρτίας τὸν κόσμον, ἀποκαθαίροντα, καὶ φθορὰν καὶ θάνατον ἐξαφανίσαντα, ἱερεῖον ὡς ἄμωμον, ἐτύθης θεόφρον, σύμφυτος γενόμενος τῷ ὁμοιώματι, μάκαρ ζωηφόρου θανάτου· νῦν δὲ τῆς αὐτοῦ βασιλείας, ἀξιομακάριστε τετύχηκας."

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera04.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera04.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera04.incipit = "Ἀγαθαῖς ἀγγελίαις σε, συνοδίτην καὶ…"
meVE.Stichera04.text = "Ἀγαθαῖς ἀγγελίαις σε, συνοδίτην καὶ σύναθλον, Κλήμης ὁ Πανάριστος κατεπλούτησε· μεθʼ οὗ τοὺς δρόμους διήνυσας, τοὺς θείους στρεβλούμενος, καὶ παντοίοις ἀλγεινοῖς, ὁμιλῶν Ἀγαθάγγελε, ἕως τέλειος, γεγονὼς στεφανίτης πρὸς τὰ ἄνω, μεταβέβηκας Ἀγγέλοις, συνεπαγάλλεσθαι πάντοτε."

meVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera05.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera05.incipit = "Καὶ ξεσμοῖς δαπανώμενος, καὶ πυρὶ…"
meVE.Stichera05.text = "Καὶ ξεσμοῖς δαπανώμενος, καὶ πυρὶ λιπαινόμενος, καὶ λαμπάσι πάντοθεν φλογιζόμενος, ἐπὶ κραβάτου ἁπλούμενος, σοφὲ Ἀγαθάγγελε, καὶ ὡς ἄρτος καθαρός, ἐπʼ ἀνθράκων ὀπτώμενος, προσενήνεξαι, οὐρανίῳ τραπέζῃ ἱκετεύων, τοὺς ἐν πίστει σε τιμῶντας, πάσης ῥυσθῆναι κολάσεως."

meVE.Stichera06.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera06.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera06.incipit = "Ῥαβδισμοὺς ἐκαρτέρησας· καὶ ἐν ξύλῳ…"
meVE.Stichera06.text = "Ῥαβδισμοὺς ἐκαρτέρησας· καὶ ἐν ξύλῳ τεινόμενος, σπαραγμοὺς ὑπήνεγκας καρτερώτατα· καὶ ἐπὶ τέλει τῶν ἄθλων σου, σοφὲ Ἀγαθάγγελε, ἐκτμηθεὶς τὴν κεφαλήν, ταῖς ῥανίσι τοῦ αἵματος, ὅλην ἤρδευσας, τὴν σεπτὴν Ἐκκλησίαν εὐφημοῦσαν, τὰς λαμπράς σου ἀριστείας, κλέος Μαρτύρων πολύαθλε."

meVE.SticGlory.poet = poets_gr_GR_cog.po.Anatoliou
meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Τὴν τῶν χρόνων τετραχῶς περίοδον…"
meVE.SticGlory.text = "Τὴν τῶν χρόνων τετραχῶς περίοδον, θεόληπτε ἑπταπλασίασας, τυπτόμενος, ξεόμενος, ἀμείβων πόλεις καὶ χώρας, σταυρούμενος ὑπὲρ τοῦ Χριστοῦ, ἀλλʼ οὔτε πῦρ, οὔτε ξίφος, οὔτε μάστιγες, τὸ τῆς ψυχῆς σου ἔλυσαν στερέμνιον· ἔθραυσας δὲ δαιμόνων ἰσχύν, ἱερομάρτυς Κλήμη· διὸ πρέσβευε Χριστῷ τῷ Θεῷ, σωθῆναι τὰς ψυχάς ἡμῶν."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.SticTheotokion.greekmelody = he.a.m8_gr_GR_cog.heAU.OiMartyresSouKyrie.greekname
meVE.SticTheotokion.melody = he.a.m8_gr_GR_cog.heAU.OiMartyresSouKyrie.name
meVE.SticTheotokion.incipit = me.m01.d21_gr_GR_cog.meVE.AposTheotokion.incipit
meVE.SticTheotokion.text = me.m01.d21_gr_GR_cog.meVE.AposTheotokion.text

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.SticStavrotheotokion.greekmelody = he.a.m8_gr_GR_cog.heAU.OiMartyresSouKyrie.greekname
meVE.SticStavrotheotokion.melody = he.a.m8_gr_GR_cog.heAU.OiMartyresSouKyrie.name
meVE.SticStavrotheotokion.incipit = "Οὐ φέρω τέκνον…"
meVE.SticStavrotheotokion.text = "Οὐ φέρω τέκνον βλέπειν σε, τὸν τὴν ἐγρήγορσιν πᾶσι διδόντα, ξύλῳ ὑπνώσαντα, ὅπως τοῖς πάλαι, ἐκ παραβάσεως καρποῦ, ὕπνῳ ὀλεθρίῳ ἀφυπνώσασι, θείαν καὶ σωτήριον ἐγρήγορσιν, παράσχῃς· ἡ Παρθένος, ἔλεγε θρηνῳδοῦσα· ἣν μεγαλύνομεν."

meVE.AposGlory.poet = poets_gr_GR_cog.po.Anatoliou
meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Τὸν θαυμαστὸν ἐν ἱερεῦσι, Μάρτυρα…"
meVE.AposGlory.text = "Τὸν θαυμαστὸν ἐν ἱερεῦσι, Μάρτυρα Κλήμεντα, ἡ ἐν μακρῷ τῷ χρόνῳ δοκιμὴ τῶν αἰκισμῶν, τῆς εἰς ἀεὶ τῶν ἀγαθῶν ἐπιτυχεῖν, ἠξίωσε τρυφῆς, καὶ πλουτεῖ τὰ θεῖα, ὁ πολλοὺς πρὸς ἀγῶνας ἀλείψας, τῷ καθʼ αὐτὸν ὑποδείγματι, καὶ πείσας τὴν σάρκα, ἀνωτέρω φρονεῖν τοῦ θανάτου· Πρὸς ὃν οἱ πιστοὶ βοήσωμεν· Μεγαλομάρτυς ἀοίδιμε, ταῖς πρὸς Χριστὸν πρεσβείαις σου, τὰς χρονίους ἐνστάσεις, λῦσον τῶν παθῶν ἡμῶν, καὶ ῥῦσαι τῶν δεινῶν ταῖς πρεσβείαις σου."

meVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.AposTheotokion.greekmelody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.greekname
meVE.AposTheotokion.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.AposTheotokion.incipit = "Ῥάβδῳ τῆς σῆς προστασίας, Θεοκυῆτορ…"
meVE.AposTheotokion.text = "Ῥάβδῳ τῆς σῆς προστασίας, Θεοκυῆτορ Ἁγνή, τὰ θηριώδη πάθη, τῆς ἀθλίας ψυχῆς μου, ἀπέλασον ἐντεῦθεν, εἰρηνικῶς, πρὸς ζωήν με ἰθύνουσα, καὶ τῇ ἁγίᾳ με ποίμνῃ τῶν ἐκλεκτῶν, σοῦ προβάτων συναρίθμησον."

meVE.AposStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.AposStavrotheotokion.greekmelody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.greekname
meVE.AposStavrotheotokion.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.AposStavrotheotokion.incipit = "Ἐν τῷ Σταυρῷ…"
meVE.AposStavrotheotokion.text = "Ἐν τῷ Σταυρῷ παρεστῶσα τοῦ σοῦ Υἱοῦ καὶ Θεοῦ, καὶ τὴν μακροθυμίαν, τούτου ἀποσκοποῦσα, ἔλεγες θρηνοῦσα Μῆτερ ἁγνή· Οἴμοι! τέκνον γλυκύτατον, τί ταῦτα πάσχεις ἀδίκως Λόγε Θεοῦ, ἵνα σώσῃς τὸ ἀνθρώπινον."

meVE.Apolytikion1.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Apolytikion1.melody = ""
meVE.Apolytikion1.incipit = "Κλῆμα ὁσιότητος…"
meVE.Apolytikion1.text = "Κλῆμα ὁσιότητος, καὶ στέλεχος ἀθλήσεως, ἄνθος ἱερώτατον, καὶ καρπὸς ὡς θεόσδοτος, τοῖς πιστοῖς πανίερε, ἡδύτατος ἐβλάστησας, Ἀλλʼ ὡς Μαρτύρων σύναθλος, καὶ ἱεραρχῶν σύνθρονος, πρέσβευε Χριστῷ τῷ Θεῷ, σωθῆναι τὰς ψυχὰς ἡμῶν."

meMA.C1.acrostic.title = "Κανὼν τοῦ Ἁγίου Κλήμεντος,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Μέλπω τὸ κλῆμα τῆς νοητῆς ἀμπέλου."
meMA.C1.poet = poets_gr_GR_cog.po.Theofanous
meMA.C1.title = "Κανὼν τοῦ Ἁγ. Κλήμεντος."
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.C2.acrostic.title = "Κανὼν τοῦ Ἁγίου Ἀγαθαγγέλου,"
meMA.C2.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C2.acrostic.text = "Τὴν σὴν ἀνυμνῶ Παμμάκαρ χαίρων χάριν. Ἰωσήφ."
meMA.C2.title = "Κανὼν τοῦ Ἁγ. Ἀγαθαγγέλου."
meMA.C2.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C11.greekmelody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.greekname
meMA.Ode1C11.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C11.incipit = "Μετὰ τῆς ἄνω χορείας…"
meMA.Ode1C11.text = "Μετὰ τῆς ἄνω χορείας, ὡς Ἱερεύς, καὶ ὡς Μάρτυς ἔνδοξος, τῷ Χριστῷ παρεστηκώς, ἐκτενῶς ἱκέτευε τυχεῖν, τῆς ἐλλάμψεως τῆς σῆς, τοὺς εὐφημοῦντάς σε."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C12.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C12.incipit = "Ἐκτεταμένους ἀγῶνας ἐπὶ τῆς γῆς…"
meMA.Ode1C12.text = "Ἐκτεταμένους ἀγῶνας ἐπὶ τῆς γῆς, διανύσας Ὅσιε, βασιλείας οὐρανῶν, ἠξιώθης στέφανον λαβεῖν, καὶ αἰώνιον ζωὴν τὴν ἀκατάλυτον."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C13.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C13.incipit = "Λελυτρωμένος τῷ πάθει τοῦ ἀπαθοῦς…"
meMA.Ode1C13.text = "Λελυτρωμένος τῷ πάθει τοῦ ἀπαθοῦς, διὰ πάθους ἔσπευσας, πρὸς αὐτὸν ἀναδραμεῖν, μιμητὴς γενόμενος παθῶν, θεοφόρε τῶν αὐτοῦ Ἀγγέλων σύσκηνε."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C1T.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C1T.incipit = "Πεποικιλμένη τῷ κάλλει τῶν ἀρετῶν…"
meMA.Ode1C1T.text = "Πεποικιλμένη τῷ κάλλει τῶν ἀρετῶν, Θεομῆτορ ἄχραντε, τὸν Θεὸν τὸν ἀληθῆ, ὑπὲρ νοῦν συνέλαβες ἡμῖν, τὴν πηγῆν τῶν ἀγαθῶν ἀναπηγάσασα."

meMA.Ode1C21.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C21.greekmelody = he.h.m4_gr_GR_cog.heHE.OPataxasAigypton.greekname
meMA.Ode1C21.melody = he.h.m4_gr_GR_cog.heHE.OPataxasAigypton.name
meMA.Ode1C21.incipit = "Τὸν κλεινὸν ἐν Μάρτυσι…"
meMA.Ode1C21.text = "Τὸν κλεινὸν ἐν Μάρτυσι, τῶν ἀθλητῶν τὸ καύχημα, τὸν ἄγγελον τῇ κλήσει, γεγενημένον καὶ τῇ πράξει, χαρμονικῶς σήμερον, τιμήσωμεν ἐν πίστει, καὶ μακαρίσωμεν."

meMA.Ode1C22.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C22.melody = he.h.m4_gr_GR_cog.heHE.OPataxasAigypton.name
meMA.Ode1C22.incipit = "Ἠξιώθης, Ἔνδοξε, τῆς τῶν Μαρτύρων…"
meMA.Ode1C22.text = "Ἠξιώθης, Ἔνδοξε, τῆς τῶν Μαρτύρων εὐκλείας, ἀθλοῦντα θεωρήσας μεγαλοφρόνως ἐν τῇ Ῥώμῃ, τὸν Ἱερὸν Κλήμεντα· μεθ’ οὗ σε συνελθόντες, πίστει γεραίρομεν."

meMA.Ode1C23.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C23.melody = he.h.m4_gr_GR_cog.heHE.OPataxasAigypton.name
meMA.Ode1C23.incipit = "Νεκρωθεὶς Μακάριε, παντὶ τῷ κόσμῳ…"
meMA.Ode1C23.text = "Νεκρωθεὶς Μακάριε, παντὶ τῷ κόσμῳ ἔδραμες, τὴν νέκρωσιν κηρύττων, τοῦ Ζωοδότου ἐν σταδίῳ· καὶ ὑποστὰς βάσανα, ζωῆς ἀδιαδόχου, νῦν κατηξίωσαι."

meMA.Ode1C2T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C2T.melody = he.h.m4_gr_GR_cog.heHE.OPataxasAigypton.name
meMA.Ode1C2T.incipit = "Σαρκωθέντα Κύριον, διʼ εὐσπλαγχνίαν ἄφατον…"
meMA.Ode1C2T.text = "Σαρκωθέντα Κύριον, διʼ εὐσπλαγχνίαν ἄφατον, ἐκύησας Παρθένε, ὃν Ἀγαθάγγελος ποθήσας, ἔξω σαρκὸς γέγονεν, ἀθλήσας παραδόξως, μεθʼ οὗ ὑμνοῦμέν σε."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C11.greekmelody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.greekname
meMA.Ode3C11.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.name
meMA.Ode3C11.incipit = "Ὡραίους ἤνεγκας καρπούς…"
meMA.Ode3C11.text = "Ὡραίους ἤνεγκας καρπούς, κλῆμα τῆς ζωηφόρου, χρηματίσας ἀμπέλου, καὶ τούτους μαρτυρικαῖς, κοσμήσας μαρμαρυγαῖς, τῷ Σωτῆρι, πάντων καθιέρωσας."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C12.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.name
meMA.Ode3C12.incipit = "Τοῦ Παύλου ὤφθης μιμητής, πᾶσαν…"
meMA.Ode3C12.text = "Τοῦ Παύλου ὤφθης μιμητής, πᾶσαν τὴν οἰκουμένην, διατρέχων Παμμάκαρ, βαπτίσματι θεουργῷ, καὶ αἵματος ῥαντισμῷ, ἁγιάζων, τῆς ὁμολογίας σου."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C1T.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.name
meMA.Ode3C1T.incipit = "Οὐκ ἔστιν ἄμεμπτος ὡς σύ…"
meMA.Ode3C1T.text = "Οὐκ ἔστιν ἄμεμπτος ὡς σύ, πάναγνε Θεομῆτορ· μόνη γὰρ ἐξ αἰῶνος, τὸν Θεὸν τὸν ἀληθῆ, καὶ πάντων Δημιουργόν, Θεὸν Λόγον, Πάναγνε ἐκύησας."

meMA.Ode3C21.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C21.greekmelody = he.h.m4_gr_GR_cog.heHE.EstereothiIKardiaMouEnKyrio.greekname
meMA.Ode3C21.melody = he.h.m4_gr_GR_cog.heHE.EstereothiIKardiaMouEnKyrio.name
meMA.Ode3C21.incipit = "Ὑμνολογῶ σου τοὺς ἀπείρους παμμάκαρ…"
meMA.Ode3C21.text = "Ὑμνολογῶ σου τοὺς ἀπείρους παμμάκαρ πόνους, τὰς στρεβλώσεις καὶ τὰς πολλὰς αἰκίσεις, τὴν ἀνδρείαν, τοὺς ξεσμούς, καὶ τὸν θάνατον, διʼ ὧν ἠξιώθης, ζωῆς Ἀγαθάγγελε."

meMA.Ode3C22.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C22.melody = he.h.m4_gr_GR_cog.heHE.EstereothiIKardiaMouEnKyrio.name
meMA.Ode3C22.incipit = "Μετὰ μυρίους αἰκισμούς σε καὶ…"
meMA.Ode3C22.text = "Μετὰ μυρίους αἰκισμούς σε καὶ ἀλγηδόνας, ῥαβδισμούς τε καὶ ξέσεις Ἀθλοφόρε, ὑποβρύχιος θαλάσσῃ, δέδοσαι ἔνδοξε· ἐξ ἧς ὁ τῶν ὅλων, Δημιουργός σε ἐῤῥύσατο."

meMA.Ode3C23.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C23.melody = he.h.m4_gr_GR_cog.heHE.EstereothiIKardiaMouEnKyrio.name
meMA.Ode3C23.incipit = "Νεανικῶς τε καὶ ἀνδρείως γενναῖε…"
meMA.Ode3C23.text = "Νεανικῶς τε καὶ ἀνδρείως γενναῖε Μάρτυς, πυρακτώσεις ὑπήνεγκας τῶν ἥλων, καιομένης τῆς σαρκός, καὶ ἄνωθεν δρόσον δεχομένης, ὑπομονῆς Ἀγαθάγγελε."

meMA.Ode3C2T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C2T.melody = he.h.m4_gr_GR_cog.heHE.EstereothiIKardiaMouEnKyrio.name
meMA.Ode3C2T.incipit = "Ὤ παραδόξου μυστηρίου! πῶς ἡ…"
meMA.Ode3C2T.text = "Ὤ παραδόξου μυστηρίου! πῶς ἡ Παρθένος, πλατυτέρα τῶν οὐρανῶν ἐδείχθη, ἐν νηδύϊ τὸν ἀπεριόριστον, ἀστενοχωρήτως χωρήσασα."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3H.greekmelody = he.h.m4_gr_GR_cog.heHE.EstereothiIKardiaMouEnKyrio.greekname
meMA.Ode3H.melody = he.h.m4_gr_GR_cog.heHE.EstereothiIKardiaMouEnKyrio.melody
meMA.Ode3H.incipit = he.h.m4_gr_GR_cog.heHE.EstereothiIKardiaMouEnKyrio.incipit
meMA.Ode3H.text = he.h.m4_gr_GR_cog.heHE.EstereothiIKardiaMouEnKyrio.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3Kathisma1.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
meMA.Ode3Kathisma1.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Ode3Kathisma1.incipit = "Τοῦ μαρτυρίου ἀληθῶς τῇ δρεπάνῃ…"
meMA.Ode3Kathisma1.text = "Τοῦ μαρτυρίου ἀληθῶς τῇ δρεπάνῃ, κατατεμνόμενος σοφὲ Ἱεράρχα, ὡς καρποφόρος ἄμπελος ἐξήνθησας, βότρυας περκάζοντας, καὶ σταλάζοντας γλεῦκος, θείας ἐπιγνώσεως, καὶ ἀθλήσεως Πάτερ· ἐξ ὧν μετέχων πᾶς τις εὐσεβῶς, καταγλυκαίνει ψυχῆς αἰσθητήρια."

meMA.Ode3Kathisma2.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3Kathisma2.greekmelody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.greekname
meMA.Ode3Kathisma2.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
meMA.Ode3Kathisma2.incipit = "Ἀγαθόν σε Ἄγγελον γεγενημένον, θεοσδότοις…"
meMA.Ode3Kathisma2.text = "Ἀγαθόν σε Ἄγγελον γεγενημένον, θεοσδότοις λάμψεσιν, ἀνευφημοῦντες εὐσεβῶς, ἐπιτελοῦμεν τὴν μνήμην σου, κλέος Μαρτύρων, σοφὲ Ἀγαθάγγελε."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaT.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
meMA.Ode3KathismaT.incipit = "Προστασία ἄμαχε τῶν θλιβομένων, καὶ…"
meMA.Ode3KathismaT.text = "Προστασία ἄμαχε τῶν θλιβομένων, καὶ πρεσβεία ἕτοιμε, τῶν ἀπορούντων ἐν δεινοῖς, ἀπὸ κινδύνων με λύτρωσαι· μή με παρίδῃς, ἡ πάντων ἀντίληψις."

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaSt.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
meMA.Ode3KathismaSt.incipit = "Ἐπὶ ξύλου βλέπουσα ἀναρτηθέντα, τὸν…"
meMA.Ode3KathismaSt.text = "Ἐπὶ ξύλου βλέπουσα ἀναρτηθέντα, τὸν Υἱόν σου Πάναγνε, σπλάγχνα μητρῷα μητρικῶς, σπαρασσομένη ἐκραύγαζες· Οἴμοι πῶς ἔδυς, τὸ φῶς μου τὸ ἄχρονον."

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C11.greekmelody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.greekname
meMA.Ode4C11.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C11.incipit = "Κυκλώσας ἅπασαν, τὴν γῆν ἐξέτεινας…"
meMA.Ode4C11.text = "Κυκλώσας ἅπασαν, τὴν γῆν ἐξέτεινας, τῶν ἀγώνων τὸ κλῆμα ἀθλητικήν, στάζον ἀγαλλίασιν, καὶ εὐωδίας γλυκασμόν, Ἀθλοφόρε παμμακάριστε."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C12.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C12.incipit = "Λειμῶνα θέοντες, τῆς σῆς ἀθλήσεως…"
meMA.Ode4C12.text = "Λειμῶνα θέοντες, τῆς σῆς ἀθλήσεως, ἰαμάτων τὰ ἄνθη μάκαρ τῶν σῶν, Ἔνδοξε δρεπόμεθα, καὶ ποικιλίᾳ θαυμάτων, τὰς αἰσθήσεις κατευφραίνομεν."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C13.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C13.incipit = "Ἡμέρας γέγονας, υἱὸς θαυμάσιε, καὶ…"
meMA.Ode4C13.text = "Ἡμέρας γέγονας, υἱὸς θαυμάσιε, καὶ φωτὸς ἀνεσπέρου διηνεκῶς, περιαυγαζόμενος, τῷ τρισηλίῳ φωτισμῷ, καὶ τῇ αἴγλῃ τοῦ κηρύγματος."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C1T.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C1T.incipit = "Μαρία Πάναγνε, ἡ καθαρώτατον, γενομένη…"
meMA.Ode4C1T.text = "Μαρία Πάναγνε, ἡ καθαρώτατον, γενομένη χωρίον χωρητικόν, θείας ἐνοικήσεως, τὸν ψυχικόν μου μολυσμόν, καὶ τὸν ῥύπον ἐξαφάνισον."

meMA.Ode4C21.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C21.greekmelody = he.h.m4_gr_GR_cog.heHE.EisakikoaOTheos.greekname
meMA.Ode4C21.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaOTheos.name
meMA.Ode4C21.incipit = "Πολυώδυνα ἐνεγκών, βασάνων εἴδη γενναῖε…"
meMA.Ode4C21.text = "Πολυώδυνα ἐνεγκών, βασάνων εἴδη γενναῖε Μάρτυς, σὺν τῷ θείῳ χαίρων Κλήμεντι, ταῖς ῥοαῖς τοῦ αἵματος, πᾶσαν τὴν γῆν θεόφρον ἡγίασας."

meMA.Ode4C22.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C22.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaOTheos.name
meMA.Ode4C22.incipit = "Ἀνηρτήθης ὡς ὁ Χριστός, ἐπὶ…"
meMA.Ode4C22.text = "Ἀνηρτήθης ὡς ὁ Χριστός, ἐπὶ τοῦ ξύλου καὶ κατεξάνθης, τὰς πλευρὰς σιδήρῳ ἔνδοξε, καταπλήξας ἅπαντας, ὑπομονῇ σοφὲ Ἀγαθάγγελε."

meMA.Ode4C23.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C23.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaOTheos.name
meMA.Ode4C23.incipit = "Μεγαλύνοντες τὸν Χριστόν, φρουρὰν κατῴκουν…"
meMA.Ode4C23.text = "Μεγαλύνοντες τὸν Χριστόν, φρουρὰν κατῴκουν οἱ Ἀθλοφόροι, ὡς φρουροὶ θείων προστάξεων, Κλήμης ὁ πανάριστος, καὶ Ἀγαθάγγελος ὁ ἀοίδιμος."

meMA.Ode4C2T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C2T.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaOTheos.name
meMA.Ode4C2T.incipit = "Μακαρίζομέν σε ἀεί, Θεοκυῆτορ εὐλογημένη…"
meMA.Ode4C2T.text = "Μακαρίζομέν σε ἀεί, Θεοκυῆτορ εὐλογημένη· διʼ ἧς δόξης ἠξιώθημεν, καὶ τὸν πρὶν Παράδεισον, ὃν ἀπωλέσαμεν ἀπελάβομεν."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C11.greekmelody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.greekname
meMA.Ode5C11.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C11.incipit = "Αἰκίσεις πάνσοφε καρτερῶν, τὰς πολυχρονίους…"
meMA.Ode5C11.text = "Αἰκίσεις πάνσοφε καρτερῶν, τὰς πολυχρονίους καὶ μακροτάτας, πολύαθλος πέφηνας· νῦν δὲ τῆς ἀφθάρτου μακαριότητος, τρυφὴν κατεκληρώσω διαιωνίζουσαν."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C12.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C12.incipit = "Τὴν πίστιν ἄγκυραν ἀσφαλῆ, ὡς…"
meMA.Ode5C12.text = "Τὴν πίστιν ἄγκυραν ἀσφαλῆ, ὡς καὶ τὴν ἐλπίδα καὶ τὴν ἀγάπην, θεμέλιον θέμενος, τῇ σεπτῇ Τριάδι σαυτὸν ἀνέθηκας, ναὸν ἡγιασμένον Πάτερ πανόλβιε."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C13.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C13.incipit = "Ἡ θεοκόσμητος ξυρωνίς, ἡ διαφανὴς…"
meMA.Ode5C13.text = "Ἡ θεοκόσμητος ξυρωνίς, ἡ διαφανὴς ἠγωνισμένη, ἀθλήσεως στάδιον, ἐπιλαβομένη τῆς αἰωνίου ζωῆς, Ἀγγέλοις συγχορεύει καὶ συναγάλλεται."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C1T.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C1T.incipit = "Σῶσαι βουλόμενος ἐκ φθορᾶς, τὴν…"
meMA.Ode5C1T.text = "Σῶσαι βουλόμενος ἐκ φθορᾶς, τὴν καταφθαρεῖσαν φύσιν, τῶν ἀνθρώπων ὁ Κτίστης καὶ Κύριος, μήτραν ἁγνισθεῖσαν Ἁγίῳ Πνεύματι, οἰκήσας ἀποῤῥήτως ἀνεμορφώσατο."

meMA.Ode5C21.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C21.greekmelody = he.h.m4_gr_GR_cog.heHE.OrthronFaeinon.greekname
meMA.Ode5C21.melody = he.h.m4_gr_GR_cog.heHE.OrthronFaeinon.name
meMA.Ode5C21.incipit = "Ἄνθραξι πυρούμενοι, ἀγαπήσεως τοῦ Παντουργοῦ…"
meMA.Ode5C21.text = "Ἄνθραξι πυρούμενοι, ἀγαπήσεως τοῦ Παντουργοῦ, ἐν ἀσβέστῳ πυρωθείσῃ ἐβλήθητε, καλλίνικοι Μάρτυρες."

meMA.Ode5C22.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C22.melody = he.h.m4_gr_GR_cog.heHE.OrthronFaeinon.name
meMA.Ode5C22.incipit = "Κόσμος ὡραιότατος, ἀνεδείχθητε τῶν Ἀθλητῶν…"
meMA.Ode5C22.text = "Κόσμος ὡραιότατος, ἀνεδείχθητε τῶν Ἀθλητῶν, ἀφαιρούμενοι δορὰν τὴν τοῦ σώματος, ἀήττητοι Μάρτυρες."

meMA.Ode5C23.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C23.melody = he.h.m4_gr_GR_cog.heHE.OrthronFaeinon.name
meMA.Ode5C23.incipit = "Ἁπλωθεὶς εἰς κράβατον, καὶ ὀπτώμενος…"
meMA.Ode5C23.text = "Ἁπλωθεὶς εἰς κράβατον, καὶ ὀπτώμενος ἐν τῇ πυρᾷ, Ἀγαθάγγελε Ἀγγέλους ἐξέπληξας, ὁρῶντας τοὺς ἄθλους σου."

meMA.Ode5C2T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C2T.melody = he.h.m4_gr_GR_cog.heHE.OrthronFaeinon.name
meMA.Ode5C2T.incipit = "Ῥυομένη φάνηθι, Ἀπειρόγαμε πάντας ἡμᾶς…"
meMA.Ode5C2T.text = "Ῥυομένη φάνηθι, Ἀπειρόγαμε πάντας ἡμᾶς, πειρασμῶν τε καὶ κινδύνων καὶ θλίψεων, τοὺς πόθῳ ὑμνοῦντάς σε."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C11.greekmelody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.greekname
meMA.Ode6C11.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C11.incipit = "Νομίμως ἀθλήσαντες…"
meMA.Ode6C11.text = "Νομίμως ἀθλήσαντες, τοὺς στεφάνους ἐκ χειρός, ζωαρχικῆς ἐδέξασθε, χαρισμάτων ποικίλων διανομήν, καὶ χάριν ἰάσεων, τῶν πιστῶν θεραπεύειν τὰ νοσήματα."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C12.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C12.incipit = "Ὁ βίος ὁ ἔνθεος, τῶν…"
meMA.Ode6C12.text = "Ὁ βίος ὁ ἔνθεος, τῶν ἀγώνων ἡ τριβή, τῶν αἰκισμῶν ἡ ἔνστασις, εὐπρεπείας στεφάνωμα μυστικόν, καὶ κάλλους διάδημα, καὶ στολὴ ἀφθαρσίας σοι γεγόνασιν."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C1T.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C1T.incipit = "Ἡ Πάναγνος Δέσποινα, ἡ τεκοῦσα…"
meMA.Ode6C1T.text = "Ἡ Πάναγνος Δέσποινα, ἡ τεκοῦσα τοῖς βροτοῖς, τὸν κυβερνήτην Κύριον, τῶν παθῶν μου τὸν ἄστατον καὶ δεινόν, κατεύνασον τάραχον, καὶ γαλήνην παράσχου τῇ καρδίᾳ μου."

meMA.Ode6C21.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C21.greekmelody = he.h.m4_gr_GR_cog.heHE.EnPelageiTouViou.greekname
meMA.Ode6C21.melody = he.h.m4_gr_GR_cog.heHE.EnPelageiTouViou.name
meMA.Ode6C21.incipit = "Χαριστήριον αἶνον Θεῷ προσῆξας, θεόφρον…"
meMA.Ode6C21.text = "Χαριστήριον αἶνον Θεῷ προσῆξας, θεόφρον Ἀθλητά, ἐν τῇ καμίνῳ ἐμβληθείς, ὡς πάλαι οἱ αἰχμάλωτοι Παῖδες, καὶ δρόσον δεχόμενος, Ἀγαθάγγελε οὐρανόθεν."

meMA.Ode6C22.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C22.melody = he.h.m4_gr_GR_cog.heHE.EnPelageiTouViou.name
meMA.Ode6C22.incipit = "Ἀγαθαῖς ἀγγελίαις…"
meMA.Ode6C22.text = "Ἀγαθαῖς ἀγγελίαις ταῖς δι’ Ἀγγέλων, νευρούμενος τὸν νοῦν, τοὺς αἰκισμούς τε καὶ ἀλγηδόνας, ὥσπερ πάσχοντος ἄλλου, ῥαδίως ὑπήνεγκας, Ἀγαθάγγελε γενναιόφρον."

meMA.Ode6C23.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C23.melody = he.h.m4_gr_GR_cog.heHE.EnPelageiTouViou.name
meMA.Ode6C23.incipit = "Ἱερὰν ξυνωρίδα ὑμᾶς ὁ πλάνος…"
meMA.Ode6C23.text = "Ἱερὰν ξυνωρίδα ὑμᾶς ὁ πλάνος, θεασάμενος σοφοί, δεσμοῖς συνθλίβει, καὶ ποιναῖς συγκόπτει, καὶ φρουραῖς κατακλείει καὶ γέλωτα ὤφλησε, τῇ ἀτρέπτῳ ὑμῶν ἐνστάσει."

meMA.Ode6C2T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C2T.melody = he.h.m4_gr_GR_cog.heHE.EnPelageiTouViou.name
meMA.Ode6C2T.incipit = "Ῥαθυμίαν ὕπνου θανατηφόρου, ἀπάλλαξον Ἁγνή…"
meMA.Ode6C2T.text = "Ῥαθυμίαν ὕπνου θανατηφόρου, ἀπάλλαξον Ἁγνή, καὶ πρὸς ἐνθέους, γρηγορεῖν με ὕμνους, καὶ καλὰς ἐργασίας, ἐνίσχυσον Δέσποινα, ἵνα πόθῳ ὑμνολογῶ σε."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6H.greekmelody = he.h.m4_gr_GR_cog.heHE.EnPelageiTouViou.greekname
meMA.Ode6H.melody = he.h.m4_gr_GR_cog.heHE.EnPelageiTouViou.melody
meMA.Ode6H.incipit = he.h.m4_gr_GR_cog.heHE.EnPelageiTouViou.incipit
meMA.Ode6H.text = he.h.m4_gr_GR_cog.heHE.EnPelageiTouViou.text

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Kontakion1.greekmelody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.greekname
meMA.Kontakion1.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
meMA.Kontakion1.incipit = "Τῆς ἀμπέλου γέγονας, τίμιον κλῆμα…"
meMA.Kontakion1.text = "Τῆς ἀμπέλου γέγονας, τίμιον κλῆμα, τοῦ Χριστοῦ πανεύφημε, Κλήμη πολύαθλος ὀφθείς, σὺν τοῖς συνάθλοις τε ἔκραζες· Χριστέ, Μαρτύρων φαιδρὸν ἀγαλλίαμα."

meMA.Oikos1.text = "Υἱὸς φωτὸς ἀναδειχθείς, Θεοῦ συγκληρονόμος, ὡς Ἠλιοὺ ὁ θεῖος, τὸν Ἀχαὰβ ἤλεγξεν, οὕτω καὶ σύ, Κλήμη σοφέ, Βασιλεῖς ἀνόμους, καὶ Τυράννους ἀπηνεῖς, Ἑλλήνων τοὺς πρωτεύοντας, ἐν λόγῳ καὶ ἀληθείᾳ ἐνίκησας, καὶ προσάγεις θῦμα τῷ Κυρίῳ νῦν τὰ πλήθη τῶν εἰς Χριστὸν πιστευσάντων. Διὸ κοινωνὸν τῆς σῆς μαρτυρίας Ἀγαθάγγελον εὑρών, πόλεις ἐναθλῶν συνώδευσας φαιδρῶς κραυγάζων· Χριστέ, Μαρτύρων φαιδρὸν ἀγαλλίαμα."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C11.greekmelody = he.h.m6_gr_GR_cog.heHE.OiPaidesEnVavyloni.greekname
meMA.Ode7C11.melody = he.h.m6_gr_GR_cog.heHE.OiPaidesEnVavyloni.name
meMA.Ode7C11.incipit = "Τῇ αἴγλῃ τοῦ Μαρτυρίου…"
meMA.Ode7C11.text = "Τῇ αἴγλῃ τοῦ Μαρτυρίου, τὴν οἰκουμένην ἐφαίδρυνας, ἀναμέλπων Χριστῷ διανοίας, καὶ ψυχῆς καθαρότητι· Εὐλογητὸς εἶ Κύριε, ὁ Θεὸς τῶν Πατέρων ἡμῶν."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C12.melody = he.h.m6_gr_GR_cog.heHE.OiPaidesEnVavyloni.name
meMA.Ode7C12.incipit = "Ἡ τῶν σῶν κατορθωμάτων, ἱερωτάτη…"
meMA.Ode7C12.text = "Ἡ τῶν σῶν κατορθωμάτων, ἱερωτάτη πανήγυρις, οὐρανίῳ φωτὶ λαμπομένη, καταυγάζει τοὺς κράζοντας· Εὐλογητὸς εἶ Κύριε, ὁ Θεὸς τῶν Πατέρων ἡμῶν."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C1T.melody = he.h.m6_gr_GR_cog.heHE.OiPaidesEnVavyloni.name
meMA.Ode7C1T.incipit = "Σοφίας τῆς ὑπερσόφου, Παρθένε Μήτηρ…"
meMA.Ode7C1T.text = "Σοφίας τῆς ὑπερσόφου, Παρθένε Μήτηρ γεγένησαι, τῆς τὰ πάντα σοφῶς κυβερνώσης, φυσικῇ ἀγαθότητι· Εὐλογημένος Πάναγνε, ὁ καρπὸς τῆς κοιλίας σου."

meMA.Ode7C21.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C21.greekmelody = he.h.m4_gr_GR_cog.heHE.MiParadoisImas.greekname
meMA.Ode7C21.melody = he.h.m4_gr_GR_cog.heHE.MiParadoisImas.name
meMA.Ode7C21.incipit = "Ὥσπερ οἱ δύο ἀεὶ φωστῆρες…"
meMA.Ode7C21.text = "Ὥσπερ οἱ δύο ἀεὶ φωστῆρες, φαιδρῶς τὴν Ἐκκλησίαν, φωτίζουσι πλουσίως ἄθλων λαμπρότητι, σὺν Ἀγαθαγγέλῳ ὁ μέγας Κλήμης σκοτασμὸν λύοντες πονηρῶν ἀπιστίας ἐχθρῶν· οὓς εὐφημήσωμεν μεγαλοφώνως."

meMA.Ode7C22.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C22.melody = he.h.m4_gr_GR_cog.heHE.MiParadoisImas.name
meMA.Ode7C22.incipit = "Νεανικῶς τοὺς ξεσμοὺς ὑπέστης, καὶ…"
meMA.Ode7C22.text = "Νεανικῶς τοὺς ξεσμοὺς ὑπέστης, καὶ πάσας τρικυμίας, τῶν ἀνυποίστων πόνων σαρκός σου τραύμασιν, ἐχθροὺς τραυματίζων τοὺς ἀοράτους, ἀθλητὰ ἔνδοξε, τῶν παθῶν τοῦ Χριστοῦ κοινωνέ, Ἀγγέλων σύσκηνε, Μαρτύρων κλέος."

meMA.Ode7C23.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C23.melody = he.h.m4_gr_GR_cog.heHE.MiParadoisImas.name
meMA.Ode7C23.incipit = "Χαίρων ὑπέστης σοφέ, μολύβδου βαρείας…"
meMA.Ode7C23.text = "Χαίρων ὑπέστης σοφέ, μολύβδου βαρείας πυρακτώσεις, κατὰ τῆς θείας κάρας ἐπενεχθείσας σου, καὶ καταφλεγούσας ταύτην διόλου, ὥσπερ τις ἄσαρκος, Ἀγαθάγγελε στρατιῶτα Χριστοῦ· ὅθεν πίστει σε δοξολογοῦμεν."

meMA.Ode7C2T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C2T.melody = he.h.m4_gr_GR_cog.heHE.MiParadoisImas.name
meMA.Ode7C2T.incipit = "Ἀνερμηνεύτου λόγῳ, μετέσχες Παρθένε μυστηρίου…"
meMA.Ode7C2T.text = "Ἀνερμηνεύτου λόγῳ, μετέσχες Παρθένε μυστηρίου, Θεὸν τὸν ἐν πᾶσιν ὄντα ἀχώρητον, ἀστενοχωρήτως χωρεῖς καὶ τίκτεις, καὶ μαζοῖς ἔθρεψας, βουληθέντα οἰκτειρῆσαι ἡμᾶς, τοὺς Θεοτόκον σε ὁμολογοῦντας."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C11.greekmelody = he.h.m6_gr_GR_cog.heHE.NomonPatroon.greekname
meMA.Ode8C11.melody = he.h.m6_gr_GR_cog.heHE.NomonPatroon.name
meMA.Ode8C11.incipit = "Ἀναφανέντες φαεινότατοι, ἐπὶ τῆς γῆς…"
meMA.Ode8C11.text = "Ἀναφανέντες φαεινότατοι, ἐπὶ τῆς γῆς φωστῆρες κατελαμπρύνατε, τὸ στερέωμα Πανόβλιοι, τῆς σεπτῆς Ἐκκλησίας· ἐν οὐρανοῖς δέ, φέγγει τῆς ἀθλήσεως ὑμῶν, πρωτοτόκων πανήγυριν εὐφραίνετε βοῶντες· Τὸν Κύριον ὑμνεῖτε τὰ ἔργα, καὶ ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C12.melody = he.h.m6_gr_GR_cog.heHE.NomonPatroon.name
meMA.Ode8C12.incipit = "Μετʼ εὐφροσύνης τὴν χαρμόσυνον, τῶν…"
meMA.Ode8C12.text = "Μετʼ εὐφροσύνης τὴν χαρμόσυνον, τῶν σῶν ἀγώνων μνήμην νῦν ἑορτάζομεν· ὡς γὰρ ἄσαρκος ὑπέμεινας αἰκισμῶν τρικυμίας· ἀλλʼ ἀντὶ τούτων, διαιωνίζουσαν τρυφήν ἐπαξίως ἀπείληφας, ἀντίδοσιν πλουσίαν· Τὸν Κύριον ὑμνεῖτε κραυγάζων, καὶ ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C13.melody = he.h.m6_gr_GR_cog.heHE.NomonPatroon.name
meMA.Ode8C13.incipit = "Πεποικιλμένην καὶ ὑπέρλαμπρον, καταστολὴν σὺ…"
meMA.Ode8C13.text = "Πεποικιλμένην καὶ ὑπέρλαμπρον, καταστολὴν σὺ δόξης ἀμφιασάμενος, ἀντὶ πνεύματος πανόβλιε, χαλεπῆς ἀκηδίας, ἀντὶ βασάνων, τὴν Ἀγγελικὴν διαγωγήν, ἀντηλλάξω λαβόμενος, ζωῆς τῆς ἀϊδίου· Τὸν Κύριον ὑμνεῖτε κραυγάζων, καὶ ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C1T.melody = he.h.m6_gr_GR_cog.heHE.NomonPatroon.name
meMA.Ode8C1T.incipit = "Ἐξ ἀϊδίου τῷ Γεννήτορι, ὁ…"
meMA.Ode8C1T.text = "Ἐξ ἀϊδίου τῷ Γεννήτορι, ὁ συνυπάρχων Λόγος καὶ συννοούμενος, ἐπὶ τέλει τῶν αἰώνων δέ, σαρκωθεὶς ἐκ Παρθένου, τὴν τῶν ἀνθρώπων, πᾶσαν ἐθεούργησε μορφήν, ἑαυτῷ καθʼ ὑπόστασιν, ἀσυγχύτως ἑνώσας· Τὸν Κύριον ὑμνεῖτε βοώντων, καὶ ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C21.greekmelody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.greekname
meMA.Ode8C21.melody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.name
meMA.Ode8C21.incipit = "Ῥανίσιν αἱμάτων σου, πῦρ ἀποσβέσας…"
meMA.Ode8C21.text = "Ῥανίσιν αἱμάτων σου, πῦρ ἀποσβέσας ἀθεΐας, ἤρδευσας Πανεύφημε, Χριστοῦ τὴν Ἐκκλησίαν, πίστει ἀναθάλλουσαν, καὶ εὐφημοῦσαν ἀξίως, τοὺς μεγίστους σου πόνους, τὰ παλαίσματα, τὰς λαμπρὰς ἀριστείας, ἀπαύστως σοφὲ Ἀγαθάγγελε."

meMA.Ode8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C22.melody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.name
meMA.Ode8C22.incipit = "Ἴσους ἐκομίσαντο, τῆς νίκης τοὺς…"
meMA.Ode8C22.text = "Ἴσους ἐκομίσαντο, τῆς νίκης τοὺς στεφάνους, Κλήμης ὁ πανάριστος, καὶ Ἀγαθάγγελος· ὅθεν, ἐν ὑψίστοις τῷ πάντων βασιλεύοντι παρεστῶντες, προστάται καὶ ῥύσται ἡμῶν χρηματίζουσιν, εὐλογοῦντες ὑμνοῦντες ἀπαύστως τὸν Κύριον."

meMA.Ode8C23.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C23.melody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.name
meMA.Ode8C23.incipit = "Νέους ἐκμιμούμενος, τοὺς κατασβέσαντας τὴν…"
meMA.Ode8C23.text = "Νέους ἐκμιμούμενος, τοὺς κατασβέσαντας τὴν φλόγα, τὸ πῦρ ὥσπερ ἄσαρκος, ὑπῆλθες ἀθλοφόρε, ζήλῳ πυρακτούμενος τῆς τοῦ Κυρίου ἀγάπης, καὶ θερμῶς ἀνεβόας Ἀγαθάγγελε· Εὐλογεῖτε τὰ ἔργα Κυρίου, ἀπαύστως τὸν Κύριον."

meMA.Ode8C2T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C2T.melody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.name
meMA.Ode8C2T.incipit = "Ἰσχυρὰν παράκλησιν, καὶ ἀκαταίσχυντον ἐλπίδα…"
meMA.Ode8C2T.text = "Ἰσχυρὰν παράκλησιν, καὶ ἀκαταίσχυντον ἐλπίδα, τεῖχος ἀπροσμάχητον, καὶ θείαν προστασίαν, ὁ λαός σου ἔχει σε, ὁ σὲ δοξάζων Παρθένε· καὶ σῳζόμενος, κράζει ἐμμελέστατα· Εὐλογεῖτε τὰ ἔργα Κυρίου, ἀπαύστως τὸν Κύριον."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8H.greekmelody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.greekname
meMA.Ode8H.melody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.melody
meMA.Ode8H.incipit = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.incipit
meMA.Ode8H.text = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C11.greekmelody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.greekname
meMA.Ode9C11.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.name
meMA.Ode9C11.incipit = "Λουτρῷ τοῦ φωτοειδοῦς βαπτίσματος…"
meMA.Ode9C11.text = "Λουτρῷ τοῦ φωτοειδοῦς βαπτίσματος, τελειωθείς, καὶ τῆς ἱερωσύνης τῷ χαρίσματι, καὶ Μαρτύρων αἵματι λουσάμενος, ὅλος πεφωτισμένος, χαίρων ἀνέδραμες, πρός τὰς οὐρανίους στρατιὰς θεομακάριστε."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C12.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.name
meMA.Ode9C12.incipit = "Ὁ τῶν ἁγίων Μαρτύρων στέφανος…"
meMA.Ode9C12.text = "Ὁ τῶν ἁγίων Μαρτύρων στέφανος, Λόγος Θεοῦ στεφάνῳ τῶν χαρίτων ἐκόσμησε, σὴν ἁγίαν κορυφὴν θεσπέσιε, ὁ τῆς δικαιοσύνης, ἄδυτος Ἥλιος, διʼ ὃν τοὺς ἀγῶνας τοὺς μακρούς, χαίρων ὑπέμεινας."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C1T.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.name
meMA.Ode9C1T.incipit = "Υἱὸς καὶ Λόγος Θεοῦ ὁ…"
meMA.Ode9C1T.text = "Υἱὸς καὶ Λόγος Θεοῦ ὁ ἄναρχος, σωματωθείς, υἱὸς καὶ τῆς Παρθένου γεγένηται, εὐδοκίᾳ τοῦ Πατρὸς καὶ Πνεύματος, θείου τῇ συνεργείᾳ· ὅθεν ἀνέπλασε, τὴν καταφθαρεῖσάν μου μορφήν, ὡς παντοδύναμος."

meMA.Ode9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C21.greekmelody = he.h.m4_gr_GR_cog.heHE.EpoiiseKratos.greekname
meMA.Ode9C21.melody = he.h.m4_gr_GR_cog.heHE.EpoiiseKratos.name
meMA.Ode9C21.incipit = "Ὡς ζεῦγος ὡραῖον, Ἀγαθάγγελος ὁμοῦ…"
meMA.Ode9C21.text = "Ὡς ζεῦγος ὡραῖον, Ἀγαθάγγελος ὁμοῦ, ὁ ἔνδοξος καὶ Κλήμης ὁ γενναῖος, φανέντες μαρτυρικαῖς, ἐλαμπρύνθησαν στολαῖς· καὶ νῦν στεφανηφόροι τῷ Θεῷ, καὶ Βασιλεῖ τῶν ὅλων, εὐκλεῶς παρίστανται, σὺν τοῖς Ἀσωμάτοις."

meMA.Ode9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C22.melody = he.h.m4_gr_GR_cog.heHE.EpoiiseKratos.name
meMA.Ode9C22.incipit = "Σαρκὸς οὐκ ἐφείσω, ὁμιλούσης χαλεποῖς…"
meMA.Ode9C22.text = "Σαρκὸς οὐκ ἐφείσω, ὁμιλούσης χαλεποῖς, ἐν πλείοσι καιροῖς κολαστηρίοις, ἐφέσει τῶν ἀγαθῶν, ὧν ἡτοίμασε Θεός, τοῖς θείοις θεράπουσιν αὐτοῦ· μεθʼ ὧν περιπολεύεις, Μάρτυς Ἀγαθάγγελε, χαίρων εἰς αἰῶνας."

meMA.Ode9C23.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C23.melody = he.h.m4_gr_GR_cog.heHE.EpoiiseKratos.name
meMA.Ode9C23.incipit = "Ἡ γῆ ἑορτάζει, καὶ χορεύει…"
meMA.Ode9C23.text = "Ἡ γῆ ἑορτάζει, καὶ χορεύει οὐρανός, ἀγάλλονται χοροὶ τῶν Ἀσωμάτων, καὶ καρδίαι τῶν πιστῶν, εὐσεβῶς δοξάζουσι, τὴν μνήμην σου σήμερον σοφέ· ἐν ᾗ τοὺς σὲ τιμῶντας, σῷζε ταῖς πρεσβείαις σου, πάσης ἐπηρείας."

meMA.Ode9C2T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C2T.melody = he.h.m4_gr_GR_cog.heHE.EpoiiseKratos.name
meMA.Ode9C2T.incipit = "Φωτίζεις τὸν κόσμον, ἀνατείλασα τὸ…"
meMA.Ode9C2T.text = "Φωτίζεις τὸν κόσμον, ἀνατείλασα τὸ φῶς Πανάμωμε, τὸ λάμψαν πρὸ αἰώνων, ἐκ τοῦ Πατρὸς ὑπὲρ νοῦν, διὰ τοῦτό σοι βοῶ. Τὸ σκότος ἀπέλασον Ἁγνή, ἐκ τῆς ἐμῆς καρδίας, τῶν ἀτάκτων λογισμῶν, ὅπως ἀνυμνῶ σε."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9H.greekmelody = he.h.m4_gr_GR_cog.heHE.EpoiiseKratos.greekname
meMA.Ode9H.melody = he.h.m4_gr_GR_cog.heHE.EpoiiseKratos.melody
meMA.Ode9H.incipit = he.h.m4_gr_GR_cog.heHE.EpoiiseKratos.incipit
meMA.Ode9H.text = he.h.m4_gr_GR_cog.heHE.EpoiiseKratos.text

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Exaposteilarion1.greekmelody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.greekname
meMA.Exaposteilarion1.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
meMA.Exaposteilarion1.incipit = "Ὡς Παῦλος ὁ Ἀπόστολος, τὴν…"
meMA.Exaposteilarion1.text = "Ὡς Παῦλος ὁ Ἀπόστολος, τὴν γῆν κυκλώσας ἅπασαν, καὶ τῶν μακρῶν σου ἀγώνων, ἐκτείνας Κλήμη τὸ κλῆμα, τῇ ἕλικι τῆς Πίστεως, ζωγρεῖς τὸν Ἀγαθάγγελον, συγκοινωνόν σοι Μάρτυρα, τῆς ἀγαθῆς ἀγγελίας, ἐπώνυμον ἀθλοφόρον."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.ExapTheotokion.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
meMA.ExapTheotokion.incipit = "Ὡς οὖσα καθαρώτατον, δοχεῖον Θεονύμφευτε…"
meMA.ExapTheotokion.text = "Ὡς οὖσα καθαρώτατον, δοχεῖον Θεονύμφευτε, τῆς τῶν παθῶν με ἀχλύος, δεῖξον ἐλεύθερον Κόρη, βρυγμοῦ ὀδόντων σκώληκος, καὶ τοῦ πυρὸς ἐξάρπασον, τοῦ αἰωνίου Δέσποινα, ὅπως ἐν Πίστει ὑμνῶ σε, εὐλογημένη Μαρία."

meLI.Kontakion1.mode = me.m01.d23_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.greekmelody = me.m01.d23_gr_GR_cog.meMA.Kontakion1.greekmelody
