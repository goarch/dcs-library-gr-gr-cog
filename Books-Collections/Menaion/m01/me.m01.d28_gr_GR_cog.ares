meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera01.greekmelody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.greekname
meVE.Stichera01.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera01.incipit = "Τοῦ Παραδείσου τὰ κάλλη κατοπτρισάμενος…"
meVE.Stichera01.text = "Τοῦ Παραδείσου τὰ κάλλη κατοπτρισάμενος, καὶ δαψιλῶς τρυφήσας, ἀκηράτους λειμῶνας, ἐξήνθησας τῷ κόσμῳ, γνῶσιν Θεοῦ· ἧς μετέχοντες Ὅσιε, πνευματικῇ διαθέσει τῇ τῶν ψυχῶν, ἀναθάλλομεν ἐν πνεύματι."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera02.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera02.incipit = "Τὴν τοῦ Κριτοῦ παρουσίαν ἱστορησάμενος…"
meVE.Stichera02.text = "Τὴν τοῦ Κριτοῦ παρουσίαν ἱστορησάμενος, τοῖς τῶν δακρύων ῥείθροις, τῶν ψυχῶν τὰς λαμπάδας, ἀνάπτειν ἐκδιδάσκεις, πᾶσι βοῶν, τοῦ Νυμφίου τὴν ἔλευσιν· Περιβαλώμεθα πάντες στολὴν λαμπράν, ὑπαντῆσαι τῷ Νυμφίῳ Χριστῷ."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera03.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera03.incipit = "Τῇ ἐγκρατείᾳ τὸ σῶμα περιφραξάμενος…"
meVE.Stichera03.text = "Τῇ ἐγκρατείᾳ τὸ σῶμα περιφραξάμενος, τὰς τῶν παθῶν κινήσεις, ἀπενέκρωσας Πάτερ, εὐχαῖς καὶ ἀγρυπνίαις· ὅθεν ἐν σοί, ἡ τοῦ Πνεύματος δύναμις, ἐπισκιάσασα ἔδειξε νοητόν, σὲ φωστήρα καὶ παγκόσμιον."

meVE.SticGlory.poet = poets_gr_GR_cog.po.Anatoliou
meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Ἐμφρόνως τῶν ὀχληρῶν τοῦ βίου…"
meVE.SticGlory.text = "Ἐμφρόνως τῶν ὀχληρῶν τοῦ βίου ἐπαναστάς, Ἐφραὶμ ἀοίδιμε, φιλησυχίᾳ τὴν ἔρημον κατέλαβες· καὶ δι’ αὐτῆς πρὸς Θεὸν πρακτικῶς ἀναγόμενος, τῷ κόσμῳ ἔλαμψας φωστήρ, καὶ ῥήματα ζωῆς τοῖς ἀνθρώποις ἐπήγασας· διὸ μὴ παύσῃ ἐν ταῖς εὐχαῖς σου στηρίζων ἡμᾶς, ἐκ βλάβης τοῦ ἀλλοτρίου, ῥυσθῆναι τὰς ψυχὰς ἡμῶν, Ὅσιε Πάτερ."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticTheotokion.melody = ""
meVE.SticTheotokion.incipit = "Θεὸν ἐκ σοῦ σαρκωθέντα ἔγνωμεν…"
meVE.SticTheotokion.text = "Θεὸν ἐκ σοῦ σαρκωθέντα ἔγνωμεν, Θεοτόκε Παρθένε· αὐτὸν ἱκέτευε, σωθῆναι τὰς ψυχὰς ἡμῶν."

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticStavrotheotokion.greekmelody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.greekname
meVE.SticStavrotheotokion.melody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.name
meVE.SticStavrotheotokion.incipit = oc.m6.d4_gr_GR_cog.ocVE.AposTheotokion.incipit
meVE.SticStavrotheotokion.text = oc.m6.d4_gr_GR_cog.ocVE.AposTheotokion.text

meVE.AposGlory.poet = poets_gr_GR_cog.po.Anatoliou
meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Προφητικῶς καταβρέχων τὴν στρωμνὴν τοῖς…"
meVE.AposGlory.text = "Προφητικῶς καταβρέχων τὴν στρωμνὴν τοῖς δάκρυσι, καὶ μελέτην βίου ποιούμενος τὴν μετάνοιαν, τῆς κρίσεως τὸν φόβον ἔργοις ἡμῖν, καὶ διὰ λόγων ὑπέδειξας. Διὸ τὴν σὴν τιμῶμεν ἅπαντες, συνελθόντες Παμμάκαρ μνήμην, παραδόξων πραγμάτων αὐτουργέ, Ἐφραὶμ ἀοίδιμε· καὶ νῦν δυσωποῦμέν σε· Πρέσβευε Χριστῷ τῷ Θεῷ, ὑπὲρ τῶν ψυχῶν ἡμῶν."

meVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.AposTheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.AposTheotokion.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.AposTheotokion.incipit = "Κατακρίσεως ῥῦσαί με…"
meVE.AposTheotokion.text = "Κατακρίσεως ῥῦσαί με, Παναγία Θεόνυμφε· καὶ δεινῶν πταισμάτων, τὴν ταπεινήν μου ψυχήν, καὶ τοῦ θανάτου ἀπάλλαξον, εὐχαῖς σου καὶ δώρησαι, δικαιώσεως τυχεῖν, ἐν ἡμέρᾳ ἐτάσεως, ἧς ἐπέτυχον, τῶν Ἁγίων οἱ δῆμοι μετανοίᾳ, καθαρθέντα με πρὸ τέλους, καὶ τῶν δακρύων ταῖς χύσεσιν."

meVE.AposStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.AposStavrotheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.AposStavrotheotokion.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.AposStavrotheotokion.incipit = me.m01.d16_gr_GR_cog.meMA.LaudsStavrotheotokion.incipit
meVE.AposStavrotheotokion.text = me.m01.d16_gr_GR_cog.meMA.LaudsStavrotheotokion.text

meVE.Apolytikion1.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Apolytikion1.melody = he.ga_gr_GR_cog.heGA.TaisTonDakryonSou.name
meVE.GeneralApolytikion1.name = "Ἐφραὶμ πατὴρ ἡμῶν ὅσιε," // name of saint for General Apolytikia
meVE.MM.GeneralApolytikion1.text = properties_gr_GR_cog.media.key

meMA.C1.acrostic.title = "Κανὼν τοῦ Ἁγίου,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Ἐφραὶμ γεραίρω τὸν νοητὸν Εὐφράτην."
meMA.C1.poet = poets_gr_GR_cog.po.Theofanous
meMA.C1.title = titles_gr_GR_cog.ti.CanonDevoutM
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_DevoutMan.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C11.greekmelody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.greekname
meMA.Ode1C11.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C11.incipit = "Εὐφραντικῇ ἐπομβρίᾳ σῶν προσευχῶν, τὴν…"
meMA.Ode1C11.text = "Εὐφραντικῇ ἐπομβρίᾳ σῶν προσευχῶν, τὴν ψυχήν μου ἄρδευσον ξηρανθεῖσαν τῷ αὐχμῷ, τῶν παθῶν, καὶ λόγον μοι τὴν σήν, εὐφημοῦντι ἑορτήν, Παμμάκαρ ἔμπνευσον."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C12.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C12.incipit = "Φῶς νοητὸν ἀπαστράψας φωτιστικός, ἀνεδείχθης…"
meMA.Ode1C12.text = "Φῶς νοητὸν ἀπαστράψας φωτιστικός, ἀνεδείχθης ἥλιος, φεγγοβόλοις ἀρεταῖς, καὶ δογμάτων κάλλεσιν Ἐφραίμ, καταυγάζων τῶν Πιστῶν, ἄπαν τὸ πλήρωμα."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C13.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C13.incipit = "Ῥείθροις δακρύων τὴν φλόγα τὴν…"
meMA.Ode1C13.text = "Ῥείθροις δακρύων τὴν φλόγα τὴν τῶν παθῶν, κατασβέσας γέγονας, σκεῦος τίμιον Ἐφραίμ, τοῦ Ἁγίου Πνεύματος πηγάς, ἀναβλύζων διδαχῶν, θεομακάριστε."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C1T.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C1T.incipit = "Ἀδιαφθόρως τὸν Λόγον ἐν σῇ…"
meMA.Ode1C1T.text = "Ἀδιαφθόρως τὸν Λόγον ἐν σῇ γαστρί, δεξαμένη τέτοκας, τὸν λυτρούμενον φθορᾶς, τοὺς αὐτὸν λατρεύοντας ἀεί, Μητροπάρθενε σεμνή, πύλη τῆς ὄντως ζωῆς."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C11.greekmelody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.greekname
meMA.Ode3C11.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.name
meMA.Ode3C11.incipit = "Ἰλύος πάσης ἐμπαθοῦς, σεαυτὸν ἐκκαθάρας…"
meMA.Ode3C11.text = "Ἰλύος πάσης ἐμπαθοῦς, σεαυτὸν ἐκκαθάρας, ἀνεδείχθης δοχεῖον ἀρετῶν ὡς ἀληθῶς, καὶ σκεῦος χωρητικόν, χαρισμάτων, τοῦ Ἁγίου Πνεύματος."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C12.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.name
meMA.Ode3C12.incipit = "Μηδόλως ὕπνον ὀφθαλμοῖς, δεδωκὼς οἶκος…"
meMA.Ode3C12.text = "Μηδόλως ὕπνον ὀφθαλμοῖς, δεδωκὼς οἶκος ὤφθης, τῆς Ἁγίας Τριάδος, καὶ σοφίας θησαυρός, τὸν κόσμον καταπλουτῶν, χρυσαυγέσι, δόγμασι Μακάριε."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C13.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.name
meMA.Ode3C13.incipit = "Γνωρίζει ἄλλον σε Χριστοῦ, ἡ…"
meMA.Ode3C13.text = "Γνωρίζει ἄλλον σε Χριστοῦ, ἡ σεπτὴ Ἐκκλησία, χρυσοῤῥόαν Εὐφράτην, πελαγίζοντα σοφῶν, δογμάτων ἐπιροαῖς, καὶ τὴν κτίσιν, πᾶσαν καταρδεύοντα."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C1T.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.name
meMA.Ode3C1T.incipit = "Ἐν δύω φύσεσιν ὁ εἷς…"
meMA.Ode3C1T.text = "Ἐν δύω φύσεσιν ὁ εἷς, τῆς Ἁγίας Τριάδος, ἐξ ἀγνῶν σου αἱμάτων, σαρκωθεὶς θεοπρεπῶς, προῆλθε τοὺς ἐξ Ἀδάμ, διασῴζων, Πάναγνε χρηστότητι."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3H.greekmelody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.greekname
meMA.Ode3H.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.melody
meMA.Ode3H.incipit = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.incipit
meMA.Ode3H.text = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode3Kathisma1.greekmelody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.greekname
meMA.Ode3Kathisma1.melody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.name
meMA.Ode3Kathisma1.incipit = "Τὸν θησαυρὸν τῆς σοφίας…"
meMA.Ode3Kathisma1.text = "Τὸν θησαυρὸν τῆς σοφίας τῶν μυστηρίων Χριστοῦ, τὸν κρατῆρα τὸν θεῖον τῆς κατανύξεως, ἀνυμνήσωμεν πιστοί, ἐν τῇ μνήμῃ αὐτοῦ· φερωνύμως γὰρ ἀεί, τὰς καρδίας τῶν πιστῶν, εὐφραίνει ἔπεσι θείοις, Ἐφραίμ, ὡς πράκτωρ καὶ μύστης, τῶν τοῦ Κυρίου ἀποκαλύψεων."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode3KathismaT.melody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.name
meMA.Ode3KathismaT.incipit = oc.m5.d2_gr_GR_cog.ocMA.Kathisma13.incipit
meMA.Ode3KathismaT.text = oc.m5.d2_gr_GR_cog.ocMA.Kathisma13.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode3KathismaSt.melody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.name
meMA.Ode3KathismaSt.incipit = oc.m5.d4_gr_GR_cog.ocMA.Kathisma23.incipit
meMA.Ode3KathismaSt.text = oc.m5.d4_gr_GR_cog.ocMA.Kathisma23.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C11.greekmelody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.greekname
meMA.Ode4C11.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C11.incipit = "Ῥημάτων δύναμις, τῶν σῶν διέδραμεν…"
meMA.Ode4C11.text = "Ῥημάτων δύναμις, τῶν σῶν διέδραμεν, ἐπὶ πάντα τὸν κόσμον ὑψοποιῶ, φέγγει ταπεινώσεως, τὴν ἀβλεψίαν τῶν ψυχῶν, ἐκδιώκουσα Μακάριε."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C12.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C12.incipit = "Ἀμέμπτως ἤνυσας, τὸν βίον δάκρυσι…"
meMA.Ode4C12.text = "Ἀμέμπτως ἤνυσας, τὸν βίον δάκρυσι, σεαυτὸν ἀποπλύνας, καὶ τοῦ Κριτοῦ, πᾶσι τὴν ἐπέλευσιν, καθιστορῶν λόγοις σοφοῖς, θεοφάντορ ἀξιάγαστε."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C13.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C13.incipit = "Ἰδών σου Κύριος, τῆς ταπεινώσεως…"
meMA.Ode4C13.text = "Ἰδών σου Κύριος, τῆς ταπεινώσεως, τὸ περίδοξον ὕψος ὑψοποιόν, λόγον σοι χαρίζεται, δι οὗ αἱρέσεων δεινά, τεταπείνωται ὑψώματα."

meMA.Ode4C14.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C14.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C14.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C14.incipit = "Ῥωσθεὶς τῇ χάριτι, τοῦ Παντοκράτορος…"
meMA.Ode4C14.text = "Ῥωσθεὶς τῇ χάριτι, τοῦ Παντοκράτορος, πρὸς ἀρχὰς παρετάξω δαιμονικάς, Πάτερ καὶ νενίκηκας, ὑπὲρ ἡμῶν ἐκδυσωπῶν, τῶν θερμῶς ἀνευφημούντων σε."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C1T.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C1T.incipit = "Ὡς θεῖον τέμενος, ὡς ὄρος…"
meMA.Ode4C1T.text = "Ὡς θεῖον τέμενος, ὡς ὄρος ἅγιον, ὡς πηγὴν ἀφθαρσίας, ὡς ἐκλεκτήν, μόνην χρηματίσασαν, τῷ πλαστουργῷ ἡμῶν Θεῷ, τὴν Παρθένον μακαρίσωμεν."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C11.greekmelody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.greekname
meMA.Ode5C11.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C11.incipit = "Ταῖς τῶν δακρύων ἐπιῤῥοαῖς, τὸ…"
meMA.Ode5C11.text = "Ταῖς τῶν δακρύων ἐπιῤῥοαῖς, τὸ τῶν ἡδονῶν ὁλοσχερῶς, Πάτερ ἐξήρανας πέλαγος· καὶ τῇ ἀναβλύσει τῶν διδαγμάτων σου, αἱρέσεων χειμάῤῥους Μάκαρ κατέκλυσας."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C12.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C12.incipit = "Ὁ νοῦς σου νεύσει τῇ…"
meMA.Ode5C12.text = "Ὁ νοῦς σου νεύσει τῇ πρὸς Θεόν, Πάτερ λαμπρυνόμενος Ἐφραίμ, θεοειδὴς ὅλος γέγονεν, ἔσοπτρον καθάπερ τοῦ θείου Πνεύματος, ἀΰλους τὰς ἐμφάσεις ὑποδεχόμενος."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C13.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C13.incipit = "Ναὸς ἐγένου χωρητικός, Πάτερ τῆς…"
meMA.Ode5C13.text = "Ναὸς ἐγένου χωρητικός, Πάτερ τῆς Τριάδος ἀληθῶς, πεποικιλμένος τῇ χάριτι, καὶ τῇ διαυγίᾳ τῶν καθαρῶν ἀρετῶν, καὶ τῇ τῶν διδαγμάτων ἀκεραιότητι."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C1T.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C1T.incipit = "Νεκρόν με ἔδειξεν ἐν Ἐδέμ…"
meMA.Ode5C1T.text = "Νεκρόν με ἔδειξεν ἐν Ἐδέμ, γεῦσις ἡ τοῦ ξύλου πονηρά, ἐπιβουλὴ τῇ τοῦ ὄφεως· σὺ δὲ ζωοδότην Χριστὸν κυήσασα, ἐζώωσάς με μόνη Θεοχαρίτωτε."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C11.greekmelody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.greekname
meMA.Ode6C11.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C11.incipit = "Οὐ ψάμμον θεμέλιον, ἀλλὰ πίστιν…"
meMA.Ode6C11.text = "Οὐ ψάμμον θεμέλιον, ἀλλὰ πίστιν ἀῤῥαγῆ, ὁ Θεοφόρος θέμενος, ταῖς τοῦ ἐχθροῦ παντοίαις ἐπιβουλαῖς, ἀκλόνητος ἔμεινεν, ἀηττήτῳ δυνάμει κυβερνώμενος."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C12.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C12.incipit = "Ἡ γλῶσσά σου κάλαμος, ὀξυγράφου…"
meMA.Ode6C12.text = "Ἡ γλῶσσά σου κάλαμος, ὀξυγράφου ἀληθῶς, ὡς γραμματέως γέγονεν, ὑφηγουμένη γνῶσιν πανευσεβῆ, πλαξὶν ἐγχαράττουσα, καρδιῶν Πάτερ νόμον τὸν τοῦ Πνεύματος."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C13.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C13.incipit = "Τὸ σὸν οἱ ἐκπλέοντες, τῶν…"
meMA.Ode6C13.text = "Τὸ σὸν οἱ ἐκπλέοντες, τῶν δογμάτων γαληνόν, Ἐφραὶμ θεόφρον πέλαγος, τρικυμιῶν λυτροῦνται ψυχοβλαβῶν, καὶ ζάλης αἱρέσεων, ἀνανεύοντες πίστει διασῴζονται."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C1T.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C1T.incipit = "Ὁ πάσης ἐπέκεινα, νοουμένης ὡς…"
meMA.Ode6C1T.text = "Ὁ πάσης ἐπέκεινα, νοουμένης ὡς Θεός, καὶ ὀρωμένης κτίσεως, σωματωθεὶς προῆλθεν ἐκ σῆς γαστρός, τηρήσας σε ἄφθορον, ὥσπερ ἦς πρὸ τοῦ τόκου σου Θεονύμφευτε."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6H.greekmelody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.greekname
meMA.Ode6H.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.melody
meMA.Ode6H.incipit = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.incipit
meMA.Ode6H.text = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.text

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Kontakion1.greekmelody = he.a.m2_gr_GR_cog.heAU.TaAnoZiton.greekname
meMA.Kontakion1.melody = he.a.m2_gr_GR_cog.heAU.TaAnoZiton.name
meMA.Kontakion1.incipit = "Τὴν ὥραν ἀεί…"
meMA.Kontakion1.text = "Τὴν ὥραν ἀεί, προβλέπων τῆς ἐτάσεως, ἐθρήνεις πικρῶς, Ἐφραὶμ ὡς φιλήσυχος· πρακτικὸς δὲ γέγονας, ἐν τοῖς ἔργοις διδάσκαλος Ὅσιε. Ὅθεν Πάτερ παγκόσμιε, ῥαθύμους ἐγείρεις πρὸς μετάνοιαν."

meMA.Oikos1.text = "Ἰχνηλατεῖν βουλόμενος, Πάτερ, τοῦ Προδρόμου ταῖς τρίβοις, ἐκ τοῦ κόσμου μόνος αὐτὸς ἀπάρας, εἰς ἔρημον κατῴκησας. Βλέπων σε οὖν οὕτω βιοῦντα ὁ ἐχθρὸς τὸν δίκαιον, γύναιον πάνυ ἀναιδὲς κατὰ σοῦ διεγείρει, οἰόμενος διὰ τοῦ ἀρχαίου ὅπλου τὴν σὴν ἀνδρείαν καταβαλεῖν, καὶ τὴν ἁγνείαν μολύνειν σου, ἵνα μὴ ἐν τοῖς λόγοις καὶ ἔργοις σου ῥαθύμους ἐγείρῃς πρὸς μετάνοιαν."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C11.greekmelody = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.greekname
meMA.Ode7C11.melody = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.name
meMA.Ode7C11.incipit = "Νομοθέτης Μοναζόντων ἀκριβέστατος, ὤφθης σεβασμιώτατε…"
meMA.Ode7C11.text = "Νομοθέτης Μοναζόντων ἀκριβέστατος, ὤφθης σεβασμιώτατε, ὑπαλείπτης τε, πρὸς ἐχθρῶν παντοίων συμπλοκάς· διό σου τιμῶμεν τὸ σεπτόν, καὶ ἱερὸν ἐπὶ τῆς γῆς Πάτερ μνημόσυνον."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C12.melody = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.name
meMA.Ode7C12.incipit = "Ἐναρμόνιον τοῦ Πνεύματος ἀοίδιμε, ὄργανον…"
meMA.Ode7C12.text = "Ἐναρμόνιον τοῦ Πνεύματος ἀοίδιμε, ὄργανον ἐχρημάτισας, ὑπηχούμενος, ταῖς αὐτοῦ ἑκάστοτε πνοαῖς, καὶ μέλος σωτήριον ἡμῖν, τῆς μετανοίας μελῳδοῦν, τοῖς ἀνυμνοῦσί σε."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C1T.melody = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.name
meMA.Ode7C1T.incipit = "Ὑπὲρ λόγον σου ἡ σύλληψις…"
meMA.Ode7C1T.text = "Ὑπὲρ λόγον σου ἡ σύλληψις Θεόνυμφε· Θεὸν γὰρ Λόγον τέτοκας, τὸν ῥυσάμενον, ἀλογίας πάντας τοὺς βροτούς, καὶ λόγον παρέχοντα βοᾶν· Εὐλογητὸς εἶ ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C11.greekmelody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.greekname
meMA.Ode8C11.melody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.name
meMA.Ode8C11.incipit = "Φωτοφόρος ὡς ἄλλος ἐδείχθης ἥλιος…"
meMA.Ode8C11.text = "Φωτοφόρος ὡς ἄλλος ἐδείχθης ἥλιος, διδαγμάτων ἀκτῖνας πέμπων τοῖς πέρασι, σκότος ἀφεγγές, ἐκμειώσας Μακάριε, πάσης ἁμαρτίας, φωτὶ τῆς μετανοίας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C12.melody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.name
meMA.Ode8C12.incipit = "Ῥείθροις θείων δογμάτων περικυκλούμενος, ποταμὸς…"
meMA.Ode8C12.text = "Ῥείθροις θείων δογμάτων περικυκλούμενος, ποταμὸς ὡς ἐξ ἄλλης Ἐδὲμ πεπόρευσαι, πρόσωπον τῆς γῆς, καταρδεύων θεσπέσιε, καὶ τῆς ἀσεβείας, ζιζάνια συμπνίγων."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C1T.melody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.name
meMA.Ode8C1T.incipit = "Ἀληθῆ Θεοτόκον ὁμολογοῦντές σε, τοῦ…"
meMA.Ode8C1T.text = "Ἀληθῆ Θεοτόκον ὁμολογοῦντές σε, τοῦ Ἀγγέλου τὸ Χαῖρε πίστει βοῶμέν σοι· μόνη τὴν χαράν, ἐπὶ τῆς γῆς ἐκύησας, Κεχαριτωμένη, ἀεὶ εὐλογημένη."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8H.greekmelody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.greekname
meMA.Ode8H.melody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.melody
meMA.Ode8H.incipit = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.incipit
meMA.Ode8H.text = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C11.greekmelody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.greekname
meMA.Ode9C11.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.name
meMA.Ode9C11.incipit = "Τρωθεὶς ἀγάπῃ τοῦ Παντοκράτορος, ὅλον…"
meMA.Ode9C11.text = "Τρωθεὶς ἀγάπῃ τοῦ Παντοκράτορος, ὅλον σαυτοῦ τὸν βίον, θρηνῳδῶν διετέλεσας, ἐκβοῶν μετʼ ἐκπλήξεως Ὅσιε· Ἄνες τὰ κύματά σου, Σῶτερ τῆς χάριτος, ταύτην μοι πλουσίως συντηρῶν, ἐν τῇ μελλούσῃ ζωῇ."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C12.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.name
meMA.Ode9C12.incipit = "Ἡδὺς ὁ λόγος σου κατανύξεως…"
meMA.Ode9C12.text = "Ἡδὺς ὁ λόγος σου κατανύξεως, παρεκτικὸς καὶ πλήρης φωτισμοῦ τοῖς προστρέχουσι, θεοφόρε Ἐφραὶμ ἀξιάγαστε· ἄμεμπτος δὲ ὁ βίος, πάσαις κοσμούμενος, ταῖς θεοφεγγέσιν ἀρεταῖς, καὶ λαμπρυνόμενος."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C13.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.name
meMA.Ode9C13.incipit = "Ναὸς τοῦ Πνεύματος ἐχρημάτισας, καὶ…"
meMA.Ode9C13.text = "Ναὸς τοῦ Πνεύματος ἐχρημάτισας, καὶ ποταμὸς ναμάτων ζωηρύτων πληρούμενος, Ἐκκλησίας θεμέλιος ἄσειστος, ἔρεισμα μοναζόντων, ῥεῖθρον ἀέναον, θείας κατανύξεως, Ἐφραὶμ ἀξιοθαύμαστε."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C1T.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.name
meMA.Ode9C1T.incipit = "Νοεῖν οὐ δύναται νοῦς ἀνθρώπινος…"
meMA.Ode9C1T.text = "Νοεῖν οὐ δύναται νοῦς ἀνθρώπινος, τὸ ὑπὲρ νοῦν τοῦ τόκου σου Παρθένε μυστήριον·ὁ Θεὸς γὰρ σκηνώσας ἐν μέσῳ σου, κλεῖθρα τῆς παρθενίας, οὐ παρεσάλευσε, μόνος ὡς ἐπίσταται αὐτός, ὁ ἀκατάληπτος."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9H.greekmelody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.greekname
meMA.Ode9H.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.melody
meMA.Ode9H.incipit = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.incipit
meMA.Ode9H.text = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.text

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_gr_GR_cog.heAU.OOuranonToisAstrois.greekname
meMA.Exaposteilarion1.melody = he.a.m3_gr_GR_cog.heAU.OOuranonToisAstrois.name
meMA.Exaposteilarion1.incipit = "Ὡς ποταμὸς ὑπάρχεις…"
meMA.Exaposteilarion1.text = "Ὡς ποταμὸς ὑπάρχεις, ῥεῖθρα χρυσόῤῥυτα βρύων, καὶ τοὺς λαοὺς διεγείρων, τῆς μετανοίας πρὸς τρίβον, Χριστὸν ἱκέτευε Πάτερ, Ἐφραὶμ σωθῆναι τὸν κόσμον."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.ExapTheotokion.melody = he.a.m3_gr_GR_cog.heAU.OOuranonToisAstrois.name
meMA.ExapTheotokion.incipit = "Ἐλπὶς τῶν ἀπηλπισμένων, καταφυγὴ Χριστιανῶν…"
meMA.ExapTheotokion.text = "Ἐλπὶς τῶν ἀπηλπισμένων, καταφυγὴ Χριστιανῶν, πανύμνητε Θεοτόκε, τῶν θλιβομένων ἡ χαρά, ἐκ πάσης θλίψεως ῥῦσαι, τοὺς ἀναξίους σου δούλους."

meMA.AposGlory.poet = poets_gr_GR_cog.po.Kyprianou
meMA.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.AposGlory.melody = ""
meMA.AposGlory.incipit = "Ὥσπερ φοίνιξ δαυϊτικῶς…"
meMA.AposGlory.text = "Ὥσπερ φοίνιξ δαυϊτικῶς ἐξανθήσας Ὅσιε Πάτερ, τὰς γλώσσας τῶν βλασφήμων ἐξέκοψας, ἐν τῇ μαχαίρᾳ τῶν λόγων σου Ἐφραίμ· τὰς ἀβύσσους τῶν παθῶν ἐξήρανας διʼ ἐγκρατείας· ὄργανον ἀνεδείχθης τοῦ Ἁγίου Πνεύματος, τοῦ Σταυροῦ τὸ ὅπλον ἀναλαβών, Χριστὸν ἀπαύστως δυσώπει ὑπὲρ ἡμῶν, τῶν ἐπιτελούντων τὴν πανέορτον μνήμην σου."

meMA.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.AposTheotokion.greekmelody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.greekname
meMA.AposTheotokion.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
meMA.AposTheotokion.incipit = oc.m2.d1_gr_GR_cog.ocSV.Aposticha1.incipit
meMA.AposTheotokion.text = oc.m2.d1_gr_GR_cog.ocSV.Aposticha1.text

meMA.AposStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.AposStavrotheotokion.greekmelody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.greekname
meMA.AposStavrotheotokion.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
meMA.AposStavrotheotokion.incipit = me.m01.d22_gr_GR_cog.meVE.AposStavrotheotokion.incipit
meMA.AposStavrotheotokion.text = me.m01.d22_gr_GR_cog.meVE.AposStavrotheotokion.text

meLI.Kontakion1.mode = me.m01.d28_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.greekmelody = me.m01.d28_gr_GR_cog.meMA.Kontakion1.greekmelody
meLI.Kontakion1.melody = me.m01.d28_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m01.d28_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m01.d28_gr_GR_cog.meMA.Kontakion1.text

meLI.Megalynarion.text = ""

