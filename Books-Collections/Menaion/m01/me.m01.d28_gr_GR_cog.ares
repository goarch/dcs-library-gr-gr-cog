meDA.pdfheaderdate = "τῆς 28ης Ἰανουαρίου"
meDA.fordate = "διὰ τὴν 28ην Ἰανουαρίου"
meLE.commemoration1 = "Μνήμη τοῦ Ὁσίου Πατρὸς ἡμῶν Ἐφραὶμ τοῦ Σύρου."
meLE.commemoration2 = ""
