meLE.commemoration1 = "Μνήμη τῶν ἐν Ἁγίοις Πατέρων ἡμῶν Ἀθανασίου καί Κυρίλλου, Πατριαρχῶν Ἀλεξανδρείας."
meLE.commemoration2 = ""
