meDA.commemoration.first = "Μνήμη τῶν Ἁγίων Ἀθανασίου καὶ Κυρίλλου, Ἀρχιεπισκόπων Ἀλεξανδρείας"
meDA.commemoration.first_short = "Μνήμη τῶν Ἁγίων Ἀθανασίου καὶ Κυρίλλου, Ἀρχιεπισκόπων Ἀλεξανδρείας"
meDA.commemoration.first_title = "Τοῦ Ἁγ. Ἀθανασίου."
meDA.commemoration.first_name = ""
