meLI.Megalynarion.incipit = "Σάρκα ὀκταήμερος…"
meLI.Megalynarion.text = "Σάρκα ὀκταήμερος ὡς βροτός, ὁ τῶν ὅλων Κτίστης, περιτέμνεται νομικῶς, τὴν ἐξ ἀκρασίας, ἡμῶν κακίαν τέμνων· Αὐτοῦ τὴν ἀγαθότητα μεγαλύνωμεν."

meLI.Megalynarion.rubric = "Εἰς τὰ δίπτυχα εἴθισται νὰ ψάλλεται τὸ ἑξῆς μεγαλυνάριον τοῦ ἁγίου."
meLI.Megalynarion2.incipit = "Τὸν οὐρανοφάντορα τοῦ Χριστοῦ…"
meLI.Megalynarion2.text = "Τὸν οὐρανοφάντορα τοῦ Χριστοῦ, μύστην τοῦ Δεσπότου, τὸν φωστῆρα τὸν φαεινόν, τὸν ἐκ Καισαρείας, καὶ Καππαδόκων χώρας, Βασίλειον τὸν μέγαν πάντες τιμήσωμεν."
