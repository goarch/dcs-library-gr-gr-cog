A_Resource_Whose_Name = me.m01.d01_gr_GR_cog

meDA.date = "Τῌ Αʹ ΙΑΝΟΥΑΡΙΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
meDA.commemoration.full = "Ἡ κατὰ σάρκα Περιτομὴ τοῦ Κυρίου καὶ Θεοῦ καὶ Σωτῆρος ἡμῶν Ἰησοῦ Χριστοῦ, καὶ Μνήμη τοῦ ἐν Ἁγίοις Πατρὸς ἡμῶν Βασιλείου τοῦ Μεγάλου." //full title of day
meDA.commemoration.first = "Μνήμη τοῦ ἐν Ἁγίοις Πατρὸς ἡμῶν Βασιλείου τοῦ Μεγάλου"
meDA.commemoration.first_short = "Μνήμη τοῦ ἐν Ἁγίοις Πατρὸς ἡμῶν Βασιλείου τοῦ Μεγάλου"
meDA.commemoration.first_title = "Τῆς Περιτομῆς."
meDA.commemoration.first_name = "Περιτομὴ τοῦ Κυρίου"
meDA.commemoration.second_title = titles_gr_GR_cog.ti.SaintM
meDA.commemoration.second_name = "Ἅγιος Βασίλειος"
meDA.insert1 = "τοῦ ἐν Ἁγίοις Πατρὸς ἡμῶν Βασιλείου, Ἀρχιεπισκόπου Καισαρίας τῆς Καππαδοκίας τοῦ Μεγάλου," //for use in petitions and dismissal
meDA.insert2 = "οὗ καὶ τὴν μνήμην ἐπιτελοῦμεν·" //for use in petitions and dismissal
meDA.note = ""
meDA.pdfcoverdate = "τῆς 1ης Ἰανουαρίου,"
meDA.pdfdatebefore = "τῆς 31ης Δεκεμβρίου"
meDA.pdfheaderdate = "τῆς 1ης Ἰανουαρίου"
meDA.fordate = "διὰ τὴν 1ην Ἰανουαρίου"
meLE.commemoration1 = "Ἡ κατὰ Σάρκα Περιτομὴ τοῦ Κυρίου καὶ Θεοῦ καὶ Σωτῆρος ἡμῶν Ἰησοῦ Χριστοῦ"
meLE.commemoration2 = "Μνήμη τοῦ ἐν Ἁγίοις Πατρὸς ἡμῶν Βασιλείου τοῦ Μεγάλου"
meHO.number = "1."
meHO.rank = ""
meHO.commemorations = ""
meHO.note1 = rubrical_gr_GR_cog.ru.HolidayAll
meHO.note2 = ""
meDA.dismissal = dismissals_gr_GR_cog.dis00.circumcision
meDA.dismissal.incipit = dismissals_gr_GR_cog.dis00.circumcision.incipit

meVE.Stichera01.poet = poets_gr_GR_cog.po.Anatoliou
meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera01.melody = ""
meVE.Stichera01.incipit = "Συγκαταβαίνων ὁ Σωτήρ…"
meVE.Stichera01.text = "Συγκαταβαίνων ὁ Σωτήρ, τῷ γένει τῶν ἀνθρώπων, κατεδέξατο σπαργάνων περιβολήν· οὐκ ἐβδελύξατο σαρκὸς τὴν περιτομήν, ὁ ὀκταήμερος κατὰ τὴν Μητέρα, ὁ ἄναρχος κατὰ τὸν Πατέρα. Αὐτῷ πιστοὶ βοήσωμεν· Σὺ εἶ ὁ Θεὸς ἡμῶν, ἐλέησον ἡμᾶς."

meVE.Stichera02.poet = poets_gr_GR_cog.po.Anatoliou
meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera02.melody = ""
meVE.Stichera02.incipit = "Οὐκ ἐπῃσχύνθη…"
meVE.Stichera02.text = "Οὐκ ἐπῃσχύνθη ὁ πανάγαθος Θεός, τῆς σαρκὸς τὴν περιτομὴν ἀποτμηθῆναι· ἀλλʼ ἔδωκεν ἑαυτόν, τύπον καὶ ὑπογραμμόν, πᾶσι πρὸς σωτηρίαν· ὁ γὰρ τοῦ Νόμου Ποιητής, τά τοῦ Νόμου ἐκπληροῖ, καὶ τῶν προφητῶν τὰ κηρυχθέντα περὶ αὐτοῦ. Ὁ πάντα περιέχων δρακί, καὶ ἐν σπαργάνοις εἱληθείς, Κύριε δόξα σοι."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera03.greekmelody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.greekname
meVE.Stichera03.melody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.name
meVE.Stichera03.incipit = "Ὁ ἐπωνύμως κληθείς…"
meVE.Stichera03.text = "Ὁ ἐπωνύμως κληθεὶς τῆς βασιλείας, ὅτε τὸ βασίλειον σὺ ἱεράτευμα, τὸ τοῦ Χριστοῦ ἔθνος ἅγιον, φιλοσοφίᾳ, καὶ ἐπιστήμη Πάτερ ἐποίμανας, τότε διαδήματι, σὲ κατεκόσμησε, τῆς βασιλείας Βασίλειε, βασιλευόντων, ὁ βασιλεύων καὶ πάντων Κύριος, ὁ τῷ τεκόντι συννοούμενος, ἀϊδίως Υἱὸς καὶ συνάναρχος· ὃν ἱκέτευε σῶσαι, καὶ φωτίσαι τὰς ψυχὰς ἡμῶν."

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera04.melody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.name
meVE.Stichera04.incipit = "Ἱεραρχίας στολαῖς…"
meVE.Stichera04.text = "Ἱεραρχίας στολαῖς ἠγλαϊσμένος, χαίρων ἀνεκήρυξας τὸ Εὐαγγέλιον, τῆς βασιλείας Βασίλειε, Ὀρθοδοξίας, τῇ Ἐκκλησίᾳ βλύσας διδάγματα· οἷς νῦν φωτιζόμενοι, μίαν Θεότητα, τὴν ἐν Πατρὶ παντοκράτορι, μονογενεῖ τε, τοῦ Θεοῦ Λόγῳ καὶ θείῳ Πνεύματι, θεολογοῦμεν καὶ δοξάζομεν, ἐν προσώποις τρισὶν ἀδιαίρετον· ἣν ἱκέτευε σῶσαι, καὶ φωτίσαι τὰς ψυχὰς ἡμῶν."

meVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera05.melody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.name
meVE.Stichera05.incipit = "Ὁ οὐρανίαις συνών…"
meVE.Stichera05.text = "Ὁ οὐρανίαις συνὼν χοροστασίαις, καὶ συναυλιζόμενος πάτερ Βασίλειε· ὧν καὶ τὸν βίον ἐζήλωσας, τῇ λαμπροτάτῃ, εἰλικρινείᾳ τῆς πολιτείας σου, ἔτι μετὰ σώματος ἀναστρεφόμενος, τοῖς ἐπὶ γῆς ὥς τις ἄσαρκος· τοὺς ἐντρυφῶντας, τῆς θεοπνεύστου διδασκαλίας σου, ἐκ τῶν κινδύνων, καὶ τοῦ σκότους τῆς ἀγνωσίας, Χριστὸν τὸν Θεὸν ἡμῶν, καθικέτευε σῶσαι, καὶ φωτίσαι τὰς ψυχὰς ἡμῶν."

meVE.SticGlory.poet = poets_gr_GR_cog.po.Anatoliou
meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Σοφίας ἐραστὴς γενόμενος…"
meVE.SticGlory.text = "Σοφίας ἐραστὴς γενόμενος Ὅσιε, καὶ πάντων τῶν ὄντων, τὴν πρὸς Θεὸν προκρίνας συμβίωσιν, μελέτην θανάτου, εἰκότως τῷ βίῳ κατέλιπες· τὰ γὰρ σαρκὸς πάθη, ἐγκρατείας πόνοις, σεαυτῷ περιελόμενος, καὶ θείου μελέτῃ Νόμου, ἀδούλωτον τῆς ψυχῆς τηρήσας τὸ ἀξίωμα, ἀρετῆς περιουσίᾳ, ὅλον τῆς σαρκὸς τὸ φρόνημα, καθυπέταξας τῷ πνεύματι· διὸ σάρκα μισήσας, καὶ κόσμον καὶ κοσμοκράτορα, παριστάμενος τῷ Χριστῷ, αἴτησαι ταῖς ψυχαῖς ἡμῶν τὸ μέγα ἔλεος."

meVE.SticBoth.poet = poets_gr_GR_cog.po.Anatoliou
meVE.SticBoth.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.SticBoth.melody = ""
meVE.SticBoth.incipit = me.m01.d01_gr_GR_cog.meVE.Stichera01.incipit
meVE.SticBoth.text = me.m01.d01_gr_GR_cog.meVE.Stichera01.text

meVE.Lity1.poet = poets_gr_GR_cog.po.Germanou
meVE.Lity1.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.Lity1.melody = ""
meVE.Lity1.incipit = "Χριστὸν εἰσοικισάμενος…"
meVE.Lity1.text = "Χριστὸν εἰσοικισάμενος ἐν τῇ ψυχῇ σου, διὰ τῆς καθαρᾶς σου πολιτείας, τὴν πηγὴν τῆς ζωῆς, Ἱεροφάντα Βασίλειε, ποταμοὺς ἀνέβλυσας δογμάτων εὐσεβῶν τῇ οἰκουμένῃ, ἐξ ὧν ποτιζόμενος ὁ πιστὸς τῆς Ἐκκλησίας λαός, καρπὸν χειλέων ὁμολογούντων, τὴν χάριν προσφέρει τῷ δοξάσαντι τὴν μνήμην σου, εἰς αἰῶνα αἰῶνος."

meVE.Lity2.poet = poets_gr_GR_cog.po.Germanou
meVE.Lity2.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.Lity2.melody = ""
meVE.Lity2.incipit = "Μύρον ἐκκενωθὲν ἐπὶ σοὶ τῆς…"
meVE.Lity2.text = "Μύρον ἐκκενωθὲν ἐπὶ σοὶ τῆς χάριτος, ἔχρισέ σε ἱερουργῆσαι τὸ Εὐαγγέλιον τῆς βασιλείας τῶν οὐρανῶν, Βασίλειε Θεοφάντορ· τοῦ Χριστοῦ γὰρ εὐωδία γενόμενος, τῆς ὀσμῆς τῆς γνώσεως αὐτοῦ, τὴν οἰκουμένην ἐπλήρωσας· διὸ τὰς φωνὰς τῶν οἰκετῶν σου εὐμενῶς δεχόμενος, αἴτησαι ἡμῖν τοῖς τιμῶσι σε, τὸ μέγα ἔλεος,"

meVE.Lity3.poet = poets_gr_GR_cog.po.Vyzantos
meVE.Lity3.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.Lity3.melody = ""
meVE.Lity3.incipit = "Τὴν ἱερατικὴν στολὴν ἀμπεχόμενος, Τριάδος…"
meVE.Lity3.text = "Τὴν ἱερατικὴν στολὴν ἀμπεχόμενος, Τριάδος ὑπέρμαχε Βασίλειε, θρόνῳ παρέστης δικαστικῷ, προκινδυνεύων τῆς πίστεως, καὶ ἀθλητικὴν ἔνστασιν ἐπιδειξάμενος, θυμὸν Ἐπάρχου κατῄσχυνας, θρασυνομένου τῷ κράτει τῆς ἀσεβείας, καὶ σπλάγχνων ἐκτομὴν ἀπειλοῦντος, προθύμως ταῦτα προέκρινας, καὶ Μάρτυς γενόμενος τῇ προαιρέσει, τὸν στέφανον ἀνεδήσω τῆς νίκης παρὰ Χριστοῦ, τοῦ ἔχοντος τὸ μέγα ἔλεος."

meVE.LityGlory.poet = poets_gr_GR_cog.po.Vyzantiou
meVE.LityGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.LityGlory.melody = ""
meVE.LityGlory.incipit = "Ἐξεχύθη ἡ χάρις ἐν χείλεσί…"
meVE.LityGlory.text = "Ἐξεχύθη ἡ χάρις ἐν χείλεσί σου, Ὅσιε Πάτερ, καὶ γέγονας ποιμὴν τῆς του Χριστοῦ Ἐκκλησίας, διδάσκων τὰ λογικὰ πρόβατα, πιστεύειν εἰς Τριάδα ὁμοούσιον, ἐν μιᾷ Θεότητι."

meVE.LityBoth.poet = poets_gr_GR_cog.po.Anatoliou
meVE.LityBoth.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.LityBoth.melody = ""
meVE.LityBoth.incipit = "Συγκαταβαίνων ὁ Σωτήρ, τῷ γένει…"
meVE.LityBoth.text = "Συγκαταβαίνων ὁ Σωτήρ, τῷ γένει τῶν ἀνθρώπων, κατεδέξατο σπαργάνων περιβολήν, οὐκ ἐβδελύξατο σαρκὸς τὴν περιτομήν, ὁ ὀκταήμερος κατὰ τὴν Μητέρα, ὁ ἄναρχος κατὰ τὸν Πατέρα. Αὐτῷ πιστοὶ βοήσωμεν. Σὺ εἶ ὁ Θεὸς ἡμῶν, ἐλέησον ἡμᾶς."

meVE.Aposticha1.poet = poets_gr_GR_cog.po.Vyzantos
meVE.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Aposticha1.melody = ""
meVE.Aposticha1.incipit = "Ὦ θεία καὶ ἱερὰ τῆς…"
meVE.Aposticha1.text = "Ὦ θεία καὶ ἱερὰ τῆς Χριστοῦ Ἐκκλησίας μέλισσα, Βασίλειε παμμακάριστε· σὺ γὰρ τοῦ θείου πόθου τῷ κέντρῳ, σεαυτὸν καθοπλίσας, τῶν θεοστυγῶν αἱρέσεων τὰς βλασφημίας κατέτρωσας· καὶ ταῖς ψυχαῖς τῶν πιστῶν εὐσεβείας τὸν γλυκασμὸν ἐθησαύρισας· καὶ νῦν τοὺς θείους λειμῶνας, τῆς ἀκηράτου διερχόμενος νομῆς, μνημόνευε καὶ ἡμῶν, παρεστὼς τὴν Τριάδα τὴν ὁμοούσιον."

meVE.Aposticha2.poet = poets_gr_GR_cog.po.VasileiouMonachou
meVE.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Aposticha2.melody = ""
meVE.Aposticha2.incipit = "Πάντων τῶν ἁγίων ἀνεμάξω τὰς…"
meVE.Aposticha2.text = "Πάντων τῶν ἁγίων ἀνεμάξω τὰς ἀρετάς, Πατὴρ ἡμῶν Βασίλειε, Μωϋσέως τὸ πρᾶον, Ἠλιοὺ τὸν ζῆλον, Πέτρου τὴν ὁμολογίαν, Ἰωάννου τὴν Θεολογίαν, ὡς ὁ Παῦλος ἐκβοῶν οὐκ ἐπαύσω. Τίς ἀσθενεῖ, καὶ οὐκ ἀσθενῶ; τίς σκανδαλίζεται, καὶ οὐκ ἐγὼ πυροῦμαι; Ὅθεν σὺν αὐτοῖς αὐλιζόμενος, ἱκέτευε σωθῆναι τὰς ψυχὰς ἡμῶν."

meVE.Aposticha3.poet = poets_gr_GR_cog.po.IoannouMonachou
meVE.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Aposticha3.melody = ""
meVE.Aposticha3.incipit = "Τῶν ὄντων ἐκμελετήσας τὴν φύσιν…"
meVE.Aposticha3.text = "Τῶν ὄντων ἐκμελετήσας τὴν φύσιν, καὶ πάντων περισκοπήσας τὸ ἄστατον, μόνον εὗρες ἀκίνητον, τὸν ὑπερουσίως ὄντα Δημιουργὸν τοῦ παντός, ᾧ καὶ μᾶλλον προσθέμενος, τῶν οὐκ ὄντων τὸν πόθον ἀπέῤῥιψας. Πρέσβευε καὶ ἡμᾶς τοῦ θείου πόθου τυχεῖν, Ἱεροφάντα Βασίλειε."

meVE.AposGlory.poet = poets_gr_GR_cog.po.Vyzantiou
meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Ὁ τὴν χάριν τῶν θαυμάτων…"
meVE.AposGlory.text = "Ὁ τὴν χάριν τῶν θαυμάτων οὐρανόθεν κομισάμενος, καὶ τὴν πλάνην τῶν εἰδώλων στηλιτεύσας ἐν τοῖς δόγμασιν, Ἀρχιερέων ὑπάρχεις δόξα καὶ ἑδραίωμα, παμμακάριστε Βασίλειε, καὶ πάντων τῶν Πατέρων διδασκαλίας ὑπόδειγμα. Παῤῥησίαν ἔχων πρὸς Χριστόν, αὐτὸν ἱκέτευε, σωθῆναι τὰς ψυχὰς ἡμῶν."

meVE.AposBoth.poet = poets_gr_GR_cog.po.Anatoliou
meVE.AposBoth.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.AposBoth.melody = ""
meVE.AposBoth.incipit = me.m01.d01_gr_GR_cog.meVE.Stichera02.incipit
meVE.AposBoth.text = me.m01.d01_gr_GR_cog.meVE.Stichera02.text

meVE.Apolytikion1.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Apolytikion1.melody = ""
meVE.Apolytikion1.incipit = "Εἰς πᾶσαν τὴν γῆν ἐξῆλθεν…"
meVE.Apolytikion1.text = "Εἰς πᾶσαν τὴν γῆν ἐξῆλθεν ὁ φθόγγος σου, ὡς δεξαμένην τὸν λόγον σου, διʼ οὗ θεοπρεπῶς ἐδογμάτισας, τὴν φύσιν τῶν ὄντων ἐτράνωσας, τὰ τῶν ἀνθρώπων ἤθη κατεκόσμησας, Βασίλειον Ἱεράτευμα, Πάτερ Ὅσιε, Χριστὸν τὸν Θεὸν ἱκέτευε, δωρήσασθαι ἡμῖν τὸ μέγα ἔλεος."

meVE.Apolytikion2.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Apolytikion2.greekmelody = he.a.m1_gr_GR_cog.heAU.TouLithouSfragisthentos.greekname
meVE.Apolytikion2.melody = he.a.m1_gr_GR_cog.heAU.TouLithouSfragisthentos.name
meVE.Apolytikion2.incipit = "Μορφὴν ἀναλλοιώτως…"
meVE.Apolytikion2.text = "Μορφὴν ἀναλλοιώτως ἀνθρωπίνην προσέλαβες, Θεὸς ὢν κατʼ οὐσίαν, πολυεύσπλαγχνε Κύριε· καὶ Νόμον ἐκπληρῶν, περιτομήν, θελήσει καταδέχῃ σαρκικήν, ὅπως παύσῃς τὰ σκιώδη, καὶ περιέλῃς τὸ κάλυμμα τῶν παθῶν ἡμῶν. Δόξα τῇ ἀγαθότητι τῇ σῇ, δόξᾳ τῇ εὐσπλαγχνίᾳ σου, δόξα τῇ ἀνεκφράστῳ Λόγε συγκαταβάσει σου."

meMA.Kathisma11.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Kathisma11.greekmelody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.greekname
meMA.Kathisma11.melody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.name
meMA.Kathisma11.incipit = "Ὡς βασίλειον κόσμον τῆς Ἐκκλησίας…"
meMA.Kathisma11.text = "Ὡς βασίλειον κόσμον τῆς Ἐκκλησίας Χριστοῦ, τὸν Βασίλειον πάντες ἀνευφημήσωμεν, τῶν δογμάτων θησαυρὸν τὸν ἀνέκλειπτον· διὰ τούτων γὰρ αὐτός, ἐξεπαίδευσεν ἡμᾶς, Τριάδα σέβειν ἁγίαν, ἡνωμένην μὲν τῇ οὐσίᾳ, διαιρετὴν δὲ ταῖς ὑποστάσεσι."

meMA.Kathisma12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kathisma12.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meMA.Kathisma12.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Kathisma12.incipit = "Βασίλειε σοφέ, παρεστὼς τῇ Τριάδι…"
meMA.Kathisma12.text = "Βασίλειε σοφέ, παρεστὼς τῇ Τριάδι, ἱκέτευε λαβεῖν, ἐν ἡμέρᾳ τῆς δίκης, ἡμᾶς τοὺς ὑμνοῦντας σε, καὶ τιμῶντας τὴν μνήμην σου, χάριν ἔλεος, καὶ ἱλασμὸν τῶν πταισμάτων, ὅπως στόματι, δοξάζωμεν καὶ καρδίᾳ, τὸν μόνον φιλάνθρωπον."

meMA.Kathisma13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kathisma13.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Kathisma13.incipit = "Ὁ πάντων Ποιητής, καὶ Δεσπότης…"
meMA.Kathisma13.text = "Ὁ πάντων Ποιητής, καὶ Δεσπότης τοῦ κόσμου, ὁ ὢν σὺν τῷ Πατρί, καὶ τῷ Πνεύματι ἄνω, ὡς βρέφος περιτέμνεται, ἐπὶ γῆς ὀκταήμερος. Ὄντως θεῖά τε, καὶ θαυμαστά σου τὰ ἔργα! σὺ γὰρ Δέσποτα, ὑπὲρ ἡμῶν περιτέμνῃ, ὡς ὤν Νόμου πλήρωμα."

meMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Kathisma21.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Kathisma21.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Kathisma21.incipit = "Τῆς ἀῤῥήτου σοφίας θεοπρεπῶς…"
meMA.Kathisma21.text = "Τῆς ἀῤῥήτου σοφίας θεοπρεπῶς, ἑξαντλήσας τὸν πλοῦτον τὸν μυστικόν, πᾶσιν ἐθησαύρισας, ὀρθοδοξίας τὰ νάματα, τῶν μὲν πιστῶν τὰς καρδίας, ἐνθέως εὐφραίνοντα, τῶν δὲ ἀπίστων τὰ δόγματα, ἀξίως βυθίζοντα. Ὅθεν διʼ ἀμφοτέρων, εὐσεβείας ἱδρῶσιν, ἐδείχθης ἀήττητος, τῆς Τριάδος ὑπέρμαχος, Ἱεράρχα Βασίλειε, πρέσβευε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ, τὴν ἁγίαν μνήμην σου."

meMA.Kathisma22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Kathisma22.greekmelody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.greekname
meMA.Kathisma22.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
meMA.Kathisma22.incipit = "Ὡς ὑπάρχων ἄβυσσος, φιλανθρωπίας…"
meMA.Kathisma22.text = "Ὡς ὑπάρχων ἄβυσσος, φιλανθρωπίας, ἐνεδύσω Δέσποτα, μορφὴν τοῦ δούλου, καὶ σαρκί, περιετμήθης δωρούμενος, ἀνθρώποις πᾶσι, τὸ μέγα σου ἔλεος."

meMA.Kathisma31.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Kathisma31.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Kathisma31.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Kathisma31.incipit = "Τῇ δυνάμει τῶν λόγων…"
meMA.Kathisma31.text = "Τῇ δυνάμει τῶν λόγων τῶν θεϊκῶν, καθελὼν τὰς αἱρέσεις τὰς ζοφεράς, πάντα τὰ φρυάγματα, τοῦ Ἀρείου ἐβύθισας· τοῖς γὰρ βροτοῖς τὸ Πνεῦμα, Θεὸν ἀνεκήρυξας, καὶ τῶν χειρῶν ἐκτάσει, ἐχθροὺς ἐθανάτωσας, πᾶσαν ἐκδιώξας, Σαβελλίου λατρείαν, καὶ πάντα φρονήματα, Νεστορίου κατήργησας. Ἱεράρχα Βασίλειε, πρέσβευε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ, τὴν ἁγίαν μνήμην σου."

meMA.Kathisma32.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Kathisma32.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Kathisma32.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Kathisma32.incipit = "Ἡ τῶν λόγων σου χάρις…"
meMA.Kathisma32.text = "Ἡ τῶν λόγων σου χάρις τῶν θεϊκῶν, καὶ δογμάτων τὸ ὕψος τὸ μυστικόν, θείας ἡμῖν γέγονεν, ἀναβάσεως κλῖμαξ· πνευματικὴν γὰρ Πάτερ, κτησάμενος σάλπιγγα, ἐν αὐτῇ ἐκήρυξας, τὰ θεῖα διδάγματα. Ὅθεν καὶ εἰς τόπον, κατεσκήνωσας χλόης, μισθοὺς τῶν ἀγώνων σου, κομισάμενος Ὅσιε. Ἱεράρχα Βασίλειε, πρέσβευε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ, τὴν ἁγίαν μνήμην σου."

meMA.Kathisma3T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Kathisma3T.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Kathisma3T.incipit = "Ὁ τῶν ὅλων Δεσπότης καὶ…"
meMA.Kathisma3T.text = "Ὁ τῶν ὅλων Δεσπότης καὶ Ποιητής, ἐξ ἀχράντου σου μήτρας σάρκα λαβών, προστάτιν σε ἔδειξε, τῶν ἀνθρώπων Πανάμωμε· διὰ τοῦτο πάντες, πρός σε καταφεύγομεν, ἱλασμὸν πταισμάτων, αἰτούμενοι Δέσποινα, καὶ αἰωνιζούσης, λυτρωθῆναι βασάνου, καὶ πάσης κακώσεως, τοῦ δεινοῦ κοσμοκράτορος· διὰ τοῦτο βοῶμέν σοι. Πρέσβευε τῷ σῷ Υἱῷ καὶ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς προσκυνοῦσιν ἐν πίστει, τὸν πανάγιον τόκον σου."

meMA.PostGospelGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.PostGospelGlory.melody = ""
meMA.PostGospelGlory.incipit = ho.ho03_gr_GR_cog.hoMA.PostGospelHierarch.incipit
meMA.PostGospelGlory.text = ho.ho03_gr_GR_cog.hoMA.PostGospelHierarch.text

meMA.PostGospelBoth.mode = miscellanea_gr_GR_cog.misc.Mode2
