meSV.Stichera1.mode = miscellanea_gr_GR_cog.misc.Mode1
meSV.Stichera1.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
meSV.Stichera1.incipit = "Θεωρὸς γεγένησαι νοΐ, νοερῶν δυνάμεων…"
meSV.Stichera1.text = "Θεωρὸς γεγένησαι νοΐ, νοερῶν δυνάμεων, ὡς πρακτικὸς θεῖα λόγια, διατιθέμενος, ἐν τῇ σῇ καρδίᾳ, ἐν ᾗ καὶ ἀνάβασιν, ὡς κλίμακα ἐστήριξας Ὅσιε, Σάββα Πατήρ ἡμῶν, καὶ πρεσβεύεις δωρηθῆναι ἡμῖν, τὴν εἰρήνην, καὶ τὸ μέγα ἔλεος."

meSV.Stichera2.mode = miscellanea_gr_GR_cog.misc.Mode1
meSV.Stichera2.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
meSV.Stichera2.incipit = "Σάββα Ὁσιώτατε τὴν σήν, ἐκ…"
meSV.Stichera2.text = "Σάββα Ὁσιώτατε τὴν σήν, ἐκ παιδὸς ἀνέθηκας, ζωὴν Χριστῷ τῷ Θεῷ ἡμῶν, ὑφʼ οὗ σθενούμενος, τῆς σαρκὸς τὰ πάθη, λογισμῷ ὑπέταξας, τὸ χεῖρον ὑποτάττων τῷ κρείττονι· διὸ ἱκέτευε, δωρηθῆναι ταῖς ψυχαῖς ἡμῶν, τὴν εἰρήνην, καὶ τὸ μέγα ἔλεος."

meSV.Stichera3.mode = miscellanea_gr_GR_cog.misc.Mode1
meSV.Stichera3.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
meSV.Stichera3.incipit = "Θεόφρον Πατὴρ ἡμῶν φωστήρ, καθωράθης…"
meSV.Stichera3.text = "Θεόφρον Πατὴρ ἡμῶν φωστήρ, καθωράθης μέγιστος, φωταγωγῶν τὴν ὑφήλιον, θαυμάτων λάμψεσι, καὶ ἐνθέων ἔργων· ὅθεν μετὰ κοίμησιν, τὸ ἄδυτόν σε φῶς ὑπεδέξατο· διὸ ἱκέτευε, δωρηθῆναι ταῖς ψυχαῖς ἡμῶν, τὴν εἰρήνην, καὶ τὸ μέγα ἔλεος."

meSV.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
meSV.SticGlory.melody = ""
meSV.SticGlory.incipit = me.m12.d05_gr_GR_cog.meVE.Lity3.incipit
meSV.SticGlory.text = me.m12.d05_gr_GR_cog.meVE.Lity3.text

meSV.SticBoth.mode = miscellanea_gr_GR_cog.misc.Mode2
meSV.SticBoth.melody = ""
meSV.SticBoth.incipit = ho.ho23_gr_GR_cog.hoCA.Troparion7.incipit
meSV.SticBoth.text = ho.ho23_gr_GR_cog.hoCA.Troparion7.text

meSV.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode2
meSV.Aposticha1.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meSV.Aposticha1.incipit = "Ὤφθης ἐκ μητρικῶν, σπαργάνων θεοφόρε…"
meSV.Aposticha1.text = "Ὤφθης ἐκ μητρικῶν, σπαργάνων θεοφόρε, ἡγιασμένον σκεῦος, Πατὴρ ἡμῶν καὶ οἶκος, τοῦ παναγίου Πνεύματος."

meSV.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode2
meSV.Aposticha2.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meSV.Aposticha2.incipit = "Φέρων ἐν ταῖς χερσί, σοῦ…"
meSV.Aposticha2.text = "Φέρων ἐν ταῖς χερσί, σοῦ Σάββα τοῦ Κυρίου, Σταυρὸν τὰ τῶν δαιμόνων, φαντάσματα τελείως, Πατὴρ ἡμῶν ἠφάνισας."

meSV.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode2
meSV.Aposticha3.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meSV.Aposticha3.incipit = "Δόλους τῶν πονηρῶν, δαιμόνων θριαμβεύσας…"
meSV.Aposticha3.text = "Δόλους τῶν πονηρῶν, δαιμόνων θριαμβεύσας, τῇ τοῦ Σταυροῦ δυνάμει, ἐτράνωσας τὴν δόξαν, Χριστοῦ Σάββα Πατὴρ ἡμῶν."

meSV.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
meSV.AposGlory.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
meSV.AposGlory.incipit = me.m08.d14_gr_GR_cog.meMA.AposGlory.incipit
meSV.AposGlory.text = me.m08.d14_gr_GR_cog.meMA.AposGlory.text

meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Stichera01.greekmelody = he.a.m5_gr_GR_cog.heAU.OsiePater.greekname
meVE.Stichera01.melody = he.a.m5_gr_GR_cog.heAU.OsiePater.name
meVE.Stichera01.incipit = "Σάββα θεόφρον…"
meVE.Stichera01.text = "Σάββα θεόφρον, τῶν Ἀγγέλων ἰσοστάσιε, ὁμόσκηνε Ὁσίων, συνόμιλε Προφητῶν, Μαρτύρων Ἀποστόλων συγκληρονόμε, φῶς τὸ ἀνέσπερον, ὁ νῦν κατοικῶν, οὗ ταῖς φρυκτωρίαις, λαμπόμενος ταῖς θείαις, τῷ ἀκροτάτῳ τῶν ἐφετῶν, ὁ παρεστὼς παῤῥησίᾳ λελαμπρυσμένος, καὶ ἐνηδόμενος αὐτοῦ ταῖς θεωρίαις, καὶ ἐντρυφῶν αὐτοῦ, τῷ κάλλει ἀνενδότως, Χριστὸν ἱκέτευε, Χριστὸν δυσώπει Ὅσιε, δωρηθῆναι τῇ Ἐκκλησίᾳ, ὁμόνοιαν, εἰρήνην, καὶ μέγα ἔλεος."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Stichera02.melody = he.a.m5_gr_GR_cog.heAU.OsiePater.name
meVE.Stichera02.incipit = "Σάββα παμμάκαρ…"
meVE.Stichera02.text = "Σάββα παμμάκαρ, ἐγκρατείας λύχνος ἄσβεστος, φωστὴρ τῶν μοναζόντων ὁ διαυγέστατος, ἀγάπης φρυκτωρίαις λελαμπρυσμένος, πύργος ἀκλόνητος τῆς ὑπομονῆς, ἔρεισμα καὶ σθένος τῶν πίστει σε τιμώντων, τῶν ἰαμάτων ὁ θησαυρός, ὁ πολιστὴς τῆς ἐρήμου ὡς ἀληθῶς, ὁ ὡς Παράδεισον αὐτὴν ἔνθεον δείξας, θείους προσφέρουσαν, καρπούς τῶν σῳζομένων, Χριστὸν ἱκέτευε, Χριστὸν δυσώπει Ὅσιε, δωρηθῆναι τῇ Ἐκκλησίᾳ, ὁμόνοιαν, εἰρήνην, καὶ μέγα ἔλεος."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Stichera03.melody = he.a.m5_gr_GR_cog.heAU.OsiePater.name
meVE.Stichera03.incipit = "Σάββα θεόφρον, ἀρετῶν στῦλος…"
meVE.Stichera03.text = "Σάββα θεόφρον, ἀρετῶν στῦλος ὁ πύρινος, πυρσὸς ὁ ἐκ θαλάσσης, τῆς κοσμικῆς τοὺς λαούς, λιμένα πρὸς τὸν θεῖον καθοδηγῶν· πλάνης τὰ πνεύματα ὁ καταβαλών, Πνεύματος Ἁγίου τὸ καθαρὸν δοχεῖον, ὁ ποδηγέτης τῶν μοναστῶν, ἠκριβωμένη τε στάθμη τῆς ἐγκρατείας, τῆς ταπεινώσεως, περίβλεπτον τὸ ὕψος, κρήνη ἡ βρύουσα, ἰάσεων πελάγη, Χριστὸν ἱκέτευε, Χριστὸν δυσώπει Ὅσιε, δωρηθῆναι τῇ Ἐκκλησία, ὁμόνοιαν, εἰρήνην, καὶ μέγα ἔλεος."

meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Τὸ κατʼ εἰκόνα τηρήσας ἀλώβητον…"
meVE.SticGlory.text = "Τὸ κατʼ εἰκόνα τηρήσας ἀλώβητον, νοῦν ἡγεμόνα κατὰ παθῶν ὀλεθρίων, ἀσκητικῶς ἐνστησάμενος, εἰς τὸ καθʼ ὁμοίωσιν ὡς δυνατὸν ἀνελήλυθας· ἀνδρικῶς γὰρ τὴν φύσιν ἐκβιασάμενος, ἔσπευσας τὸ χεῖρον καθυποτάξαι τῷ κρείττονι, καὶ τὴν σάρκα δουλῶσαι τῷ πνεύματι. Ὅθεν μοναζόντων, ἀνεδείχθης ἀκρότης, πολιστὴς τῆς ἐρήμου, εὐδρομούντων ἀλείπτης, κανὼν ἀρετῆς ἀκριβέστατος. Καὶ νῦν ἐν οὐρανοῖς, τῶν ἐσόπτρων λυθέντων μακάριε, καθαρῶς ἐποπτεύεις, τὴν ἁγίαν Τριάδα, ἐντυγχάνων ἀμέσως, ὑπὲρ τῶν πίστει καὶ πόθῳ τιμώντων σε."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticTheotokion.melody = ""
meVE.SticTheotokion.incipit = oc.m6.d1_gr_GR_cog.ocVE.SticTheotokion.incipit
meVE.SticTheotokion.text = oc.m6.d1_gr_GR_cog.ocVE.SticTheotokion.text

meVE.Lity1.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Lity1.melody = ""
meVE.Lity1.incipit = "Ἀσκητικὸν γυμνάσιον συγκροτήσας ἐπὶ γῆς…"
meVE.Lity1.text = "Ἀσκητικὸν γυμνάσιον συγκροτήσας ἐπὶ γῆς, Ὅσιε Σάββα, τῶν παθῶν τὰς προσβολάς, ἐν τῇ ῥοῇ τῶν δακρύων σου, πάσας ἀπήμβλυνας. Κλῖμαξ θεία καὶ σεπτή, εἰς οὐρανούς ἀνάγουσα, τοῖς πᾶσιν ἐγνωρίσθη, ὁ θεόληπτος βίος σου. Εὐσεβείας γὰρ καρποὺς ἐν αὐτῷ ἐνδειξάμενος, θεραπεύεις διʼ αὐτῶν τὰς ἀσθενείας τῶν παθῶν, τῶν πιστῶς ἐκβοώντων σοι. Χαίροις τῆς Ἑῴας ἀστὴρ χρυσαυγέστατος, καὶ τῶν Μοναζόντων λαμπαδοῦχε καὶ ποιμήν. Χαίροις Ἀοίδιμε, τὸ τῆς ἐρήμου κάλλιστον θρέμμα, καὶ τῆς Ἐκκλησίας ἀκράδαντον ἔρεισμα. Χαίροις τῶν πλανωμένων ὁ μέγας ὁδηγός. Χαίροις τὸ ἡμέτερον καύχημα, καὶ τῆς οἰκουμένης φαιδρὸν ἀγαλλίαμα."

meVE.Lity2.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Lity2.melody = ""
meVE.Lity2.incipit = "Τὸν ἐπὶ γῆς Ἄγγελον, καὶ…"
meVE.Lity2.text = "Τὸν ἐπὶ γῆς Ἄγγελον, καὶ ἐν οὐρανοῖς ἄνθρωπον Θεοῦ, τοῦ κόσμου τὴν εὐκοσμίαν, τὴν τρυφὴν τῶν ἀγαθῶν καὶ τῶν ἀρετῶν, τῶν Ἀσκητῶν τὸ καύχημα, Σάββαν τιμήσωμεν· πεφυτευμένος γὰρ ἐν τῷ οἴκῳ τοῦ Θεοῦ, ἐξήνθησε δικαίως, καὶ ὡσεὶ κέδρος ἐν ἐρήμῳ, ἐπλήθυνε τὸ ποίμνιον τοῦ Χριστοῦ, τῶν λογικῶν προβάτων, ἐν ὁσιότητι καὶ δικαιοσύνῃ."

meVE.Lity3.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Lity3.melody = ""
meVE.Lity3.incipit = "Ὅσιε Πάτερ, ἐκ βρέφους τὴν…"
meVE.Lity3.text = "Ὅσιε Πάτερ, ἐκ βρέφους τὴν ἀρετὴν ἐπιμελῶς ἀσκήσας, ὄργανον γέγονας τοῦ Ἁγίου Πνεύματος καὶ παρʼ αὐτοῦ λαβὼν τῶν θαυμάτων τὴν ἐνέργειαν, ἔπεισας τοὺς ἀνθρώπους καταφρονεῖν τῶν ἡδέων· νῦν δὲ τῷ θείῳ φωτί, καθαρώτερον ἐλλαμπόμενος, φώτισον καὶ ἡμῶν τὰς διανοίας, Σάββα Πατὴρ ἡμῶν."

meVE.LityGlory.poet = poets_gr_GR_cog.po.Theofanous
meVE.LityGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.LityGlory.melody = ""
meVE.LityGlory.incipit = "Τῶν ὑπὲρ νοῦν ἀγαθῶν δεξάμενος…"
meVE.LityGlory.text = "Τῶν ὑπὲρ νοῦν ἀγαθῶν δεξάμενος ἔρωτα, πάντα τὰ ἐν τῷ κόσμῳ τερπνὰ ὑπερεῖδες θεόληπτε· ἐντεῦθεν γὰρ τῷ καρπῷ οὐχ ἑάλως, καθάπερ Ἀδάμ· τὸν ὄφιν δὲ ἐναποκρουσάμενος διʼ ἐγκρατείας, ἀγγελικῶς τὸν βίον διήνυσας, καὶ νῦν ἐν οὐρανοῖς αὐλίζῃ, ἐπαπολαύων τοῦ ξύλου τῆς ζωῆς, Θεὸν ἱλεούμενος ὑπὲρ ἡμῶν, τῶν πιστῶς ἐκτελούντων, ἡγιασμένε Σάββα τὴν μνήμην σου."

meVE.LityBoth.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.LityBoth.melody = ""
meVE.LityBoth.incipit = ho.ho23_gr_GR_cog.hoCA.Troparion7.incipit
meVE.LityBoth.text = ho.ho23_gr_GR_cog.hoCA.Troparion7.text

meVE.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Aposticha1.greekmelody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.greekname
meVE.Aposticha1.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.melody
meVE.Aposticha1.incipit = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.incipit
meVE.Aposticha1.text = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.text

meVE.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Aposticha2.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meVE.Aposticha2.incipit = "Ἄνθραξ θεοφεγγὴς τῷ πυρί…"
meVE.Aposticha2.text = "Ἄνθραξ θεοφεγγὴς τῷ πυρί, προσομιλήσας Θεοφόρε τοῦ Πνεύματος, ἐδείχθης ἐν κόσμῳ Σάββα, καταλαμπρύνων ψυχάς, τῶν πιστῶς θεόφρον προσιόντων σοι, πρὸς φῶς ὁδηγῶν αὐτούς, τὸ ἀνέσπερον Ὅσιε, ἐρημικοὺς δέ, δροσιζόμενος ἄνωθεν, θείᾳ χάριτι κατεμάρανας ἄνθρακας. Ὅθεν καὶ τὸν τῆς νίκης σοι, προδήλως δεδώρηται, στέφανον Πάτερ τῆς θείας, δικαιοσύνης ὁ πρύτανις, Χριστός· ὃν δυσώπει, ταῖς ψυχαῖς ἡμῶν δοθῆναι, τὸ μέγα ἔλεος."

meVE.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Aposticha3.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meVE.Aposticha3.incipit = "Κλῖμαξ οὐρανομήκης σαφῶς…"
meVE.Aposticha3.text = "Κλῖμαξ οὐρανομήκης σαφῶς, ἡ πολιτεία σου Θεόφρον γεγένηται, διʼ ἧς περ πρὸς ὕψος ἤρθης, καὶ τῷ Δεσπότῃ Χριστῷ, ὁμιλεῖν παμμάκαρ κατηξίωσαι, τὸν νοῦν ἐλλαμπόμενος, ταῖς ἐκεῖθεν ἐλλάμψεσι· μαρμαρυγαῖς δέ, ταῖς αὐτοῦ φωτιζόμενος, τὴν ἰσάγγελον, ἐκομίσω φαιδρότητα· ᾧ καὶ νῦν παριστάμενος, ἱκέτευε Ὅσιε, τοὺς ἐκτελοῦντας τὴν θείαν, καὶ πανσεβάσμιον μνήμην σου, σὺν σοὶ παραστῆναι, καὶ τῷ κόσμῳ δωρηθῆναι, τὸ μέγα ἔλεος."

meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Τῶν μοναστῶν τὰ πλήθη…"
meVE.AposGlory.text = "Τῶν μοναστῶν τὰ πλήθη, τὸν Καθηγητήν σε τιμῶμεν, Σάββα Πατὴρ ἡμῶν· διὰ σοῦ γὰρ τὴν τρίβον, τὴν ὄντως εὐθεῖαν, πορεύεσθαι ἔγνωμεν. Μακάριος εἶ, τῷ Χριστῷ δουλεύσας, καὶ ἐχθροῦ θριαμβεύσας τὴν δύναμιν, Ἀγγέλων συνόμιλε, Δικαίων ὁμόσκηνε, καὶ Ὁσίων· μεθʼ ὧν πρέσβευε τῷ Κυρίῳ, ἐλεηθῆναι τὰς ψυχὰς ἡμῶν."

meVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.AposTheotokion.melody = ""
meVE.AposTheotokion.incipit = oc.m8.d1_gr_GR_cog.ocVE.AposTheotokion.incipit
meVE.AposTheotokion.text = oc.m8.d1_gr_GR_cog.ocVE.AposTheotokion.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Apolytikion1ger.greekmelody = he.a.m1_gr_GR_cog.heAU.TisErimouPolitis.greekname
meVE.Apolytikion1ger.melody = he.a.m1_gr_GR_cog.heAU.TisErimouPolitis.name
meVE.Apolytikion1ger.incipit = "Τῶν Ὁσίων ἀκρότης καὶ Ἀγγέλοις…"
meVE.Apolytikion1ger.text = "Τῶν Ὁσίων ἀκρότης καὶ Ἀγγέλοις ἐφάμιλλος, ὡς ἡγιασμένος ἐδείχθης, ἐκ παιδὸς Σάββα Ὅσιε· οὐράνιον γὰρ βίον ὑπελθών, πρὸς ἔνθεον ζωὴν χειραγωγεῖς, διὰ λόγου τε καὶ πράξεως ἀληθοῦς, τοὺς πίστει ἐκβοῶντάς σοι· δόξα τῷ δεδωκότι σοι ἰσχύν, δόξα τῷ σὲ στεφανώσαντι, δόξα τῷ ἐνεργοῦντι διὰ σοῦ, πᾶσιν ἰάματα."

meVE.GeneralApolytikion1.name = "Σάββα πατὴρ ἡμῶν ὅσιε."
meVE.MM.GeneralApolytikion1.text = properties_gr_GR_cog.media.key

meMA.Kathisma11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kathisma11.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meMA.Kathisma11.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Kathisma11.incipit = "Τὸν βίον εὐσεβῶς…"
meMA.Kathisma11.text = "Τὸν βίον εὐσεβῶς, ἐπὶ γῆς ἐκτελέσας, δοχεῖον καθαρόν, σὺ τοῦ Πνεύματος ὤφθης, φωτίζων τοὺς ἐν πίστει σοι, προσιόντας μακάριε· ὅθεν αἴτησαι, τὸν σόν Δεσπότην, φωτίσαι, τὰς ψυχὰς ἡμῶν, τῶν ἀνυμνούντων σε Σάββα, θεόφρον Πατὴρ ἡμῶν."

meMA.Kathisma1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kathisma1T.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Kathisma1T.incipit = oc.m1.d1_gr_GR_cog.ocMA.Kathisma13.incipit
meMA.Kathisma1T.text = oc.m1.d1_gr_GR_cog.ocMA.Kathisma13.text

meMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Kathisma21.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Kathisma21.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Kathisma21.incipit = "Τὸν Σταυρὸν τοῦ Κυρίου…"
meMA.Kathisma21.text = "Τὸν Σταυρὸν τοῦ Κυρίου ἄρας σοφέ, καὶ αὐτῷ μέχρι τέλους ἀκολουθῶν, τὸν νοῦν οὐχ ὑπέστρεψας, ἐν τῷ κόσμῳ θεόσοφε· ἐγκρατείᾳ καὶ πόνοις, τὰ πάθη ἐνέκρωσας, καὶ ναὸν ἡτοίμασας, σαυτὸν τῷ Κυρίῳ σου· ὅθεν χαρισμάτων, ἀμοιβὴν ἐκομίσω, ἰᾶσθαι νοσήματα, καὶ διώκειν τὰ πνεύματα, Θεοφόρε μακάριε. Πρέσβευε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ, τὴν ἁγίαν μνήμην σου."

meMA.Kathisma2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Kathisma2T.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.melody
meMA.Kathisma2T.incipit = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.incipit
meMA.Kathisma2T.text = "Τὴν Σοφίαν καὶ Λόγον ἐν σῇ γαστρί, συλλαβοῦσα ἀφράστως Μήτηρ Θεοῦ, τῷ κόσμῳ ἐκύησας, τὸν τὸν κόσμον κατέχοντα· καὶ ἐν ἀγκάλαις ἔσχες, τὸν πάντα συνέχοντα, τὸν τροφοδότην πάντων, καὶ Πλάστην τῆς κτίσεως. Ὅθεν δυσωπῶ σε, Παναγία Παρθένε, ῥυσθῆναι πταισμάτων μου, ὅταν μέλλω παρίστασθαι, πρὸ προσώπου τοῦ Κτίστου μου. Δέσποινα Παρθένε ἁγνή, τὴν σὴν βοήθειαν τότε μοι δώρησαι· καὶ γὰρ δύνασαι, ὅσα θέλεις πανάμωμε."

meMA.Kathisma31.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Kathisma31.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Kathisma31.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Kathisma31.incipit = "Τὰ ἐπίγεια πάντα καταλιπών, καὶ…"
meMA.Kathisma31.text = "Τὰ ἐπίγεια πάντα καταλιπών, καὶ ἐν κόσμῳ ὑπάρχων σωματικῶς, τῷ πνεύματι γέγονας, τῶν Ἀγγέλων συμμέτοχος· τὰ γὰρ παρόντα πάθη νεκρώσας τοῦ σώματος, τῆς Τριάδος ἐδείχθης θεράπων Μακάριε. Ὅθεν καὶ νοσούντων, θεραπεύεις τὰ πάθη, καὶ λόγῳ τὰ πνεύματα, ἀπελαύνεις τῇ χάριτι, θεοφόρε Πατὴρ ἡμῶν. Πρέσβευε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ, τὴν ἁγίαν μνήμην σου."

meMA.Kathisma3T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Kathisma3T.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Kathisma3T.incipit = oc.m8.d1_gr_GR_cog.ocMA.Kathisma13.incipit
meMA.Kathisma3T.text = oc.m8.d1_gr_GR_cog.ocMA.Kathisma13.text

meMA.PostGospelGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.PostGospelGlory.melody = ""
meMA.PostGospelGlory.incipit = ho.ho03_gr_GR_cog.hoMA.PostGospelMonastic.incipit
meMA.PostGospelGlory.text = ho.ho03_gr_GR_cog.hoMA.PostGospelMonastic.text

meMA.PostGospelBoth.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.PostGospelBoth.melody = ""
meMA.PostGospelBoth.incipit = ho.ho03_gr_GR_cog.hoMA.PostGospelTheotokos.incipit
meMA.PostGospelBoth.text = ho.ho03_gr_GR_cog.hoMA.PostGospelTheotokos.text

meMA.PostGospelIdiomelon.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.PostGospelIdiomelon.melody = ""
meMA.PostGospelIdiomelon.incipit = me.m01.d15_gr_GR_cog.meVE.AposGlory.incipit
meMA.PostGospelIdiomelon.text = me.m01.d15_gr_GR_cog.meVE.AposGlory.text

meMA.C1.acrostic.title = "Κανὼν τοῦ Ἁγίου,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Τον Πανάριστον ἐν Ἀσκηταῖς Σάβαν ἔξοχα μέλπω."
meMA.C1.acrostic.notice2 = "Γράφεται τό, Σ ά β α ν ἐνταῦθα διʼ ἑνὸς β, οὐχ ὡς ἁμάρτημα, ἀλλὰ διὰ τὸ μέτρον τοῦ στίχου· ὅρα καὶ τὰ ἐφεξῆς τῆ Ἀκροστιχίδος Τροπάρια."
meMA.C1.poet = poets_gr_GR_cog.po.Theofanous
meMA.C1.title = titles_gr_GR_cog.ti.CanonDevoutM
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_DevoutMan.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C11.greekmelody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.greekname
meMA.Ode1C11.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C11.incipit = "Τῇ φωταυγείᾳ τοῦ Ἁγίου Πνεύματος…"
meMA.Ode1C11.text = "Τῇ φωταυγείᾳ τοῦ Ἁγίου Πνεύματος, Σάββα καταύγασον, τοὺς εὐσεβεῖς πόθῳ, ὕμνοις εὐφημοῦντάς σε, τῶν Ἀσκητῶν τὸ καύχημα, Μοναζόντων τὸ κλέος, τὸν τῆς ἐρήμου κοσμήτορα, τὸν τῆς παρθενίας Διδάσκαλον."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C12.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C12.incipit = "Ὅλον τὸν πόθον πρὸς Θεὸν…"
meMA.Ode1C12.text = "Ὅλον τὸν πόθον πρὸς Θεὸν ἀνέτεινας, ἀπὸ νεότητος, καὶ πρὸς αὐτὸν ἔχων, πᾶσάν σου τὴν ἔφεσιν, τὰ τῆς σαρκὸς κινήματα, καὶ παθῶν τὰς ἐφόδους, διʼ ἐγκρατείας ἐνέκρωσας, Σάββα θεοφόρε πανεύφημε."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C13.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C13.incipit = "Νενικηκὼς τὸν τῷ καρπῷ κρυπτόμενον…"
meMA.Ode1C13.text = "Νενικηκὼς τὸν τῷ καρπῷ κρυπτόμενον, ὄφιν ἐπάτησας, καὶ τοὺς αὐτοῦ βρόχους, κούφως ὑπερβέβηκας, θεοσεβείας πτέρυξιν, ἀνιπτάμενος Πάτερ· ζωὴν δὲ χαίρων ἐτρύγησας, ἀπὸ τοῦ φυτοῦ τοῦ τῆς γνώσεως."

meMA.Ode1C14.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C14.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C14.incipit = "Περιλαμπόμενος φωτὶ τῆς χάριτος, τὸ…"
meMA.Ode1C14.text = "Περιλαμπόμενος φωτὶ τῆς χάριτος, τὸ πῦρ εἰσέδραμες, ὥσπερ οἱ τρεῖς παῖδες, μείνας ἀκατάφλεκτος, σὲ τοῦ Θεοῦ φυλάξαντος, καὶ μηνύσαντος πᾶσι, τὴν ἐσομένην σοι ὕστερον, Πάτερ προκοπὴν καὶ λαμπρότητα."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C1T.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C1T.incipit = "Ἀκατασχέτοις καθʼ ἡμῶν ὁ θάνατος…"
meMA.Ode1C1T.text = "Ἀκατασχέτοις καθʼ ἡμῶν ὁ θάνατος, ὁρμαῖς ἐκέχρητο· ἀλλὰ τῷ σῷ τόκῳ προσεγγίσας ὤλετο, καὶ προσβαλὼν κατήργηται, Θεοτόκε Παρθένε· ζωὴν γὰρ ὄντως ἀΐδιον, σεσωματωμένην γεγέννηκας."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C11.greekmelody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.greekname
meMA.Ode3C11.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C11.incipit = "Νοῦν ἡγεμόνα τῶν παθῶν, Πανόλβιε…"
meMA.Ode3C11.text = "Νοῦν ἡγεμόνα τῶν παθῶν, Πανόλβιε καταστήσας, βραβευτὴς δικαιοσύνης ἐδείχθης· τῷ γὰρ κρείττονι σαφῶς, τὸ χεῖρον καθυπέταξας· ὅθεν ὡς φοίνιξ Πάτερ, ἐν τοῖς ἐρήμοις ἐξήνθησας."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C12.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C12.incipit = "Ἀκολουθῆσαι διαγνούς, τοῖς ἴχνεσι τοῦ…"
meMA.Ode3C12.text = "Ἀκολουθῆσαι διαγνούς, τοῖς ἴχνεσι τοῦ Δεσπότου, μετανάστης τῆς πατρίδος ἐγένου, καὶ τὴν ἔρημον οἰκῶν, τὸ τρόπαιον ἀνέστησας, κατὰ τῶν ἀντιπάλων, θείᾳ δυνάμει ῥωννύμενος."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C13.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C13.incipit = "Ῥωμαλεότητι φρενῶν, Παμμάκαρ ὠχυρωμένος, τὰς…"
meMA.Ode3C13.text = "Ῥωμαλεότητι φρενῶν, Παμμάκαρ ὠχυρωμένος, τὰς ποικίλας τοῦ ἐχθροῦ μεθοδείας, ἐθριάμβευσας σοφέ, καὶ πᾶσιν ἐφανέρωσας, καὶ τὴν ὀφρὺν ἐκείνου τὴν ἐπηρμένην κατέβαλες."

meMA.Ode3C14.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C14.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C14.incipit = "Ἱλαρωτάτῃ σε ψυχῇ, καὶ προσηνεῖ…"
meMA.Ode3C14.text = "Ἱλαρωτάτῃ σε ψυχῇ, καὶ προσηνεῖ διαθέσει, ἀρεταῖς κατακοσμούμενον βλέπων, ὁ λαμπρότατος φωστήρ, Εὐθύμιος ἐδέξατο, φωτιστικῶς θεσπίζων, τὴν σὴν Παμμάκαρ φαιδρότητα."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C1T.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C1T.incipit = "Σωτηριώδους διʼ ἡμᾶς, τοῦ Λόγου…"
meMA.Ode3C1T.text = "Σωτηριώδους διʼ ἡμᾶς, τοῦ Λόγου οἰκονομίας, φωτεινὴ σὺ Μητροπάρθενε πύλη, ἐγνωρίσθης ἀληθῶς· σὺ γὰρ ἡμῖν εἰσήγαγες, τὴν νοητὴν ἀκτῖνα, τῆς ὑπερθέου Θεότητος."

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3Kathisma1.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Ode3Kathisma1.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3Kathisma1.incipit = "Τοὺς θορύβους τοῦ βίου καταλιπών…"
meMA.Ode3Kathisma1.text = "Τοὺς θορύβους τοῦ βίου καταλιπών, τὸν σταυρόν σου ἐπʼ ὤμων ἀναλαβών, ὅλον ἀνατέθεικας, σεαυτὸν τῷ Κυρίῳ σου, καὶ σαρκὸς δὲ ἔξω, καὶ κόσμου γενόμενος, τοῦ Ἁγίου ἐγένου, συνόμιλος Πνεύματος· ὅθεν καὶ πρὸς ζῆλον, τοὺς λαοὺς διεγείρων, τὰς πόλεις ἐκένωσας, καὶ ἐρήμους ἐπόλισας, θεοφόρε Πατὴρ ἡμῶν. Πρέσβευε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ, τὴν ἁγίαν μνήμην σου."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3KathismaT.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3KathismaT.incipit = "Τὴν ψυχήν μου Παρθένε, τὴν…"
meMA.Ode3KathismaT.text = "Τὴν ψυχήν μου Παρθένε, τὴν ταπεινήν, ἀπὸ βρέφους μολύνας ὁ μιαρός, καὶ λόγοις καὶ πράξεσιν, ἐμαυτὸν κατεῤῥύπωσα, καὶ οὐκ ἔχω τί πράξω, ἢ ποῦ καταφεύξομαι, ἀλλʼ οὐδʼ ἄλλην ἐλπίδα, πλήν σου Κόρη ἐπίσταμαι. Φεῦ μοι ὁ ἀχρεῖος! διὰ τοῦτο ἱκέτης, πρὸς σὲ τὴν Πανάχραντον, νῦν προστρέχω καὶ δέομαι, ὁμολογῶν σοι τό, Ἥμαρτον. Πρέσβευε τῷ σῷ Υἱῷ καὶ Θεῷ, τῶν πταισμάτων ἄφεσιν δοθῆναί μοι· εἰς σὲ γὰρ πάσας Παρθένε, τὰς ἐλπίδας ἀνέθηκα."

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C11.greekmelody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.greekname
meMA.Ode4C11.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C11.incipit = "Τὴν τῆς ψυχῆς, ἀνακαθαίρων κατάστασιν…"
meMA.Ode4C11.text = "Τὴν τῆς ψυχῆς, ἀνακαθαίρων κατάστασιν, καὶ πλατύνων, θείοις θεωρήμασι, χωρητικήν, ταύτην ἀληθῶς, θείων χαρισμάτων, εἰργάσω θεομακάριστε, ἁφῇ δὲ τῶν χειρῶν σου, ἀσθενοῦντας ἰάσω, μιμητὴς τοῦ Δεσπότου γενόμενος."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C12.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C12.incipit = "Ὁ κατὰ σοῦ, Πάτερ δεινῶς…"
meMA.Ode4C12.text = "Ὁ κατὰ σοῦ, Πάτερ δεινῶς θρασυνόμενος, κατεπόθη, ὡς Δαθὰν ὁ δείλαιος, ὡς Ἀβειρὼν ἐξαφανισθείς· σὲ γὰρ ἀοράτως, ἡ θεία χάρις ἐφύλαττε, πολλῶν προνοουμένη διὰ σοῦ σωζομένων, καὶ τοῖς σοῖς ἑπομένων διδάγμασι."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C13.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C13.incipit = "Νόμῳ Θεοῦ, παιδαγωγήσας θεσπέσιε, τὰς…"
meMA.Ode4C13.text = "Νόμῳ Θεοῦ, παιδαγωγήσας θεσπέσιε, τὰς αἰσθήσεις, πρὸς τὴν κατανόησιν, τῶν ἀσωμάτων καὶ νοητῶν, σοῦ ἐπιτηδείαν, κατέστησας τὴν διάνοιαν, προβαίνων ἀνενδότως, ἀπὸ δόξης εἰς δόξαν, ἐκ δυνάμεως Πάτερ εἰς δύναμιν."

meMA.Ode4C14.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C14.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C14.incipit = "Εὐεργετεῖν, τοὺς ὁμοφύλους προθέμενος, ἐν…"
meMA.Ode4C14.text = "Εὐεργετεῖν, τοὺς ὁμοφύλους προθέμενος, ἐν ἐρήμῳ, πόλεις ᾠκοδόμησας, θεοπρεπεῖς καὶ ψυχωφελεῖς καὶ ἐν γῇ διψώσῃ, πηγὰς ὑδάτων ἐξήγαγες, καὶ ὄμβρους οὐρανόθεν, παραδόξως θεόφρον, ἐν ἀνύδροις χωρίοις κατήγαγες."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C1T.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C1T.incipit = "Νεοθαλής, ἀθανασίας Παράδεισος, καὶ ὡραῖος…"
meMA.Ode4C1T.text = "Νεοθαλής, ἀθανασίας Παράδεισος, καὶ ὡραῖος, ὄντως ἀναδέδειξαι, ξύλον ζωῆς, ἐν σοὶ φυτευθέν, θεαρχικωτάτως, κυοφοροῦσα καὶ τίκτουσα, τὸ πᾶσιν ἀποστάζον, ζωηφόρους ἐλπίδας, τοῖς πιστῶς Θεοτόκον φρονοῦσί σε."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C11.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
meMA.Ode5C11.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C11.incipit = "Ἀκλινεῖ διανοίᾳ, πρὸς τὸν σὸν…"
meMA.Ode5C11.text = "Ἀκλινεῖ διανοίᾳ, πρὸς τὸν σὸν ποθούμενον ἀνατεινόμενος, παρʼ αὐτοῦ τὴν χάριν, τῶν μεγίστων θαυμάτων τὴν ἄφθονον, ἐκομίσω Πάτερ, καὶ τοὺς πιστῶς προσερχομένους, συμπαθῶς ἐθεράπευσας Ὅσιε."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C12.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C12.incipit = "Σαρκικῶν βαρημάτων, ὄγκον ἀποθέμενος, σκεῦος…"
meMA.Ode5C12.text = "Σαρκικῶν βαρημάτων, ὄγκον ἀποθέμενος, σκεῦος θεότευκτον, ἐκλογῆς ἐγένου, τοῦ ἁγίου θεσπέσιε Πνεύματος, ἀποχῇ βρωμάτων, καὶ προσευχῇ καὶ καρτερίᾳ, καὶ ταπεινοφροσύνῃ κοσμούμενος."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C13.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C13.incipit = "Κήρυξ θείων δογμάτων, μεγαλοφωνότατος κεχειροτόνησαι…"
meMA.Ode5C13.text = "Κήρυξ θείων δογμάτων, μεγαλοφωνότατος κεχειροτόνησαι, τῶν Συνόδων Πάτερ, τῶν Ἁγίων συνήγορος γέγονας, Βασιλεῖς σοφίζων, οἷς ἐμφανῶς χάριτι θείᾳ, τειχιζόμενος ὤφθης μακάριε."

meMA.Ode5C14.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C14.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C14.incipit = "Ἡ θεόθεν δοθεῖσα, χάρις σοι…"
meMA.Ode5C14.text = "Ἡ θεόθεν δοθεῖσα, χάρις σοι Θεόπνευστε διαβεβόηται, διεδόθη πᾶσιν, εἰς τὰ τῆς οἰκουμένης ἀκρότατα, ἐναργεῖς ποιοῦσα, θεοπρεπῶς τὰς ἀποδείξεις, τῶν θαυμάτων τὴν θείαν ἐνεργειαν."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C1T.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C1T.incipit = "Τῶν πιστῶν ἡ προστάτις, τεῖχος…"
meMA.Ode5C1T.text = "Τῶν πιστῶν ἡ προστάτις, τεῖχος ἀκατάλυτον, τῶν εὐφημούντων σε, ἡ παντὶ τῷ γένει, τῶν ἀνθρώπων φανεῖσα σωτήριος, ὡς Θεὸν τεκοῦσα, σωματικῶς ἐπιφανέντα, τὴν ψυχήν μου διάσωσον Πάναγνε."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C11.greekmelody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.greekname
meMA.Ode6C11.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C11.incipit = "Ἀγάπην πρὸς τὸν Θεόν, καὶ…"
meMA.Ode6C11.text = "Ἀγάπην πρὸς τὸν Θεόν, καὶ τὸν πλησίον κτησάμενος, τοῦ Νόμου καὶ Προφητῶν, πληροῖς τὸ κεφάλαιον· τὴν γὰρ ὑπερέχουσαν, πασῶν ἀσυγκρίτως, ἀρετὴν Πάτερ κατώρθωσας."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C12.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C12.incipit = "Ἰσάγγελον ἐπὶ γῆς, σὺ πολιτείαν…"
meMA.Ode6C12.text = "Ἰσάγγελον ἐπὶ γῆς, σὺ πολιτείαν διήνυσας, ἰσάγγελον δὲ τιμήν, Χριστός σοι δεδώρηται, Ἁγίων τὰ τάγματα, συνοδοιποροῦντα, τῇ ψυχῇ σου παρασχόμενος."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C13.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C13.incipit = "Σοφίας γόνος ὀφθείς, ἀρχὴν σοφίας…"
meMA.Ode6C13.text = "Σοφίας γόνος ὀφθείς, ἀρχὴν σοφίας ἐπόθησας, τὸν φόβον τὸν τοῦ Θεοῦ, ᾧ καὶ στοιχειούμενος, πρὸς τὴν τελειότητα, τὴν ἐνδεχομένην, τοῖς ἀνθρώποις Πάτερ ἔφθασας."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C1T.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C1T.incipit = "Σωτῆρα καὶ Λυτρωτήν, Θεὸν τῶν…"
meMA.Ode6C1T.text = "Σωτῆρα καὶ Λυτρωτήν, Θεὸν τῶν ὅλων καὶ Κύριον, τεκοῦσα διὰ σαρκός, ἡμῖν ὁμιλήσαντα, διάσωσον Πάναγνε, τοὺς προσκαλουμένους, ἐκ κινδύνων σε τὴν Δέσποιναν."

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Kontakion1.greekmelody = he.a.m8_gr_GR_cog.heAU.TiYpermacho.greekname
meMA.Kontakion1.melody = he.a.m8_gr_GR_cog.heAU.TiYpermacho.name
meMA.Kontakion1.incipit = "Ὡς ἀπὸ βρέφους τῷ Θεῷ…"
meMA.Kontakion1.text = "Ὡς ἀπὸ βρέφους τῷ Θεῷ θυσία ἄμωμος, προσενεχθεὶς διʼ ἀρετῆς, Σάββα μακάριε, τῷ σὲ πρὶν γεννηθῆναι ἐπισταμένῳ, ἐχρημάτισας Ὁσίων ἐγκαλλώπισμα, πολιστὴς τε τῆς ἐρήμου ἀξιέπαινος, διὸ κράζω σοι· Χαίροις Πάτερ ἀοίδιμε."

meMA.Oikos1.text = "Σοφίας ὑπάρχων βλάστημα, Σάββα Ὅσιε, παιδιόθεν ἐπόθησας Σοφίαν τὴν ἐνυπόστατον· ἣ συνοικήσασά σοι, ἀπὸ γῆς σε ἐχώρισε, καὶ πρὸς ὕψος ἀνήγαγεν, ἐξ ἀΰλων ἀνθέων πλέξασα στέφανον, καὶ τῇ σῇ ἐπιθεῖσα ἡγιασμένῃ κάρᾳ θεόφρον· ᾧπερ κεκοσμημένος, ἐξιλέωσαι τὸ Θεῖον, τοῦ δοθῆναί μοι σοφίαν λόγου ἐπαξίως, ὅπως ἀνυμνήσω τὴν ἁγίαν σου κοίμησιν, ἣν ἐδόξασε Χριστὸς ὁ Θεὸς ἡμῶν· διὸ καὶ ἡμεῖς κράζομέν σοι· Χαίροις Πάτερ ἀοίδιμε."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C11.greekmelody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.greekname
meMA.Ode7C11.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C11.incipit = "Ἀπέθου τὰ πρόσκαιρα, τῶν αἰωνίων…"
meMA.Ode7C11.text = "Ἀπέθου τὰ πρόσκαιρα, τῶν αἰωνίων διαμειβόμενος· σὺν Ἀγγέλοις χορεύεις, ὡς τῶν Ἀγγέλων πολιτευσάμενος, τὴν πολιτείαν, μεθʼ ὧν καὶ συνέψαλλες· Εὐλογητὸς ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C12.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C12.incipit = "Βοᾷ χαριστήρια, ἡ σὴ μεγίστη…"
meMA.Ode7C12.text = "Βοᾷ χαριστήρια, ἡ σὴ μεγίστη Λαύρα καὶ πάντιμος, οἰκιστήν σε καὶ κτίστην, καὶ πολιοῦχον προβαλλομένη Σοφέ, καὶ καυχωμένη κραυγάζει πρὸς κύριον· Εὐλογητός ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C13.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C13.incipit = "Ἀπαύστως ἱκέτευε, Σάββα θεόφρον ὑπὲρ…"
meMA.Ode7C13.text = "Ἀπαύστως ἱκέτευε, Σάββα θεόφρον ὑπὲρ τῆς ποίμνης σου, ἐκτενῶς τε δυσώπει, τοὺς σοὺς καμάτους διαιωνίζειν ἀεί, καρποφοροῦντας, τοὺς πόθῳ κραυγάζοντας· Εὐλογητός ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C1T.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C1T.incipit = "Νυμφῶνα πανάχραντον, τῆς ὑπὲρ λόγον…"
meMA.Ode7C1T.text = "Νυμφῶνα πανάχραντον, τῆς ὑπὲρ λόγον Λόγου σαρκώσεως, καὶ Παστάδα καὶ Θρόνον, ὀρθὰ φρονοῦντες σὲ ὀνομάζομεν, καὶ γεγηθότες, τῷ τόκῳ σου ψάλλομεν· Εὐλογητός ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C11.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
meMA.Ode8C11.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C11.incipit = "Ἐν εὐφροσύνῃ Ὅσιε, τῶν Ἁγίων…"
meMA.Ode8C11.text = "Ἐν εὐφροσύνῃ Ὅσιε, τῶν Ἁγίων τὰ τάγματα, τῆς καθαρωτάτης, σοῦ ψυχῆς προτρέχουσιν, εἰς τόπον ἀνέσεως, εἰς φωτεινὰ σκηνώματα, ἔνθα τῶν Ἁγίων, οἱ χοροὶ ποδηγοῦντες· μεθʼ ὧν νῦν ἀναμέλπεις· Ἱερεῖς εὐλογεῖτε, λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C12.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C12.incipit = "Ξένα τὰ σὰ θαυμάσια· τοὺς…"
meMA.Ode8C12.text = "Ξένα τὰ σὰ θαυμάσια· τοὺς γὰρ θῆρας ἡμέρωσας, προκατηρεμίσας, τῶν παθῶν τὰ κύματα, προλέγεις τὰ μέλλοντα, προφητικῷ χαρίσματι, στίφη τῶν δαιμόνων, φυγαδεύων ἐλαύνεις, εὐτόνοις ἀγρυπνίαις, προσευχαῖς καὶ νηστείαις, Σταυροῦ τε τῇ ἀμάχῳ, δυνάμει θεοφόρε."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C13.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C13.incipit = "Ὁ Μωϋσῇ τὸ πρότερον, ἀπὸ…"
meMA.Ode8C13.text = "Ὁ Μωϋσῇ τὸ πρότερον, ἀπὸ στύλου φθεγγόμενος, στῦλον ἀπὸ γῆς, εἰς οὐρανοὺς ὁλόφωτον, ἐκτείνας σοι ἔδειξεν, ἔνθα καὶ νῦν κατάκειται, τὸ καρτερικόν σου, καὶ πολύαθλον σῶμα· ᾧ πίστει παρεστῶτες, εὐσεβῶς μελῳδοῦμεν· Λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

meMA.Ode8C14.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C14.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C14.incipit = "Χαρμονικῶς ἡ μνήμη σου, ἐκτελεῖται…"
meMA.Ode8C14.text = "Χαρμονικῶς ἡ μνήμη σου, ἐκτελεῖται Πανεύφημε· τὴν χαροποιὸν γὰρ ἀρετὴν ἐνδέδυσαι, τὸ ὄντως ἱμάτιον, τοῦ σωτηρίου καὶ καθαρόν, καὶ φωτοειδῆ τῆς εὐφροσύνης χιτῶνα· ᾧ νῦν ὡραϊσμένως, μελῳδεῖς ἀνενδότως· Λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C1T.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C1T.incipit = "Ἀπειρογάμως τέτοκας, καὶ Παρθένος διέμεινας…"
meMA.Ode8C1T.text = "Ἀπειρογάμως τέτοκας, καὶ Παρθένος διέμεινας, καὶ τῷ ξένῳ τόκῳ σου, συνῆψας ἅπαντα, τὸν χρόνιον πόλεμον, καὶ τὴν μακρὰν διάστασιν λύσασα, Χριστὸν τὸν τῆς εἰρήνης δοτῆρα, βαστάζοντα ἐν κόλποις· ὃν πιστῶς εὐλογοῦντες, σὲ πόθῳ ἀνυμνοῦμεν, τὴν μόνην Θεοτόκον."

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C11.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9C11.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C11.incipit = "Μυρίζει σου ἡ θήκη πνευματικήν…"
meMA.Ode9C11.text = "Μυρίζει σου ἡ θήκη πνευματικήν, εὐωδίαν πλουσίως εὐφραίνουσα, τοὺς σοὺς υἱούς, σὲ περιεστώτας εἰλικρινῶς, ἐνθυμουμένους Ὅσιε, τὴν Ἀγγελικήν σου διαγωγήν, καὶ τὴν σοὶ δεδομένην, λαμπρότητα καὶ δόξαν, καὶ τὴν ἀΐδιον τερπνότητα."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C12.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C12.incipit = "Ἐῤῥάγη ἐν ἐρήμῳ ὕδωρ καὶ…"
meMA.Ode9C12.text = "Ἐῤῥάγη ἐν ἐρήμῳ ὕδωρ καὶ γῆ, ἡ διψῶσα εἰς ἕλη ἐγένετο, ταῖς προσευχαῖς, μετασκευασθεῖσα Πάτερ ταῖς σαῖς· ἀσκητικαὶ γὰρ φάλαγγες, ταύτην κατοικοῦσι ποταμηδόν, ἡ χώρα Ἰορδάνου, ἐξήνθησεν ὡς κρίνον, ἀρδευομένη τοῖς σοῖς δάκρυσι."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C13.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C13.incipit = "Λαμπρότης τῶν Ἁγίων ἐν οὐρανοῖς…"
meMA.Ode9C13.text = "Λαμπρότης τῶν Ἁγίων ἐν οὐρανοῖς, ὡς δικαίῳ σοι Πάτερ ἀνέτειλε· τὸν γὰρ Χριστόν, τὴν δικαιοσύνην τὴν ἀληθῆ, περιφανῶς ἠγάπησας, οὗ τὴν πολιτείαν ἰχνηλατῶν, τὴν τούτου ζωηφόρον, Παμμάκαρ ἐμιμήσω, ὡς δυνατόν σοι ἁγιότητα."

meMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C14.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C14.incipit = "Πλουσίως Θεοφόρε λάμπων φωτί, καὶ…"
meMA.Ode9C14.text = "Πλουσίως Θεοφόρε λάμπων φωτί, καὶ χορείας Ἀγγέλων θεώμενος, φωτοειδεῖς, περιπολευούσας τὸ τρισσὸν φῶς, καὶ δεχομένας χάριτι, τὰς τῆς θεοπτίας ἐπιβολάς, μὴ παύσῃ ἱκετεύων, ἀφέσεως πταισμάτων, ἀξιωθῆναι τοὺς ὑμνοῦντάς σε."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C1T.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C1T.incipit = "Ὡράθης ὦ Παρθένε Μήτηρ Θεοῦ…"
meMA.Ode9C1T.text = "Ὡράθης ὦ Παρθένε Μήτηρ Θεοῦ, ὑπὲρ φύσιν τεκοῦσα ἐν σώματι, τὸν ἀγαθόν, Λόγον ἐκ καρδίας τῆς ἑαυτοῦ, ὃν ὁ Πατὴρ ἠρεύξατο, πάντων πρὸ αἰώνων ὡς ἀγαθός, ὃν νῦν καὶ τῶν σωμάτων, ἐπέκεινα νοοῦμεν, εἰ καὶ τὸ σῶμα περιβέβληται."

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_gr_GR_cog.heAU.EnPnevmatiToIero.greekname
meMA.Exaposteilarion1.melody = he.a.m3_gr_GR_cog.heAU.EnPnevmatiToIero.name
meMA.Exaposteilarion1.incipit = "Τὴν ἔρημον ἐπόλισας…"
meMA.Exaposteilarion1.text = "Τὴν ἔρημον ἐπόλισας, τρόποις ἐν φιλοσόφοις, Πατέρων τὸ ἀγλάϊσμα, Σάββα Πάτερ θεόφρον, καὶ ταύτην ἀπετέλεσας, νοητὸν Παράδεισον, κομῶσαν ἄνθεσι θείοις, μονοτρόπων τῷ πλήθει, τῶν ἀξίως τελούντων, τὴν σὴν σεβάσμιον μνήμην."

meMA.Exaposteilarion2.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Exaposteilarion2.greekmelody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.greekname
meMA.Exaposteilarion2.melody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.name
meMA.Exaposteilarion2.incipit = "Ἡ ἔρημος εὐφραινέσθω…"
meMA.Exaposteilarion2.text = "Ἡ ἔρημος εὐφραινέσθω, καὶ ἐξανθείτω ὡς κρίνον, ὅτι ἐπλήθυνας ταύτης, τὰ τέκνα Σάββα θεόφρον, ἡ χώρα τοῦ Ἰορδάνου, ἀγαλλιάσθω νῦν χαρμοσύνως, ἐπὶ τῇ θείᾳ σου μνήμῃ."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.ExapTheotokion.melody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.name
meMA.ExapTheotokion.incipit = ho.ho23_gr_GR_cog.hoCA.Exaposteilarion4.incipit
meMA.ExapTheotokion.text = ho.ho23_gr_GR_cog.hoCA.Exaposteilarion4.text

meMA.Lauds1.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Lauds1.greekmelody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.greekname
meMA.Lauds1.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meMA.Lauds1.incipit = "Ὁ ὑπερόπτης τῶν κάτω, καὶ…"
meMA.Lauds1.text = "Ὁ ὑπερόπτης τῶν κάτω, καὶ παρεπίδημος, ὁ ἐραστὴς τῶν ἄνω, καὶ ἐρημοπολίτης, Σάββας ὁ θεόφρων, πάντας ἡμᾶς, ἑορτάσαι προτρέπεται, τῆς πρὸς Θεὸν ἐκδημίας αὐτοῦ πιστῶς, τὴν ἡμέραν τὴν σεβάσμιον."

meMA.Lauds2.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Lauds2.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meMA.Lauds2.incipit = "Ἔξω σαρκὸς καὶ τοῦ κόσμου…"
meMA.Lauds2.text = "Ἔξω σαρκὸς καὶ τοῦ κόσμου, ταῖς ἀρεταῖς γεγονώς, καὶ διʼ αὐτῶν δοξάσας, ἐπὶ γῆς διὰ βίου, τὸν Κύριον τῆς δόξης, Πάτερ σοφέ, κατʼ ἀξίαν δεδόξασαι, καὶ ἰαμάτων ἐδείχθης θεία πηγή, παρʼ αὐτοῦ Σάββα θεόληπτε."

meMA.Lauds3.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Lauds3.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meMA.Lauds3.incipit = "Μέτριος ἄκακος πρᾶος, ἁπλοῦς, ἡσύχιος…"
meMA.Lauds3.text = "Μέτριος ἄκακος πρᾶος, ἁπλοῦς, ἡσύχιος, ὡς χρηματίσας Πάτερ, ὑπὲρ ἄνθρωπον ὄντως, καὶ ἄϋλος ἐν ὕλῃ, οἶκος Θεοῦ, καθωράθης πανάξιος, τὰς ἐξ αὐτοῦ προϊούσας σοι δωρεάς, συμπαθῶς διαπορθμεύων ἡμῖν."

meMA.LaudsGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.LaudsGlory.melody = ""
meMA.LaudsGlory.incipit = me.m01.d15_gr_GR_cog.meVE.AposGlory.incipit
