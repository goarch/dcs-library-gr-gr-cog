meVE.Stichera01.poet = poets_gr_GR_cog.po.Anatoliou
meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera01.melody = ""
meVE.Stichera01.incipit = "Προεορτάσωμεν λαοί…"
meVE.Stichera01.text = "Προεορτάσωμεν λαοί, Χριστοῦ τὰ Γενέθλια· καὶ ἐπάραντες τὸν νοῦν, ἐπὶ τὴν Βηθλεὲμ ἀναχθῶμεν τῇ διανοίᾳ, καὶ κατίδωμεν τὴν Παρθένον, τοῖς ψυχικοῖς λογισμοῖς, ἐπειγομένην τίκτειν ἐν Σπηλαίῳ τὸν τῶν ὅλων Κύριον καὶ Θεὸν ἡμῶν· οὗ Ἰωσὴφ κατιδὼν τῶν θαυμάτων τὸ μέγεθος, ἐδόκει ἄνθρωπον θεωρεῖν, ὡς βρέφος σπαργανούμενον· ὑπενόει δὲ ἐκ τῶν πραγμάτων, Θεὸν εἶναι ἀληθινόν, τὸν παρέχοντα ταῖς ψυχαῖς ἡμῶν, τὸ μέγα ἔλεος."

meVE.Stichera02.poet = poets_gr_GR_cog.po.Anatoliou
meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera02.melody = ""
meVE.Stichera02.incipit = "Προεορτάσωμεν λαοί…"
meVE.Stichera02.text = "Προεορτάσωμεν λαοί, Χριστοῦ τὰ Γενέθλια· καὶ ἐπάραντες τὸν νοῦν, ἐπὶ τὴν Βηθλεὲμ ἀναχθῶμεν τῇ διανοίᾳ, καὶ κατίδωμεν τὸ ἐν Σπηλαίῳ μέγα μυστήριον· ἤνοικται γὰρ ἡ Ἐδέμ, ἐκ Παρθένου ἁγνῆς Θεοῦ προερχομένου, ὑπάρχοντος τελείου τοῦ αὐτοῦ, ἐν Θεότητι καὶ ἀνθρωπότητι· διὸ κράξωμεν· Ἅγιος ὁ Θεός, ὁ Πατὴρ ὁ ἄναρχος, Ἅγιος Ἰσχυρός, ὁ Υἱὸς ὁ σαρκωθείς· Ἅγιος Ἀθάνατος, τὸ παράκλητον Πνεῦμα. Τριὰς Ἁγία, δόξα σοι."

meVE.Stichera03.poet = poets_gr_GR_cog.po.Anatoliou
meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera03.melody = ""
meVE.Stichera03.incipit = "Ἄκουε οὐρανέ…"
meVE.Stichera03.text = "Ἄκουε οὐρανέ, καὶ ἐνωτίζου ἡ γῆ· ἰδοὺ γὰρ ὁ Υἱὸς καὶ Λόγος τοῦ Θεοῦ καὶ Πατρός, πρόεισι τεχθῆναι, ἐκ Κόρης ἀπειράνδρου, εὐδοκίᾳ τοῦ φύσαντος αὐτὸν ἀπαθῶς, καὶ συνεργείᾳ τοῦ Ἁγίου Πνεύματος. Βηθλεὲμ εὐτρεπίζου, ἄνοιγε πύλην ἡ Ἐδέμ· ὅτι ὁ ὤν, γίνεται ὃ οὐκ ἦν, καὶ ὁ πλαστουργὸς πάσης κτίσεως διαπλάττεται· ὁ παρέχων τῷ κόσμῳ, τὸ μέγα ἔλεος."

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera04.greekmelody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.greekname
meVE.Stichera04.melody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.name
meVE.Stichera04.incipit = "Ὁ Θεοφόρος καλούμενος…"
meVE.Stichera04.text = "Ὁ Θεοφόρος καλούμενος ἀξίως, ὅτε ὁ Δεσπότης σε, μάκαρ Ἰγνάτιε, ὡς συμπαθὴς ἠγκαλίσατο, φιλοσοφίας, τῆς ἀνωτάτω φαίνων τὰ δόγματα, τότε τὴν πολύφωτον αἴγλην εἰσδέδεξαι, καθάπερ σπόγγος τὰ νάματα, ἐκ τῆς ἀβύσσου, τῶν φωτισμάτων ἀνιμησάμενος· ὅθεν κατʼ ἴχνος ἠκολούθησας, τῷ καλοῦντι Χριστῷ τῷ Θεῷ ἡμῶν, ὃν ἱκέτευε σῶσαι, καὶ φωτίσαι τὰς ψυχὰς ἡμῶν."

meVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera05.melody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.name
meVE.Stichera05.incipit = "Ὁ τετρωμένος ἀγάπῃ…"
meVE.Stichera05.text = "Ὁ τετρωμένος ἀγάπῃ τῇ τελείᾳ, ὅτε ὁ πρηστήριος, ἔρως ἀνέφλεγε, σοῦ τὴν ψυχὴν ἱερώτατε, πρὸς τὸν Δεσπότην, σὲ κατεπείγων Πάτερ πορεύεσθαι, τότε τὸν ἀοίδιμον λόγον ἐβόησας· Σῖτος ὑπάρχω τοῦ Κτίσαντος, καὶ διʼ ὀδόντων, δεῖ με θηρίων πάντως ἀλήθεσθαι, ἵνα τῷ Λόγῳ καθαρώτατος, ἄρτος φανῶ τῷ Θεῷ ἡμῶν· ὃν ἱκέτευε σῶσαι, καὶ φωτίσαι τὰς ψυχὰς ἡμῶν."

meVE.Stichera06.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera06.melody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.name
meVE.Stichera06.incipit = "Συνεσταυρώθης Χριστῷ…"
meVE.Stichera06.text = "Συνεσταυρώθης Χριστῷ Ἱεροφάντορ, ὅτε τὸν θεόπνευστον λόγον ἀνέκραξας· Ὁ ἐμὸς ἔρως ἐσταύρωται, καὶ κοινωνῆσαι, τούτῳ τοῦ πάθους λίαν ἐπείγομαι· ἐντεῦθεν Ἰγνάτιε, καθάπερ ἥλιος, Ἀνατολῆς ἐξορμώμενος, ἐπὶ τὴν Δύσιν, καταφωτίζων μάκαρ διέδραμες, καὶ βασιλείας διαδήματι, ἐκοσμήθης Χριστῷ προσαγόμενος· ὃν ἱκέτευε σῶσαι, καὶ φωτίσαι τὰς ψυχὰς ἡμῶν."

meVE.MM.Stichera456as567.text = properties_gr_GR_cog.media.key

meVE.SticGlory.poet = poets_gr_GR_cog.po.Anatoliou
meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Θεοφόρε Ἰγνάτιε…"
meVE.SticGlory.text = "Θεοφόρε Ἰγνάτιε, τὸν σὸν ἔρωτα Χριστὸν ἐνστερνισάμενος, μισθὸν ἐκομίσω, τῆς ἱερουργίας τοῦ Εὐαγγελίου τοῦ Χριστοῦ, τὸ τελειωθῆναι διʼ αἵματος· διὸ σῖτος γενόμενος τοῦ ἀθανάτου γεωργοῦ, δι ὀδόντων θηρίων ἠλέσθης, καὶ ἄρτος ἡδὺς αὐτῷ ἀνεδείχθης· πρέσβευε ὑπὲρ ἡμῶν, Ἀθλητὰ μακάριε."

meVE.SticBoth.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.SticBoth.melody = ""
meVE.SticBoth.incipit = me.m11.d30_gr_GR_cog.meMA.LaudsBoth.incipit
meVE.SticBoth.text = me.m11.d30_gr_GR_cog.meMA.LaudsBoth.text

meVE.Aposticha1.poet = poets_gr_GR_cog.po.Kyprianou
meVE.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Aposticha1.melody = ""
meVE.Aposticha1.incipit = "Βηθλεὲμ γῆ Ἰούδα…"
meVE.Aposticha1.text = "Βηθλεὲμ γῆ Ἰούδα, τὸ κατὰ σάρκα πολίτευμα, φαιδρῶς εὐτρέπισον τὸ θεῖον Σπήλαιον, ἐν ᾧ Θεὸς σαρκὶ τίκτεται, ἐξ ἀπειράνδρου ἁγίας Παρθένου, εἰς τὸ σῶσαι τὸ γένος ἡμῶν."

meVE.Aposticha2.poet = poets_gr_GR_cog.po.AndreouPyrou
meVE.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Aposticha2.melody = ""
meVE.Aposticha2.incipit = "Δεῦτε ἅπαντες…"
meVE.Aposticha2.text = "Δεῦτε ἅπαντες, Χριστοῦ τὰ Γενέθλια, πιστῶς προεορτάσωμεν· καὶ νοητῶς τὸν ὕμνον, ὡς ἀστέρα προβαλλόμενοι, Μαγικὰς δοξολογίας, μετὰ Ποιμένων βοήσωμεν· Ἦλθεν ἡ σωτηρία τῶν βροτῶν, ἐκ παρθενικῆς νηδύος, πιστοὺς ἀνακαλέσασθαι."

meVE.Aposticha3.poet = poets_gr_GR_cog.po.Kyprianou
meVE.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Aposticha3.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.melody
meVE.Aposticha3.incipit = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.incipit
meVE.Aposticha3.text = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.text

meVE.AposGlory.poet = poets_gr_GR_cog.po.Stouditou
meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Ὢ τῆς στεῤῥᾶς…"
meVE.AposGlory.text = "Ὢ τῆς στεῤῥᾶς καὶ ἀδαμαντίνου σου ψυχῆς, ἀξιομακάριστε Ἰγνάτιε! σὺ γὰρ πρὸς τὸν ὄντως σὸν ἐραστήν, ἀνένδοτον ἔχων τὴν ἔφεσιν, ἔλεγες· Οὐκ ἔστιν ἐν ἐμοὶ πῦρ φιλόϋλον, ὕδωρ δὲ μᾶλλον ζῶν, καὶ λαλοῦν ἐν ἐμοί, ἔνδοθέν μοι λέγον· Δεῦρο πρὸς τὸν Πατέρα· ὅθεν θείῳ Πνεύματι πυρπολούμενος, θῆρας ἠρέθισας, κόσμου σε θᾶττον χωρίσαι, καὶ πρὸς τὸν ποθούμενον παραπέμψαι Χριστόν· ὃν ἱκέτευε, σωθῆναι τὰς ψυχὰς ἡμῶν."

meVE.AposBoth.poet = poets_gr_GR_cog.po.Kyprianou
meVE.AposBoth.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.AposBoth.melody = ""
meVE.AposBoth.incipit = me.m12.d12_gr_GR_cog.meVE.AposBoth.incipit
meVE.AposBoth.text = me.m12.d12_gr_GR_cog.meVE.AposBoth.text

meVE.Apolytikion1.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Apolytikion1.greekmelody = he.a.m4_gr_GR_cog.heAU.KateplagiIosif.greekname
meVE.Apolytikion1.melody = he.a.m4_gr_GR_cog.heAU.KateplagiIosif.name
meVE.Apolytikion1.incipit = "Ἑτοιμάζου Βηθλεέμ…"
meVE.Apolytikion1.text = "Ἑτοιμάζου Βηθλεέμ· ἤνοικται πᾶσιν ἡ Ἐδέμ. Εὐτρεπίζου Ἐφραθᾶ, ὅτι τὸ ξύλον τῆς ζωῆς, ἐν τῷ Σπηλαίῳ ἐξήνθησεν ἐκ τῆς Παρθένου. Παράδεισος καὶ γάρ, ἡ ἐκείνης γαστήρ, ἐδείχθη νοητός, ἐν ᾧ τὸ θεῖον φυτόν· ἐξ οὗ φαγόντες ζήσομεν, οὐχὶ δὲ ὡς ὁ Ἀδὰμ τεθνηξόμεθα. Χριστὸς γεννᾶται, τὴν πρὶν πεσοῦσαν, ἀναστήσων εἰκόνα."

meVE.Apolytikion2ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion2ger.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.Apolytikion2ger.greekmelody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.greekname
meVE.Apolytikion2ger.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meVE.Apolytikion2ger.incipit = "Θείῳ ἔρωτι ἐπτερωμένος…"
meVE.Apolytikion2ger.text = "Θείῳ ἔρωτι ἐπτερωμένος, τοῦ σὲ ψεύσαντος, χερσὶν ἀχράντοις, Θεοφόρος ἀνεδείχθης Ἰγνάτιε· καὶ ἐν τῇ Δύσει τελέσας τὸν δρόμον σου, πρὸς τὴν ἀνέσπερον λῆξιν ἐσκήνωσας. Πάτερ Ὅσιε, Χριστὸν τὸν Θεὸν ἱκέτευε, δωρήσασθαι ἡμῖν τὸ μέγα ἔλεος."

meCO.C1.acrostic.title = "Τριῴδιον ψαλλόμενον ἐν τοῖς Ἀποδείπνοις,"
meCO.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meCO.C1.acrostic.text = "Τῇ δευτέρᾳ."
meCO.C1.title = "Κανὼν Τριῴδιον Προεόρτιον"
meCO.C1.verse = prayers_gr_GR_cog.pr.verse_God.text

meCO.Ode1C1H.ode = miscellanea_gr_GR_cog.misc.Ode1
meCO.Ode1C1H.mode = miscellanea_gr_GR_cog.misc.Mode2
meCO.Ode1C1H.melody = he.h.m2_gr_GR_cog.heHE.ToTinAvaton.melody
meCO.Ode1C1H.incipit = he.h.m2_gr_GR_cog.heHE.ToTinAvaton.incipit
meCO.Ode1C1H.text = he.h.m2_gr_GR_cog.heHE.ToTinAvaton.text

meCO.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meCO.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode2
meCO.Ode1C11.melody = he.h.m2_gr_GR_cog.heHE.ToTinAvaton.name
meCO.Ode1C11.incipit = "Ἡ ἀπόῤῥητος, Λόγου Θεοῦ κατάβασις…"
meCO.Ode1C11.text = "Ἡ ἀπόῤῥητος, Λόγου Θεοῦ κατάβασις, ὅπερ αὐτὸς θεάνθρωπος, Χριστὸς γινώσκεται, τὸ Θεὸς οὐχ ἁρπαγμόν, εἶναι ἡγησάμενος, ἔρχεται δούλου μορφήν, ἀναδεξόμενος, Κόρης ἐξ ἁγνῆς θεόπαιδος."

meCO.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meCO.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode2
meCO.Ode1C12.melody = he.h.m2_gr_GR_cog.heHE.ToTinAvaton.name
meCO.Ode1C12.incipit = "Διακονῆσαι, Χριστὸς ἑκὼν προέρχεται, οὗ…"
meCO.Ode1C12.text = "Διακονῆσαι, Χριστὸς ἑκὼν προέρχεται, οὗ τὴν μορφὴν ὁ πλαστουργὸς νῦν ὑποδύεται, τῷ πτωχεύσαντι Ἀδάμ, ὁ πλουτῶν θεότητι, ξένην ἀνάπλασιν, καὶ ἀναγέννησιν, ὡς εὔσπλαγχνος δωρούμενος."

meCO.Ode8C1H.ode = miscellanea_gr_GR_cog.misc.Ode8
meCO.Ode8C1H.mode = miscellanea_gr_GR_cog.misc.Mode2
meCO.Ode8C1H.melody = he.h.m2_gr_GR_cog.heHE.EfrixePaidonEvagon.melody
meCO.Ode8C1H.incipit = he.h.m2_gr_GR_cog.heHE.EfrixePaidonEvagon.incipit
meCO.Ode8C1H.text = he.h.m2_gr_GR_cog.heHE.EfrixePaidonEvagon.text

meCO.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meCO.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode2
meCO.Ode8C11.melody = he.h.m2_gr_GR_cog.heHE.EfrixePaidonEvagon.name
meCO.Ode8C11.incipit = "Ὑμᾶς μου πάντας συγγενεῖς, ἄρτι…"
meCO.Ode8C11.text = "Ὑμᾶς μου πάντας συγγενεῖς, ἄρτι θήσομαι, εἰ τὰς ἐμὰς ἐντολὰς τηρήσετε, φησὶν ὁ Χριστὸς ἀνθρώποις, ἐκ μήτρας Ἁγνῆς, προερχόμενος· οἷς τὴν εἰρήνην διδούς, τὰ ταπεινὰ φρονεῖν νῦν ὑποτίθεται, καὶ Κύριον γινώσκειν τοῦτον καὶ ψάλλειν· Σὲ ὑπερυψοῦμεν, εἰς πάντας τοὺς αἰῶνας."

meCO.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meCO.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode2
meCO.Ode8C12.melody = he.h.m2_gr_GR_cog.heHE.EfrixePaidonEvagon.name
meCO.Ode8C12.incipit = "Τάξεως ἔμπαλιν ἐν σοί, σαρκικῆς…"
meCO.Ode8C12.text = "Τάξεως ἔμπαλιν ἐν σοί, σαρκικῆς ἐστιν ὁ τόκος Λόγε Θεοῦ· οὐχ αἷμα γὰρ καὶ σάρξ, σὴν Ἁγίαν σάρκα συνίστησιν, ἀλλὰ Πνεύματος Ἁγίου παρουσία, καὶ τοῦ Ὑψίστου θεία ἐπισκίασις· καὶ Κύριον γινώσκοντές σε ὑμνοῦμεν, καὶ ὑπερυψοῦμεν, εἰς πάντας τοὺς αἰῶνας."

meCO.Ode9C1H.ode = miscellanea_gr_GR_cog.misc.Ode9
meCO.Ode9C1H.mode = miscellanea_gr_GR_cog.misc.Mode2
meCO.Ode9C1H.melody = he.h.m2_gr_GR_cog.heHE.EmegalynasChriste.melody
meCO.Ode9C1H.incipit = he.h.m2_gr_GR_cog.heHE.EmegalynasChriste.incipit
meCO.Ode9C1H.text = he.h.m2_gr_GR_cog.heHE.EmegalynasChriste.text

meCO.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meCO.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode2
meCO.Ode9C11.melody = he.h.m2_gr_GR_cog.heHE.EmegalynasChriste.name
meCO.Ode9C11.incipit = "Ῥύπον πάντα ἐμπαθῆ, ἀπωσάμενοι ἐπαξίως…"
meCO.Ode9C11.text = "Ῥύπον πάντα ἐμπαθῆ, ἀπωσάμενοι ἐπαξίως, τῆς παρουσίας Χριστοῦ, γνώμην ἀναλάβωμεν ἔμφρονα· καὶ γὰρ ἀῤῥυπάρως προέρχεται σάρκα φορέσαι, καὶ πᾶσι δωρήσασθαι, θείαν διὰ Πνεύματος ἀνάπλασιν."

meCO.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meCO.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode2
meCO.Ode9C12.melody = he.h.m2_gr_GR_cog.heHE.EmegalynasChriste.name
meCO.Ode9C12.incipit = "Ἀφορῶντες εἰς Χριστόν, ταπεινούμενον ὑψωθῶμεν…"
meCO.Ode9C12.text = "Ἀφορῶντες εἰς Χριστόν, ταπεινούμενον ὑψωθῶμεν, ἐκ χαμαιζήλων παθῶν, ζήλῳ δὲ καλῷ μὴ φρονεῖν ὑψηλά, πίστει παιδευθέντες, ἐν πνεύματι ταπεινωθῶμεν· ὅπως τὸν τικτόμενον, ἐν ὑψοποιοῖς ἔργοις ὑψώσωμεν."

meMA.Kathisma11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kathisma11.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meMA.Kathisma11.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Kathisma11.incipit = "Ὁ κλίνας οὐρανούς…"
meMA.Kathisma11.text = "Ὁ κλίνας οὐρανούς, καὶ Παρθένῳ οἰκήσας, προέρχεται σαρκί, Βηθλεὲμ ἐν Σπηλαίῳ, τεχθῆναι καθὼς γέγραπται, ὁραθῆναί τε νήπιος, ὁ τὰ νήπια, ζωογονῶν ἐν τῇ μήτρᾳ· τούτῳ χαίροντες, νῦν ὑπαντήσωμεν πάντες, καρδίας εὐθύτητι."

meMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kathisma21.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meMA.Kathisma21.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Kathisma21.incipit = "Ἀγάλλου ἡ Σιών…"
meMA.Kathisma21.text = "Ἀγάλλου ἡ Σιών· Βηθλεὲμ εὐτρεπίζου, ὁ πάντων συνοχεύς, τὸν Ἀστέρα προπέμψας, μηνύει τὴν ἄμετρον, ἑαυτοῦ συγκατάβασιν· ὃν γὰρ τρέμουσι, τῶν οὐρανῶν αἱ Δυνάμεις, ὄντως τίκτεται, ἐκ τῆς Παρθένου ἀτρέπτως, ὁ μόνος Φιλάνθρωπος."

meMA.C1.acrostic.title = "Κανὼν ὁ Προεόρτιος,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "ᾌδει ταῦτα προεόρτια. Ὁ Ἰωσήφ."
meMA.C1.title = titles_gr_GR_cog.ti.CanonForefeast
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_God.text

meMA.C2.poet = poets_gr_GR_cog.po.AndreouKritis
meMA.C2.title = titles_gr_GR_cog.ti.CanonSaintM
meMA.C2.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.Ode1C1H.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1H.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C1H.greekmelody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.greekname
meMA.Ode1C1H.melody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.melody
meMA.Ode1C1H.incipit = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.incipit
meMA.Ode1C1H.text = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C11.greekmelody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.greekname
meMA.Ode1C11.melody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.name
meMA.Ode1C11.incipit = "Ἀρξώμεθα σήμερον, προεορτάζειν, Χριστοῦ τὰ…"
meMA.Ode1C11.text = "Ἀρξώμεθα σήμερον, προεορτάζειν, Χριστοῦ τὰ Γενέθλια, τοῦ τεχθέντος σώματι, ἐκ τῆς Παρθένου Μητρός, ἐν τῷ Σπηλαίῳ Βηθλεέμ, διʼ εὐσπλαγχνίαν πολλήν."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C12.melody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.name
meMA.Ode1C12.incipit = "Δεσμῶν ἀπολύων με, τῆς ἁμαρτίας…"
meMA.Ode1C12.text = "Δεσμῶν ἀπολύων με, τῆς ἁμαρτίας, σπαργάνοις εἱλίσσεται, καὶ ἐν φάτνῃ τίθεται, βρέφος ὁρώμενος, ὁ προαιώνιος Θεός· Δόξα τῷ κράτει αὐτοῦ."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C13.melody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.name
meMA.Ode1C13.incipit = "Ἐδὲμ διανοίγεται, σοῦ τικτομένου, ἐκ…"
meMA.Ode1C13.text = "Ἐδὲμ διανοίγεται, σοῦ τικτομένου, ἐκ Κόρης θεόπαιδος, ἐν τῇ πόλει Δέσποτα, τῇ Βηθλεὲμ ἐν σαρκί. Ὑμνολογοῦμεν τὴν φρικτὴν οἰκονομίαν σου."

meMA.Ode1C14.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C14.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C14.melody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.name
meMA.Ode1C14.incipit = "Ἰδοὺ νῦν πεπλήρωται, τοῦ Ἠσαΐου…"
meMA.Ode1C14.text = "Ἰδοὺ νῦν πεπλήρωται, τοῦ Ἠσαΐου, ἡ πρόῤῥησις Πάναγνε· τοῦ τεκεῖν τὸν ἄχρονον· ἐν Σπηλαίῳ γὰρ Υἱόν, ἐλήλυθας, πᾶσα ἡ γῆ διὸ εὐφραίνεται."

meMA.Ode1C21.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C21.greekmelody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.greekname
meMA.Ode1C21.melody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.name
meMA.Ode1C21.incipit = "Φαιδρῶς ἑορτάζοντες, εὐωχηθῶμεν, ὁ Μάρτυς…"
meMA.Ode1C21.text = "Φαιδρῶς ἑορτάζοντες, εὐωχηθῶμεν, ὁ Μάρτυς Ἰγνάτιος, ἱερῶς προτρέπεται, τὴν Ἐκκλησίαν Χριστοῦ, ἐπὶ τὴν ἄθλησιν αὐτοῦ, τὴν πολυΰμνητον."

meMA.Ode1C22.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C22.melody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.name
meMA.Ode1C22.incipit = "Τὴν ἔνδοξον μνήμην σου, πάντες…"
meMA.Ode1C22.text = "Τὴν ἔνδοξον μνήμην σου, πάντες τιμῶμεν, παμμάκαρ Ἰγνάτιε, καὶ ψαλμοῖς γεραίρομεν, τὸν στεφανώσαντα, τὴν πάνσεπτόν σου κορυφήν, θεομακάριστε."

meMA.Ode1C23.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C23.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C23.melody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.name
meMA.Ode1C23.incipit = "Φωστὴρ διαυγέστατος, τῆς Ἐκκλησίας, ὑπάρχων…"
meMA.Ode1C23.text = "Φωστὴρ διαυγέστατος, τῆς Ἐκκλησίας, ὑπάρχων Ἰγνάτιε, καταλάμπεις ἅπαντα, τῆς γῆς τὰ πέρατα, καὶ τὴν Ἑσπέραν δᾳδουχεῖς, ἐκ τῆς Ἑῴας ἐλθών."

meMA.Ode1C24.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C24.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C24.melody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.name
meMA.Ode1C24.incipit = "Τοῦ Παύλου μιμούμενος, τοὺς κατὰ…"
meMA.Ode1C24.text = "Τοῦ Παύλου μιμούμενος, τοὺς κατὰ τόπον, κινδύνους Ἰγνάτιε, καὶ ὑπάρχων δέσμιος, οὐ κατενάρκησας, στηρίζων γράμμασι πυκνοῖς, τὰς Ἐκκλησίας Χριστοῦ."

meMA.Ode1C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C2Tr.melody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.name
meMA.Ode1C2Tr.incipit = "Τριὰς Ὑπερούσιε, μία Θεότης, Μονὰς…"
meMA.Ode1C2Tr.text = "Τριὰς Ὑπερούσιε, μία Θεότης, Μονὰς Τρισυπόστατε, τοὺς πιστῶς βοῶντάς σοι Ἅγιος, Ἅγιος, Ἅγιος, εἶ Δημιουργέ, σῶσον ἐλέησον."

meMA.Ode1C2T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C2T.melody = he.h.m1_gr_GR_cog.heHE.OdinEpinikion.name
meMA.Ode1C2T.incipit = "Ἐδὲμ εὐτρεπίσθητι· ἡ Ἐφραθᾶ γάρ…"
meMA.Ode1C2T.text = "Ἐδὲμ εὐτρεπίσθητι· ἡ Ἐφραθᾶ γάρ, τῷ Κτίστῃ ἡτοίμασται, γεννηθῆναι μέλλοντι, ἐκ τῆς Παρθένου Μητρός, ἐν τῷ Σπηλαίῳ Βηθλεέμ, διʼ εὐσπλαγχνίαν πολλήν."

meMA.Ode3C1H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1H.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C1H.greekmelody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.greekname
meMA.Ode3C1H.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.melody
meMA.Ode3C1H.incipit = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.incipit
meMA.Ode3C1H.text = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.text

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C11.greekmelody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.greekname
meMA.Ode3C11.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.name
meMA.Ode3C11.incipit = "Ταύτην τοῦ Χριστοῦ τὴν σάρκωσιν…"
meMA.Ode3C11.text = "Ταύτην τοῦ Χριστοῦ τὴν σάρκωσιν, γνοὺς ὁ Ἠσαΐας, Πνεύματι Ἁγίῳ, ἐμφανῶς προλέγει, Παιδίον ἐκ Παρθένου, γεννᾶται ὁ Κύριος, εἰς ἀναγέννησιν ἡμῶν, οὗ ἡ ἀρχὴ ἐπὶ τοῦ ὤμου αὐτοῦ."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C12.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.name
meMA.Ode3C12.incipit = "Ἄστρον ἤδη ἀνατέταλκεν…"
meMA.Ode3C12.text = "Ἄστρον ἤδη ἀνατέταλκεν, ἐκ φυλῆς, Ἰούδα, ὅπερ ἐπιγνόντες, Βασιλεῖς κινήσεις, ἀνατολῶν ποιοῦνται, καὶ φθάσαι ἐπείγονται, ὅπως θεάσωνται Χριστόν, ἐν Βηθλεέμ σαρκὶ τικτόμενον."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C13.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.name
meMA.Ode3C13.incipit = "Ὕμνον πᾶσα προεόρτιον…"
meMA.Ode3C13.text = "Ὕμνον πᾶσα προεόρτιον, προσαδέτω κτίσις, τῷ πρὸ ἑωσφόρου, ἐκ Πατρὸς γεννηθέντι, καὶ νῦν ἐκ τῆς Παρθένου, ἀῤῥήτως ἐκλάμποντι, καὶ τικτομένῳ σαρκικῶς, ἐν Βηθλεὲμ διʼ εὐσπλαγχνίαν πολλήν."

meMA.Ode3C21.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C21.greekmelody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.greekname
meMA.Ode3C21.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.name
meMA.Ode3C21.incipit = "Τύπος Ἱερᾶς ἀθλήσεως, ἀνεδείχθης Μάκαρ…"
meMA.Ode3C21.text = "Τύπος Ἱερᾶς ἀθλήσεως, ἀνεδείχθης Μάκαρ, στήλη καρτερίας, καὶ κανὼν ἀνδρείας, καὶ στῦλος Ἐκκλησίας, καὶ Πίστεως ἔρεισμα, καὶ ἀρετῆς ὑπογραμμός, ἄθλοις σεπτοῖς, στεφανωθεὶς ἐν Χριστῷ."

meMA.Ode3C22.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C22.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.name
meMA.Ode3C22.incipit = "Ὄντως φερωνύμως κέκλησαι, Θεοφόρος Πάτερ…"
meMA.Ode3C22.text = "Ὄντως φερωνύμως κέκλησαι, Θεοφόρος Πάτερ· νήπιος γὰρ ἔτι, κομιδῇ ὑπάρχων, εἰς χεῖρας τοῦ Κυρίου, φερόμενος ἵστασο, ἀναφωνοῦντος πρὸς ἡμᾶς· Γίνεσθέ μοι ὡς τὸ παιδίον τοῦτο."

meMA.Ode3C23.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C23.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C23.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.name
meMA.Ode3C23.incipit = "Ποῖος τόπος οὐχ ἡγίασται, τοῖς…"
meMA.Ode3C23.text = "Ποῖος τόπος οὐχ ἡγίασται, τοῖς παθήμασί σου; ποία παροικία, οὐκ ἐγνώσθης Μάρτυς; ἢ ποία φυλακή σε, σχεδὸν οὐκ ἐδέξατο, δέσμιον Μάρτυρα Χριστοῦ; ζῆλος γάρ σε θεῖος ἠρέθιζε."

meMA.Ode3C24.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C24.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C24.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.name
meMA.Ode3C24.incipit = "Σῖτος καθαρὸς Θεῷ ἡμῶν, ἀνεβόας…"
meMA.Ode3C24.text = "Σῖτος καθαρὸς Θεῷ ἡμῶν, ἀνεβόας πέλων, σπεύδω ἀλεσθῆναι, ὑπὸ θηρῶν ἀγρίων, θλασθήτω τὰ ὀστᾶ μου, βρωθήτω τὰ μέλη μου, καὶ βρῶμα γένωμαι θηρῶν, ἵνα Χριστῷ, καθαρὸς ἄρτος ὀφθῶ."

meMA.Ode3C25.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C25.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C25.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.name
meMA.Ode3C25.incipit = "Ξένον Μαρτυρίου στάδιον, ἱερῶς ἀνύσας…"
meMA.Ode3C25.text = "Ξένον Μαρτυρίου στάδιον, ἱερῶς ἀνύσας, ξένην παρὰ πάντας, τοὺς προηθληκότας, ἀνδρείαν ἐπεδείξω, τῷ πόθῳ πυρούμενος, τοῦ ἀνενδότου ἐραστοῦ, ὃς τις ὡς πῦρ, τὴν σὴν ἀνῆπτε ψυχήν."

meMA.Ode3C26.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C26.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C26.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.name
meMA.Ode3C26.incipit = "Ζέων εἰς ἀεὶ τῷ πνεύματι…"
meMA.Ode3C26.text = "Ζέων εἰς ἀεὶ τῷ πνεύματι, ὁ Ἱερομάρτυς, ἔκραζε σὺν πόθῳ, ἐν μέσῳ τῶν κινδύνων· Χριστὸν διώκω χαίρων, Χριστῷ συνεσταύρωμαι· ζῶ δὲ οὐκ ἔτι μὲν ἐγώ, ζῇ δὲ φησίν, ἐν ἐμοὶ μόνος Χριστός."

meMA.Ode3C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C2Tr.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.name
meMA.Ode3C2Tr.incipit = "Μίαν προσκυνῶ Θεότητα, ὡς ἀρχὴν…"
meMA.Ode3C2Tr.text = "Μίαν προσκυνῶ Θεότητα, ὡς ἀρχὴν καὶ τέλος, πάντων τε τῶν ὄντων, καὶ τῶν γενησομένων, Πατέρα ἀγέννητον, Υἱὸν ἀχρόνως γεννητόν, Πνεῦμα εὐθές, ἐκπορευτὸν ἐκ Πατρός."

meMA.Ode3C2T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C2T.melody = he.h.m1_gr_GR_cog.heHE.LithonOnApedokimasan.name
meMA.Ode3C2T.incipit = "Δεῦρο Ἠσαΐα βόησον· Ἰδοὺ ἡ…"
meMA.Ode3C2T.text = "Δεῦρο Ἠσαΐα βόησον· Ἰδοὺ ἡ Παρθένος, ἔχει ἐν κοιλίᾳ, τὸν Λυτρωτὴν τοῦ Κόσμου, καὶ τίκτει ἐν Σπηλαίῳ, καὶ ἔσται τὸ ὄνομα, τοῦ τικτομένου Ἰησοῦ, Θεὸς μεθ ἡμῶν, Ἐμμανουὴλ Σαβαώθ."

meMA.Kontakion1.mode = he.a.m3_gr_GR_cog.heAU.IParthenosSimeron.mode
meMA.Kontakion1.greekmelody = he.a.m3_gr_GR_cog.heAU.IParthenosSimeron.greekname
meMA.Kontakion1.melody = he.a.m3_gr_GR_cog.heAU.IParthenosSimeron.melody
meMA.Kontakion1.incipit = "Ἡ Παρθένος σήμερον…"
meMA.Kontakion1.text = "Ἡ Παρθένος σήμερον, τὸν προαιώνιον Λόγον, ἐν Σπηλαίῳ ἔρχεται, ἀποτεκεῖν ἀποῤῥήτως. Χόρευε, ἡ οἰκουμένη ἀκουτισθεῖσα, δόξασον, μετὰ Ἀγγέλων καὶ τῶν Ποιμένων, βουληθέντα ἐποφθῆναι, Παιδίον νέον, τὸν πρὸ αἰώνων Θεόν."

meMA.Oikos1.text = "Ἱεραὶ Προφητῶν ῥήσεις, τὸ πέρας δέχονται· ἡ Παρθένος ἰδού, τίκτει Θεὸν ἐν σαρκί, Βηθλεὲμ ἐν πόλει, ἔνδον τοῦ Σπηλαίου· ἡ κτίσις πᾶσα καταπλουτίσθητι, ἀγάλλου καὶ χόρευε· μετὰ τῶν δούλων συναναστρέφεσθαι, πάντων ὁ Δεσπότης παραγέγονε, τῆς δεσποτείας τοῦ ἀλλοτρίου ἀπολυτρούμενος ἡμᾶς, καθυπαχθέντας τῇ φθορᾷ· καὶ ὁρᾶται ὡς βρέφος σπαργανούμενον ἐν φάτνῃ, Παιδίον νέον, ὁ πρὸ αἰώνων Θεός."

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3Kathisma1.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Ode3Kathisma1.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3Kathisma1.incipit = "Ἐξ Ἑῴας ἐκλάμψας ὥσπερ ἀστήρ…"
meMA.Ode3Kathisma1.text = "Ἐξ Ἑῴας ἐκλάμψας ὥσπερ ἀστήρ, καὶ ἀκτῖσι τῶν λόγων λαμπαδουχῶν, τὸν κόσμον ἐφώτισας, καὶ τὸ σκότος ἐμείωσας, καὶ ὡς ὁ Παῦλος τὸν δρόμον, γενναίως διήνυσας, ὑπομείνας κινδύνους, ἐν Ἔθνεσί τε καὶ πόλεσιν· ὅθεν καὶ ὡς σῖτος, τῶν θηρῶν τοῖς ὁδοῦσιν, ἠλέσθης γενόμενος, προσφορὰ τῷ Κυρίῳ σου, Θεοφόρε Ἰγνάτιε· πρέσβευε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ, τὴν ἁγίαν μνήμην σου."

meMA.Ode3Kathisma2.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3Kathisma2.greekmelody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.greekname
meMA.Ode3Kathisma2.melody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.name
meMA.Ode3Kathisma2.incipit = "Χειροθετούμενος, ὑπὸ Χριστοῦ τοῦ Θεοῦ…"
meMA.Ode3Kathisma2.text = "Χειροθετούμενος, ὑπὸ Χριστοῦ τοῦ Θεοῦ, ἐγκατελάμπρυνας, τὴν ἱεράν σου στολήν, καὶ μαρτυρίου ἀληθῶς, ἐπέτυχες Θεοφόρε· θῆρας γὰρ ἠρέθισας, ἐκ τοῦ κόσμου χωρίσαι σε, Παῦλον ἐκμιμούμενος, τὸν θεσπέσιον ἔνδοξε· διὸ καὶ ἐν τῇ Ῥώμῃ ἐπλήρωσας, Πάτερ ἀξίως τὸ Μαρτύριον."

meMA.Ode3Kathisma3.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3Kathisma3.greekmelody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.greekname
meMA.Ode3Kathisma3.melody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.name
meMA.Ode3Kathisma3.incipit = "Χαρᾶς πεπλήρωνται, πάντα τὰ πέρατα…"
meMA.Ode3Kathisma3.text = "Χαρᾶς πεπλήρωνται, πάντα τὰ πέρατα· ἡ Θεοτόκος γάρ, γεννᾶν ἐπείγεται, τὸν Βασιλέα τοῦ παντός, ὢ θαύματος ἀνερμηνεύτου! ἄρχεται ὁ ἄναρχος, καὶ σαρκοῦται ὁ Ἄσαρκος, Σπήλαιον εἰσδέχεται, τὸν συνέχοντα ἅπαντα. Ἡ Βηθλεὲμ ἀγάλλου καὶ χόρευε, ἡ κτίσις ἡμέραν προεόρτιον."

meMA.Ode4C1H.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1H.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C1H.greekmelody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.greekname
meMA.Ode4C1H.melody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.melody
meMA.Ode4C1H.incipit = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.incipit
meMA.Ode4C1H.text = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C11.greekmelody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.greekname
meMA.Ode4C11.melody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.name
meMA.Ode4C11.incipit = "Τὰ ὄρη οἱ βουνοί τε…"
meMA.Ode4C11.text = "Τὰ ὄρη οἱ βουνοί τε, καὶ ξύλα τοῦ δρυμοῦ, ποταμοὶ καὶ θάλασσαι, καὶ ἅπασα πνοή, ἐν εὐφροσύνῃ σκιρτήσατε· νῦν ἐγγίζει, ἡ σωτηρία Ἰησοῦς ἐκ τῆς Παρθένου, πόλει Βηθλεὲμ ἀποτίκτεσθαι."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C12.melody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.name
meMA.Ode4C12.incipit = "Ἀνάλαβε Προφῆτα, ψαλτήριον Δαυΐδ, καὶ…"
meMA.Ode4C12.text = "Ἀνάλαβε Προφῆτα, ψαλτήριον Δαυΐδ, καὶ μελῴδει Πνεύματι, Ἁγίῳ ἐμφανῶς, ἐκ τῆς Παρθένου γεγέννηται ἀσυγχύτως, ὁ πρὸ ἑωσφόρου, ἐκ γαστρὸς Πατρὸς ἐκλάμψας, Κύριος τῆς δόξης Χριστὸς ὁ Θεός."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C13.melody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.name
meMA.Ode4C13.incipit = "Πῶς δέξεταί σε Λόγε, τικτόμενον…"
meMA.Ode4C13.text = "Πῶς δέξεταί σε Λόγε, τικτόμενον σαρκί, Σπήλαιον σμικρότατον, καὶ λίαν εὐτελές; πῶς εἱληθήσῃ σπαργάνοις ὁ περιβάλλων, πόλον νεφέλαις; πῶς ἐν φάτνῃ τῶν ἀλόγων, ἐπανακλιθήσῃ ὡς νήπιον;"

meMA.Ode4C21.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C21.greekmelody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.greekname
meMA.Ode4C21.melody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.name
meMA.Ode4C21.incipit = "Ἐφαίδρυνας τῇ αἴγλῃ, τῶν ἄθλων…"
meMA.Ode4C21.text = "Ἐφαίδρυνας τῇ αἴγλῃ, τῶν ἄθλων σου τὴν γῆν, Ἱερὲ Ἰγνάτιε, δεσμώτης ἀπαχθείς· διαδραμὼν γὰρ ὡς ἥλιος ταῖς ἀκτῖσι, τοῦ μαρτυρίου τὴν Ἑσπέραν ἐξ Ἑῴας, πᾶσαν δᾳδουχῶν κατεφώτισας."

meMA.Ode4C22.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C22.melody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.name
meMA.Ode4C22.incipit = "Ὡς Παῦλος δεδεμένος, θηρίοις λογικοῖς…"
meMA.Ode4C22.text = "Ὡς Παῦλος δεδεμένος, θηρίοις λογικοῖς, ἐπὶ Ῥώμην ἔτρεχες, Ἰγνάτιε σοφέ· ἀλλʼ οὐκ ἐπαύσω καὶ δέσμιος ὢν στηρίζων, τὰς Ἐκκλησίας ἐπιστέλλων κατὰ πόλιν, πᾶσι τοῖς Χριστοῦ Ἱεράρχαις θαῤῥεῖν."

meMA.Ode4C23.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C23.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C23.melody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.name
meMA.Ode4C23.incipit = "Θηρίων μοι γενέσθω, τὰ στόματα…"
meMA.Ode4C23.text = "Θηρίων μοι γενέσθω, τὰ στόματα σφαγή, καὶ γαστέρες μνήματα, ἐβόας Ἀθλητά· μηδεὶς ὀχλείτω, μηδείς μου θρύψει τὸν τόνον· ἐγὼ γὰρ σπεύδω ἀλεσθῆναι ὥσπερ σῖτος, καὶ ἄρτος εὑρεθῆναι Θεοῦ καθαρός."

meMA.Ode4C24.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C24.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C24.melody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.name
meMA.Ode4C24.incipit = "Χριστοῦ σπεύδω γενέσθαι, Χριστοῦ μόνου…"
meMA.Ode4C24.text = "Χριστοῦ σπεύδω γενέσθαι, Χριστοῦ μόνου ἐρῶ· ὅλος γὰρ Χριστοῦ εἰμι, ἐβόας Ἀθλητά, αὐτὸν διώκω, αὐτὸν ἐπείγομαι φθάσαι· καὶ διὰ τοῦτο πῦρ καὶ ξίφος καὶ θηρία, πάντα καρτερῶ, ἵνα τύχω αὐτοῦ."

meMA.Ode4C25.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C25.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C25.melody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.name
meMA.Ode4C25.incipit = "Διήνυσας τὸ σκάμμα, ζεούσῃ τῇ…"
meMA.Ode4C25.text = "Διήνυσας τὸ σκάμμα, ζεούσῃ τῇ ψυχῇ Μάρτυς καρτερόψυχε, τῷ ἔρωτι τρωθείς, τοῦ ἐραστοῦ σου· Χριστὸς γὰρ ἦν σοι ὁ ἔρως· ὃν ἀναπνέων καὶ διώκων ἐκαρτέρεις, πάντων τῶν δεινῶν τὰ ἐπίπονα."

meMA.Ode4C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C2Tr.melody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.name
meMA.Ode4C2Tr.incipit = "Τριάδα ἐν Μονάδι, δοξάσωμεν πιστοί…"
meMA.Ode4C2Tr.text = "Τριάδα ἐν Μονάδι, δοξάσωμεν πιστοί, ἀσιγήτοις στόμασι, βοῶντες πρὸς αὐτήν· Ἡ ἐν Μονάδι Τριὰς Ἁγία προσκυνουμένη, καὶ ἐν Τριάδι ὑμνουμένη ἀσυγχύτως, δόξα σοι Τριὰς ὁμοούσιος."

meMA.Ode4C2T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C2T.melody = he.h.m1_gr_GR_cog.heHE.EnPnevmatiProvlepon.name
meMA.Ode4C2T.incipit = "Σπηλαίῳ ὑπογαίῳ, τεχθῆναι διʼ ἡμᾶς…"
meMA.Ode4C2T.text = "Σπηλαίῳ ὑπογαίῳ, τεχθῆναι διʼ ἡμᾶς, Θεὸς ὢν ἠξίωσας, πτωχεύσας Ἀγαθέ, τὴν ἡμετέραν πτωχείαν διʼ εὐσπλαγχνίαν, καὶ ἐκ Παρθένου προελθὼν σεσαρκωμένος, μείνας εἷς Υἱὸς ἐκ Πατρὸς καὶ Μητρός."

meMA.Ode5C1H.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1H.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C1H.greekmelody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.greekname
meMA.Ode5C1H.melody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.melody
meMA.Ode5C1H.incipit = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.incipit
meMA.Ode5C1H.text = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.text

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C11.greekmelody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.greekname
meMA.Ode5C11.melody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.name
meMA.Ode5C11.incipit = "Ῥανάτωσαν γηθόμενοι, νεφέλαι γλυκασμόν· ἤδη…"
meMA.Ode5C11.text = "Ῥανάτωσαν γηθόμενοι, νεφέλαι γλυκασμόν· ἤδη γὰρ ἐγγίζει ὁ Κύριος, ἀποτεχθῆναι ὥσπερ νήπιον, ἐκ τῆς Ἁγνῆς Παρθένου, ἐν εὐτελεῖ Σπηλαίῳ."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C12.melody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.name
meMA.Ode5C12.incipit = "Οἱ θεῖοι νῦν σκιρτήσατε, Προφῆται…"
meMA.Ode5C12.text = "Οἱ θεῖοι νῦν σκιρτήσατε, Προφῆται τοῦ Θεοῦ· ἥκει γὰρ Χριστὸς ἡ ἀλήθεια, ἀποκληρῶσαι τὰ κηρύγματα, ὑμῶν τῆς θείας γλώσσης, τικτόμενος ὡς βρέφος."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C13.melody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.name
meMA.Ode5C13.incipit = "Ἐδὲμ πάλαι κλεισθεῖσά μοι, ἀνοίχθητι…"
meMA.Ode5C13.text = "Ἐδὲμ πάλαι κλεισθεῖσά μοι, ἀνοίχθητι λοιπόν, βλέπουσα Χριστόν, σαρκὶ νηπιάσαντα, καὶ ἐν τῇ πόλει ὡς εὐδόκησε, τῆς Βηθλεὲμ ἐκ Κόρης, τικτόμενον Παρθένου."

meMA.Ode5C21.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C21.greekmelody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.greekname
meMA.Ode5C21.melody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.name
meMA.Ode5C21.incipit = "Τοιοῦτος ἡμῖν ἔπρεπε, σοφὸς Ἀρχιερεύς…"
meMA.Ode5C21.text = "Τοιοῦτος ἡμῖν ἔπρεπε, σοφὸς Ἀρχιερεύς, ὅσιος, πιστός, ἀμίαντος, ἄκακος, βοῶν ὁ Παῦλος προϋπέγραψε, την ἱερὰν εἰκόνα, τῶν ἱερῶν σου τρόπων."

meMA.Ode5C22.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C22.melody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.name
meMA.Ode5C22.incipit = "Κανόνα ἀπαράτρωτον, καὶ τύπον εὐσεβῆ…"
meMA.Ode5C22.text = "Κανόνα ἀπαράτρωτον, καὶ τύπον εὐσεβῆ, ἔχοντες τὴν σὴν τοῦ βίου ἀκρόπολιν, πρὸς ταύτην Πάτερ ἀναγόμεθα, οἱ τῆς ἀρχαίας δόξης, τυχεῖν ἐπιποθοῦντες."

meMA.Ode5C23.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C23.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C23.melody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.name
meMA.Ode5C23.incipit = "Τὰ Παύλου κατορθώματα, ζηλώσας εὐσεβῶς…"
meMA.Ode5C23.text = "Τὰ Παύλου κατορθώματα, ζηλώσας εὐσεβῶς, ὅλους τοὺς αὐτοῦ, κινδύνους ὑπέμεινας, Ἱερομάρτυς ἀξιάγαστε, τὸ τῆς Ἑῴας φέγγος καὶ τῆς Ἑσπέρας ἄστρον."

meMA.Ode5C24.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C24.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C24.melody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.name
meMA.Ode5C24.incipit = "Δεσμώτης ἀπαγόμενος, παθεῖν Ἀρχιερεῦ, δέσμιος…"
meMA.Ode5C24.text = "Δεσμώτης ἀπαγόμενος, παθεῖν Ἀρχιερεῦ, δέσμιος Χριστοῦ, Ἰγνάτιε ἔγραφες, ταῖς Ἐκκλησίαις καὶ ταῖς πόλεσιν, ἐπιστηρίζων πάντας, ἐν τῇ ὁμολογίᾳ."

meMA.Ode5C25.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C25.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C25.melody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.name
meMA.Ode5C25.incipit = "Ὡς στῦλος καὶ ἑδραίωμα, καὶ…"
meMA.Ode5C25.text = "Ὡς στῦλος καὶ ἑδραίωμα, καὶ πρόβολος ἡμῶν, Μάρτυς καὶ Ποιμήν, ἀσάλευτον φύλαττε, τῆς Ἐκκλησίας τὴν ὁμόνοιαν, ἐν τῇ ὁμολογίᾳ, τῆς Χριστοῦ ἀληθείας."

meMA.Ode5C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C2Tr.melody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.name
meMA.Ode5C2Tr.incipit = "Τριάδος τὸ ὁμότιμον, ὑμνῶ καὶ…"
meMA.Ode5C2Tr.text = "Τριάδος τὸ ὁμότιμον, ὑμνῶ καὶ προσκυνῶ, μίαν προσφυῶς, δοξάζων Θεότητα, τρισὶ Προσώποις ἀδιαίρετον, καὶ ἐν μιᾷ οὐσίᾳ, ἀεὶ γνωριζομένην."

meMA.Ode5C2T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C2T.melody = he.h.m1_gr_GR_cog.heHE.TinSinEirinin.name
meMA.Ode5C2T.incipit = "Θεὸς ἀνθρώποις ὅμοιος, γενόμενος ἐκ…"
meMA.Ode5C2T.text = "Θεὸς ἀνθρώποις ὅμοιος, γενόμενος ἐκ σοῦ, βρέφος διʼ ἡμᾶς, γεννᾶται Θεόνυμφε, καὶ μένει ὅλως ἀναλλοίωτος, καὶ ἐν σαρκὶ ὁρᾶται, Θεὸς ἐνανθρωπήσας."

meMA.Ode6C1H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1H.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C1H.greekmelody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.greekname
meMA.Ode6C1H.melody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.melody
meMA.Ode6C1H.incipit = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.incipit
meMA.Ode6C1H.text = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.text

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C11.greekmelody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.greekname
meMA.Ode6C11.melody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.name
meMA.Ode6C11.incipit = "Οὐρανὸς ἐπὶ τῆς γῆς, τὸν…"
meMA.Ode6C11.text = "Οὐρανὸς ἐπὶ τῆς γῆς, τὸν οὐράνιον δηλοῖ, Βασιλέα διʼ ἡμᾶς, διʼ ἀστέρος φαεινοῦ, τικτόμενον, τοῖς Ἀστρολόγοις, νῦν ἐν τῇ πόλει Δαυΐδ."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C12.melody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.name
meMA.Ode6C12.incipit = "Ῥητορεύει καὶ βοᾷ, ὁ Προφήτης…"
meMA.Ode6C12.text = "Ῥητορεύει καὶ βοᾷ, ὁ Προφήτης ἐμφανῶς, Οἶκος σὺ τοῦ Ἐφραθᾶ, Βηθλεὲμ ἐν ᾗ Θεός, ὀφθήσεται, ἐκ τῆς Παρθένου, σκίρτα καὶ χόρευε."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C13.melody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.name
meMA.Ode6C13.incipit = "Ἐν Σπηλαίῳ Βηθλεέμ, Κόρη τίκτει…"
meMA.Ode6C13.text = "Ἐν Σπηλαίῳ Βηθλεέμ, Κόρη τίκτει ἐμφανῶς, τὸν Θεὸν τὸν τοῦ παντός, Ποιητὴν καὶ ὡς βροτόν, εἱλήσασα, σπαργάνοις φάτνῃ, ἐπανακλίνει αὐτόν."

meMA.Ode6C21.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C21.greekmelody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.greekname
meMA.Ode6C21.melody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.name
meMA.Ode6C21.incipit = "Ὡς τὸν ὄντως ἐραστήν, ἀγαπήσας…"
meMA.Ode6C21.text = "Ὡς τὸν ὄντως ἐραστήν, ἀγαπήσας ἀκλινῶς, καὶ τὸ πῦρ τὸ πρὸς αὐτόν, ἀναφλέξας νοερῶς, Ἰγνάτιε, τὸ ὕδωρ ἔσχες, ἐν σοὶ τὸ ζῶν καὶ λαλοῦν."

meMA.Ode6C22.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C22.melody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.name
meMA.Ode6C22.incipit = "Εἰ καὶ ἔπιες Χριστοῦ, τὸ…"
meMA.Ode6C22.text = "Εἰ καὶ ἔπιες Χριστοῦ, τὸ ποτήριον καινόν, ἀλλʼ ἐνέμεινας διψῶν, τὸ θανεῖν ὑπὲρ τὸ ζῆν, καὶ ἔκραζες· Οὐδέν μοι ταῦτα, πρὸς τὸ τυχεῖν με τοῦ ζῆν."

meMA.Ode6C23.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C23.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C23.melody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.name
meMA.Ode6C23.incipit = "Τὸ μαρτύριον τῆς σῆς, συνειδήσεως…"
meMA.Ode6C23.text = "Τὸ μαρτύριον τῆς σῆς, συνειδήσεως πληρῶν, οὐκ ἐνάρκησας ὁρῶν, τῶν θηρίων τὰς ὁρμάς, οὐκ ἔπτηξας, ὡς σῖτος μέλλων, μύλαις ἀλήθεσθαι."

meMA.Ode6C24.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C24.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C24.melody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.name
meMA.Ode6C24.incipit = "Ὑπερζέων Ἀθλητά, τῇ ἀγάπῃ τοῦ…"
meMA.Ode6C24.text = "Ὑπερζέων Ἀθλητά, τῇ ἀγάπῃ τοῦ Χριστοῦ, πρὸς τὸ πῦρ τῶν πειρασμῶν, ὡς εἰς δρόσον πρωϊνήν, ἀνέτρεχες, ἐκεῖνο φθάσαι, τὸ ὄντως, Ὂν ἐραστόν."

meMA.Ode6C25.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C25.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C25.melody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.name
meMA.Ode6C25.incipit = "Τοὺς μακρούς σου πειρασμούς, καὶ…"
meMA.Ode6C25.text = "Τοὺς μακρούς σου πειρασμούς, καὶ τὰ ἄλυτα δεσμά, τοὺς ἐν Ῥώμῃ σπαραγμούς, καὶ τὸ πῦρ τῶν διωκτῶν, οὐδὲν ἡγοῦ, Ἱερομάρτυς, διὰ τὸν σὸν ἐραστήν."

meMA.Ode6C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C2Tr.melody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.name
meMA.Ode6C2Tr.incipit = "Ὑπερούσιε Τριάς, ὑπεράγαθε Μονάς, ὁ…"
meMA.Ode6C2Tr.text = "Ὑπερούσιε Τριάς, ὑπεράγαθε Μονάς, ὁ Πατὴρ καὶ ὁ Υἱός, καὶ τὸ Πνεῦμα τὸ εὐθές, ἐλέησον, τοὺς προσκυνοῦντας, τὸ θεῖον κράτος σου."

meMA.Ode6C2T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C2T.melody = he.h.m1_gr_GR_cog.heHE.TonProfitinIonan.name
meMA.Ode6C2T.incipit = "Εὐτρεπίζου Βηθλεέμ, ἑτοιμάζου Ἐφραθᾶ, ὁ…"
meMA.Ode6C2T.text = "Εὐτρεπίζου Βηθλεέμ, ἑτοιμάζου Ἐφραθᾶ, ὁ Ἀμήτωρ ἐκ Πατρός, καὶ Ἀπάτωρ ἐκ Μητρός, βαστάζεται, κυοφορεῖται, τίκτεται σῴζων ἡμᾶς."

meMA.Kontakion2.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Kontakion2.greekmelody = he.a.m3_gr_GR_cog.heAU.IParthenosSimeron.greekname
meMA.Kontakion2.melody = he.a.m3_gr_GR_cog.heAU.IParthenosSimeron.name
meMA.Kontakion2.incipit = "Τῶν λαμπρῶν ἀγώνων…"
meMA.Kontakion2.text = "Τῶν λαμπρῶν ἀγώνων σου, ἡ φωτοφόρος ἡμέρα, προκηρύττει ἅπασι, τὸν ἐκ Παρθένου τεχθέντα· τούτου γάρ, διψῶν ἐκ πόθου κατατρυφῆσαι, ἔσπευσας, ὑπὸ θηρίων ἀναλωθῆναι· διὰ τοῦτο Θεοφόρος, προσηγορεύθης, Ἰγνάτιε ἔνδοξε."

meMA.Oikos2.text = "Ἀβραὰμ μέν ποτε τὸν υἱὸν ἐθυσίαζε, τὴν σφαγὴν προτυπῶν τοῦ τὰ πάντα κατέχοντος, καὶ νῦν ἐν Σπηλαίῳ σπεύδοντος τεχθῆναι· σὺ δὲ θεόφρον, ὅλον προσήγαγες σαυτὸν ὥς περ σφάγιον· καὶ τῶν θηρίων βρῶμα γενόμενος, σῖτος καθαρὸς ὤφθης τῷ Κτίστῃ σου, ἐν ἀποθήκαις ἐπουρανίαις διαιωνίζων ἀληθῶς, καὶ τοῦ σοῦ ἔρωτος τρυφῶν· διʼ ὃν πάντα τὸν κόσμον καταλείψας παμμάκαρ, Θεοφόρος προσηγορεύθης, Ἰγνάτιε ἔνδοξε."

meMA.Ode7C1H.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1H.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C1H.greekmelody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.greekname
meMA.Ode7C1H.melody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.melody
meMA.Ode7C1H.incipit = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.incipit
meMA.Ode7C1H.text = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.text

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C11.greekmelody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.greekname
meMA.Ode7C11.melody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.name
meMA.Ode7C11.incipit = "Τὴν τοῦ Χριστοῦ ἐν σώματι…"
meMA.Ode7C11.text = "Τὴν τοῦ Χριστοῦ ἐν σώματι δηλῶν, ἀνάδειξιν, ὁ Ἱερεμίας ἐκβοᾷ· Ἐπὶ τῆς γῆς σωματωθεὶς ὁ Θεὸς ὤφθη, ἐπιστήμης εὗρέ τε πᾶσαν ὁδόν, γεννηθεὶς ἐν Βηθλεὲμ ἐκ Μητρός."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C12.melody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.name
meMA.Ode7C12.incipit = "Ἰδοὺ ἐκ ῥίζης ῥάβδος, ἐβλάστησεν…"
meMA.Ode7C12.text = "Ἰδοὺ ἐκ ῥίζης ῥάβδος, ἐβλάστησεν, ἄνθος ἀναθάλλουσα Χριστόν· καὶ ἐπʼ αὐτῷ νῦν τικτομένῳ ἐν Σπηλαίῳ, Πνεῦμα ἀναπαύσεται, συνέσεως καὶ βουλῆς, καὶ θείας γνώσεως."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C13.melody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.name
meMA.Ode7C13.incipit = "Ἀκουτισθῶμεν λόγων ἱερῶν. ὁ Κύριος…"
meMA.Ode7C13.text = "Ἀκουτισθῶμεν λόγων ἱερῶν. ὁ Κύριος τίκτεται Παιδίον διʼ ἡμᾶς, οὗ ἡ ἀρχὴ ἐπὶ τοῦ ὤμου ἐγενήθη, καὶ καλεῖται Ἄγγελος, βουλῆς μεγάλης Πατρός, ἄρχων εἰρήνης Χριστός."

meMA.Ode7C21.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C21.greekmelody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.greekname
meMA.Ode7C21.melody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.name
meMA.Ode7C21.incipit = "Οὐκ ἔσχες πῦρ φιλόϋλον ἐν…"
meMA.Ode7C21.text = "Οὐκ ἔσχες πῦρ φιλόϋλον ἐν σοί, Ἰγνάτιε, ὕδωρ δὲ ζῶν μᾶλλον καὶ λαλοῦν, ὕδωρ καλοῦν· Δεῦρο ταχὺ πρὸς τὸν Πατέρα, ὕδωρ τὸ ἁλλόμενον, τὸ ἐκ ζωῆς εἰς ζωὴν μετοχετεῦον ἡμᾶς."

meMA.Ode7C22.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C22.melody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.name
meMA.Ode7C22.incipit = "Οἱ τῶν θηρῶν ὀδόντες μοι…"
meMA.Ode7C22.text = "Οἱ τῶν θηρῶν ὀδόντες μοι φησί, γενέσθωσαν, ξίφη καὶ ῥομφαῖαι καὶ σφαγαί· τάφος δέ μοι τὰ τῶν λεόντων σπλάγχνα ἔστω, καὶ τὸ πῦρ νεμέσθω μου, πρὸ τῆς φθορᾶς, τῆς δορᾶς τὸ ἐγκατάλειμμα."

meMA.Ode7C23.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C23.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C23.melody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.name
meMA.Ode7C23.incipit = "Τὸ ζῆν ἐμοὶ οὐκ ἔστιν…"
meMA.Ode7C23.text = "Τὸ ζῆν ἐμοὶ οὐκ ἔστιν ἐραστόν, ἐν σώματι· πνεύματι γὰρ ζῆν ἐπιποθῶ· ἐμοὶ τὸ ζῆν Χριστὸς ὁ θεῖος ἔρως, πρὸς αὐτὸν ἐπείγομαι, αὐτὸν φησὶν ἀγαπῶ, αὐτοῦ τυχεῖν προσδοκῶ."

meMA.Ode7C24.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C24.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C24.melody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.name
meMA.Ode7C24.incipit = "Ἐμοὶ γλυκὺς ὁ θάνατος φησίν…"
meMA.Ode7C24.text = "Ἐμοὶ γλυκὺς ὁ θάνατος φησίν, ἡδέα μοι, πάντα τὰ τῶν πόνων ἀλγεινά, θῆρες τερπνοί, δρόσος τὸ πῦρ ἐστί μοι τοῦτο· οὐ τοῦ ζῆν ἀνθέξομαι· διὸ καὶ σπεύδω θανεῖν, ἵνα συζήσω Χριστῷ."

meMA.Ode7C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C2Tr.melody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.name
meMA.Ode7C2Tr.incipit = "Τριαδικὴν προσάξωμεν ᾠδὴν δοξάζοντες, ἄναρχον…"
meMA.Ode7C2Tr.text = "Τριαδικὴν προσάξωμεν ᾠδὴν δοξάζοντες, ἄναρχον Πατέρα καὶ Υἱόν, Πνεῦμα εὐθές, μοναδικὴν μίαν οὐσίαν, ἣν τρισσῶς ὑμνήσωμεν· Ἅγιος, Ἅγιος, Ἅγιος, κράζοντες· ὁ τῶν Πατέρων Θεός."

meMA.Ode7C2T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C2T.melody = he.h.m1_gr_GR_cog.heHE.TousEnKaminoPaidas.name
meMA.Ode7C2T.incipit = "Ὁ τοῖς Προφήταις πάλαι προῤῥηθείς…"
meMA.Ode7C2T.text = "Ὁ τοῖς Προφήταις πάλαι προῤῥηθείς, ἐγγίζει μοι, βρέφος ἐκ Παρθένου κυηθείς. Χαίρει Ἀδάμ, καὶ ἡ Προμήτωρ Εὔα, τῶν ὠδίνων λέλυται· καὶ συγχορεύει Δαυΐδ, ὁ τῆς Παρθένου πατήρ."

meMA.Ode8C1H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1H.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C1H.greekmelody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.greekname
meMA.Ode8C1H.melody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.melody
meMA.Ode8C1H.incipit = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.incipit
meMA.Ode8C1H.text = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.text

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C11.greekmelody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.greekname
meMA.Ode8C11.melody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.name
meMA.Ode8C11.incipit = "Ὁ Κύριος ἔρχεται, ἐν ξένῳ…"
meMA.Ode8C11.text = "Ὁ Κύριος ἔρχεται, ἐν ξένῳ τοκετῷ, σαφῶς εἰς τὰ ἴδια, δεξώμεθα αὐτόν, ὅπως ξενωθέντας Παραδείσου τρυφῆς, πάλιν οἰκειώσῃ, τικτόμενος Σπηλαίῳ."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C12.melody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.name
meMA.Ode8C12.incipit = "Ἰδοὺ ἡ ἀνάκλησις, ἡμῶν ἐπιδημεῖ…"
meMA.Ode8C12.text = "Ἰδοὺ ἡ ἀνάκλησις, ἡμῶν ἐπιδημεῖ· ἠχήσωμεν ᾄσματα, χαρμόσυνα σπουδῇ, καὶ ᾄσωμεν μέλη προεόρτια, τῷ ἐν σμικροτάτῳ, χωρουμένῳ Σπηλαίῳ."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C13.melody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.name
meMA.Ode8C13.incipit = "Ὡς ὤμοσε Κύριος, πεπλήρωκεν ἰδού…"
meMA.Ode8C13.text = "Ὡς ὤμοσε Κύριος, πεπλήρωκεν ἰδού, ἐκ σπέρματος δοὺς ἡμῖν, Δαυῒδ τὴν ἑαυτοῦ, Μητέρα Παρθένον, ἐξ ἧς βρέφος σαρκί, ἐτέχθη ἐν πόλει, Βηθλεὲμ ὑπὲρ λόγον."

meMA.Ode8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C21.greekmelody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.greekname
meMA.Ode8C21.melody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.name
meMA.Ode8C21.incipit = "Ὑμνείσθω Ἰγνάτιος, ὁ μέγας Ἱερεύς…"
meMA.Ode8C21.text = "Ὑμνείσθω Ἰγνάτιος, ὁ μέγας Ἱερεύς, διττῶς στεφανούμενος, ὡς Μάρτυς καὶ Ποιμήν· ἀθλήσας γὰρ οὗτος, δι ἀγάπην Θεοῦ, ἐρῶν τοῦ ἐρᾶσθαι, παθεῖν οὐ παρῃτεῖτο."

meMA.Ode8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C22.melody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.name
meMA.Ode8C22.incipit = "Διψῶν τὸ ποτήριον τοῦ πάθους…"
meMA.Ode8C22.text = "Διψῶν τὸ ποτήριον τοῦ πάθους τοῦ Χριστοῦ, δεσμώτης ἀνέτρεχες, Ἰγνάτιε σοφέ, καὶ φθάσας τὸ σκάμμα, οὐκ ἐπαύσω βοῶν· Διψῶ τοῦ διψᾶσθαι, Χριστῷ εἰς τοὺς αἰῶνας."

meMA.Ode8C23.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C23.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C23.melody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.name
meMA.Ode8C23.incipit = "Τοῖς δρόμοις τῆς Πίστεως, ὡς…"
meMA.Ode8C23.text = "Τοῖς δρόμοις τῆς Πίστεως, ὡς ἥλιος τὴν γῆν, γενναίως διέδραμες, ἀπʼ ἄκρων οὐρανοῦ, καὶ δύνας ἀδύτως, ἀπὸ γῆς εἰς Χριστόν, τὸ φῶς συναστράπτεις, αὐτῷ τῆς ἀφθαρσίας."

meMA.Ode8C24.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C24.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C24.melody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.name
meMA.Ode8C24.incipit = "Δεσμοῖς κατεχόμενος, διώδευσας τὴν γῆν…"
meMA.Ode8C24.text = "Δεσμοῖς κατεχόμενος, διώδευσας τὴν γῆν, μυρίσας τοῖς ἄθλοις σου, ἡμᾶς τοὺς ἐν αὐτῇ, καὶ νῦν μετὰ τέλος, ὥσπερ κρίνον ἀγροῦ, καὶ κρίνον πεδίου, ἡμᾶς εὐωδιάζεις."

meMA.Ode8C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C2Tr.melody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.name
meMA.Ode8C2Tr.incipit = "Μονὰς οὐσιότητι, ὑμνείσθω ἡ Τριάς…"
meMA.Ode8C2Tr.text = "Μονὰς οὐσιότητι, ὑμνείσθω ἡ Τριάς, τριὰς ὑποστάσεσι, τιμάσθω ἡ Μονάς, ὡς μία τῇ φύσει, τοῖς προσώποις δὲ τρεῖς, οὐ διαιρουμένη, οὐ συναλειφομένη."

meMA.Ode8C2T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C2T.melody = he.h.m1_gr_GR_cog.heHE.OnFrittousinAngeloi.name
meMA.Ode8C2T.incipit = "Τὸ ἄστρον ἀνέτειλε, Χριστὸς ἐν…"
meMA.Ode8C2T.text = "Τὸ ἄστρον ἀνέτειλε, Χριστὸς ἐν, Ἰακώβ, καὶ Μάγοι συντρέχουσιν, ἐν πόλει Βηθλεέμ, ὑμνῆσαι, τιμῆσαι, προσκυνῆσαι αὐτῷ, τεχθέντι ἐκ μήτρας, Ἁγνῆς τῆς Θεοτόκου."

meMA.Ode9C1H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1H.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C1H.greekmelody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.greekname
meMA.Ode9C1H.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.melody
meMA.Ode9C1H.incipit = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.incipit
meMA.Ode9C1H.text = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C11.greekmelody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.greekname
meMA.Ode9C11.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
meMA.Ode9C11.incipit = "Σὺν Πατριάρχαις, Δικαίοις τε ἅπασι…"
meMA.Ode9C11.text = "Σὺν Πατριάρχαις, Δικαίοις τε ἅπασι, καὶ τοῖς Ἁγίοις Προφήταις σκιρτήσωμεν, ἐκ Παρθένου Κύριος, Ἰησοῦς ἡ λύτρωσις, ὁ φωτισμὸς ἡ ζωὴ ἡ σωτηρία, νῦν ἐν τῇ Πόλει, Δαυῒδ ἀποτίκτεται."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C12.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
meMA.Ode9C12.incipit = "Ἤδη τῆς θείας τοῦ Λόγου…"
meMA.Ode9C12.text = "Ἤδη τῆς θείας τοῦ Λόγου σαρκώσεως, πᾶσιν ἠνοίχθη σαφῶς τὰ προπύλαια, οὐρανοὶ ἀγάλλεσθε· Ἄγγελοι σκιρτήσατε, καὶ εὐφραινέσθω ἡ γῆ σὺν τοῖς ἀνθρώποις, μετὰ Ποιμένων καὶ Μάγων ἐν πνεύματι."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C13.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
meMA.Ode9C13.incipit = "Φέρει Χριστὸν ὥσπερ μύρον ἀκένωτον…"
meMA.Ode9C13.text = "Φέρει Χριστὸν ὥσπερ μύρον ἀκένωτον, τὸ νοητὸν ἡ Παρθένος ἀλάβαστρον, καὶ τοῦτο προέρχεται, ἐν Σπηλαίῳ πνεύματι, ἀποκενῶσαι σαφῶς, ὅπως πληρώσῃ, τῆς εὐωδίας αὐτοῦ τὰς ψυχὰς ἡμῶν."

meMA.Ode9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C21.greekmelody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.greekname
meMA.Ode9C21.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
meMA.Ode9C21.incipit = "Ὁ Θεοφόρος ἡμᾶς εἱστιάσατο, τοὺς…"
meMA.Ode9C21.text = "Ὁ Θεοφόρος ἡμᾶς εἱστιάσατο, τοὺς ἱεροὺς αὐτοῦ ἄθλους προθεὶς ἡμῖν. Δεῦτε φιλομάρτυρες, ἱερῶς δρεψάμενοι, τὰ μυστικὰ τῶν τερπνῶν ᾀσμάτων ἄνθη, τὰς κορυφάς ἑαυτῶν στεφανώσωμεν."

meMA.Ode9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C22.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
meMA.Ode9C22.incipit = "Τὴν ἱεράν σου στολὴν ἱερώτατε…"
meMA.Ode9C22.text = "Τὴν ἱεράν σου στολὴν ἱερώτατε, ἱερωτέραν εἰργάσω τοῖς ἄθλοις σου· διὸ καὶ τὸν στέφανον, διττῶς κομισάμενος, μετὰ Μαρτύρων ὑμνεῖς καὶ τῶν Ποιμένων, Ἱερομάρτυς Χριστὸν τὸν Θεὸν ἡμῶν."

meMA.Ode9C23.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C23.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C23.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
meMA.Ode9C23.incipit = "Σῖτος Θεοῦ καθαρὸς εἰμι ἔλεγες…"
meMA.Ode9C23.text = "Σῖτος Θεοῦ καθαρὸς εἰμι ἔλεγες, καὶ διʼ ὀδόντων θηρίων ἀλήθομαι, ἵνα ἄρτος γένωμαι, ἱεροτελούμενος τῷ ἐραστῇ καὶ Θεῷ κεκαθαρμένος, ὃν καὶ ποθῶν, οὐ πτοοῦμαι τὸν θάνατον."

meMA.Ode9C24.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C24.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C24.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
meMA.Ode9C24.incipit = "Ὡς ὑπερόπτης τῶν κάτω Ἰγνάτιε…"
meMA.Ode9C24.text = "Ὡς ὑπερόπτης τῶν κάτω Ἰγνάτιε, καὶ ὑπηρέτης τῶν ἄνω μυήσεων, ὡς λατρείαν ἄμωμον, τελῶν καὶ τελούμενος, ἱερουργεῖς σεαυτὸν τῷ μαρτυρίῳ, πρός τε θηρία καὶ πῦρ ἑτοιμαζόμενος."

meMA.Ode9C25.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C25.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C25.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
meMA.Ode9C25.incipit = "Σπλάγχνα θηρίων σοι τάφος γεγόνασιν…"
meMA.Ode9C25.text = "Σπλάγχνα θηρίων σοι τάφος γεγόνασιν· ἔχεις δὲ νῦν τὴν Σιὼν ἐνδιαίτημα, καὶ ζῇς ἐν καινότητι, ζωηφόρου Πνεύματος, ἐν οὐρανοῖς τῷ Χριστῷ συμβασιλεύων, καὶ ἐντρυφῶν τῇ αὐτοῦ ὡραιότητι."

meMA.Ode9C26.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C26.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C26.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
meMA.Ode9C26.incipit = "Τῷ ἀπροσίτῳ φωτὶ ἐλλαμπόμενος, καὶ…"
meMA.Ode9C26.text = "Τῷ ἀπροσίτῳ φωτὶ ἐλλαμπόμενος, καὶ ἐν ταῖς ἄνω μοναῖς αὐλιζόμενος, ἱερὲ Ἰγνάτιε, τῷ Θεῷ καὶ Κτίστῃ σου, ὑπὲρ τῆς ποίμνης σου ταύτης ἐντυγχάνων, ἀδιαλείπτως μὴ παύσῃ δεόμενος."

meMA.Ode9C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C2Tr.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
meMA.Ode9C2Tr.incipit = "Τὸ ὑπεράρχιον φῶς ἡ ζωὴ…"
meMA.Ode9C2Tr.text = "Τὸ ὑπεράρχιον φῶς ἡ ζωὴ ἡμῶν, Πατὴρ Υἱὸς καὶ τὸ Πνεῦμα τὸ Ἅγιον, τρισὶν ὑποστάσεσι, καὶ μιᾷ, θεότητι, ὑπερουσίως ἀεὶ θεολογείσθω, Τριὰς ἁπλὴ, συμφυὴς καὶ ὁμότιμος."

meMA.Ode9C2T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C2T.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
meMA.Ode9C2T.incipit = "Χαῖρε Ἁγνὴ τοῦ Θεοῦ Πόλις…"
meMA.Ode9C2T.text = "Χαῖρε Ἁγνὴ τοῦ Θεοῦ Πόλις ἔμψυχε, ἐν ᾗ Θεοῦ χωρηθῆναι εὐδόκησε· μὴ λιπὼν τὰ ἄνω γάρ, πρὸς σὲ καταβέβηκεν, ὡς ὑετὸς ἐπὶ γῆς Θεογεννῆτορ, καὶ ἐν τῇ πόλει Βηθλεὲμ βρέφος τίκτεται."

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_gr_GR_cog.heAU.EpeskepsatoImas.greekname
meMA.Exaposteilarion1.melody = he.a.m3_gr_GR_cog.heAU.EpeskepsatoImas.name
meMA.Exaposteilarion1.incipit = "Ἑτοιμάζου Βηθλεέμ…"
meMA.Exaposteilarion1.text = "Ἑτοιμάζου Βηθλεέμ· Σπήλαιον εὐτρεπίσθητι· ὑπόδεξαι καὶ ἡ Φάτνη, τὸν ἀπερίγραπτον Θεόν, σαρκὶ περιγραφόμενον· ἔρχεται γὰρ τεχθῆναι, καθώσπερ εὐδόκησεν."

meMA.Exaposteilarion2.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Exaposteilarion2.greekmelody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.greekname
meMA.Exaposteilarion2.melody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.name
meMA.Exaposteilarion2.incipit = "Σῖτος ὑπάρχω ἔλεγες…"
meMA.Exaposteilarion2.text = "Σῖτος ὑπάρχω ἔλεγες, τοῦ Θεοῦ καὶ Σωτῆρος, καὶ δεῖ με νῦν ἀλήθεσθαι, διʼ ὀδόντων θηρίων, Ἰγνάτιε Θεοφόρε, ὅπως ἄρτος ἡδύς τε, καὶ καθαρὸς ὀφθήσομαι, τῇ Ἁγίᾳ Τριάδι· ᾗ παρεστώς, μνημονεύοις πάνσοφε τῶν τελούντων, τὴν φωτοφόρον μνήμην σου, Ἱεράρχα καὶ Μάρτυς."

meMA.Exaposteilarion3.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Exaposteilarion3.greekmelody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.greekname
meMA.Exaposteilarion3.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
meMA.Exaposteilarion3.incipit = "Ὡς τετρωμένος ἔρωτι…"
meMA.Exaposteilarion3.text = "Ὡς τετρωμένος ἔρωτι, ἀγάπης τοῦ Κυρίου σου, Ὁ ἐμὸς ἔρως ἐβόας, Χριστὸς ἐσταύρωται θέλων· διὸ διψῶ τοῦ διψᾶσθαι, καὶ ζῶν ἐρῶ τοῦ ἐρᾶσθαι· οὗ κοινωνὸς γενηθῆναι, ἐπιποθῶ καὶ τοῦ πάθους, καὶ τῆς αὐτοῦ βασιλείας."

meMA.Exaposteilarion4.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Exaposteilarion4.greekmelody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.greekname
meMA.Exaposteilarion4.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
meMA.Exaposteilarion4.incipit = "Πιστοὶ τὰ προεόρτια…"
meMA.Exaposteilarion4.text = "Πιστοὶ τὰ προεόρτια, τῶν Γενεθλίων ᾄσματα, νῦν προηχήσωμεν πίστει· ἔρχεται ἥκει γὰρ Χριστός, ἐν Βηθλεὲμ τοῦ τεχθῆναι, ὡς βροτὸς ἐκ Παρθένου, καὶ ὁραθῆναι νήπιος, σπαργάνοις ἐνειλημένος, ὁ πρὸ αἰώνων ὑπάρχων."

meMA.Lauds1.poet = poets_gr_GR_cog.po.RomanouTouMelodou
meMA.Lauds1.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Lauds1.melody = he.a.m6_gr_GR_cog.heAU.AiAngelikai.melody
meMA.Lauds1.incipit = he.a.m6_gr_GR_cog.heAU.AiAngelikai.incipit
meMA.Lauds1.text = he.a.m6_gr_GR_cog.heAU.AiAngelikai.text

meMA.Lauds2.poet = poets_gr_GR_cog.po.RomanouTouMelodou
meMA.Lauds2.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Lauds2.melody = he.a.m6_gr_GR_cog.heAU.AiAngelikai.name
meMA.Lauds2.incipit = "Ἀνίσχει ὁ Ἀστήρ…"
meMA.Lauds2.text = "Ἀνίσχει ὁ Ἀστήρ, Ἰακὼβ ἐν τῷ Σπηλαίῳ. Δεῦτε καὶ ἡμεῖς, προεόρτια τελοῦντες, συνδράμωμεν τοῖς Μάγοις, τοῖς Ποιμέσι συνέλθωμεν· ἴδωμεν Θεὸν ἐν τοῖς σπαργάνοις· ἴδωμεν Παρθένον γαλουχοῦσαν· φρικτὸν θέαμα! Ὁ Βασιλεὺς τοῦ Ἰσραήλ, Χριστὸς παραγίνεται."

meMA.Lauds3.poet = poets_gr_GR_cog.po.RomanouTouMelodou
meMA.Lauds3.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Lauds3.melody = he.a.m6_gr_GR_cog.heAU.AiAngelikai.name
meMA.Lauds3.incipit = "Βουνοὶ γλυκασμόν…"
meMA.Lauds3.text = "Βουνοὶ γλυκασμόν, σταλαξάτωσαν· ἰδοὺ γάρ, ἥκει ὁ Θεός, ἐκ Θαιμὰν Ἔθνη ἡττᾶσθε· ἀγάλλεσθε Προφῆται· Πατριάρχαι σκιρτήσατε· ἄνθρωποι χορεύσατε ἐνθέως· ὁ ἰσχυρὸς καὶ μέγας Ἄρχων, Χριστὸς τίκτεται· ὁ Βασιλεὺς τῶν οὐρανῶν, ἐν γῇ παραγίνεται."

meMA.Lauds4.poet = poets_gr_GR_cog.po.RomanouTouMelodou
meMA.Lauds4.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Lauds4.greekmelody = he.a.m6_gr_GR_cog.heAU.AiAngelikai.greekname
meMA.Lauds4.melody = he.a.m6_gr_GR_cog.heAU.AiAngelikai.name
meMA.Lauds4.incipit = "Γῆθεν ἀνυψῶν…"
meMA.Lauds4.text = "Γῆθεν ἀνυψῶν, τοὺς βροτοὺς ὁ Πλάστης ἥκει, τὴν βασιλικήν, καινουργῶν αὖθις εἰκόνα· συγχάρητε τῶν ἄνω, αἱ Δυνάμεις ὑμνήσατε· ἔχθρας τὸ μεσότοιχον ἐλύθη· ἦλθεν ᾧ ἀπέκειτο· Θεὸς γάρ, βροτὸς γίνεται· ὁ Βασιλεὺς τοῦ Ἰσραήλ, Χριστὸς παραγίνεται."

meMA.Lauds5.poet = poets_gr_GR_cog.po.RomanouTouMelodou
meMA.Lauds5.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Lauds5.melody = he.a.m6_gr_GR_cog.heAU.AiAngelikai.name
meMA.Lauds5.incipit = "Δεῦτε οἱ πιστοί…"
meMA.Lauds5.text = "Δεῦτε οἱ πιστοί, ὑπαντήσωμεν τῷ Κτίστῃ, ἥκοντι εἰς γῆν, ἐκ Παρθένου ἀνατεῖλαι· ἁγνείᾳ λαμπρυνθῶμεν, ἀρεταῖς ἀστραφθείημεν· τρόμῳ καὶ χαρᾷ ἑτοιμασθῶμεν, Χριστόν ἰδέσθαι βρεφωθέντα, νοὸς ὄμμασιν, ἡμᾶς θεοῦντα τοὺς βροτούς, ἄκρᾳ ἀγαθότητι."

meMA.LaudsGlory.poet = poets_gr_GR_cog.po.RomanouTouMelodou
meMA.LaudsGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.LaudsGlory.melody = he.a.m6_gr_GR_cog.heAU.AiAngelikai.name
meMA.LaudsGlory.incipit = "Ἐγγίζει ὁ Χριστός…"
meMA.LaudsGlory.text = "Ἐγγίζει ὁ Χριστός· Βηθλεὲμ προετοιμάζου· ἤδη τῶν Ἐθνῶν, τὸ σωτήριον αὐγάζει· εὐτρέπισον τὴν φάτνην, τοὺς Ποιμένας συνάγαγε, κάλεσον τοὺς Μάγους ἐκ Περσίδος· αἱ Στρατιαὶ τῶν Ἀσωμάτων, Νοῶν κράζουσιν· Ὁ Βασιλεὺς τῶν οὐρανῶν, Χριστὸς παραγίνεται."

meMA.LaudsBoth.poet = poets_gr_GR_cog.po.RomanouTouMelodou
meMA.LaudsBoth.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.LaudsBoth.melody = he.a.m6_gr_GR_cog.heAU.AiAngelikai.name
meMA.LaudsBoth.incipit = "Ζῆλός τε καὶ πῦρ…"
meMA.LaudsBoth.text = "Ζῆλός τε καὶ πῦρ, καταφάγεταί σε ἄφρον, πλάνε ἀληθῶς, καὶ τοῦ νόμου συκοφάντα· ἰδοὺ γὰρ ἡ Παρθένος, Ἠσαΐας ὡς ἔφησεν, ἔσχεν ἐν γαστρὶ καὶ ἐπὶ φάτνης, ἀνακλινεῖ τὸν Βασιλέα· διὸ ἅπαντες, οἱ ἐξ Ἰούδα τῆς φυλῆς, δυνάσται ἐκλείψουσιν."

meMA.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Aposticha1.melody = ""
meMA.Aposticha1.incipit = "Βηθλεὲμ εὐτρεπίζου…"
meMA.Aposticha1.text = "Βηθλεὲμ εὐτρεπίζου, ὕμνησον πόλις Σιών· ἀγάλλου ἡ ἔρημος, προμνηστευθεῖσα τὴν χαράν· ἀστὴρ γὰρ προέρχεται, ἐν Βηθλεὲμ μηνύων, μέλλοντα τίκτεσθαι Χριστόν· καὶ Σπήλαιον δέχεται, τὸν ἀχώρητον παντί· καὶ Φάτνη ἑτοιμάζεται, ὑποδέξασθαι ζωὴν τὴν αἰώνιον· αὐτῷ πάντες ᾄσωμεν καὶ βοήσωμεν· Σῶσον τὰς ψυχὰς ἡμῶν, Ἰησοῦ ὁ Θεός, ὁ σαρκωθεὶς διʼ ἡμᾶς."

meMA.Aposticha2.poet = poets_gr_GR_cog.po.Anatoliou
meMA.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Aposticha2.melody = ""
meMA.Aposticha2.incipit = "Χριστὸς ὁ ἐρχόμενος…"
meMA.Aposticha2.text = "Χριστὸς ὁ ἐρχόμενος, ἐμφανῶς Θεὸς ἡμῶν, ἥξει καὶ οὐ χρονιεῖ· ἐξ ἀπειρογάμου Νύμφης ὀφθήσεται, ἐν Σπηλαίῳ δὲ λοιπὸν προσαναπαύσεται· καὶ φάτνη τῶν ἀλόγων, ὃν οὐκ ἐχώρει οὐρανός, ὑποδέχου, μέλλοντα σπαργανοῦσθαι ἐν σοί, τὸν τῷ λόγῳ λύσαντα, τῆς ἀλογίας ἡμᾶς. Ἀστὴρ μηνύει, Μάγοι προσκυνοῦσι, Ποιμένες ἀγραυλοῦσι, θαῦμα ὁρῶντες τὸ φρικτόν· καὶ Ἄγγελοι μέλπουσιν, ἐπὶ γῆς θεώμενοι, τὴν ἀπολύτρωσιν τοῦ γένους ἡμῶν."

