meDA.date = "Τῌ Κʹ ΔΕΚΕΜΒΡΙΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
meDA.commemoration.full = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Ἰγνατίου τοῦ Θεοφόρου· καὶ Προεόρτια τῶν Γενεθλίων τοῦ Σωτῆρος ἡμῶν." // full title of day
meDA.commemoration.first = "Προεόρτια τῶν Γενεθλίων τοῦ Σωτῆρος ἡμῶν"
meDA.commemoration.first_short = "Προεόρτια τῶν Γενεθλίων τοῦ Σωτῆρος ἡμῶν"
meDA.commemoration.second_short = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Ἰγνατίου τοῦ Θεοφόρου"
meDA.commemoration.first_title = ""
meDA.commemoration.first_name = ""
