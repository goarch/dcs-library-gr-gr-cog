meMA.MM.Lauds1234as5678.text = properties_gr_GR_cog.media.key
meMA.MM.Lauds1234as3456.text = properties_gr_GR_cog.media.key

meMA.LaudsGlory.poet = poets_gr_GR_cog.po.Anatoliou
meMA.LaudsGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.LaudsGlory.melody = ""
meMA.LaudsGlory.incipit = "Αἷμα καὶ πῦρ, καὶ ἀτμίδα…"
meMA.LaudsGlory.text = "Αἷμα καὶ πῦρ, καὶ ἀτμίδα Καπνοῦ, τέρατα γῆς, ἃ προεῖδεν Ἰωήλ, αἷμα τὴν Σάρκωσιν· πῦρ τὴν Θεότητα· ἀτμίδα δὲ καπνοῦ, τὸ Πνεῦμα τὸ Ἅγιον, τὸ ἐπελθὸν τῇ Παρθένῳ, καὶ κόσμον εὐωδιάσαν. Μέγα τὸ μυστήριον, τῆς σῆς ἐνανθρωπήσεως, Κύριε δόξα σοι."

meLI.Kontakion1.mode = me.m12.dAC_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.greekmelody = me.m12.dAC_gr_GR_cog.meMA.Kontakion1.greekmelody
meLI.Kontakion1.melody = me.m12.dAC_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m12.dAC_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m12.dAC_gr_GR_cog.meMA.Kontakion1.text

meLI.Megalynarion.text = "Μνήστωρ τῆς Παρθένου ὁ Ἰωσήφ, καὶ φύλαξ ἐδείχθη, Θεοπάτωρ δὲ ὁ Δαβίδ, Ἰάκωβος ὁ ὁμαίμων, τοῦ Λόγου ὠνομάσθη· διὸ καὶ τῇ γεννήσει τούτου συγχαίρουσι."
