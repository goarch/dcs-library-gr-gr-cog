meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C11.greekmelody = he.h.m6_gr_GR_cog.heHE.KymatiThalassis.greekname
meMA.Ode1C11.melody = he.h.m6_gr_GR_cog.heHE.KymatiThalassis.name
meMA.Ode1C11.incipit = "Φόβῳ σοι θανάτου…"
meMA.Ode1C11.text = "Φόβῳ σοι θανάτου, ἀνοίγονται πύλαι καὶ διαῤῥήσσονται, μοχλοὶ αἰώνιοι· τῇ γὰρ σεπτῇ σου καθόδῳ, ἐξανέστησαν οἱ πάλαι νεκροί, ἐν εὐφροσύνῃ ψάλλοντες, Χριστὲ τὴν σὴν Ἀνάστασιν."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C12.melody = he.h.m6_gr_GR_cog.heHE.KymatiThalassis.name
meMA.Ode1C12.incipit = "Σήμερον τὸ κλίτος, τῶν θείων…"
meMA.Ode1C12.text = "Σήμερον τὸ κλῆτος, τῶν θείων Πατέρων, Χριστοῦ τὴν Γέννησιν, προεορτάζει φαιδρῶς, καὶ ὑπογράφεται ταύτης, τὸ παράδοξον τῆς χάριτος· Ἀβραὰμ γὰρ σύμβολον, τοῦ νόμου καὶ οἱ Παῖδές εἰσιν."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C13.melody = he.h.m6_gr_GR_cog.heHE.KymatiThalassis.name
meMA.Ode1C13.incipit = "Πάλαι δεξιοῦται, θεότητα μίαν, τὴν…"
meMA.Ode1C13.text = "Πάλαι δεξιοῦται, θεότητα μίαν, τὴν τρισυπόστατον, ὁ Ἱερὸς Ἀβραάμ· νῦν δὲ ὁ σύνθρονος Λόγος, τῷ Πατρὶ καὶ θείῳ Πνεύματι, τοῖς παισὶ προέρχεται, ἐνδόξως εὐφημούμενος."

meMA.Ode1C14.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C14.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C14.melody = he.h.m6_gr_GR_cog.heHE.KymatiThalassis.name
meMA.Ode1C14.incipit = "Ἀβραὰμ ἐῤῥύσθη, χειρὸς ἐξ ἀδίκου…"
meMA.Ode1C14.text = "Ἀβραὰμ ἐῤῥύσθη, χειρὸς ἐξ ἀδίκου, φλογὸς καμίνου δέ, οἱ θεῖοι Παῖδες ποτέ, καὶ Δανιὴλ ὁ Προφήτης, ἐκ θηρῶν καὶ λάκκου σέσωσται· διὸ νῦν τὴν Γέννησιν Χριστοῦ προεορτάζουσιν."

meMA.Ode1C15.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C15.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C15.melody = he.h.m6_gr_GR_cog.heHE.KymatiThalassis.name
meMA.Ode1C15.incipit = "Ἀριθμῷ καὶ πίστει, τῆς θείας…"
meMA.Ode1C15.text = "Ἀριθμῷ καὶ πίστει, τῆς θείας Τριάδος, τὴν ἀθεότητα καταστρεψάμενοι, ἐν τῇ καμίνῳ οἱ Παῖδες, ἐν συμβόλοις τὰ ἐσόμενα, τοῦ Θεοῦ μυστήρια, τῷ κόσμῳ προϋπέφηναν."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C1T.melody = he.h.m6_gr_GR_cog.heHE.KymatiThalassis.name
meMA.Ode1C1T.incipit = "Κεχαριτωμένη, ἀνύμφευτε Μήτηρ Παρθένε ἄφθορε…"
meMA.Ode1C1T.text = "Κεχαριτωμένη, ἀνύμφευτε Μήτηρ Παρθένε ἄφθορε, σὲ μακαρίζομεν· τοῦ Ἀβραὰμ γὰρ ἐκ γένους, καὶ φυλῆς Δαυΐδ ἐξήνθησας, τὸν Χριστὸν δὲ τέτοκας, Προφήταις κηρυχθέντα τὸ πρίν."

meMA.Ode1C21.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C21.greekmelody = he.h.m1_gr_GR_cog.heHE.ChristosGennatai.greekname
meMA.Ode1C21.melody = he.h.m1_gr_GR_cog.heHE.ChristosGennatai.name
meMA.Ode1C21.incipit = "Χριστὸν σαρκὶ νηπιάσαντα…"
meMA.Ode1C21.text = "Χριστὸν σαρκὶ νηπιάσαντα, Χριστὸν ἐθελουσίως πτωχεύσαντα, Χριστὸν ὁρατὸν γενόμενον, ἔρχεται ἡ Παρθένος ἐν Βηθλεέμ, νῦν ἀποκυῆσαι, οὐρανός τε καὶ ἡ γῆ ἀγαλλιάσθωσαν."

meMA.Ode1C22.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C22.melody = he.h.m1_gr_GR_cog.heHE.ChristosGennatai.name
meMA.Ode1C22.incipit = "Βουνοὶ καὶ ὄρη σκιρτήσατε…"
meMA.Ode1C22.text = "Βουνοὶ καὶ ὄρη σκιρτήσατε, Προφῆται θεηγόροι χορεύσατε· Λαοὶ καὶ Ἔθνη κροτήσατε· πάντων ἡ σωτηρία, ὁ φωτισμός, ἤγγικεν ἐπέστη, ἐν τῇ πόλει Βηθλεὲμ ἀποτικτόμενος."

meMA.Ode1C2T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C2T.melody = he.h.m1_gr_GR_cog.heHE.ChristosGennatai.name
meMA.Ode1C2T.incipit = "Πτωχὸς ὁ πλούσιος γίνεται…"
meMA.Ode1C2T.text = "Πτωχὸς ὁ πλούσιος γίνεται, πτωχίζων τοὺς κακίᾳ πλουτίζοντας· βροτὸς ὁ Θεὸς γνωρίζεται, Κόρης ἀπειρογάμου, δίχα τροπῆς, πάντες ἐν αἰνέσει, ἀνυμνήσωμεν αὐτόν, ὅτι δεδόξασται."

meMA.Ode3C1H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.SeTonEpiYdaton.greekname
meMA.Ode3C1H.melody = he.h.m6_gr_GR_cog.heHE.SeTonEpiYdaton.melody
meMA.Ode3C1H.incipit = he.h.m6_gr_GR_cog.heHE.SeTonEpiYdaton.incipit
meMA.Ode3C1H.text = he.h.m6_gr_GR_cog.heHE.SeTonEpiYdaton.text

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C11.greekmelody = he.h.m6_gr_GR_cog.heHE.SeTonEpiYdaton.greekname
meMA.Ode3C11.melody = he.h.m6_gr_GR_cog.heHE.SeTonEpiYdaton.name
meMA.Ode3C11.incipit = "Τάφῳ τριημερεύσας, ἀνέστησας ζωαρχικῇ ἐγέρσει…"
meMA.Ode3C11.text = "Τάφῳ τριημερεύσας, ἀνέστησας ζωαρχικῇ ἐγέρσει, θανόντας τοὺς ἀπʼ αἰῶνος, καὶ καταδίκης λυόμενοι, χαρμονικῶς ἠγάλλοντο· ἰδοὺ ἡ λύτρωσις, ἦλθες Κύριε κραυγάζοντες."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C12.melody = he.h.m6_gr_GR_cog.heHE.SeTonEpiYdaton.name
meMA.Ode3C12.incipit = "Τὴν κατʼ εἰκόνα δόξαν, καὶ…"
meMA.Ode3C12.text = "Τὴν κατʼ εἰκόνα δόξαν, καὶ καθʼ ὁμοίωσιν Θεοῦ φρονοῦντες Παῖδες, χρυσῆς εἰκόνος φλόγα, ἐν τῷ πυρὶ τῷ τοῦ Πνεύματος, ἀθλητικῶς κατέσβεσαν, ἐν πίστει ψάλλοντες· Πλήν σου Κύριον οὐκ οἴδαμεν."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C13.melody = he.h.m6_gr_GR_cog.heHE.SeTonEpiYdaton.name
meMA.Ode3C13.incipit = "Σοφίας τῷ περιόντι, καὶ Πνεύματος…"
meMA.Ode3C13.text = "Σοφίας τῷ περιόντι, καὶ Πνεύματος τῇ δυνάμει οἱ Παῖδες, τοὺς σοφοὺς Βαβυλῶνος, αἰχμαλωτεύσαντες ᾔσχυναν, καὶ θαρσαλέως ἔκραζον· Οὐκ ἔστιν Ἅγιος, πλήν σου Κύριε φιλάνθρωπε."

meMA.Ode3C14.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C14.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C14.melody = he.h.m6_gr_GR_cog.heHE.SeTonEpiYdaton.name
meMA.Ode3C14.incipit = "Χαίρει καὶ συγχορεύει, τοῖς Παισὶ…"
meMA.Ode3C14.text = "Χαίρει καὶ συγχορεύει, τοῖς Παισὶ καὶ Προφήταις ὁ νόμος, καὶ προσκιρτᾷ τοῦ Κυρίου, τὴν θείαν ἔλλαμψιν σήμερον, καὶ Ἀβραὰμ ἀγάλλεται, ὅτι ἐκ σπέρματος αὐτοῦ, εἶδε Κύριον σαρκούμενον."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C1T.melody = he.h.m6_gr_GR_cog.heHE.SeTonEpiYdaton.name
meMA.Ode3C1T.incipit = "Ἡ σύλληψις ἄνευ πάθους, ἡ…"
meMA.Ode3C1T.text = "Ἡ σύλληψις ἄνευ πάθους, ἡ πρόσληψις ὑπὲρ λόγον καὶ φύσιν, τοῦ τόκου σου προῆλθε· τὸ γὰρ Προφήταις θρυλλούμενον, ὑπερφυῶς Μυστήριον, ἡμῖν ἐπέφανε, Λόγος τοῦ Θεοῦ ὑπάρχων Κύριος."

meMA.Ode3C21.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C21.greekmelody = he.h.m1_gr_GR_cog.heHE.ToProTonAionon.greekname
meMA.Ode3C21.melody = he.h.m1_gr_GR_cog.heHE.ToProTonAionon.name
meMA.Ode3C21.incipit = "Ὁ πρὸ τῶν αἰώνων, ἐκ…"
meMA.Ode3C21.text = "Ὁ πρὸ τῶν αἰώνων, ἐκ Πατρὸς γεννηθεὶς ὑπὲρ ἔννοιαν, ἐκ τῆς Παρθένου ἐπʼ ἐσχάτων, ἐσαρκώθη ὡς οἶδεν, αὐτὸς θέλων τὸ ἀνθρώπινον, ἀνακαινίσαι φθαρὲν πονηροῦ, συμβουλίᾳ ὄφεως."

meMA.Ode3C22.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C22.melody = he.h.m1_gr_GR_cog.heHE.ToProTonAionon.name
meMA.Ode3C22.incipit = "Ὁ ἐν τοῖς ὑψίστοις, συνεδρεύων…"
meMA.Ode3C22.text = "Ὁ ἐν τοῖς ὑψίστοις, συνεδρεύων Πατρὶ καὶ τῷ Πνεύματι, ταπεινωθεῖσαν τῶν ἀνθρώπων, θεωρήσας τὴν φύσιν, Υἱὸς τοῦ Θεοῦ ὁ ἄναρχος, ἀρχὴν λαμβάνει καὶ μέλλει σαρκί. τίκτεσθαι ὡς ἄνθρωπος."

meMA.Ode3C2T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C2T.melody = he.h.m1_gr_GR_cog.heHE.ToProTonAionon.name
meMA.Ode3C2T.incipit = "Ἡ Ἁγιωτέρα, τῶν Ἀγγέλων καὶ…"
meMA.Ode3C2T.text = "Ἡ Ἁγιωτέρα, τῶν Ἀγγέλων καὶ πάσης τῆς κτίσεως, βουλῆς μεγάλης τῆς πατρῴας, νῦν τὸν Ἄγγελον τίκτει, σαρκὶ πάντων εἰς ἀνάκλησιν, μελῳδούντων ἀπαύστως αὐτῷ, Ἅγιος εἶ Κύριε."

meMA.Hypakoe.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Hypakoe.melody = ""
meMA.Hypakoe.incipit = "Ἄγγελος Παίδων ἐδρόσιζε…"
meMA.Hypakoe.text = "Ἄγγελος Παίδων ἐδρόσιζε κάμινον, νῦν δὲ γυναικῶν κλαυθμὸν διεκώλυε, λέγων· Τί ἐπιφέρεσθε μύρα; τίνα ζητεῖτε ἐν τάφῳ; ἀνέστη ὁ Χριστὸς καὶ Θεός· ὑπάρχει γὰρ ζωὴ καὶ σωτηρία, τοῦ γένους τῶν ἀνθρώπων."

meMA.Ode4C1H.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.TinEnStavroSou.greekname
meMA.Ode4C1H.melody = he.h.m6_gr_GR_cog.heHE.TinEnStavroSou.melody
meMA.Ode4C1H.incipit = he.h.m6_gr_GR_cog.heHE.TinEnStavroSou.incipit
meMA.Ode4C1H.text = he.h.m6_gr_GR_cog.heHE.TinEnStavroSou.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C11.greekmelody = he.h.m6_gr_GR_cog.heHE.TinEnStavroSou.greekname
meMA.Ode4C11.melody = he.h.m6_gr_GR_cog.heHE.TinEnStavroSou.name
meMA.Ode4C11.incipit = "Ἡ ἐν τῷ ᾅδῃ θεία…"
meMA.Ode4C11.text = "Ἡ ἐν τῷ ᾅδῃ θεία κάθοδος, σοῦ Χριστὲ ὁ Θεός, νεκροῖς ζωὴ ἐδείχθη· σὺ γὰρ ἐχθροὺς ἐδέσμευσας, κάτω ἀγαθέ, καὶ οὐράνιον τρίβον, ἀνθρώποις ἤνοιξας."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C12.melody = he.h.m6_gr_GR_cog.heHE.TinEnStavroSou.name
meMA.Ode4C12.incipit = "Τὰ τῶν Πατέρων ἀκροθίνια, Ἀβραὰμ…"
meMA.Ode4C12.text = "Τὰ τῶν Πατέρων ἀκροθίνια, Ἀβραὰμ Ἰσαάκ, καὶ Ἰακωβ τιμῶμεν, ὅτι αὐτῶν ἐκ σπέρματος, ἔλαμψε Χριστός, σαρκωθεὶς ἐκ Παρθένου, ὡς Παντοδύναμος."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C13.melody = he.h.m6_gr_GR_cog.heHE.TinEnStavroSou.name
meMA.Ode4C13.incipit = "Προϋπογράφων τὰ ἐσόμενα, τῇ καθόδῳ…"
meMA.Ode4C13.text = "Προϋπογράφων τὰ ἐσόμενα, τῇ καθόδῳ Χριστοῦ, ὁ Δανιὴλ τοὺς θῆρας ὡς πρόβατα ἀπέδειξε, πᾶσιν ἐναργῶς, ὡς προέγνω τὸ μέλλον, οἷα Προφήτης Θεοῦ."

meMA.Ode4C14.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C14.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C14.melody = he.h.m6_gr_GR_cog.heHE.TinEnStavroSou.name
meMA.Ode4C14.incipit = "Τῆς ἁμαρτίας μὴ σπασάμενοι, τὸν…"
meMA.Ode4C14.text = "Τῆς ἁμαρτίας μὴ σπασάμενοι, τὸν ἰὸν ἐκ φλογός, ἐῤῥύσθησαν οἱ Παῖδες· χρυσίου γὰρ ὑπέρτιμοι, ὄντες ἀληθῶς, ἐν καμίνῳ τῆς πλάνης, οὐκ ἐχωνεύθησαν."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C1T.melody = he.h.m6_gr_GR_cog.heHE.TinEnStavroSou.name
meMA.Ode4C1T.incipit = "Μεγαλοφώνως προκηρύττεται, προσδοκία Ἐθνῶν, καὶ…"
meMA.Ode4C1T.text = "Μεγαλοφώνως προκηρύττεται, προσδοκία Ἐθνῶν, καὶ σωτηρία κόσμου, ὁ ὑπὲρ φύσιν τόκος σου, ἄχραντε σεμνή, ὃν ὑμνεῖ τῶν Πατέρων, ὅμιλος σήμερον."

meMA.Ode4C21.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C21.greekmelody = he.h.m1_gr_GR_cog.heHE.RavdosEkTisRizis.greekname
meMA.Ode4C21.melody = he.h.m1_gr_GR_cog.heHE.RavdosEkTisRizis.name
meMA.Ode4C21.incipit = "Ῥάβδος ἐκ τῆς ῥίζης, Ἰεσσαί…"
meMA.Ode4C21.text = "Ῥάβδος ἐκ τῆς ῥίζης, Ἰεσσαί, Παρθένος ἀνεβλάστησας, ἄνθος ἀνθήσασα ἀμάραντον, τὸν πάντων Δημιουργόν, τὸν τὴν γῆν τοῖς ἄνθεσι, πᾶσαν ὡς Θεὸς κατακοσμοῦντα, ἀναβοῶσαν αὐτῷ· Δόξα τῇ δυνάμει σου Κύριε."

meMA.Ode4C22.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C22.melody = he.h.m1_gr_GR_cog.heHE.RavdosEkTisRizis.name
meMA.Ode4C22.incipit = "Βρώσει με κλαπέντα πονηρᾷ, καὶ…"
meMA.Ode4C22.text = "Βρώσει με κλαπέντα πονηρᾷ, καὶ γνώμῃ ὀλισθαίνοντα, ὁμοιωθέντα τοῖς ἀλόγοις τε, ὁ Λόγος ὁ τοῦ Θεοῦ, ἦλθες ἀνακτώμενος, βρέφος γεγονώς, καὶ ἐπὶ φάτνης, ἀλόγων ἀνακλιθείς· Δόξα τῇ δυνάμει σου Κύριε."

meMA.Ode4C2T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C2T.melody = he.h.m1_gr_GR_cog.heHE.RavdosEkTisRizis.name
meMA.Ode4C2T.incipit = "Ὄρους κατασκίου Ἰησοῦ, Παρθένου σε…"
meMA.Ode4C2T.text = "Ὄρους κατασκίου Ἰησοῦ, Παρθένου σε σαρκούμενον, ὁ Ἀββακοὺμ προεθεάσατο, τὰ ὄρη τὰ πονηρά, καὶ βουνοὺς συντρίβοντα, καὶ ἀφανισμῷ παραδιδόντα, ἐπάρσεις τοῦ πονηροῦ, καὶ τὰ τῶν δαιμόνων ὑψώματα."

meMA.Ode5C1H.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.TheofaneiasSouChriste.greekname
meMA.Ode5C1H.melody = he.h.m6_gr_GR_cog.heHE.TheofaneiasSouChriste.melody
meMA.Ode5C1H.incipit = he.h.m6_gr_GR_cog.heHE.TheofaneiasSouChriste.incipit
meMA.Ode5C1H.text = he.h.m6_gr_GR_cog.heHE.TheofaneiasSouChriste.text

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C11.greekmelody = he.h.m6_gr_GR_cog.heHE.TheofaneiasSouChriste.greekname
meMA.Ode5C11.melody = he.h.m6_gr_GR_cog.heHE.TheofaneiasSouChriste.name
meMA.Ode5C11.incipit = "Τὸ ἐξαστράπτον τῆς χαρᾶς, ὑποτυπῶν…"
meMA.Ode5C11.text = "Τὸ ἐξαστράπτον τῆς χαρᾶς, ὑποτυπῶν ἐμφανῶς ὁ Ἄγγελος, ἐν τῷ τάφῳ λαμπροφόρος δείκνυται, Γυναιξὶ κηρύττων ἀνάστασιν, καὶ ἀφέμεναι τοῦ κλαυθμοῦ, ἠγαλλιάσαντο, Χριστοῦ ἀναστάντος, τὸ χαίρετε Ἀποστόλοις διαγγέλλουσαι."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C12.melody = he.h.m6_gr_GR_cog.heHE.TheofaneiasSouChriste.name
meMA.Ode5C12.incipit = "Τὴν τῶν Πατέρων ἀπαρχήν, ὡς…"
meMA.Ode5C12.text = "Τὴν τῶν Πατέρων ἀπαρχήν, ὡς ἀρχηγὸν νόμου καὶ τῆς Χάριτος, Ἀβραὰμ τὸν Πατριάρχην σήμερον, συνελθόντες πίστει τιμήσωμεν· ὡς Προφήτης γὰρ τοῦ Θεοῦ, προκατηγγείλατο Χριστὸν ἐκ Παρθένου, καὶ τούτου προϋπαντᾷ τὴν θείαν Γέννησιν."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C13.melody = he.h.m6_gr_GR_cog.heHE.TheofaneiasSouChriste.name
meMA.Ode5C13.incipit = "Προϋπογράφοντες τρανῶς, τὴν πρὸς ἡμᾶς…"
meMA.Ode5C13.text = "Προϋπογράφοντες τρανῶς, τὴν πρὸς ἡμᾶς τοῦ Κυρίου ἔλευσιν, οἱ Ἀγγέλου παρουσίας ἔσβεσαν, Ἀβραὰμ οἱ Παῖδες τὴν κάμινον, καὶ ἀτμίδα δρόσου τὸ πῦρ, ἀπεργασάμενοι ἐν τούτῳ τῇ πίστει, εἰκόνος χρυσῆς δόξαν ἐχώνευσαν."

meMA.Ode5C14.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C14.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C14.melody = he.h.m6_gr_GR_cog.heHE.TheofaneiasSouChriste.name
meMA.Ode5C14.incipit = "Ἔφραξε στόματα θηρῶν, ὁ Δανιὴλ…"
meMA.Ode5C14.text = "Ἔφραξε στόματα θηρῶν, ὁ Δανιὴλ ἐν τῷ λάκκῳ Πνεύματι, τοῦ πυρὸς δὲ τὴν ἰσχὺν κατέσβεσαν, Ἀβραὰμ οἱ Παῖδες τῇ χάριτι, καὶ σωθέντες οὗτοι φθορᾶς, προκαταγγέλλουσι Χριστὸν ἐκ Παρθένου, αἰτοῦντες ὡς λυτρωτὴν τὴν σωτηρίαν ἡμῶν."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C1T.melody = he.h.m6_gr_GR_cog.heHE.TheofaneiasSouChriste.name
meMA.Ode5C1T.incipit = "Ἐν θείῳ Πνεύματι δηλῶν, τὴν…"
meMA.Ode5C1T.text = "Ἐν θείῳ Πνεύματι δηλῶν, τὴν ἐξ ἡμῶν ἀπαθῶς σου πρόσληψιν, Ἠσαΐας ἀνεβόα Κύριε, γρηγορῶν τῷ νόμῳ τῆς χάριτος. Τὸν ἐκ γένους μὲν Ἀβραάμ, ἐκ τῆς Ἰούδα δὲ φυλῆς κατὰ σάρκα, Παρθένος ἄνευ σπορᾶς, ἔρχεται τίκτουσα."

meMA.Ode5C21.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C21.greekmelody = he.h.m1_gr_GR_cog.heHE.TheosOnEirinis.greekname
meMA.Ode5C21.melody = he.h.m1_gr_GR_cog.heHE.TheosOnEirinis.name
meMA.Ode5C21.incipit = "Ὁ φύσει Δεσπότης, ἐν δούλοις…"
meMA.Ode5C21.text = "Ὁ φύσει Δεσπότης, ἐν δούλοις τελεῖς, ὁ Υἱὸς τοῦ Θεοῦ ὁ παντέλειος, εὐδόκησας διʼ ἔλεος, καλεῖσθαι καὶ Υἱός, ἀνθρώπου Πανοικτίρμον· διὸ ἐν τῷ Σπηλαίῳ, ἑκουσίως πτωχεύσας, ἔρχῃ τεχθῆναι Ὑπεράγαθε."

meMA.Ode5C22.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C22.melody = he.h.m1_gr_GR_cog.heHE.TheosOnEirinis.name
meMA.Ode5C22.incipit = "Ἀχώρητε φύσει, Χριστὲ Βασιλεῦ, πῶς…"
meMA.Ode5C22.text = "Ἀχώρητε φύσει, Χριστὲ Βασιλεῦ, πῶς μικρόν σε εἰσδέξεται Σπήλαιον; πῶς φάτνη σε δυνήσεται, χωρῆσαι Ἰησοῦ; Μητρὸς ἐξ ἀπειράνδρου, σαρκὶ ἐπιδημοῦντα, εἰς τὰ ἴδια ὅπως, τοὺς ξενωθέντας σώσῃς Κύριε."

meMA.Ode5C2T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C2T.melody = he.h.m1_gr_GR_cog.heHE.TheosOnEirinis.name
meMA.Ode5C2T.incipit = "Ἀμνὰς τὸν ποιμένα, προῆλθε τεκεῖν…"
meMA.Ode5C2T.text = "Ἀμνὰς τὸν ποιμένα, προῆλθε τεκεῖν, εὐτρεπίζου τὸ ἅγιον Σπήλαιον. Ποιμένες ἐπισπεύσατε, Ποιμένα καὶ Ἀμνὸν τεχθέντα θεωρῆσαι, οἱ Μάγοι μετὰ δώρων, εὐτρεπίσθητε τοῦτον, ὡς Βασιλέα προσκυνῆσαι σαρκί."

meMA.Ode6C1H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.greekname
meMA.Ode6C1H.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.melody
meMA.Ode6C1H.incipit = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.incipit
meMA.Ode6C1H.text = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.text

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C11.greekmelody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.greekname
meMA.Ode6C11.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C11.incipit = "Θανάτου τὴν νέκρωσιν, καὶ τοῦ…"
meMA.Ode6C11.text = "Θανάτου τὴν νέκρωσιν, καὶ τοῦ ᾅδου ἀγαθέ, εἰργάσω τὴν καθαίρεσιν, τριημέρῳ ταφῇ σου θεοπρεπῶς· ζωὴν δὲ ἐπήγασας, ἀναστὰς τοῖς ἐν κόσμῳ Ἰησοῦ Βασιλεῦ."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C12.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C12.incipit = "Ὁ τρόπος φιλόξενος, ἡ δὲ…"
meMA.Ode6C12.text = "Ὁ τρόπος φιλόξενος, ἡ δὲ πίστις ὑψηλή, Ἀβραὰμ τοῦ προπάτορος· ὅθεν θεῖον μυστήριον τυπικῶς, δεξάμενος ἔχαιρε· τοῦ Χριστοῦ δὲ προτρέχων νῦν ἀγάλλεται."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C13.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C13.incipit = "Τὴν κτίσιν ὑπέταξε, νῦν ἡ…"
meMA.Ode6C13.text = "Τὴν κτίσιν ὑπέταξε, νῦν ἡ πίστις τοῖς Παισί, τῇ δωρεᾷ τοῦ Πνεύματος· τὸ γὰρ πῦρ τὸ παμφάγον καὶ ἀναιδές, ᾐδέσθη τοὺς σέβοντας, τοῦ πυρὸς τὸν ἐργάτην, Ἰησοῦν τὸν Χριστόν."

meMA.Ode6C14.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C14.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C14.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C14.incipit = "Τοῦ κόσμου τὸ ἄγριον, τῇ…"
meMA.Ode6C14.text = "Τοῦ κόσμου τὸ ἄγριον, τῇ ἐλεύσει τοῦ Χριστοῦ, ῥυθμίζεσθαι ὑπέφηνεν, εἰρήνην πρὸς τὴν θείαν θεοπρεπῶς, φιμώσας τοὺς λέοντας, Δανιὴλ ὁ Προφήτης ἐν τῷ λάκκω ποτέ."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C1T.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C1T.incipit = "Νηδύος ἐκύησας, ἐκ Παρθένου τὸν…"
meMA.Ode6C1T.text = "Νηδύος ἐκύησας, ἐκ Παρθένου τὸν Χριστόν, Μαρία Μήτηρ ἄνανδρε, ὃν εἶδον οἱ Προφῆται θεοπτικῶς, αὐτοῦ προχορεύουσιν, οἱ Πατέρες νυνὶ δὲ τὰ Γενέθλια."

meMA.Ode6C21.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C21.greekmelody = he.h.m1_gr_GR_cog.heHE.SplanchnonIonan.greekname
meMA.Ode6C21.melody = he.h.m1_gr_GR_cog.heHE.SplanchnonIonan.name
meMA.Ode6C21.incipit = "Νέος οὐρανός, ὑπάρχουσα Δέσποινα, ἐκ…"
meMA.Ode6C21.text = "Νέος οὐρανός, ὑπάρχουσα Δέσποινα, ἐκ μήτρας τῆς σῆς, ὡς ἐκ νεφέλης Χριστόν, δόξης Ἥλιον, ἀνατεῖλαι ἐπείγῃ Σπηλαίῳ σαρκί, ὡς μέλλοντα ταῖς λάμψεσι, ταῖς ἑαυτοῦ σαφῶς, πάντα τὰ τῆς γῆς πληρώματα, κραυγάζειν διʼ οἶκτον ἀμέτρητον."

meMA.Ode6C22.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C22.melody = he.h.m1_gr_GR_cog.heHE.SplanchnonIonan.name
meMA.Ode6C22.incipit = "Εἶδες τὴν ἡμῶν, ὀδύνην καὶ…"
meMA.Ode6C22.text = "Εἶδες τὴν ἡμῶν, ὀδύνην καὶ κάκωσιν οἰκτίρμον Χριστέ, καὶ οὐ παρεῖδες ἡμᾶς· ἀλλʼ ἐκένωσας, σεαυτὸν μὴ ἐκστὰς τοῦ Γεννήτορος, καὶ ἐσκήνωσας εἰς μήτραν ἀπειρόγαμον, ἥτις ἀνωδίνως τέξεσθαι; σὲ σαρκὶ ἐν Σπηλαίῳ προέρχεται."

meMA.Ode6C2T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C2T.melody = he.h.m1_gr_GR_cog.heHE.SplanchnonIonan.name
meMA.Ode6C2T.incipit = "Ὄρη καὶ βουνοί, πεδία καὶ…"
meMA.Ode6C2T.text = "Ὄρη καὶ βουνοί, πεδία καὶ φάραγγες, λαοὶ καὶ φυλαί, ἔθνη καὶ πᾶσα πνοή, ἀλαλάξατε, εὐφροσύνης ἐνθέου πληρούμενα· ἦλθε πάντων ἐπεδήμησεν ἡ λύτρωσις, Λόγος τοῦ Θεοῦ ὁ ἄχρονος, ὑπὸ χρόνον διʼ οἶκτον γενόμενος."

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Kontakion1.melody = ""
meMA.Kontakion1.incipit = me.m12.d17_gr_GR_cog.meMA.Kontakion2.incipit
meMA.Kontakion1.text = me.m12.d17_gr_GR_cog.meMA.Kontakion2.text

meMA.Oikos1.text = me.m12.d17_gr_GR_cog.meMA.Oikos2.text

meMA.Kontakion2.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kontakion2.greekmelody = he.a.m1_gr_GR_cog.heAU.ChorosAngelikos.greekname
meMA.Kontakion2.melody = he.a.m1_gr_GR_cog.heAU.ChorosAngelikos.name
meMA.Kontakion2.incipit = "Εὐφραίνου Βηθλεέμ, Εὐφραθᾶ ἑτοιμάζου· ἰδοὺ…"
meMA.Kontakion2.text = "Εὐφραίνου Βηθλεέμ, Εὐφραθᾶ ἑτοιμάζου· ἰδοὺ γὰρ ἡ Ἀμνάς, τὸν Ποιμένα τὸν μέγαν, ἐν μήτρᾳ βαστάζουσα, τοῦ τεκεῖν κατεπείγεται, ὅνπερ βλέποντες, οἱ θεοφόροι Πατέρες, ἐπαγάλλονται, μετὰ Ποιμένων ὑμνοῦντες, Παρθένον θηλάζουσαν."

meMA.Oikos2.text = "Τῆς σῆς Παρθένε κυήσεως τὴν λαμπρότητα, καθορῶντες ἐκλάμπουσαν, Ἀβραὰμ ὁ φιλόθεος, καὶ Ἰσαὰκ ὁ ἀοίδιμος, καὶ Ἰακώβ, καὶ πᾶς ὁ θεοσύλλεκτος χορὸς τῶν ἁγίων ἀγάλλεται, καὶ τὴν κτίσιν προσήγαγον, πρὸς σὴν ὑπάντησιν, ἐν χαρμοσύναις λέξεσι. Χαρᾶς γὰρ πρόξενος πᾶσιν ὤφθης, ἐν μήτρᾳ συλλαβοῦσα, τὸν ποτὲ ἐν Βαβυλῶνι ὁραθέντα, καὶ τοὺς Παῖδας, τοὺς ἐν τῇ καμίνῳ ἀδίκως βληθέντας, ἀφλέκτους συντηρήσαντα ὑπὲρ πᾶσαν ἔννοιαν. Διὸ καὶ ἀναμέλπουσι τὸν ὁρώμενον ἐν χερσὶ νεάνιδος, ὑμνοῦντες Παρθένον θηλάζουσαν."

meMA.Ode7C1H.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.AfrastonThavma.greekname
meMA.Ode7C1H.melody = he.h.m6_gr_GR_cog.heHE.AfrastonThavma.melody
meMA.Ode7C1H.incipit = he.h.m6_gr_GR_cog.heHE.AfrastonThavma.incipit
meMA.Ode7C1H.text = he.h.m6_gr_GR_cog.heHE.AfrastonThavma.text

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C11.greekmelody = he.h.m6_gr_GR_cog.heHE.AfrastonThavma.greekname
meMA.Ode7C11.melody = he.h.m6_gr_GR_cog.heHE.AfrastonThavma.name
meMA.Ode7C11.incipit = "Ὢ ξένον θαῦμα! ὁ ἐν…"
meMA.Ode7C11.text = "Ὢ ξένον θαῦμα! ὁ ἐν ὑψίστοις καθήμενος, ἐπὶ θρόνου, Κύριος αὐτός, προσλήψει σαρκός, θάνατον ὑπέμεινεν, ἀλλʼ ἐξανέστη θεότητος ἰσχύϊ, συνεγείρας νεκρούς τοὺς ἀπʼ αἰῶνος."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C12.melody = he.h.m6_gr_GR_cog.heHE.AfrastonThavma.name
meMA.Ode7C12.incipit = "Χριστὸν γεννήσας τὸ κατὰ σάρκα…"
meMA.Ode7C12.text = "Χριστὸν γεννήσας τὸ κατὰ σάρκα τῆς πίστεως, ἀρχηγέτα Πάτερ, Ἀβραάμ, ἐδείχθης Ἐθνῶν, Πνεύματι Πατὴρ ἐναργῶς, εἰς σωτηρίαν ἡμῶν τῶν μελῳδούντων· Λυτρωτὰ ὁ Θεὸς εὐλογητὸς εἶ."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C13.melody = he.h.m6_gr_GR_cog.heHE.AfrastonThavma.name
meMA.Ode7C13.incipit = "Ἀψύχων ἤχους, διακενῆς ἀλαλάζοντας, τῶν…"
meMA.Ode7C13.text = "Ἀψύχων ἤχους, διακενῆς ἀλαλάζοντας, τῶν ἐμψύχων, ἤμβλυνεν ᾠδή· καμίνου γὰρ πῦρ, φλεγομένοις σώμασι, καταπατοῦντες οἱ Παῖδες ἀλωβήτως, ἀνεβόων. ὁ Θεὸς εὐλογητός εἶ."

meMA.Ode7C14.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C14.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C14.melody = he.h.m6_gr_GR_cog.heHE.AfrastonThavma.name
meMA.Ode7C14.incipit = "Τῇ θεωρίᾳ ἐνατενίσας τοῦ Πνεύματος…"
meMA.Ode7C14.text = "Τῇ θεωρίᾳ ἐνατενίσας τοῦ Πνεύματος, ὁ Προφήτης, πάλαι Δανιήλ, Χριστοῦ προτυποῖ, τὴν δευτέραν ἔλευσιν, καὶ τὰ ἐν ταύτῃ φρικτὰ προκαταγγέλλει, ἐκβοῶν· ὁ Θεός εὐλογητὸς εἶ."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C1T.melody = he.h.m6_gr_GR_cog.heHE.AfrastonThavma.name
meMA.Ode7C1T.incipit = "Τὸ ξένον θαῦμα, τὸ ἐν…"
meMA.Ode7C1T.text = "Τὸ ξένον θαῦμα, τὸ ἐν Προφήταις θρυλούμενον, καὶ πατράσι, πάλαι ἐμφανῶς, Παρθένος Ἁγνή, τεξομένη πάρεστιν, εἰς σωτηρίαν ἡμῶν τῶν μελῳδούντων· Λυτρωτὰ ὁ Θεὸς εὐλογητὸς εἶ."

meMA.Ode7C21.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C21.greekmelody = he.h.m1_gr_GR_cog.heHE.OiPaidesEfseveia.greekname
meMA.Ode7C21.melody = he.h.m1_gr_GR_cog.heHE.OiPaidesEfseveia.name
meMA.Ode7C21.incipit = "Ἡ ἄμπελος ἡ θεία, τὸν…"
meMA.Ode7C21.text = "Ἡ ἄμπελος ἡ θεία, τὸν ἀκήρατον βότρυν περκάζουσα, ἐγγίζει ἥκει τοῦ τεκεῖν, εὐφροσύνης οἶνον βλύζοντα, καὶ ποτίζοντα ἡμᾶς, αὐτῷ κραυγάζοντας· ὁ τῶν Πατέρων, Θεὸς εὐλογητὸς εἶ."

meMA.Ode7C22.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C22.melody = he.h.m1_gr_GR_cog.heHE.OiPaidesEfseveia.name
meMA.Ode7C22.incipit = "Ἡ θεία μυροθήκη, τὸ εὐῶδες…"
meMA.Ode7C22.text = "Ἡ θεία μυροθήκη, τὸ εὐῶδες μύρον ἔνδον φέρουσα, ἐν τῷ Σπηλαίῳ Βηθλεέμ, ἐκκενῶσαι τοῦτο ἔρχεται, εὐωδίας μυστικῆς πληροῦν τοὺς μέλποντας· ὁ τῶν Πατέρων Θεός εὐλογητὸς εἶ."

meMA.Ode7C2T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C2T.melody = he.h.m1_gr_GR_cog.heHE.OiPaidesEfseveia.name
meMA.Ode7C2T.incipit = "Λαβὶς ἣν Ἠσαΐας, ὁ Προφήτης…"
meMA.Ode7C2T.text = "Λαβὶς ἣν Ἠσαΐας, ὁ Προφήτης πάλαι ἐθεάσατο, τὸν θεῖον ἄνθρακα Χριστόν, ἐν κοιλίᾳ ἥκει φέρουσα, πᾶσαν ὕλην ἁμαρτίας καταφλέγοντα, τῶν δὲ πιστῶν τὰς ψυχάς φωταγωγοῦντα."

meMA.Ode8C1H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.EkstithiFrittonOurane.greekname
meMA.Ode8C1H.melody = he.h.m6_gr_GR_cog.heHE.EkstithiFrittonOurane.melody
meMA.Ode8C1H.incipit = he.h.m6_gr_GR_cog.heHE.EkstithiFrittonOurane.incipit
meMA.Ode8C1H.text = he.h.m6_gr_GR_cog.heHE.EkstithiFrittonOurane.text

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C11.greekmelody = he.h.m6_gr_GR_cog.heHE.EkstithiFrittonOurane.greekname
meMA.Ode8C11.melody = he.h.m6_gr_GR_cog.heHE.EkstithiFrittonOurane.name
meMA.Ode8C11.incipit = "Ὢ τῆς ἀφάτου σου Χριστέ…"
meMA.Ode8C11.text = "Ὢ τῆς ἀφάτου σου Χριστέ, συγκαταβάσεως, διʼ ἡμᾶς τοὺς ταπεινούς! ἰδοὺ γὰρ θανάτου γευσάμενος, Θεὸς ἀθάνατος ὢν, ἐν τάφῳ ὡς βροτὸς κατετέθης· ἀλλʼ ἐξανέστης Λόγε, συνεγείρας τοὺς κάτω, σὲ ὑπερυψοῦντας, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C12.melody = he.h.m6_gr_GR_cog.heHE.EkstithiFrittonOurane.name
meMA.Ode8C12.incipit = "Σοῦ τὴν σφαγὴν προεκτυπών, ὁ…"
meMA.Ode8C12.text = "Σοῦ τὴν σφαγὴν προεκτυπών, ὁ Ἀβραὰμ Χριστέ, ὃν ἐγέννησεν υἱόν, ἐν ὄρει πειθαρχῶν σοι Δέσποτα, καθάπερ πρόβατον ἀνῆλθε θυσιάσων ἐν πίστει· ἀλλʼ ἐπανῆκε χαίρων, Ἰσαὰκ καὶ πρεσβύτης, σὲ ὑπερυψοῦντες, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C13.melody = he.h.m6_gr_GR_cog.heHE.EkstithiFrittonOurane.name
meMA.Ode8C13.incipit = "Φλὸξ ἡ ἀκάματος Χριστέ, ἐνδυσαμένων…"
meMA.Ode8C13.text = "Φλὸξ ἡ ἀκάματος Χριστέ, ἐνδυσαμένων σε, ὡς ἱμάτιον τὸ πῦρ, τὸ θεῖον, τῶν Ἁγίων Παίδων σου, ἀπημαυρώθη σφοδρῶς, καὶ δρόσος τῇ σῇ συγκαταβάσει, τοῖς ψάλλουσιν ἠχεῖτο, Ἱερεῖς εὐλογεῖτε, Λαὸς ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C14.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C14.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C14.melody = he.h.m6_gr_GR_cog.heHE.EkstithiFrittonOurane.name
meMA.Ode8C14.incipit = "Δίδοται λέουσι βορά, ἀῤῥήτοις κρίμασιν…"
meMA.Ode8C14.text = "Δίδοται λέουσι βορά, ἀῤῥήτοις κρίμασιν, ὁ Προφήτης Δανιήλ, ἀλλʼ ἔσχεν ἐγκρατείας δόγμασι, συννηστευτὰς εὐσεβῶς, τοὺς θῆρας ἐν τῷ βόθρῳ τοῦ λάκκου, αὐτοῦ ταῖς ἱκεσίαις, Ἀβραὰμ καὶ τῶν Παίδων, σῶσον ἐν εἰρήνῃ, Χριστὲ τοὺς σὲ ὑμνοῦντας."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C1T.melody = he.h.m6_gr_GR_cog.heHE.EkstithiFrittonOurane.name
meMA.Ode8C1T.incipit = "Ὂν προκατήγγειλαν πιστῶς, προφητικαὶ φωναί…"
meMA.Ode8C1T.text = "Ὂν προκατήγγειλαν πιστῶς, προφητικαὶ φωναί, Ἰησοῦν Ἐμμανουήλ, ἀνθρώπου ἐν μορφῇ ἐρχόμενον, τὸν τοῦ Θεοῦ καὶ Πατρός, Υἱόν τε καὶ συνάναρχον Λόγον, ἐκ Πνεύματος Ἁγίου, ἡ Παρθένος Μαρία, τίκτει ἀπειράνδρως, ἐν Βηθλεὲμ τῇ πόλει."

meMA.Ode8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C21.greekmelody = he.h.m1_gr_GR_cog.heHE.ThavmatosYperfyous.greekname
meMA.Ode8C21.melody = he.h.m1_gr_GR_cog.heHE.ThavmatosYperfyous.name
meMA.Ode8C21.incipit = "Δόξα ἐν ὑψίστοις Θεῷ μέτ’…"
meMA.Ode8C21.text = "Δόξα ἐν ὑψίστοις Θεῷ μετʼ Ἀγγέλων, ἐκβοήσωμεν ἐν εὐφροσύνῃ· ὁ Σωτὴρ τεχθήσεται· ὁ Δεσπότης ἐπιδημεῖ, ὃν ἀστὴρ ὑποδεικνύει Μάγοις σπεύδουσιν, αὐτὸν ἐπὶ φάτνης τοῦ θεάσασθαι. Εὐλογείτω ἡ κτίσις πᾶσα τὸν Κύριον, καὶ ὑπερυψούτω, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C22.melody = he.h.m1_gr_GR_cog.heHE.ThavmatosYperfyous.name
meMA.Ode8C22.incipit = "Δούλοις ἐπεγράφης ἑκὼν ὁ Δεσπότης…"
meMA.Ode8C22.text = "Δούλοις ἐπεγράφης ἑκὼν ὁ Δεσπότης, τῷ τοῦ Καίσαρος ὑπείκων νόμῳ, ὅπως τὸ ἀνθρώπινον, τῆς δουλείας τοῦ πονηροῦ, ὡς Θεὸς ἐλευθερώσης Πολυέλεε· διὸ γεγηθότες ἀναμέλπομεν. Εὐλογείτω ἡ κτίσις πᾶσα τὸν Κύριον, καὶ ὑπερυψούτω, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C2T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C2T.melody = he.h.m1_gr_GR_cog.heHE.ThavmatosYperfyous.name
meMA.Ode8C2T.incipit = "Βρέφος νέον φέρων σε ἄναρχε…"
meMA.Ode8C2T.text = "Βρέφος νέον φέρων σε ἄναρχε Λόγε, πεῖραν δὲ ὅλως ἀνδρὸς οὐκ ἔγνων, ἡ Παρθένος ἔλεγεν, ἀποροῦσα τίνα ἐν γῇ, ὀνομάσω σου Πατέρα, οὐκ ἐπίσταμαι· διὸ μετὰ πάντων ἀναμέλπω σοι· Εὐλογείτω ἡ κτίσις πᾶσα τὸν Κύριον, καὶ ὑπερυψούτω, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode9C1H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.MiEpodyrouMouMiter.greekname
meMA.Ode9C1H.melody = he.h.m6_gr_GR_cog.heHE.MiEpodyrouMouMiter.melody
meMA.Ode9C1H.incipit = he.h.m6_gr_GR_cog.heHE.MiEpodyrouMouMiter.incipit
meMA.Ode9C1H.text = he.h.m6_gr_GR_cog.heHE.MiEpodyrouMouMiter.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C11.greekmelody = he.h.m6_gr_GR_cog.heHE.MiEpodyrouMouMiter.greekname
meMA.Ode9C11.melody = he.h.m6_gr_GR_cog.heHE.MiEpodyrouMouMiter.name
meMA.Ode9C11.incipit = "Τί ἐποδύρῃ ἡ κτίσις, ἐν…"
meMA.Ode9C11.text = "Τί ἐποδύρῃ ἡ κτίσις, ἐν Σταυρῷ καθορῶσα, καὶ ἐν σορῷ τὸν τῆς ζωῆς, Δεσπότην καὶ Θεόν· ἀναστήσεται γὰρ καινοποιῶν σε φαιδρῶς, τριημέρῳ ἐγέρσει, τὸν ᾅδην καθελών, καὶ νεκροὺς συνεγείρας, ἀνευφημοῦντας αὐτόν."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C12.melody = he.h.m6_gr_GR_cog.heHE.MiEpodyrouMouMiter.name
meMA.Ode9C12.incipit = "Τῶν πρὸ τοῦ νόμου Πατέρων…"
meMA.Ode9C12.text = "Τῶν πρὸ τοῦ νόμου Πατέρων, Ἑορτὴν ἐκτελοῦντες, τὸν ἐξ αὐτῶν θεοπρεπῶς, τιμῶμεν Ἰησοῦν· Ἀβραὰμ γὰρ ὁμοῦ, καὶ Ἰσαὰκ καί, Ἰακώβ, Προφητῶν καὶ τοῦ νόμου, ἐδείχθησαν κρηπίς, καὶ τῆς Χάριτος πίστει, πνευματικαὶ ἀπαρχαί."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C13.melody = he.h.m6_gr_GR_cog.heHE.MiEpodyrouMouMiter.name
meMA.Ode9C13.incipit = "Ὁ ἐν πυρὶ ὑποδείξας, τῷ…"
meMA.Ode9C13.text = "Ὁ ἐν πυρὶ ὑποδείξας, τῷ Μωσῇ ἐν τῇ βάτῳ, τὸ ὑπὲρ νοῦν θεοπτικῶς, μυστήριον ὁ Θεός, ἐν πυρὶ τοῖς Παισὶ συγκαταβὰς ὁ αὐτός, τῷ πυρὶ τῆς ἐμφύτου, Θεότητος αὐτοῦ, τῆς καμίνου φλόγα, δρόσον ἀπέδειξε."

meMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C14.melody = he.h.m6_gr_GR_cog.heHE.MiEpodyrouMouMiter.name
meMA.Ode9C14.incipit = "Τῶ Ἀβραὰμ συνελθόντες, οἱ πανάγιοι…"
meMA.Ode9C14.text = "Τῶ Ἀβραὰμ συνελθόντες, οἱ πανάγιοι Παῖδες, καὶ Δανιὴλ ὁ θαυμαστός, Προφήτης τοῦ Θεοῦ, Ἰσαὰκ Ἰακώβ, μετὰ Μωσῆ, Ἀαρών, τοῦ Χριστοῦ πρὸ τοῦ τόκου, χορεύουσι πιστῶς, δυσωποῦντες ἀπαύστως, εἰς τὸ σωθῆναι ἡμᾶς."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C1T.melody = he.h.m6_gr_GR_cog.heHE.MiEpodyrouMouMiter.name
meMA.Ode9C1T.incipit = "Συγχαίρει πᾶσα ἡ κτίσις, τῷ…"
meMA.Ode9C1T.text = "Συγχαίρει πᾶσα ἡ κτίσις, τῷ σῷ τόκῳ Παρθένε· τὴν γὰρ Ἐδὲμ ἡ Βηθλεέμ, διήνοιξεν ἡμῖν, καὶ ἰδοὺ τῆς ζωῆς τοῦ ξύλου ἅπαντες, ἀπολαύοντες πίστει, βοῶμεν ἐκτενῶς. Τὰς ἡμῶν ἱκεσίας, Δέσποτα πλήρωσον."

meMA.Ode9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C21.greekmelody = he.h.m1_gr_GR_cog.heHE.MystirionXenon.greekname
meMA.Ode9C21.melody = he.h.m1_gr_GR_cog.heHE.MystirionXenon.name
meMA.Ode9C21.incipit = "Μυστήρια ξένα, φρικτὰ καὶ παράδοξα!…"
meMA.Ode9C21.text = "Μυστήρια ξένα, φρικτὰ καὶ παράδοξα! ὁ τῆς δόξης Κύριος, ἦλθεν ἐπὶ τῆς γῆς, καὶ Σπηλαίῳ πτωχεύσας ὑπέδυ σαρκί, τὸν Ἀδὰμ ἀνακαλέσασθαι ζητῶν, καὶ τὴν Εὔαν τῶν ὠδίνων ἐκλυτρώσασθαι."

meMA.Ode9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C22.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C22.melody = he.h.m1_gr_GR_cog.heHE.MystirionXenon.name
meMA.Ode9C22.incipit = "Σπαργάνοις σου λύεις, σειρὰς παραπτώσεων…"
meMA.Ode9C22.text = "Σπαργάνοις σου λύεις, σειρὰς παραπτώσεων, τῇ πολλῇ πτωχείᾳ δέ, πάντας καταπλουτίζεις οἰκτίρμον, ἀλόγου κακίας τεθείς, ἐν φάτνῃ, τῶν ἀλόγων δέ, βροτοὺς ἀπαλλάττεις, τοῦ Θεοῦ Λόγε προάναρχε."

meMA.Ode9C2T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C2T.melody = he.h.m1_gr_GR_cog.heHE.MystirionXenon.name
meMA.Ode9C2T.incipit = "Κηρύγματα, τῶν Προφητῶν πέρας εἴληφεν…"
meMA.Ode9C2T.text = "Κηρύγματα, τῶν Προφητῶν πέρας εἴληφεν· ὃν γὰρ προεφήτευσαν, ἥξειν ἐν συντελείᾳ τῶν χρόνων, ἐπέστη ἐφάνη, Ἁγνῆς ἐκ Παρθένου σωματούμενος, αὐτὸν διανοίᾳ, καθαρᾷ ὑποδεξώμεθα."

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Exaposteilarion1.greekmelody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.greekname
meMA.Exaposteilarion1.melody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.name
meMA.Exaposteilarion1.incipit = "Πατριαρχῶν οἱ πρόκριτοι, καὶ πρὸ…"
meMA.Exaposteilarion1.text = "Πατριαρχῶν οἱ πρόκριτοι, καὶ πρὸ νόμου Πατέρες, ἐν πίστει προεξέλαμψαν, Ἀβραάμ, Ἰσαάκ τε, καὶ Ἰακὼβ ὡς φωστῆρες· ἅπαντες γὰρ Προφῆται, καὶ Δίκαιοι ἀνήφθησαν, ἐξ αὐτῶν ὡς λαμπάδες, φωτοειδεῖς, καὶ τὴν Κτίσιν, πᾶσαν ἐσκοτισμένην, ἀκτῖσι κατεφώτισαν, τῆς σεπτῆς Προφητείας."

meMA.Exaposteilarion2.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Exaposteilarion2.greekmelody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.greekname
meMA.Exaposteilarion2.melody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.name
meMA.Exaposteilarion2.incipit = "Εὐφραίνου Βηθλεέμ, καὶ σὺ Εὐφραθᾶ…"
meMA.Exaposteilarion2.text = "Εὐφραίνου Βηθλεέμ, καὶ σὺ Εὐφραθᾶ ἑτοιμάζου· ἡ Θεοτόκος ἥκει γάρ, ἐν σπηλαίῳ καὶ φάτνῃ, τεκεῖν Θεὸν ἀποῤῥήτως. Ὢ φρικτοῦ μυστηρίου! οὗ νῦν τὴν θείαν Γέννησιν, Ἀβραὰμ Ἰσαάκ τε, καὶ Ἰακώβ, Πατριάρχαι ἅπαντες καὶ Προφῆται, φαιδρῶς προεορτάζουσι, καὶ βροτοὶ σὺν Ἀγγέλοις."

meMA.Lauds1.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Lauds1.greekmelody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.greekname
meMA.Lauds1.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meMA.Lauds1.incipit = "Ἆρόν σου τὴν φωνὴν ἀληθῶς…"
meMA.Lauds1.text = "Ἆρόν σου τὴν φωνὴν ἀληθῶς, Σιὼν Θεοῦ ἡ θεία Πόλις καὶ κήρυξον, Πατέρων τὴν θείαν μνήμην, σὺν Ἀβραάμ, Ἰσαάκ, Ἰακὼβ τιμῶσα τὸν ἀοίδιμον· ἰδοὺ σὺν Ἰούδᾳ τε, καὶ Λευῒ μεγαλύνομεν, Μωσῆν τὸν μέγαν, Ἀαρὼν τὸν θεσπέσιον, καὶ γεραίρομεν, σὺν Δαυΐδ Ἰησοῦν, Σαμουήλ. Πάντες τὴν προεόρτιον, Χριστοῦ θείαν αἴνεσιν, ὕμνοις ἐνθέοις κροτοῦντες, τῆς παρʼ αὐτοῦ ἀγαθότητος, τυχεῖν ἐξαιτοῦμεν, τοῦ παρέχοντος τῷ κόσμῳ, τὸ μέγα ἔλεος."

meMA.MM.Lauds1123as5678.text = properties_gr_GR_cog.media.key

meMA.Lauds2.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Lauds2.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meMA.Lauds2.incipit = "Δεῦρο ὁ ἐν πυρίνῳ ποτέ…"
meMA.Lauds2.text = "Δεῦρο ὁ ἐν πυρίνῳ ποτέ, ἐπιδιφρεύσας Ἠλιοὺ θείῳ ἅρματι, θεόφρον Ἐλισαιέ τε, σὺν Ἐζεκίᾳ ὁμοῦ, Ἰωσίᾳ ἅμα συναγάλλεσθε· σεπτὴ δωδεκάς τε, τῶν Προφητῶν ἡ θεόπνευστος, τοῖς Γενεθλίοις τοῦ Σωτῆρος συγχόρευε, καὶ ἐν ᾄσμασι, πάντες Δίκαιοι ᾄσατε. Παῖδες οἱ παμμακάριστοι, οἱ δρόσῳ τοῦ Πνεύματος, σβέσαντες φλόγα καμίνου, ὑπὲρ ἡμῶν ἱκετεύσατε, Χριστὸν δυσωποῦντες, ταῖς ψυχαῖς ἡμῶν δοθῆναι, τὸ μέγα ἔλεος."

meMA.Lauds3.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Lauds3.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meMA.Lauds3.incipit = "Ὤφθη ἡ ἀπʼ αἰῶνος ἐν…"
meMA.Lauds3.text = "Ὤφθη ἡ ἀπʼ αἰῶνος ἐν γῇ, κηρυττομένη Προφητῶν ἐν τοῖς φλέγμασι, Παρθένος ἡ Θεοτόκος, ἣν Πατριάρχαι σοφοί, καὶ Δικαίων δῆμοι καταγγέλλουσι· μεθʼ ὧν συγχορεύει, καὶ γυναικῶν ἡ εὐπρέπεια, Σάῤῥα, Ῥεβέκκα, καὶ Ῥαχὴλ σὺν τῇ Ἄννῃ τε, καὶ ἡ ἔνδοξος, Μαριὰμ ἡ Μωσέως ὁμοῦ· ταύταις συνεπαγάλλονται, καὶ κόσμου τὰ πέρατα, σύμπασα κτίσις γεραίρει, ὅτι Θεὸς παραγίνεται, σαρκὶ τοῦ τεχθῆναι, καὶ δωρήσασθαι τῷ κόσμῳ τὸ μέγα ἔλεος."

meMA.LaudsGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.LaudsGlory.melody = ""
meMA.LaudsGlory.incipit = "Τῶν νομικῶν διδαγμάτων ὁ σύλλογος…"
meMA.LaudsGlory.text = "Τῶν νομικῶν διδαγμάτων ὁ σύλλογος, τὴν ἐν σαρκὶ ἐμφανίζει τοῦ Χριστοῦ θείαν Γέννησιν, τοῖς πρὸ τοῦ νόμου τὴν Χάριν εὐαγγελιζομένοις, ὡς ὑπὲρ νόμον τῇ πίστει ὑπάρξασιν· ὅθεν τῆς φθορᾶς ἀπαλλαγῆς οὔσαν πρόξενον, ταῖς ἐν ᾅδῃ κατεχομέναις ψυχαῖς προεκήρυττον, διὰ τῆς ἀναστάσεως. Κύριε δόξα σοι."

meLI.Kontakion1.mode = me.m12.dBC_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.melody = me.m12.dBC_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m12.dBC_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m12.dBC_gr_GR_cog.meMA.Kontakion1.text

meLI.Megalynarion.text = "Νόμος καὶ Δικαίων πᾶσα πληθύς, ἅμα Πατριάρχαι καὶ Προφῆται σὺν Γυναιξί, ταῖς Θεοτιμήτοις, προβλέποντες σκιρτῶσιν, ἐν Βηθλεὲμ τῇ πόλει Χριστὸν τικτόμενον."
