meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera01.greekmelody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.greekname
meVE.Stichera01.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
meVE.Stichera01.incipit = "Παρθένε Πανάμωμε Θεοῦ…"
meVE.Stichera01.text = "Παρθένε πανάμωμε Θεοῦ, ἔμψυχον παλάτιον, τὸν οὐρανοῖς μὴ χωρούμενον, ἐν σοὶ ἐχώρησας· ὃν ἐν τῷ Σπηλαίω, τέξῃ ὑπὲρ ἔννοιαν, πτωχεύσαντα καὶ σάρκα γενόμενον, ἵνα θεώσῃ με, καὶ πλουτίσῃ τὸν πτωχεύσαντα, ἀκρασίᾳ, πικροτάτης βρώσεως."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera02.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
meVE.Stichera02.incipit = "Ἐναπογραφόμενος Χριστέ…"
meVE.Stichera02.text = "Ἐναπογραφόμενος Χριστέ, δούλοις τῷ τοῦ Καίσαρος, διʼ εὐσπλαγχνίαν προστάγματι, ἔρχῃ χαρίσασθαι, τὴν ἐλευθερίαν, τὴν ζωὴν καὶ λύτρωσιν, ἀγνώμοσιν οἰκέταις μακρόθυμε, τοῖς προσκυνοῦσί σου, τὰ σωτήρια Γενέθλια, τοῦ ἐλθόντος, σῶσαι τὰς ψυχὰς ἡμῶν."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera03.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
meVE.Stichera03.incipit = "Τόκον ἀκατάληπτον θεσμούς…"
meVE.Stichera03.text = "Τόκον ἀκατάληπτον θεσμούς, φύσεως καινίσαντα, ἡ Παναγία καὶ ἄμωμος, κατανοήσασα, τῷ Υἱῷ ἐβόα· Τέκνον ποθεινότατον, ἐκπλήττομαι τὸ μέγα μυστήριον· πῶς καὶ γεννήσασα, παρθενεύω τῇ δυνάμει σου, τοῦ τὰ πάντα, ποιοῦντος βουλήματι!"

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera04.greekmelody = he.a.m8_gr_GR_cog.heAU.OEnEdemParadeisos.greekname
meVE.Stichera04.melody = he.a.m8_gr_GR_cog.heAU.OEnEdemParadeisos.name
