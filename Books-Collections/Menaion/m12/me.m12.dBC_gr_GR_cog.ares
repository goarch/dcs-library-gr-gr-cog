meDA.date = "Τῌ ΙΗʹ - ΚΔʹ ΔΕΚΕΜΒΡΙΟΥ"
meDA.commemoration.full = "Κυριακὴ πρὸ τῆς Χριστοῦ Γεννήσεως" // full title of day
meDA.commemoration.first = ""
meDA.commemoration.first_short = ""
