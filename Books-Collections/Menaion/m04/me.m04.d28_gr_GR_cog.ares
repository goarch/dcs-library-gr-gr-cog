A_Resource_Whose_Name = me.m04.d28_gr_GR_cog

meDA.date = "Τῌ ΚΗʹ ΑΠΡΙΛΙΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
meDA.commemoration.full = "Μνήμη τῶν Ἁγίων Ἐννέα Μαρτύρων τῶν ἐν Κυζίκῳ" //full title of day
meDA.commemoration.first = "Μνήμη τῶν Ἁγίων Ἐννέα Μαρτύρων τῶν ἐν Κυζίκῳ"
meDA.commemoration.first_short = "Μνήμη τῶν Ἁγίων Ἐννέα Μαρτύρων τῶν ἐν Κυζίκῳ"
meDA.commemoration.first_title = titles_gr_GR_cog.ti.Saints
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = ""
meDA.commemoration.second_name = ""
meDA.insert1 = "καὶ τῶν ἁγίων ἐνδόξων ἐννέα Μαρτύρων τῶν ἐν Κυζίκῳ," //for use in petitions and dismissal
meDA.insert2 = "ὧν καὶ τὴν μνήμην ἐπιτελοῦμεν·" //for use in petitions and dismissal
meDA.note = ""
meDA.pdfcoverdate = "τῆς 28ης Ἀπριλίου,"
meDA.pdfdatebefore = "τῆς 27ης Ἀπριλίου"
meDA.pdfheaderdate = "τῆς 28ης Ἀπριλίου"
meDA.fordate = "διὰ τὴν 28ην Ἀπριλίου"
meLE.commemoration1 = "Μνήμη τῶν Ἁγίων Ἐννέα Μαρτύρων τῶν ἐν Κυζίκῳ"
meLE.commemoration2 = ""
meHO.number = ""
meHO.rank = ""
meHO.commemorations = ""
meHO.note1 = ""
meHO.note2 = ""

meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera01.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
meVE.Stichera01.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.Stichera01.incipit = "Μάρτυρες Χριστοῦ…"
meVE.Stichera01.text = "Μάρτυρες Χριστοῦ πανεύφημοι, κατακρατούσης ποτέ, τῆς Ἑλλήνων σκαιότητος, καὶ ὠθούσης ἅπαντας, πρὸς ἀθέμιτα βάραθρα, ὁδὸν εὐθεῖαν οὐ κατελίπετε, καὶ ἀθεΐᾳ οὐ προσετέθητε· ἀλλʼ ἐνηθλήσατε, γνώμης ἀνδρειότητι, καὶ τὴν ζωήν, ξίφει θανατούμενοι, κατεκληρώσασθε."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera02.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.Stichera02.incipit = "Θέογνιν Ῥοῦφον…"
meVE.Stichera02.text = "Θέογνιν Ῥοῦφον Ἀντίπατρον, Θεόστιχον Ἀρτεμᾶν, Μάγνον τε καὶ Θεόδοτον, τὸν κλεινὸν Θαυμάσιον, καὶ τὸν θεῖον Φιλήμονα, τοὺς ἐν ἀθλήσει φαιδρῶς ἐκλάμψαντας, καὶ τοὺς ἐν σκότει φωταγωγήσαντας, πίστει τιμήσωμεν, ὕμνοις μακαρίσωμεν, τὴν ἱεράν, τούτων ἑορτάζοντες, μνήμην γηθόμενοι."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera03.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.Stichera03.incipit = "Ἄνθη μαρτύρων…"
meVE.Stichera03.text = "Ἄνθη μαρτύρων τερπνότατα, παρεμβολὴ ἱερά, θεοσύλλεκτον ἄθροισμα, Ἐκκλησία ἄριστος, συνοδία θεόλεκτος, χορὸς Ἁγίων δῆμος μακάριος, ὑπὲρ Τριάδος ἀγωνισάμενοι, ταύτην αἰτήσασθε, δοῦναι ἡμῖν ἄφεσιν, ἁμαρτιῶν, καὶ εἰρήνην ἅπασι, καὶ μέγα ἔλεος."

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.Apolytikion1ger.greekmelody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.greekname
meVE.Apolytikion1ger.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meVE.Apolytikion1ger.incipit = "Θείας πίστεως…"
meVE.Apolytikion1ger.text = "Θείας πίστεως, τῇ συμφωνίᾳ, ἐννεάριθμος, Μαρτύρων δῆμος, ἐν Κυζίκῳ ἱερῶς ἠνδραγάθησε· τὸν γὰρ Ὑπέρθεον Λόγον κηρύξαντες, ὑπὲρ αὐτοῦ ὡς ἀμνοὶ σφαγιάζονται· ὅθεν ἄφεσιν, αἰτοῦνται ἡμῖν καὶ ἔλεος, τοῖς μέλπουσιν αὐτῶν τὴν θείαν ἄθλησιν."

meMA.C1.acrostic.title = "Κανὼν τῶν Ἁγίων,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Τὴν ἐννάριθμον Μαρτύρων σέβω χάριν. Ἰωσήφ."
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaints
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintsM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.greekname
meMA.Ode1C11.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C11.incipit = "Ταῖς θείαις καλλοναῖς, ἐνηδόμενοι ὄντως…"
meMA.Ode1C11.text = "Ταῖς θείαις καλλοναῖς, ἐνηδόμενοι ὄντως, καὶ χειμάῤῥου τῆς τρυφῆς, τρυφῶντες δαψιλῶς, καὶ μεθέξει θεούμενοι, Μάρτυρες στεφανηφόροι, τοὺς ὑμᾶς μακαρίζοντας, χαλεπῶν ἐκ κινδύνων λυτρώσασθε."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C12.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C12.incipit = "Ἡλίου φωταυγοῦς, ἀνατείλαντος δίκην, ταῖς…"
meMA.Ode1C12.text = "Ἡλίου φωταυγοῦς, ἀνατείλαντος δίκην, ταῖς ἀκτῖσι τῶν στεῤῥῶν, ἀγώνων Ἀθληταί, καὶ θαυμάτων ταῖς λάμψεσιν, ἅπαντας φωταγωγεῖτε, καὶ παθῶν νύκτα λύετε, καὶ δαιμόνων τὸν ζόφον σκεδάζετε."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C13.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C13.incipit = "Νεφέλαι μυστικαί, τῶν αἱμάτων τοῖς…"
meMA.Ode1C13.text = "Νεφέλαι μυστικαί, τῶν αἱμάτων τοῖς ὄμβροις, ὑετίζουσαι πιστούς, ἐδείχθητε σοφοί, Ἀθληταῖς ἀξιάγαστοι, καὶ ξηραίνουσαι τὴν πλάνην, ἀθεΐας ἐν χάριτι· διὰ τοῦτο ὑμᾶς μακαρίζομεν."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C1T.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C1T.incipit = "Ἐκύησας Χριστόν, ἐξ ἁγνῶν σου…"
meMA.Ode1C1T.text = "Ἐκύησας Χριστόν, ἐξ ἁγνῶν σου αἱμάτων, σαρκωθέντα ὑπὲρ νοῦν, μορφῇ τῇ καθʼ ἡμᾶς, Θεομῆτορ πανάμωμε· ὅθεν πᾶσαι γενεαί σε, εὐσεβῶς μακαρίζομεν, τῶν ἁγίων Μαρτύρων τὸ καύχημα."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.greekname
meMA.Ode3C11.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C11.incipit = "Νεκροῖς ξοάνοις, ἐπιθῦσαι μηδόλως θελήσαντες…"
meMA.Ode3C11.text = "Νεκροῖς ξοάνοις, ἐπιθῦσαι μηδόλως θελήσαντες, τῷ τυθέντι διʼ ἡμᾶς, θυσία ζῶσα προσήχθητε, παῖδες ὡραιότατοι, Ἅγιοι Μάρτυρες."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C12.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C12.incipit = "Νόμοις ἐνθέοις, δυναμούμενοι σθένει τοῦ…"
meMA.Ode3C12.text = "Νόμοις ἐνθέοις, δυναμούμενοι σθένει τοῦ Πνεύματος, ἀνομούντων τὰς βουλάς, καὶ τὰς ἐνέδρας καθείλετε· νομίμως δʼ ἀθλήσαντες, δόξης ἐτύχετε."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C13.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C13.incipit = "Ἀποσκοποῦντες, εἰς τὴν μέλλουσαν εὔκλειαν…"
meMA.Ode3C13.text = "Ἀποσκοποῦντες, εἰς τὴν μέλλουσαν εὔκλειαν Μάρτυρες, τὴν φθαρτὴν καὶ γεηράν, τιμὴν ἐμφρόνως ἐλίπετε, καὶ δόξαν ἀθάνατον, ὄντως ἐλάβετε."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C1T.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C1T.incipit = "Ῥομφαῖαι πᾶσαι, τοῦ ἐχθροῦ νῦν…"
meMA.Ode3C1T.text = "Ῥομφαῖαι πᾶσαι, τοῦ ἐχθροῦ νῦν εἰς τέλος ἐξέλιπον, σοῦ τεκούσης τὸν Χριστόν, τρωθέντα λόγχῃ Πανάμωμε, ὑπὲρ οὗ οἱ Μάρτυρες, τρωθέντες ἤθλησαν."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3H.greekmelody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.greekname
meMA.Ode3H.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.melody
meMA.Ode3H.incipit = he.h.m4_gr_GR_cog.heHE.OukEnSofia.incipit
meMA.Ode3H.text = he.h.m4_gr_GR_cog.heHE.OukEnSofia.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3Kathisma1.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Ode3Kathisma1.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3Kathisma1.incipit = "Σοφισθέντες τῇ γνώσει τῇ θεϊκῇ…"
meMA.Ode3Kathisma1.text = "Σοφισθέντες τῇ γνώσει τῇ θεϊκῇ, ὁπλισθέντες τοῖς ὅπλοις τοῖς νοητοῖς, ἐχθροῦ κατεβάλετε, παρατάξεις ἐν Πνεύματι, καὶ βίῳ καὶ τρόπῳ, θανέντες μετέβητε, πρός ζωὴν ἀγήρω, καὶ φῶς τὸ ἀνέσπερον· ὅθεν καὶ ἰάσεις, ἀναβλύζοντες πᾶσι, ἰᾶσθε νοσήματα, καὶ διώκετε πνεύματα, Ἀθλοφόροι ἐννάριθμοι· Πρεσβεύσατε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ τὴν ἁγίαν μνήμην ὑμῶν."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3KathismaT.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3KathismaT.incipit = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.incipit
meMA.Ode3KathismaT.text = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3KathismaSt.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3KathismaSt.incipit = oc.m8.d4_gr_GR_cog.ocMA.Kathisma13.incipit
meMA.Ode3KathismaSt.text = oc.m8.d4_gr_GR_cog.ocMA.Kathisma13.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.greekname
meMA.Ode4C11.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C11.incipit = "Ἱερεῖα Ἄθλοφόροι, καὶ νεόθυτα σφάγια…"
meMA.Ode4C11.text = "Ἱερεῖα Ἄθλοφόροι, καὶ νεόθυτα σφάγια, θεῖαι προσφοραί τε, θύματα δεκτὰ προσηνέχθητε, τῷ ἑκουσίως τυθέντι, καὶ τὸν θάνατον, θανατώσαντι· ὅθεν ὑμᾶς μακαρίζομεν."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C12.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C12.incipit = "Θαῦμα μέγιστον δεικνύντες, παρειμένας ἰάσασθε…"
meMA.Ode4C12.text = "Θαῦμα μέγιστον δεικνύντες, παρειμένας ἰάσασθε, Ἀθλοφόροι χεῖρας, καὶ δυσεντερίας ἐῤῥύσασθε, τὸν προσφυγόντα ἐκ πόθου τῇ σορῷ ὑμῶν, περιβόητον ἄνδρα, ποτὲ ἀξιάγαστοι."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C13.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C13.incipit = "Μίαν γνώμην διαφόροις, ἐν τοῖς…"
meMA.Ode4C13.text = "Μίαν γνώμην διαφόροις, ἐν τοῖς σώμασιν ἔχοντες, μαρτυρίου στέφος, ἅμα ἐκομίσασθε Μάρτυρες, ἐν οὐρανοῖς οὖν Κυρίῳ παριστάμενοι, καὶ πληρούμενοι δόξης, ἡμᾶς ἐποπτεύετε."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C1T.melody = he.h.m4_gr_GR_cog.heHE.OKathimenosEnDoxi.name
meMA.Ode4C1T.incipit = "Ὁ ἐν κόλποις τοῖς πατρῴοις…"
meMA.Ode4C1T.text = "Ὁ ἐν κόλποις τοῖς πατρῴοις, ἀχωρίστως καθήμενος, σοῦ ἐν ταῖς ἀγκάλαις, κάθηται Παρθένε ὡς νήπιος, οὗ τὸ μακάριον πάθος εἰκονίζοντες, οἱ καλλίνικοι Παῖδες, ἀρίστως ἐνήθλησαν."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C11.greekmelody = he.h.m4_gr_GR_cog.heHE.AseveisOukOpsontai.greekname
meMA.Ode5C11.melody = he.h.m4_gr_GR_cog.heHE.AseveisOukOpsontai.name
meMA.Ode5C11.incipit = "Νοητοὶ ὡς ἄνθρακες, ἀνάψαντες Σοφοί…"
meMA.Ode5C11.text = "Νοητοὶ ὡς ἄνθρακες, ἀνάψαντες Σοφοί, κατεφλέξατε ἀληθῶς, φρυγανώδη ἅπασαν, πλάνην μακάριοι, καὶ πυρὰν ἐσβέσατε, τῶν εἰδώλων δρόσῳ τοῦ Πνεύματος."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C12.melody = he.h.m4_gr_GR_cog.heHE.AseveisOukOpsontai.name
meMA.Ode5C12.incipit = "Μερισμὸν ἐν σώμασιν, οὐκ ἔσχετε…"
meMA.Ode5C12.text = "Μερισμὸν ἐν σώμασιν, οὐκ ἔσχετε πολλοῖς, ἀμερίστου ὑπεραθλεῖν, Ἀθληταῖς Τριάδος κατεπειγόμενοι· ὅθεν διελύσατε, διαβόλου πᾶσαν φάλαγγα."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C13.melody = he.h.m4_gr_GR_cog.heHE.AseveisOukOpsontai.name
meMA.Ode5C13.incipit = "Ἀνυμνείσθω σήμερον, Θέογνις Ἀρτεμᾶς, Ῥοῦφος…"
meMA.Ode5C13.text = "Ἀνυμνείσθω σήμερον, Θέογνις Ἀρτεμᾶς, Ῥοῦφος Μάγνος τε ὁ κλεινός, εὐκλεὴς Φιλήμων τε καὶ ὁ Θεόδοτος, σὺν τῷ θαυμασίῳ τε, καὶ Ἀντίπατρος Θεόστιχος."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C1T.melody = he.h.m4_gr_GR_cog.heHE.AseveisOukOpsontai.name
meMA.Ode5C1T.incipit = "Ῥυομένη φάνηθι, ἡμᾶς τῶν δυσχερῶν…"
meMA.Ode5C1T.text = "Ῥυομένη φάνηθι, ἡμᾶς τῶν δυσχερῶν, καὶ πταισμάτων φθοροποιῶν, καὶ παθῶν καὶ θλίψεων καὶ περιστάσεων, τοὺς πιστῶς ὑμνοῦντάς σε, Θεοτόκε ἀειπάρθενε."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C11.greekmelody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.greekname
meMA.Ode6C11.melody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.name
meMA.Ode6C11.incipit = "Τίμιος ὁ θάνατος ἐδείχθη, τῶν…"
meMA.Ode6C11.text = "Τίμιος ὁ θάνατος ἐδείχθη, τῶν θείων Ἀθλοφόρων, σοῦ Θεὲ τῶν ὅλων ἐναντίον, οὓς περ σαφῶς, ἰατρεῖον ἄμισθον, τοῖς νοσοῦσιν ἐναπέδειξας."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C12.melody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.name
meMA.Ode6C12.incipit = "Ὑψώσαντες χεῖρας καὶ καρδίας, ὑψηλοτάτῃ…"
meMA.Ode6C12.text = "Ὑψώσαντες χεῖρας καὶ καρδίας, ὑψηλοτάτῃ γνώμῃ, πρὸς τὸν Ὕψιστον ἀνδρειοφρόνως, τοῦ πονηροῦ τὰς ἐπάρσεις Μάρτυρες, θεοφόροι κατεῤῥάξατε."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C13.melody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.name
meMA.Ode6C13.incipit = "Ῥείθροις τῶν σεπτῶν ὑμῶν αἱμάτων…"
meMA.Ode6C13.text = "Ῥείθροις τῶν σεπτῶν ὑμῶν αἱμάτων, εἰδωλικῆς ἀπάτης, ἐξηράνατε θάλασσαν ὄντως, καὶ τὴν Χριστοῦ, Ἐκκλησίαν Μάρτυρες, κατηρδεύσατε θεόφρονες."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C1T.melody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.name
meMA.Ode6C1T.incipit = "Ὥσπερ θημονία ἡ κοιλία, σοῦ…"
meMA.Ode6C1T.text = "Ὥσπερ θημονία ἡ κοιλία, σοῦ τῆς Ἁγνῆς ὡράθη, σῖτον φέρουσα ἀθανασίας, πάντων πιστῶν, τὰς ψυχὰς τὸν τρέφοντα, καὶ τοὺς Μάρτυρας εὐφραίνοντα."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6H.greekmelody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.greekname
meMA.Ode6H.melody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.melody
meMA.Ode6H.incipit = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.incipit
meMA.Ode6H.text = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.text

meMA.Kontakion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meMA.Kontakion1ger.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kontakion1ger.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Kontakion1ger.incipit = "Ἐννάριθμος χορός, τῶν Μαρτύρων αἰνείσθω…"
meMA.Kontakion1ger.text = "Ἐννάριθμος χορός, τῶν Μαρτύρων αἰνείσθω, Θέογνις ὁ κλεινός, καὶ Ἀντίπατρος ἅμα, Μάγνος τε καὶ Θεόστιχος, Ἀρτεμᾶς καὶ Θεόδοτος, καὶ Θαυμάσιος, Φιλήμων ἅμα καὶ Ροῦφος· θείαν χάριν γάρ, ἐκ τῶν πηγῶν τοῦ Σωτῆρος, ἡμῖν ἀναβλύζουσι."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C11.greekmelody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.greekname
meMA.Ode7C11.melody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.name
meMA.Ode7C11.incipit = "Νέοι ἓξ τρισὶ πρὸς ἄλλοις…"
meMA.Ode7C11.text = "Νέοι ἓξ τρισὶ πρὸς ἄλλοις, μίαν γνώμην ἐν πολλοῖς, κτησάμενοι σώμασι, κάμινον κατέσβεσαν πλάνης, δρόσῳ θείου Πνεύματος, εὐσεβῶς δροσιζόμενοι."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C12.melody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.name
meMA.Ode7C12.incipit = "Στάζουσιν ὑμῶν οἱ πόνοι, Μάρτυρες…"
meMA.Ode7C12.text = "Στάζουσιν ὑμῶν οἱ πόνοι, Μάρτυρες θείους κρουνούς, ἰάσεων πάντοτε, νόσων ποταμοὺς ἐκμειοῦντες, καὶ ῥύπον πάντα πλύνοντες, τῶν παθῶν ἀξιάγαστοι."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C13.melody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.name
meMA.Ode7C13.incipit = "Ἔχαιρον οἱ Ἀθλοφόροι, ἐν τῷ…"
meMA.Ode7C13.text = "Ἔχαιρον οἱ Ἀθλοφόροι, ἐν τῷ θλίβεσθαι αὐτούς, χαρὰν ἀνεκλάλητον, ἔψαλλον τεμνόμενοι ξίφει· Εὐλογητὸς εἶ Κύριε, ὁ Θεὸς ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C14.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C14.melody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.name
meMA.Ode7C14.incipit = "Βάρη τὰ τῶν νοσημάτων, πάθη…"
meMA.Ode7C14.text = "Βάρη τὰ τῶν νοσημάτων, πάθη τὰ τῶν καρδιῶν, ὀδύνας τοῦ σώματος, πᾶσάν τε συμβαίνουσαν θλῖψιν, ἡμῶν κουφίσαι ἔνδοξοι, Ἀθληταῖς δυσωπήθητε."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C1T.melody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.name
meMA.Ode7C1T.incipit = "Ὤφθης πάντων τῶν Μαρτύρων, ἄχραντε…"
meMA.Ode7C1T.text = "Ὤφθης πάντων τῶν Μαρτύρων, ἄχραντε Μῆτερ Θεοῦ, κραταίωμα μέγιστον, ὤφθης τῶν ἀνθρώπων προστάτις, τῶν σὲ ὑμνούντων πάντοτε, ἱεροῖς μελῳδήμασιν."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C11.greekmelody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.greekname
meMA.Ode8C11.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C11.incipit = "Χαριστήριον αἶνον προσάξωμεν, τῷ μεγίστους…"
meMA.Ode8C11.text = "Χαριστήριον αἶνον προσάξωμεν, τῷ μεγίστους ἡμῖν ἀντιλήπτορας, τοὺς ἀθλοφόρους Μάρτυρας, παρασχόντι, βοῶντες· Πάντα τὰ ἔργα, εὐλογεῖτε ὑμνεῖτε τὸν Κύριον."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C12.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C12.incipit = "Ἀνυμνείσθω ὁ μέγας Ἀντίπατρος, θαυμαζέσθω…"
meMA.Ode8C12.text = "Ἀνυμνείσθω ὁ μέγας Ἀντίπατρος, θαυμαζέσθω ὁ θεῖος Θαυμάσιος, Ῥοῦφός τε καὶ Θεόστιχος, Μάγνος Θέογνις ἅμα τῷ Θεοδότῳ, Ἀρτεμᾷ καὶ τῷ θείῳ Φιλήμονι."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C13.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C13.incipit = "Ῥιζωθέντες ἐν πέτρᾳ τῆς πίστεως…"
meMA.Ode8C13.text = "Ῥιζωθέντες ἐν πέτρᾳ τῆς πίστεως, εὐγενῆ ὡς στελέχη οἱ Μάρτυρες, καρποὺς ἡμῖν ἀθλήσεως, νῦν προβάλλονται πίστει τοῖς μελῳδοῦσιν· Εὐλογεῖτε τὰ ἔργα τὸν Κύριον."

meMA.Ode8C14.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C14.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C14.incipit = "Ἰατῆρες παθῶν μεγαλώνυμοι, τῆς ψυχῆς…"
meMA.Ode8C14.text = "Ἰατῆρες παθῶν μεγαλώνυμοι, τῆς ψυχῆς μου τὰ πάθη ἰάσασθε, καὶ τῆς γεέννης ῥύσασθε, καὶ τοῦ σκότους ἐκείνου τοῦ ἐξωτέρου, δυσωποῦντες Χριστὸν τὸν Θεὸν ἡμῶν,"

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C1T.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C1T.incipit = "Νομοδότην Χριστὸν ἀπεκύησας, τὸν νομίμως…"
meMA.Ode8C1T.text = "Νομοδότην Χριστὸν ἀπεκύησας, τὸν νομίμως ἀθλήσαντας στέψαντα, τοὺς ἀθλοφόρους Μάρτυρας, ὃν δυσώπει, τῷ νόμῳ τῆς ἁμαρτίας, τροπωθέντα με Κόρη ἰάσασθαι."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8H.greekmelody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.greekname
meMA.Ode8H.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.melody
meMA.Ode8H.incipit = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.incipit
meMA.Ode8H.text = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C11.greekmelody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.greekname
meMA.Ode9C11.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C11.incipit = "Ἰδού, ἠνεῴχθησαν ἡμῖν οὐράνιοι, πυλεῶνες…"
meMA.Ode9C11.text = "Ἰδού, ἠνεῴχθησαν ἡμῖν οὐράνιοι, πυλεῶνες ἐναθλήσασιν, ἔφη Χριστὸς τοῖς Ἀθλοφόροις, εἰσέλθετε, κομίσασθε χαίροντες, τὰ ἔπαθλα τῶν πόνων ἐπάξια, τοῖς ἀπʼ αἰῶνος ἐναθλήσασιν."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C12.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C12.incipit = "Ὡς ἄνθη τερπνὰ τοῦ νοητοῦ…"
meMA.Ode9C12.text = "Ὡς ἄνθη τερπνὰ τοῦ νοητοῦ πανεύφημοι, Παραδείσου ἐγνωρίσθητε, κρίνα ὡς εὔοσμα καὶ ῥόδα, ἡμᾶς ἐγκατοσφραίνοντες χάριτι, καὶ πλάνης δυσωδίας ἐξαίροντες· ὅθεν ἀξίως μακαρίζεσθε."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C13.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C13.incipit = "Στῶμεν ἐν τῷ οἴκῳ τοῦ…"
meMA.Ode9C13.text = "Στῶμεν ἐν τῷ οἴκῳ τοῦ Θεοῦ γεραίροντες, Ἀντιπάτρου Θεοστίχου τε, Ῥούφου Φιλήμονος τοὺς ἄθλους, τοῦ θείου Θαυμασίου τὰ θαύματα, τοῦ Μάγνου Ἀρτεμᾶ καὶ Θεόγνιδος, καὶ Θεοδότου τὸ ἀήττητον."

meMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C14.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C14.incipit = "Ἡμέρα σωτήριος ἡμῖν ἀνέτειλε, τῶν…"
meMA.Ode9C14.text = "Ἡμέρα σωτήριος ἡμῖν ἀνέτειλε, τῶν Ἁγίων ἡ πανήγυρις, ἣν ἐκτελοῦντες ἐτησίως, βοήσωμεν αὐτοῖς μετὰ πίστεως, Μαρτύρων φωταυγῆ ἀκροθίνια πάντων καρδίας καταυγάζετε."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C1T.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C1T.incipit = "Φορέσας ἐκ σοῦ ὁ Βασιλεὺς…"
meMA.Ode9C1T.text = "Φορέσας ἐκ σοῦ ὁ Βασιλεὺς τοῦ σώματος, τὴν πορφύραν προελήλυθεν, ὅλος ὡραῖος ἐκ γαστρός σου, καὶ πάντας τοὺς ἐχθροὺς ἐτροπώσατο, καὶ νίκην Ἀθλοφόροις ἑβράβευσεν, ἄχραντε μόνη Ἀειπάρθενε."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9H.greekmelody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.greekname
meMA.Ode9H.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.melody
meMA.Ode9H.incipit = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.incipit
meMA.Ode9H.text = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.text

meLI.Kontakion1.mode = me.m04.d28_gr_GR_cog.meMA.Kontakion1ger.mode
meLI.Kontakion1.melody = me.m04.d28_gr_GR_cog.meMA.Kontakion1ger.melody
