meDA.fordate = "διὰ τὴν 17ην Ἀπριλίου"
meLE.commemoration1 = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Συμεὼν τοῦ ἐν Περσίδι, καὶ τῶν σὺν αὐτῷ."
meLE.commemoration2 = ""
