meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.greekname
meVE.Stichera01.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera01.incipit = "Ἤστραψεν ὡς ἥλιος, ἡ θεία…"
meVE.Stichera01.text = "Ἤστραψεν ὡς ἥλιος, ἡ θεία μνήμη σου σήμερον, τοὺς πιστοὺς καταυγάζουσα, τὴν κτίσιν φωτίζουσα, θείαις φρυκτωρίαις, Συμεὼν Παμμάκαρ, καὶ παθημάτων τὴν ἀχλύν, καὶ τῶν δαιμόνων σκότος διώκουσα· διό σε μακαρίζομεν, καὶ ἐτησίως γεραίρομεν, ὡς φωστῆρα παγκόσμιον, πρεσβευτὴν ὡς θερμότατον."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera02.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera02.incipit = "Σοφῶς ἀντικτώμενος, τῶν ἐπὶ γῆς…"
meVE.Stichera02.text = "Σοφῶς ἀντικτώμενος, τῶν ἐπὶ γῆς τὰ οὐράνια, καὶ ῥεόντων τὰ ἄῤῥευστα, φθαρτῆς δόξης ἄφθαρτον, ἀντημείψω χαίρων, βασάνων τε νέφους, καὶ αἰκισμῶν παντοδαπῶς, τὰ ὑπὲρ λόγον Θεοῦ Βασίλειε, ἐν οἷς καὶ ἀγαλλόμενος, σὺν τοῖς συνάθλοις σου ἔνδοξε, ὑπὲρ πάντων ἱκέτευε, τῶν πιστῶς εὐφημούντων σε."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera03.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera03.incipit = "Βέλει τῷ τῶν λόγων σου…"
meVE.Stichera03.text = "Βέλει τῷ τῶν λόγων σου, παρανομούντων συστήματα, Συμεὼν Μάρτυς ἔτρωσας· φωνὴν ὅθεν ἔδωκαν οὐρανῶν νεφέλαι, χοροὶ τῶν Ἀγγέλων, συνεπεκρότησαν λοιπόν, τῶν σῶν ἀγώνων τὴν καρτερότητα· διὸ ἐπαγαλλόμενοι, πάντες πιστῶς ἑορτάζομεν, τὴν ἁγίαν σου κοίμησιν, τὸν Σωτῆρα δοξάζοντες."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticTheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.greekname
meVE.SticTheotokion.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.SticTheotokion.incipit = "Σὲ τὸ καθαρώτατον…"
meVE.SticTheotokion.text = "Σὲ τὸ καθαρώτατον, τοῦ Βασιλέως παλάτιον, δυσωπῶ Πολυΰμνητε. Τὸν νοῦν μου καθάρισον, τὸν ἐσπιλωμένον, πάσαις ἁμαρτίαις· καὶ καταγώγιον τερπνόν, τῆς ὑπερθέου Τριάδος ποίησον· ὅπως τὴν μεσιτείαν σου, καὶ τὸ ἀμέτρητον ἔλεος, μεγαλύνω σῳζόμενος, ὁ ἀχρεῖος ἱκέτης σου."

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticStavrotheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.greekname
meVE.SticStavrotheotokion.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.SticStavrotheotokion.incipit = "Σταυρούμενον βλέπουσα, καὶ τὴν πλευρὰν…"
meVE.SticStavrotheotokion.text = "Σταυρούμενον βλέπουσα, καὶ τὴν πλευρὰν ὀρυττόμενον, ὑπὸ λόγχης ἡ Πάναγνος, Χριστὸν τὸν φιλάνθρωπον, ὕμνει τὸν ἐκ σπλάγχνων, αὐτῆς προελθόντα, καὶ τὸ μακρόθυμον αὐτοῦ, ἀποθαυμάζουσα ἀνεκραύγαζε· Τέκνον μου ποθεινότατον, μὴ ἐπιλάθῃ τῆς δούλης σου, μὴ βραδύνῃς φιλάνθρωπε, τὸ ἐμὸν καταθύμιον."

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Apolytikion1ger.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
meVE.Apolytikion1ger.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meVE.Apolytikion1ger.incipit = "Ὡς ὑποφήτης τῶν ἐνθέων δογμάτων…"
meVE.Apolytikion1ger.text = "Ὡς ὑποφήτης τῶν ἐνθέων δογμάτων, μαρτυρικὸν συνασπισμὸν ἐπαλείφεις, λόγοις ὁμοῦ καὶ πράξεσι πρὸς ἄθλους ἱερούς· μεθʼ ὧν καὶ συνήθλησας, Συμεὼν ἱεράρχα, καὶ Χριστῷ ἀνέδραμες, σὺν αὐτοῖς ἀνακράζων· Ἰδοὺ ἡμεῖς ὡς πρόβατα σφαγῆς, τῇ σῇ ἀγάπῃ Σωτὴρ ἐλογίσθημεν."

meMA.C1.acrostic.title = "Κανὼν τοῦ Ἁγίου,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Στέφω μάκαρ σε, Συμεών, μελῳδίαις. Ἰωσήφ."
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaintM
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.Ode1C1H.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1H.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode1C1H.greekmelody = he.h.m5_gr_GR_cog.heHE.IpponKaiAnavatin.greekname
meMA.Ode1C1H.melody = he.h.m5_gr_GR_cog.heHE.IpponKaiAnavatin.melody
meMA.Ode1C1H.incipit = he.h.m5_gr_GR_cog.heHE.IpponKaiAnavatin.incipit
meMA.Ode1C1H.text = he.h.m5_gr_GR_cog.heHE.IpponKaiAnavatin.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode1C11.greekmelody = he.h.m5_gr_GR_cog.heHE.IpponKaiAnavatin.greekname
meMA.Ode1C11.melody = he.h.m5_gr_GR_cog.heHE.IpponKaiAnavatin.name
meMA.Ode1C11.incipit = "Στέφανον ἀφθαρσίας ἀναδησάμενος, καὶ τῷ…"
meMA.Ode1C11.text = "Στέφανον ἀφθαρσίας ἀναδησάμενος, καὶ τῷ θρόνῳ Κυρίου, Παμμάκαρ παριστάμενος, τοὺς πίστει τιμῶντάς σου, τὴν φωσφόρον ἄθλησιν, ταῖς εὐχαῖς σου ἀεὶ περίσῳζε."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode1C12.melody = he.h.m5_gr_GR_cog.heHE.IpponKaiAnavatin.name
meMA.Ode1C12.incipit = "Τίμιον σκεῦος ὤφθης τοῦ θείου…"
meMA.Ode1C12.text = "Τίμιον σκεῦος ὤφθης τοῦ θείου Πνεύματος, Συμεὼν θεοφόρε, παρʼ οὗ χρισθεὶς ἐποίμανας, λαὸν περιούσιον, βακτηρίᾳ θείων δογμάτων, Μάρτυς ἐφʼ ὕδωρ γνώσεως."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode1C13.melody = he.h.m5_gr_GR_cog.heHE.IpponKaiAnavatin.name
meMA.Ode1C13.incipit = "Ἔλαμψας ἐν τῷ κόσμῳ πράξει…"
meMA.Ode1C13.text = "Ἔλαμψας ἐν τῷ κόσμῳ πράξει καὶ λόγῳ σοφέ, ἐν λαμπρότητι βίου, καὶ λαὸν ἐποίμανας, ἐπὶ χλόην Ὅσιε ζωηφόρον, ὅστις γεραίρει, Μάρτυς τὴν θείαν μνήμην σου."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode1C1T.melody = he.h.m5_gr_GR_cog.heHE.IpponKaiAnavatin.name
meMA.Ode1C1T.incipit = "Φέρεις χερσὶ Παρθένε τὸν πάντα…"
meMA.Ode1C1T.text = "Φέρεις χερσὶ Παρθένε τὸν πάντα φέροντα, καὶ θηλάζεις ὡς βρέφος, τὸν χορηγὸν τοῦ γάλακτος· αὐτὸν οὖν ἱκέτευε, τὸν λαόν σου ἅπαντα, οἰκτιρῆσαι πιστῶς ὑμνοῦντά σε."

meMA.Ode3C1H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1H.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode3C1H.greekmelody = he.h.m5_gr_GR_cog.heHE.OPixasEpOudenos.greekname
meMA.Ode3C1H.melody = he.h.m5_gr_GR_cog.heHE.OPixasEpOudenos.melody
meMA.Ode3C1H.incipit = he.h.m5_gr_GR_cog.heHE.OPixasEpOudenos.incipit
meMA.Ode3C1H.text = he.h.m5_gr_GR_cog.heHE.OPixasEpOudenos.text

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode3C11.greekmelody = he.h.m5_gr_GR_cog.heHE.OPixasEpOudenos.greekname
meMA.Ode3C11.melody = he.h.m5_gr_GR_cog.heHE.OPixasEpOudenos.name
meMA.Ode3C11.incipit = "Ὡραίως τὰς τῆς ψυχῆς, κινήσεις…"
meMA.Ode3C11.text = "Ὡραίως τὰς τῆς ψυχῆς, κινήσεις ποιούμενος, καὶ βαδίζων τρίβον τὴν ἄνω φέρουσαν, πάσης ἀνοδίας πονηρᾶς, ἐξέκλινας καὶ ἤχθης, πρὸς τῆς ζωῆς τὴν πύλην ἔνδοξε, πρὸς τὴν αἰωνίαν κατάπαυσιν."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode3C12.melody = he.h.m5_gr_GR_cog.heHE.OPixasEpOudenos.name
meMA.Ode3C12.incipit = "Μακρύνας τὸν λογισμόν, παθῶν τῶν…"
meMA.Ode3C12.text = "Μακρύνας τὸν λογισμόν, παθῶν τῶν τοῦ σώματος, ἀναιμάκτους Πάτερ θυσίας ἤνεγκας, Λόγῳ τῷ τυθέντι διʼ ἡμᾶς, καὶ τούτου καταγγέλλων, τὴν ὑπὲρ λόγον θείαν σάρκωσιν, τέθυσαι ἀρνίον ὡς ἄκακον."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode3C13.melody = he.h.m5_gr_GR_cog.heHE.OPixasEpOudenos.name
meMA.Ode3C13.incipit = "Ἀνήχθης ὡς καθαρά, θυσία καὶ…"
meMA.Ode3C13.text = "Ἀνήχθης ὡς καθαρά, θυσία καὶ ἄμωμος, τῇ τοῦ Θεοῦ τραπέζῃ Μάκαρ ἀοίδιμε, καὶ ὡς ὁλοκαύτωμα δεκτόν, τυθεὶς ἐθελουσίως, ὑπὲρ τῆς πίστεως εἰσδέδεξαι, δόξαν εὐκλεῆ κλεϊζόμενος."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode3C1T.melody = he.h.m5_gr_GR_cog.heHE.OPixasEpOudenos.name
meMA.Ode3C1T.incipit = "Κατάρας προγονικῆς, ἡμᾶς ἠλευθέρωσας, εὐλογίαις…"
meMA.Ode3C1T.text = "Κατάρας προγονικῆς, ἡμᾶς ἠλευθέρωσας, εὐλογίαις πάντας τὸν στεφανώσαντα, Λόγον σωματώσασα Ἁγνή, ἀεὶ εὐλογημένη, τῶν Ἀθλοφόρων ἐγκαλλώπισμα, καὶ ἁμαρτανόντων ἐξίλασμα."

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3Kathisma1.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meMA.Ode3Kathisma1.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Ode3Kathisma1.incipit = "Ὡς ἥλιος ἡμῖν, ἡ ἁγία…"
meMA.Ode3Kathisma1.text = "Ὡς ἥλιος ἡμῖν, ἡ ἁγία σου μνήμη, ἀνέτειλε σοφέ, Συμεὼν Ἱεράρχα, καὶ τῶν συμμαρτύρων σου, τοὺς πιστοὺς καταυγάζουσα, ἣν περ σήμερον, ἐπιτελοῦντες βοῶμεν· ἱκετεύσατε, ὑπὲρ ἡμῶν Ἀθλοφόροι, τὸν μόνον φιλάνθρωπον."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3KathismaT.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Ode3KathismaT.incipit = oc.m1.d1_gr_GR_cog.ocMA.Kathisma23.incipit
meMA.Ode3KathismaT.text = oc.m1.d1_gr_GR_cog.ocMA.Kathisma23.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3KathismaSt.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Ode3KathismaSt.incipit = oc.m1.d4_gr_GR_cog.octrMA.Kathisma11.incipit
meMA.Ode3KathismaSt.text = oc.m1.d4_gr_GR_cog.octrMA.Kathisma11.text

meMA.Ode4C1H.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1H.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode4C1H.greekmelody = he.h.m5_gr_GR_cog.heHE.TinTheianEnnoisas.greekname
meMA.Ode4C1H.melody = he.h.m5_gr_GR_cog.heHE.TinTheianEnnoisas.melody
meMA.Ode4C1H.incipit = he.h.m5_gr_GR_cog.heHE.TinTheianEnnoisas.incipit
meMA.Ode4C1H.text = he.h.m5_gr_GR_cog.heHE.TinTheianEnnoisas.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode4C11.greekmelody = he.h.m5_gr_GR_cog.heHE.TinTheianEnnoisas.greekname
meMA.Ode4C11.melody = he.h.m5_gr_GR_cog.heHE.TinTheianEnnoisas.name
meMA.Ode4C11.incipit = "Ἀγόμενος δεσμώτης διέλυσας, τὰς μηχανὰς…"
meMA.Ode4C11.text = "Ἀγόμενος δεσμώτης διέλυσας, τὰς μηχανὰς τοῦ πονηροῦ, Ἱερομύστα πανόλβιε, καὶ ἐναθλήσας γενναίως, στεφάνους ἀφθαρσίας ἀπείληφας."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode4C12.melody = he.h.m5_gr_GR_cog.heHE.TinTheianEnnoisas.name
meMA.Ode4C12.incipit = "Ῥημάτων σου βολίσι κατέτρωσας, Ἱερομάρτυς…"
meMA.Ode4C12.text = "Ῥημάτων σου βολίσι κατέτρωσας, Ἱερομάρτυς Συμεών, παρανομούντων συστήματα, καὶ τῷ πυρὶ τῶν αἱμάτων, πολύθεον ἀπάτην ἐνέπρησας."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode4C13.melody = he.h.m5_gr_GR_cog.heHE.TinTheianEnnoisas.name
meMA.Ode4C13.incipit = "Σταλάζουσιν οἱ πόνοι σου ἴαμα…"
meMA.Ode4C13.text = "Σταλάζουσιν οἱ πόνοι σου ἴαμα, τοῖς ἀσθενοῦσι τὰς ψυχάς, τῶν Ἀποστόλων ὁμότροπος· σὺ γὰρ σαφῶς ἀνεδείχθης, καὶ θείων Ἀθλοφόρων ἐφάμιλλος."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode4C1T.melody = he.h.m5_gr_GR_cog.heHE.TinTheianEnnoisas.name
meMA.Ode4C1T.incipit = "Ἐκ σοῦ δικαιοσύνης ὁ Ἥλιος…"
meMA.Ode4C1T.text = "Ἐκ σοῦ δικαιοσύνης ὁ Ἥλιος, ἐξανατείλας ὑπὲρ νοῦν, τὴν οἰκουμένην ἐφώτισε, θεοχαρίτωτε Κόρη, καὶ πλάνης τὸν χειμῶνα διέλυσεν."

meMA.Ode5C1H.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1H.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode5C1H.greekmelody = he.h.m5_gr_GR_cog.heHE.OAnavallomenos.greekname
meMA.Ode5C1H.melody = he.h.m5_gr_GR_cog.heHE.OAnavallomenos.melody
meMA.Ode5C1H.incipit = he.h.m5_gr_GR_cog.heHE.OAnavallomenos.incipit
meMA.Ode5C1H.text = he.h.m5_gr_GR_cog.heHE.OAnavallomenos.text

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode5C11.greekmelody = he.h.m5_gr_GR_cog.heHE.OAnavallomenos.greekname
meMA.Ode5C11.melody = he.h.m5_gr_GR_cog.heHE.OAnavallomenos.name
meMA.Ode5C11.incipit = "Στῦλος καὶ ἑδραίωμα, τῆς Ἐκκλησίας…"
meMA.Ode5C11.text = "Στῦλος καὶ ἑδραίωμα, τῆς Ἐκκλησίας Χριστοῦ, ὀφθεὶς Παμμάκαρ τῇ σῇ ἀθλήσει, ἀκλινῆ ἀκράδαντον, ταύτην εἰς αἰῶνας, συντήρει μεσιτείαις σου."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode5C12.melody = he.h.m5_gr_GR_cog.heHE.OAnavallomenos.name
meMA.Ode5C12.incipit = "Ὕμνοις μακαρίζομεν, τὴν πολιτείαν σου…"
meMA.Ode5C12.text = "Ὕμνοις μακαρίζομεν, τὴν πολιτείαν σου, τοὺς διωγμούς τε καὶ τὰς ἐνστάσεις, Συμεὼν πανόλβιε, διʼ ὧν ἠξιώθης, τῆς μακαρίας λήξεως."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode5C13.melody = he.h.m5_gr_GR_cog.heHE.OAnavallomenos.name
meMA.Ode5C13.incipit = "Μύρῳ θείας χρίσεως, ποιμὴν γενόμενος…"
meMA.Ode5C13.text = "Μύρῳ θείας χρίσεως, ποιμὴν γενόμενος, ὑπὲρ τῆς ποίμνης ἐτύθης Μάκαρ, ὡς κριὸς ἐπίσημος, καὶ τῶν πρωτοτόκων, τὴν Ἐκκλησίαν εὔφρανας."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode5C1T.melody = he.h.m5_gr_GR_cog.heHE.OAnavallomenos.name
meMA.Ode5C1T.incipit = "Εὕροιμί σε Δέσποινα, ἐξαιρουμένην με…"
meMA.Ode5C1T.text = "Εὕροιμί σε Δέσποινα, ἐξαιρουμένην με, ἐν ὥρᾳ δίκης, τῆς καταδίκης, ὁ πιστῶς δοξάζων σε, καὶ κολαστηρίων, ῥυσθείην τῶν μενόντων με."

meMA.Ode6C1H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1H.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode6C1H.greekmelody = he.h.m5_gr_GR_cog.heHE.MainomeninKlydoni.greekname
meMA.Ode6C1H.melody = he.h.m5_gr_GR_cog.heHE.MainomeninKlydoni.melody
meMA.Ode6C1H.incipit = he.h.m5_gr_GR_cog.heHE.MainomeninKlydoni.incipit
meMA.Ode6C1H.text = he.h.m5_gr_GR_cog.heHE.MainomeninKlydoni.text

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode6C11.greekmelody = he.h.m5_gr_GR_cog.heHE.MainomeninKlydoni.greekname
meMA.Ode6C11.melody = he.h.m5_gr_GR_cog.heHE.MainomeninKlydoni.name
meMA.Ode6C11.incipit = "Ὤφθης θείας ἔμπλεως, θυμηδίας Μάκαρ…"
meMA.Ode6C11.text = "Ὤφθης θείας ἔμπλεως, θυμηδίας Μάκαρ Συμεών, διὰ ξίφους τέλος τὸ μακάριον, σὺν ἑκατόν, δεξάμενος θείοις Μάρτυσι."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode6C12.melody = he.h.m5_gr_GR_cog.heHE.MainomeninKlydoni.name
meMA.Ode6C12.incipit = "Νέοι καὶ πρεσβύτεροι, μονασταί τε…"
meMA.Ode6C12.text = "Νέοι καὶ πρεσβύτεροι, μονασταί τε καὶ ἱερουργοί, τὸν καλὸν ἀγῶνα διανύσαντες, ὑπὲρ Χριστοῦ, καθάπερ ἄρνες ἐτύθητε."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode6C13.melody = he.h.m5_gr_GR_cog.heHE.MainomeninKlydoni.name
meMA.Ode6C13.incipit = "Μακαρίως ζήσαντες, Ἀθλοφόροι τέλος ἀληθῶς…"
meMA.Ode6C13.text = "Μακαρίως ζήσαντες, Ἀθλοφόροι τέλος ἀληθῶς, ἐν Χριστῷ ἠνύσατε μακάριον, διὰ ξίφους τελειωθέντες γηθόμενοι."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode6C1T.melody = he.h.m5_gr_GR_cog.heHE.MainomeninKlydoni.name
meMA.Ode6C1T.incipit = "Ἐκ σοῦ ἀνατέταλκε, Παναγία ὁ…"
meMA.Ode6C1T.text = "Ἐκ σοῦ ἀνατέταλκε, Παναγία ὁ Δημιουργός, καὶ ἀκτῖσι θείας ἐπιγνώσεως τοὺς ἐν νυκτί, τῆς ἀγνωσίας ἐφώτισεν."

meMA.Kontakion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meMA.Kontakion1ger.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Kontakion1ger.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
meMA.Kontakion1ger.incipit = "Ἐκ Περσίδος ἔλαμψας ὡς ἑωσφόρος…"
meMA.Kontakion1ger.text = "Ἐκ Περσίδος ἔλαμψας ὡς ἑωσφόρος, Συμεὼν μακάριε, δῆμον Ἁγίων Ἀθλητῶν, ἔχων ἡμῖν συνανίσχοντας, ὥσπερ ἀστέρας· μεθʼ ὧν εὐφημοῦμέν σε."

meMA.Ode7C1H.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1H.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode7C1H.greekmelody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.greekname
meMA.Ode7C1H.melody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.melody
meMA.Ode7C1H.incipit = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.incipit
meMA.Ode7C1H.text = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.text

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode7C11.greekmelody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.greekname
meMA.Ode7C11.melody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.name
meMA.Ode7C11.incipit = "Λύχνος φαίνων γνώσεως, φῶς ἐγνώσθης…"
meMA.Ode7C11.text = "Λύχνος φαίνων γνώσεως, φῶς ἐγνώσθης Ὅσιε, ἐν σκότει καθεύδουσιν, ἀγνοίας καὶ ἔλυσας, πυρσολατρῶν τὸ σκότος, ἐναθλήσας παραδόξως."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode7C12.melody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.name
meMA.Ode7C12.incipit = "Ὤφθης προηγούμενος, Ἀθλητῶν συστήματος, μεθ’…"
meMA.Ode7C12.text = "Ὤφθης προηγούμενος, Ἀθλητῶν συστήματος, μεθʼ ὧν τελειούμενος, ξίφει ἀνεκραύγαζες· Συμεὼν θεόφρον, ὁ Θεὸς εὐλογητὸς εἶ."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode7C13.melody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.name
meMA.Ode7C13.incipit = "Δῆμον πολυάριθμον, Μαρτύρων τιμήσωμεν, σεπτῶς…"
meMA.Ode7C13.text = "Δῆμον πολυάριθμον, Μαρτύρων τιμήσωμεν, σεπτῶς συγκροτούμενον, διαφόρων πόλεων, ἱερουργῶν ἐνθέων, μοναστῶν τε θεοφόρων."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode7C1T.melody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.name
meMA.Ode7C1T.incipit = "Ἴασαι Πανάμωμε, πάθη τῆς καρδίας…"
meMA.Ode7C1T.text = "Ἴασαι Πανάμωμε, πάθη τῆς καρδίας μου, κόπασον τὸν τάραχον, τὸν νοῦν μου χειμάζοντα, καὶ σῶσόν με βοῶντα· ὁ Θεὸς εὐλογητὸς εἶ."

meMA.Ode8C1H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1H.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode8C1H.greekmelody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.greekname
meMA.Ode8C1H.melody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.melody
meMA.Ode8C1H.incipit = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.incipit
meMA.Ode8C1H.text = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.text

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode8C11.greekmelody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.greekname
meMA.Ode8C11.melody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.name
meMA.Ode8C11.incipit = "Ἄνθραξ νοητός, Συμεὼν δεδειγμένος, πυρὶ…"
meMA.Ode8C11.text = "Ἄνθραξ νοητός, Συμεὼν δεδειγμένος, πυρὶ οὐκ ἐλάτρευσας, Μακαριώτατε· ὕλην πικρὰν δέ, πολυθεΐας φλέξας, ἄδυτον πρὸς φέγγος, ἀξίως μετετέθης."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode8C12.melody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.name
meMA.Ode8C12.incipit = "Ἴασαι ἡμῶν, τὰς ἀσθενείας Μάρτυς…"
meMA.Ode8C12.text = "Ἴασαι ἡμῶν, τὰς ἀσθενείας Μάρτυς, τὸν ζόφον ἀπέλασον τῶν καρδιῶν ἡμῶν, καὶ αἰωνίου ζωῆς, δεῖξον μετόχους, σαῖς πρὸς τὸν Δεσπότην, θεόφρον μεσιτείαις."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode8C13.melody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.name
meMA.Ode8C13.incipit = "Στάζουσιν ἡμῖν, οἱ σοὶ ἀγῶνες…"
meMA.Ode8C13.text = "Στάζουσιν ἡμῖν, οἱ σοὶ ἀγῶνες Πάτερ, ψυχῆς ἀγαλλίασιν, καὶ ἀπελαύνουσιν, πάθη ποικίλα, καὶ νόσους τῶν σωμάτων, τῶν προσερχομένων, πιστῶς ἐν τῇ σορῷ σου."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode8C1T.melody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.name
meMA.Ode8C1T.incipit = "Ἵνα τὸν σεπτόν, σοῦ προδηλώσῃ…"
meMA.Ode8C1T.text = "Ἵνα τὸν σεπτόν, σοῦ προδηλώσῃ τόκον, βάτος ἀκατάφλεκτος, ὡράθη Πάναγνε· πῦρ γὰρ ἐν σπλάγχνοις, τὸ θεῖον δεξαμένη, ὅλως οὐκ ἐφλέχθης· διό σε ἀνυμνοῦμεν."

meMA.Ode9C1H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1H.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode9C1H.greekmelody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.greekname
meMA.Ode9C1H.melody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.melody
meMA.Ode9C1H.incipit = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.incipit
meMA.Ode9C1H.text = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode9C11.greekmelody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.greekname
meMA.Ode9C11.melody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.name
meMA.Ode9C11.incipit = "Ὡς δεκτὸν θυμίαμα, προσηνέχθης τῷ…"
meMA.Ode9C11.text = "Ὡς δεκτὸν θυμίαμα, προσηνέχθης τῷ Παμβασιλεῖ, ὡς σφάγιον ἱερὸν ὡς περικαλές, σοφὲ καλλιέρημα, ὥσπερ μύρον, ὥσπερ προσφορά, ῥόδον ὡς εὔοσμον, ὡς Μαρτύρων ἀγαλλίαμα."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode9C12.melody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.name
meMA.Ode9C12.incipit = "Στήριγμα γενόμενος, Ἱεράρχα, πάντων τῶν…"
meMA.Ode9C12.text = "Στήριγμα γενόμενος, Ἱεράρχα, πάντων τῶν πιστῶν, ἐτύθης ὥσπερ κριός, καὶ πρὸς νοητά, μετέβης βασίλεια, καὶ Βασιλεῖ πάντων καὶ Θεῷ, χαίρων παρίστασαι, θείᾳ δόξῃ ἀστραπτόμενος."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode9C13.melody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.name
meMA.Ode9C13.incipit = "Ἡ σεπτὴ παράταξις, τῶν Μαρτύρων…"
meMA.Ode9C13.text = "Ἡ σεπτὴ παράταξις, τῶν Μαρτύρων μέσον ἀσεβῶν, κηρύξασα τὸν Χριστόν, πλήθη δυσμενῶν, δαιμόνων ἠφάνισε, καὶ στρατιαῖς ταῖς ἀγγελικαῖς, ὄντως συνήφθησαν, θείᾳ δόξῃ κλεϊζόμενοι."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Ode9C1T.melody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.name
meMA.Ode9C1T.incipit = "Φανοτάταις λάμψεσι, παναγία Μήτηρ τοῦ…"
meMA.Ode9C1T.text = "Φανοτάταις λάμψεσι, παναγία Μήτηρ τοῦ Θεοῦ, καταύγασόν μου τὸν νοῦν, σκότει χαλεπῷ, ἀγνοίας κρατούμενον, ὅπως τυχὼν θείου φωτισμοῦ, τὰ μεγαλεῖά σου καταγγέλλω ἀειπάρθενε."

meLI.Kontakion1.mode = me.m04.d17_gr_GR_cog.meMA.Kontakion1ger.mode
meLI.Kontakion1.melody = me.m04.d17_gr_GR_cog.meMA.Kontakion1ger.melody
meLI.Kontakion1.incipit = me.m04.d17_gr_GR_cog.meMA.Kontakion1ger.incipit
meLI.Kontakion1.text = me.m04.d17_gr_GR_cog.meMA.Kontakion1ger.text

meLI.MM.CommunionHymn.text = properties_gr_GR_cog.media.key

meLI.Megalynarion.text = ""

