meDA.insert1 = "καὶ τοῦ Ἁγίου Ἱερομάρτυρος Συμεὼν τοῦ ἐν Περσίδι, καὶ τῶν σὺν αὐτῷ," //for use in petitions and dismissal
meDA.insert2 = "ὧν καὶ τὴν μνήμην ἐπιτελοῦμεν·" //for use in petitions and dismissal
meDA.note = ""
meDA.pdfcoverdate = "τῆς 17ης Ἀπριλίου,"
