meDA.date = "Τῌ ΙΖʹ ΑΠΡΙΛΙΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
meDA.commemoration.full = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Συμεὼν τοῦ ἐν Περσίδι, καὶ τῶν σὺν αὐτῷ" //full title of day
meDA.commemoration.first = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Συμεὼν τοῦ ἐν Περσίδι, καὶ τῶν σὺν αὐτῷ"
meDA.commemoration.first_short = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Συμεὼν τοῦ ἐν Περσίδι, καὶ τῶν σὺν αὐτῷ"
