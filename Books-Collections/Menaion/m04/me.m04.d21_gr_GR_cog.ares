meDA.commemoration.first = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Ἰανουαρίου καὶ τῶν σὺν αὐτῷ"
meDA.commemoration.first_short = "Μνήμη τοῦ Ἁγίου Ἱερομάρτυρος Ἰανουαρίου καὶ τῶν σὺν αὐτῷ"
