meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera01.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera01.incipit = "Ἱερεὺς ἐννομώτατος, ἀθλητὴς ἱερώτατος, ὦ…"
meVE.Stichera01.text = "Ἱερεὺς ἐννομώτατος, ἀθλητὴς ἱερώτατος, ὦ Ἰανουάριε, ἐχρημάτισας, οὐκ ἀλλοτρίῳ ἐν αἵματι, οἰκείῳ δὲ μάλιστα, εἰς αὐτὸν τὸν οὐρανόν, εἰσελθών, ἔνθα πρόδρομος, πάντων πέφυκεν, Ἰησοῦς ἀενάως, τοῦτον Πάτερ, ὀπτανόμενος καὶ βλέπων, ἅπερ οἱ Ἄγγελοι βλέπουσι."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera02.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera02.incipit = "Καὶ δορὰν ἀφαιρούμενος, καὶ πυρὶ…"
meVE.Stichera02.text = "Καὶ δορὰν ἀφαιρούμενος, καὶ πυρὶ προσριπτούμενος, καὶ θηρσὶ διδόμενος, Ἀξιάγαστε, καὶ φυλακαῖς συγκλειόμενος, ἡμέραις ἐν πλείοσιν, ἀταπείνωτος τὸν νοῦν, ῥώμῃ θείᾳ διέμεινας, καὶ ἐτέλεσας, τὸν ἀγῶνα νομίμως ἐναθλήσας, ἱερὲ θαυματοφόρε, τῶν Ἀσωμάτων ἐφάμιλλε."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera03.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera03.incipit = "Δισιδέριον Πρόκουλον, Σῶσσον, Φαῦστον Εὐτύχιον…"
meVE.Stichera03.text = "Δισιδέριον Πρόκουλον, Σῶσσον, Φαῦστον Εὐτύχιον, καὶ Ἰανουάριον τὸν ἀοίδιμον, καὶ τὸν σοφὸν Ἀκουτίωνα, συμφώνως τιμήσωμεν, ὡς σοφοὺς ἱερουργούς, στεφηφόρους ὡς Μάρτυρας, ὡς τῆς Πόλεως, τῆς ἁγίας πολίτας πρεσβευτάς τε, τῶν αὐτοὺς μακαριζόντων, ἀληθεστάτους ὑπάρχοντας."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticTheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.SticTheotokion.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.SticTheotokion.incipit = "Τὴν σκηνὴν τὴν ἀμόλυντον, τὴν…"
meVE.SticTheotokion.text = "Τὴν σκηνὴν τὴν ἀμόλυντον, τὴν νεφέλην τὴν ἔμψυχον, τὸν ναὸν τὸν ἅγιον, τοῦ Θεοῦ ἡμῶν, τὴν ἀδιάβατον γέφυραν, τὴν στάμνον τὴν πάγχρυσον, τὴν ἁγίαν κιβωτόν, τὴν μετάρσιον κλίμακα, τὸ εὐρύχωρον, τοῦ Δεσπότου χωρίον, τὴν Παρθένον, καὶ Μητέρα τοῦ Κυρίου, περιφανῶς μακαρίσωμεν."

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticStavrotheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.SticStavrotheotokion.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.SticStavrotheotokion.incipit = me.m01.d16_gr_GR_cog.meMA.LaudsStavrotheotokion.incipit
meVE.SticStavrotheotokion.text = me.m01.d16_gr_GR_cog.meMA.LaudsStavrotheotokion.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Apolytikion1ger.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
meVE.Apolytikion1ger.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meVE.Apolytikion1ger.incipit = "Ὡς Ἱεράρχης καὶ σοφὸς θεηγόρος…"
meVE.Apolytikion1ger.text = "Ὡς Ἱεράρχης καὶ σοφὸς θεηγόρος, τύπος ἐγένου πρὸς ἀθλήσεως πόνους, Πάτερ Ἰανουάριε τοῖς περὶ σεαυτόν. Σῶσος γὰρ καὶ Πρόκουλος, Δισιδέριος Φαῦστος, καὶ σὺν Ἀκουτίωνι, ὁ Εὐτύχιος ἅμα, σὺν σοὶ ἀθλοῦσι μάκαρ εὐσεβῶς· μεθʼ ὧν δυσώπει, ὑπὲρ τῶν ψυχῶν ἡμῶν."

meMA.C1.acrostic.title = "Κανὼν τῶν Ἁγίων,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Σύστημα τερπνὸν Μαρτύρων ἐπαινέσω. Ὁ Ἰωσήφ."
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaints
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintsM.text

meMA.Ode1C1H.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.greekname
meMA.Ode1C1H.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.melody
meMA.Ode1C1H.incipit = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.incipit
meMA.Ode1C1H.text = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.greekname
meMA.Ode1C11.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C11.incipit = "Συνὼν ταῖς στρατιαῖς, τῶν ἀΰλων…"
meMA.Ode1C11.text = "Συνὼν ταῖς στρατιαῖς, τῶν ἀΰλων, Ἀγγέλων, καὶ μεθέξει φωτισμοῦ, ἀδύτου τὴν ψυχήν, ἱερῶς φωτιζόμενος, φώτισόν μου τὴν καρδίαν, τὴν φωσφόρον σου σήμερον, ἑορτὴν εὐφημοῦντος μακάριε."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C12.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C12.incipit = "Ὑπῆρξας ἐκ παιδός, ἱερώτατος ὅλως…"
meMA.Ode1C12.text = "Ὑπῆρξας ἐκ παιδός, ἱερώτατος ὅλως, ἀρεταῖς συναυξηθείς, καὶ χρῖσμα ἱερόν, εἰληφὼς ἱεράτευσας, Ὅσιε λαὸν ποιμάνας, μαρτυρίου δὲ αἵματι, λαμπρυνθεὶς ὑπὲρ ἥλιον ἔλαμψας."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C13.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C13.incipit = "Στρατὸς φωτοειδής, ἱερώτατος δῆμος, συναλθεῖ…"
meMA.Ode1C13.text = "Στρατὸς φωτοειδής, ἱερώτατος δῆμος, συναλθεῖ σοι καρτερῶς, σοφὲ Ἱερουργὲ μεθʼ ὧν πᾶσαν διέλυσας, ὄφεως μηχανουργίαν, ὑπομείνας πολύπλοκα, ῥωμαλέῳ φρονήματι βάσανα."

meMA.Ode1C14.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C14.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C14.incipit = "Τοῖς ἴχνεσι Χριστοῦ, τοῦ μεγάλου…"
meMA.Ode1C14.text = "Τοῖς ἴχνεσι Χριστοῦ, τοῦ μεγάλου καὶ πρώτου, ἀρχιποίμενος Σοφέ, ἑπόμενος βαφαῖς, μαρτυρίου ἐφαίδρυνας, σοῦ τῆς ἀρχιερωσύνης, τὴν στολήν· διὰ τοῦτό σε, διανοίας τιμῶμεν εὐθύτητι."

meMA.Ode1C15.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C15.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C15.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C15.incipit = "Ἠχήσας ὡς βροντή, σοῦ ὁ…"
meMA.Ode1C15.text = "Ἠχήσας ὡς βροντή, σοῦ ὁ ἔνθεος λόγος, ἐμβροντήτους ἀκοάς, παράφρονος ἐχθροῦ, κατεπτόησεν ἔνδοξε· ὅθεν σε καθυποβάλλει, ἀνηκέστοις κολάσεσι, τῷ πρὸς Κύριον φίλτρῳ πυρούμενον."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C1T.melody = he.h.m4_gr_GR_cog.heHE.TristatasKrataious.name
meMA.Ode1C1T.incipit = "Μακάριος ἐστίν, ὁ λαὸς Θεοτόκε…"
meMA.Ode1C1T.text = "Μακάριος ἐστίν, ὁ λαὸς Θεοτόκε, ὁ δοξάζων σε Θεοῦ, Μητέρα ἀψευδῆ, καὶ ἀεὶ μακαρίζων σε, ἄχραντε, καθὼς προεῖπας, ἱερῶς προφητεύουσα, ὁπηνίκα Χριστὸν ἔνδον ἔφερες."

meMA.Ode3C1H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.greekname
meMA.Ode3C1H.melody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.melody
meMA.Ode3C1H.incipit = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.incipit
meMA.Ode3C1H.text = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.text

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.greekname
meMA.Ode3C11.melody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.name
meMA.Ode3C11.incipit = "Αἴγλῃ τοῦ Ἁγίου Πνεύματος, περιηνθισμένος…"
meMA.Ode3C11.text = "Αἴγλῃ τοῦ Ἁγίου Πνεύματος, περιηνθισμένος, μέσον καμίνου ἐχόρευες, Νεανίας τοὺς πρὶν ὁσίους, Παμμακάριστε μιμούμενος."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C12.melody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.name
meMA.Ode3C12.incipit = "Τάξεις ἱερῶν δυνάμεων, μέσον τῆς…"
meMA.Ode3C12.text = "Τάξεις ἱερῶν δυνάμεων, μέσον τῆς καμίνου, σὺν σοὶ θεόφρον ἐχόρευον, μεθʼ ὧν ὕμνεις τὸν Εὐεργέτην, διαμένων ἀκατάφλεκτος."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C13.melody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.name
meMA.Ode3C13.incipit = "Ἔχων τὸν Χριστὸν ὑπέρμαχον, μέσον…"
meMA.Ode3C13.text = "Ἔχων τὸν Χριστὸν ὑπέρμαχον, μέσον τῶν τυράννων, ἑστὼς ἀπτόητος ἔμεινας, καὶ βασάνους καθυπομείνας, Μάρτυς ὤφθης ἐνδοξότατος."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C1T.melody = he.h.m4_gr_GR_cog.heHE.ToxonDynatonIsthenise.name
meMA.Ode3C1T.incipit = "Ῥῆξον τὰς σειρὰς Θεόνυνφε, τῶν…"
meMA.Ode3C1T.text = "Ῥῆξον τὰς σειρὰς Θεόνυνφε, τῶν ἁμαρτιῶν μου, ἡ τὰ δεσμὰ διαῤῥήξασα, τὰ τοῦ ᾍδου τῷ τοκετῷ σου, καὶ χαρᾶς πάντα πληρώσασα."

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3Kathisma1.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
meMA.Ode3Kathisma1.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Ode3Kathisma1.incipit = "Ἱερωσύνης τὴν στολὴν ἐπιχρώσας, ταῖς…"
meMA.Ode3Kathisma1.text = "Ἱερωσύνης τὴν στολὴν ἐπιχρώσας, ταῖς τῶν αἱμάτων σου βαφαῖς λαμπροτέραν, περιφανῶς ἀπέδειξας θεράπον Χριστοῦ· ὅθεν ἀνελήλυθας, εἰς μονὰς αἰωνίους, βρύων τοῖς τιμῶσί σε, ἰαμάτων πελάγη, καὶ ἱκετεύων πάντοτε Θεόν, πᾶσι δοθῆναι πταισμάτων συγχώρησιν."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaT.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Ode3KathismaT.incipit = ho.ho23_gr_GR_cog.hoCA.Apolytikion2.incipit
meMA.Ode3KathismaT.text = ho.ho23_gr_GR_cog.hoCA.Apolytikion2.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaSt.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Ode3KathismaSt.incipit = me.m04.d20_gr_GR_cog.meMA.Ode3KathismaSt.incipit
meMA.Ode3KathismaSt.text = me.m04.d20_gr_GR_cog.meMA.Ode3KathismaSt.text

meMA.Ode4C1H.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.greekname
meMA.Ode4C1H.melody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.melody
meMA.Ode4C1H.incipit = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.incipit
meMA.Ode4C1H.text = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C11.greekmelody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.greekname
meMA.Ode4C11.melody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.name
meMA.Ode4C11.incipit = "Πάντες Σῶσσον τὸν λευΐτην καὶ…"
meMA.Ode4C11.text = "Πάντες Σῶσσον τὸν λευΐτην καὶ ἀθλοφόρον, τὸν ἱερόν τε Φαῦστον, Πρόκουλόν τε τὸν μέγαν, καὶ τὸν Δισιδέριον, συμφώνως τιμήσωμεν."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C12.melody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.name
meMA.Ode4C12.incipit = "Νυσταγμὸν τῆς ἀσεβείας Πρόκουλε Μάρτυς…"
meMA.Ode4C12.text = "Νυσταγμὸν τῆς ἀσεβείας Πρόκουλε Μάρτυς, σὺ μὴ νυστάξας ὅλως, ἐγρηγόρσεσι θείαις, πᾶσαν κατεκοίμισας, ἀθέων κακόνοιαν."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C13.melody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.name
meMA.Ode4C13.incipit = "Ὅλως θείαις εὐτυχήσας καλῶν ἰδέαις…"
meMA.Ode4C13.text = "Ὅλως θείαις εὐτυχήσας καλῶν ἰδέαις, καὶ μαρτυρίου φέγγει ἀπαστράψας ὡραίως, μέγιστε Εὐτύχιε, Θεῷ εὐηρέστησας."

meMA.Ode4C14.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C14.melody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.name
meMA.Ode4C14.incipit = "Νέον ὥσπερ Δανιὴλ σε, θηρῶν…"
meMA.Ode4C14.text = "Νέον ὥσπερ Δανιὴλ σε, θηρῶν ἐν μέσῳ, σὺν τοῖς συνάθλοις σῴζει, ἀβλαβῆ ἐκβληθέντα ὦ Ἰανουάριε, Χριστὸς ὁ Θεὸς ἡμῶν."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C1T.melody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.name
meMA.Ode4C1T.incipit = "Μεγαλύνωμεν τὴν μόνην εὐλογημένην, δι’…"
meMA.Ode4C1T.text = "Μεγαλύνωμεν τὴν μόνην εὐλογημένην, διʼ ἧς μεγάλως πάντας, ἐπευλόγησεν ὄντως, ὁ πανυπεράγαθος, ἐκ ταύτης σαρκούμενος."

meMA.Ode5C1H.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.greekname
meMA.Ode5C1H.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.melody
meMA.Ode5C1H.incipit = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.incipit
meMA.Ode5C1H.text = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.text

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C11.greekmelody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.greekname
meMA.Ode5C11.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C11.incipit = "Αἵματι ἱερῷ, τὴν στολήν σου…"
meMA.Ode5C11.text = "Αἵματι ἱερῷ, τὴν στολήν σου Πανόλβιε, ἐτέλεσας λαμπροτέραν, καὶ ναὸν πρὸς τὸν ἄνω, ὡς ἱερεὺς ἐλήλυθας."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C12.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C12.incipit = "Ῥεῦσαν ἐπὶ τῆς γῆς, τὸ…"
meMA.Ode5C12.text = "Ῥεῦσαν ἐπὶ τῆς γῆς, τὸ πολύτιμον αἷμά σου, γεγένηται ἰαμάτων ποταμός, παθημάτων, ξηραίνων Πάτερ ῥεύματα."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C13.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C13.incipit = "Τὸν ἄδικον κριτήν, τυφλωθέντα ἐντεύξει…"
meMA.Ode5C13.text = "Τὸν ἄδικον κριτήν, τυφλωθέντα ἐντεύξει σου, ἐφώτισας εὐσπλαγχνίαν, τοῦ Δεσπότου τῶν ὅλων, μιμούμενος, πανόλβιε."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C1T.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C1T.incipit = "Ὑμνοῦμέν σε διʼ ἧς, τοῖς…"
meMA.Ode5C1T.text = "Ὑμνοῦμέν σε διʼ ἧς, τοῖς ἐν σκότει φῶς ἄδυτον, ἀνέτειλε Θεοτόκε, ὁ τῶν ὅλων Δεσπότης, καὶ πόθῳ μακαρίζομεν."

meMA.Ode6C1H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.greekname
meMA.Ode6C1H.melody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.melody
meMA.Ode6C1H.incipit = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.incipit
meMA.Ode6C1H.text = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.text

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C11.greekmelody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.greekname
meMA.Ode6C11.melody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.name
meMA.Ode6C11.incipit = "Ῥήμασι σημεῖα θεωρήσας, δῆμός σε…"
meMA.Ode6C11.text = "Ῥήμασι σημεῖα θεωρήσας, δῆμός σε παρανόμων, ἐργαζόμενον Ἱερομύστα, τῷ Ποιητῇ, ἐκ ψυχῆς προσέρχεται, παραδόξως φωτιζόμενος."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C12.melody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.name
meMA.Ode6C12.incipit = "Ὤφθης καὶ πρὸ τέλους Ἱεράρχα…"
meMA.Ode6C12.text = "Ὤφθης καὶ πρὸ τέλους Ἱεράρχα, καὶ μετὰ θεῖον τέλος, ἐργαζόμενος πλῆθος θαυμάτων, τὴν δωρεάν, τοῦ Ἁγίου Πνεύματος, ἀπὸ βρέφους κομισάμενος."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C13.melody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.name
meMA.Ode6C13.incipit = "Νῦν ἱερωτάτῃ συμφωνίᾳ, Φαῦστον καὶ…"
meMA.Ode6C13.text = "Νῦν ἱερωτάτῃ συμφωνίᾳ, Φαῦστον καὶ Σῶσσον πάντες, Δισιδέριον σὺν Εὐτυχίῳ, καὶ τῷ σοφῷ Ἀκουτίῳ μέλψωμεν, καὶ Προκούλῳ τοὺς θεόφρονας."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C1T.melody = he.h.m4_gr_GR_cog.heHE.IlthonEisTaVathi.name
meMA.Ode6C1T.incipit = "Ἐπʼ εὐεργεσίᾳ τῶν ἀνθρώπων, σῶν…"
meMA.Ode6C1T.text = "Ἐπʼ εὐεργεσίᾳ τῶν ἀνθρώπων, σῶν ἐξ ἁγνῶν αἱμάτων, σεσωμάτωται ὁ Θεὸς Λόγος, ὃν ἐκτενῶς, Θεομῆτορ αἴτησαι, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν."

meMA.Kontakion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meMA.Kontakion1ger.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Kontakion1ger.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
meMA.Kontakion1ger.incipit = "Ἐν τῷ κόσμῳ λάμψαντες ὥσπερ…"
meMA.Kontakion1ger.text = "Ἐν τῷ κόσμῳ λάμψαντες ὥσπερ λυχνία, μυστικῶς ἑπτάφωτος, καταφωτίζετε ἡμᾶς, Ἰανουάριε ἔνδοξε, σὺν τοῖς συνάθλοις, μεθʼ ὧν εὐφημοῦμέν σε."

meMA.Ode7C1H.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.greekname
meMA.Ode7C1H.melody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.melody
meMA.Ode7C1H.incipit = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.incipit
meMA.Ode7C1H.text = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.text

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C11.greekmelody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.greekname
meMA.Ode7C11.melody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.name
meMA.Ode7C11.incipit = "Παῖδες θείους ἐμιμήσω, ἀνὰ μέσον…"
meMA.Ode7C11.text = "Παῖδες θείους ἐμιμήσω, ἀνὰ μέσον τῆς φλογός, ὦ Ἰανουάριε, ἐν συγκαταβάσει, Ἀγγέλων περιχορεύων, καὶ ᾠδαῖς μυστικαῖς τὸν Σωτῆρα ὑμνῶν."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C12.melody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.name
meMA.Ode7C12.incipit = "Ἄνοσον τὸν λογισμόν σου, χάριτι…"
meMA.Ode7C12.text = "Ἄνοσον τὸν λογισμόν σου, χάριτι θείᾳ τηρῶν, καὶ πρὸ τῆς ἀθλήσεως, νόσους ἐθεράπευσας πάσας, ποιμὴν καὶ μέγας, θαυματουργὸς γνωριζόμενος."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C13.melody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.name
meMA.Ode7C13.incipit = "Ἵστασο πρὸ τῶν βημάτων, Μάρτυς…"
meMA.Ode7C13.text = "Ἵστασο πρὸ τῶν βημάτων, Μάρτυς, τῶν τυραννικῶν, ἀθλῶν καρτερώτατα, καὶ τοὺς δυσσεβεῖς καταισχύνων, καὶ πλανηθεῖσιν ἅπασιν, ὑποδεικνὺς τὴν ἀλήθειαν."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C1T.melody = he.h.m4_gr_GR_cog.heHE.NeoiTreisEnVavyloni.name
meMA.Ode7C1T.incipit = "Νέκρωσόν μου τὰς κινήσεις, Ἄχραντε…"
meMA.Ode7C1T.text = "Νέκρωσόν μου τὰς κινήσεις, Ἄχραντε τὰς τῆς σαρκός, ζωὴν ἡ κυήσασα, ζώωσον ἁγνὴ τὴν ψυχήν μου, νεκρωμένην πάθεσι, καὶ πολλοῖς ἁμαρτήμασιν."

meMA.Ode8C1H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.greekname
meMA.Ode8C1H.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.melody
meMA.Ode8C1H.incipit = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.incipit
meMA.Ode8C1H.text = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.text

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C11.greekmelody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.greekname
meMA.Ode8C11.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C11.incipit = "Εὐφημείσθω ὁ μέγας νῦν Πρόκουλος…"
meMA.Ode8C11.text = "Εὐφημείσθω ὁ μέγας νῦν Πρόκουλος, καὶ σὺν τῷ Εὐτυχίῳ Ἀκούτιος, ὁ θεῖος Δισιδέριος, Φαῦστός τε καὶ Σῶσσος ὁ γενναιόφρων, τοῦ Σωτῆρος οἱ ἔνδοξοι Μάρτυρες."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C12.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C12.incipit = "Σὲ χορὸς Ἀθλοφόρων ὁ ἔνδοξος…"
meMA.Ode8C12.text = "Σὲ χορὸς Ἀθλοφόρων ὁ ἔνδοξος, κορυφαῖον πλουτήσας ἐπάτησεν, Ἱερομύστα ἔνδοξε, κορυψὰς τῶν δαιμόνων, καὶ ἀθεΐας, κορυφούμενον θράσος ἠφάνισεν."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C13.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C13.incipit = "Ὡς οἱ Παῖδες τὸ πῦρ…"
meMA.Ode8C13.text = "Ὡς οἱ Παῖδες τὸ πῦρ κατεπάτησας, καὶ θηρῶν τὰς ὁρμὰς ἐχαλίνωσας, ὡς Δανιὴλ πανάριστε, ὡς δὲ Παῦλος τὴν κάραν ἐναπετμήθης, εὐσεβῶς τελειώσας τὸν δρόμον σου."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C1T.melody = he.h.m4_gr_GR_cog.heHE.LytrotaTouPantos.name
meMA.Ode8C1T.incipit = "Ὁ σκηνώσας ἀφράστως ἐν μήτρᾳ…"
meMA.Ode8C1T.text = "Ὁ σκηνώσας ἀφράστως ἐν μήτρᾳ σου, ἑαυτοῦ οἰκητήριον ἔδειξε, σὲ καθαρὸν Πανάχραντε, ᾧ βοῶμεν ἀπαύστως· Πάντα τὰ ἔργα, εὐλογεῖτε ὑμνεῖτε τὸν Κύριον."

meMA.Ode9C1H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C1H.greekmelody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.greekname
meMA.Ode9C1H.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.melody
meMA.Ode9C1H.incipit = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.incipit
meMA.Ode9C1H.text = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C11.greekmelody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.greekname
meMA.Ode9C11.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C11.incipit = "Ἰανουαρίου τὰ σεπτὰ παλαίσματα, τοὺς…"
meMA.Ode9C11.text = "Ἰανουαρίου τὰ σεπτὰ παλαίσματα, τοὺς ἀγῶνας καὶ τὰ στίγματα, τὴν μέχρις αἵματος ἀνδρείαν, τοὺς πόνους καὶ τὸν βίαιον θάνατον, θαυμάτων τε τὸ ἄπειρον πέλαγος, ἐν εὐφροσύνῃ μεγαλύνωμεν."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C12.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C12.incipit = "Ὡράθης ἐν ὕψει τῆς σεπτῆς…"
meMA.Ode9C12.text = "Ὡράθης ἐν ὕψει τῆς σεπτῆς ἀοίδιμε, μαρτυρίας ὥσπερ ἄδυτος ἥλιος, θείους ὡς ἀστέρας, Μαρτύρων τὴν πληθὺν ἐπαγόμενος, καὶ νῦν φωταγωγεῖται τὰ πέρατα, ἄθλων μεγίστων ταῖς λαμπρότησιν."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C13.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C13.incipit = "Σὲ τὸν ποταμὸν τὸν λογικὸν…"
meMA.Ode9C13.text = "Σὲ τὸν ποταμὸν τὸν λογικὸν πληρούμενον, τῶν ναμάτων τῶν τοῦ πνεύματος, καὶ καταρδεύοντα πλουσίως, θαυμάτων ἱεραῖς ἐπιδείξεσι, πιστῶν τὰς διανοίας, γεραίροντες, Ἱερομάρτυς μακαρίζομεν."

meMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C14.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C14.incipit = "Ἡμέραν τελέσωμεν πιστοὶ ἑόρτιον, εὐφημοῦντες…"
meMA.Ode9C14.text = "Ἡμέραν τελέσωμεν πιστοὶ ἑόρτιον, εὐφημοῦντες Ἀκουτίωνα, Πρόκουλον Σῶσσον καὶ τὸν Φαῦστον, Εὐτύχιον σοφὸν Δισιδέριον, καὶ τὸν Ἰανουάριον ᾄσμασιν, ὡς ὑπὲρ πάντων νῦν πρεσβεύοντας."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C1T.melody = he.h.m4_gr_GR_cog.heHE.EvaMenToTisParakois.name
meMA.Ode9C1T.incipit = "Φωτὸς τοῦ ἐν σοὶ μαρμαρυγαῖς…"
meMA.Ode9C1T.text = "Φωτὸς τοῦ ἐν σοὶ μαρμαρυγαῖς τυφλώττουσαν, τὴν ψυχήν μου φωταγώγησον, καὶ χειραγώγησόν με Κόρη, ὁδοὺς σωτηριώδεις πορεύεσθαι, καὶ πλάνης ἐκφυγεῖν τὰ προσκόμματα, ὅπως ἐν, πίστει μακαρίζω σε."

meLI.Kontakion1.mode = me.m04.d21_gr_GR_cog.meMA.Kontakion1ger.mode
meLI.Kontakion1.melody = me.m04.d21_gr_GR_cog.meMA.Kontakion1ger.melody
meLI.Kontakion1.incipit = me.m04.d21_gr_GR_cog.meMA.Kontakion1ger.incipit
meLI.Kontakion1.text = me.m04.d21_gr_GR_cog.meMA.Kontakion1ger.text

meLI.MM.CommunionHymn.text = properties_gr_GR_cog.media.key

meLI.Megalynarion.text = ""

