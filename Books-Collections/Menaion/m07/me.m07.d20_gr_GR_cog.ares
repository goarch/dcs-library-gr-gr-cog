meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera01.greekmelody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.greekname
meVE.Stichera01.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera01.incipit = "Ὁ τὸν Θεσβίτην Ἠλίαν, πυρίνῳ…"
meVE.Stichera01.text = "Ὁ τὸν Θεσβίτην Ἠλίαν, πυρίνῳ ἅρματι, ἀπὸ τῆς γῆς οἰκτίρμον, μεταθέμενος Λόγε, ταῖς τούτου ἱκεσίαις, σῶσον ἡμᾶς τοὺς πιστῶς σε δοξάζοντας, καὶ τὴν αὐτοῦ ἐκτελοῦντας χαρμονικῶς, θείαν μνήμην καὶ σεβάσμιον."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera02.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera02.incipit = "Οὐ συσσεισμῷ ἀλλʼ ἐν αὔρᾳ…"
meVE.Stichera02.text = "Οὐ συσσεισμῷ ἀλλʼ ἐν αὔρᾳ, λεπτῇ τεθέασαι, Θεοῦ τὴν παρουσίαν, Ἠλιοὺ θεομάκαρ, φωτίζουσάν σε πάλαι, ἅρματι δέ, ἐποχούμενος τέθριππος, τὸν οὐρανὸν διϊππεύεις ξενοπρεπῶς, θαυμαζόμενος θεόπνευστε."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera03.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera03.incipit = "Τοὺς ἱερεῖς τῆς αἰσχύνης, ξίφει…"
meVE.Stichera03.text = "Τοὺς ἱερεῖς τῆς αἰσχύνης, ξίφει κατέσφαξας, τὸν οὐρανὸν τῇ γλώττῃ, ἐπὶ γῆς τοῦ μὴ βρέχειν, ἐπέσχες ζήλῳ θείῳ πυρποληθείς, Ἐλισσαῖον δὲ ἔπλησας, τῆς μηλωτῆς ἐπιδόσει διπλῆς σοφέ, Ἠλιοὺ ἐνθέου χάριτος."

meVE.SticGlory.poet = poets_gr_GR_cog.po.Vyzantiou
meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Δεῦτε τῶν ὀρθοδόξων τὸ σύστημα…"
meVE.SticGlory.text = "Δεῦτε τῶν ὀρθοδόξων τὸ σύστημα, συναθροισθέντες σήμερον, ἐν τῷ πανσέπτῳ ναῷ τῶν θεηγόρων Προφητῶν, ψαλμικῶς ᾄσωμεν, ἐναρμόνιον μέλος, τῷ τούτους δοξάσαντι, Χριστῷ τῷ Θεῷ ἡμῶν, καὶ ἐν χαρᾷ καὶ ἀγαλλιάσει ἀναβοήσωμεν· Χαίροις ἐπίγειε ἄγγελε, καὶ οὐράνιε ἄνθρωπε, Ἠλία μεγαλώνυμε. Χαίροις ὁ διπλῆν τὴν χάριν παρὰ Θεοῦ κομισάμενος, Ἐλισσαῖε πανσεβάσμιε. Χαίρετε ἀντιλήπτορες θερμοί, καὶ προστάται καὶ ἰατροί, τῶν ψυχῶν καὶ τῶν σωμάτων τοῦ φιλοχρίστου λαοῦ. Ἀπὸ πάσης προσβολῆς, ἐναντίας καὶ περιστάσεως, καὶ παντοίων κινδύνων λυτρώσασθε, τοὺς πιστῶς ἐκτελοῦντας, τὴν πανέορτον μνήμην ὑμῶν."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticTheotokion.melody = ""
meVE.SticTheotokion.incipit = oc.m6.d1_gr_GR_cog.ocVE.SticTheotokion.incipit
meVE.SticTheotokion.text = oc.m6.d1_gr_GR_cog.ocVE.SticTheotokion.text

meVE.Lity1.poet = poets_gr_GR_cog.po.Germanou
meVE.Lity1.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Lity1.melody = ""
meVE.Lity1.incipit = "Ἠλίας ὁ ζηλωτής, καὶ τῶν…"
meVE.Lity1.text = "Ἠλίας ὁ ζηλωτής, καὶ τῶν παθῶν αὐτοκράτωρ, ἀεροβάτης ἐδέρκετο σήμερον, τῆς παγκοσμίου μυητὴς σωτηρίας προχειριζόμενος. Ὢ δόξης ἀκραιφνοῦς, ἧς ἠξίωται ὁ ὑψιπέτης Προφήτης, καὶ Προφητῶν ἐξαίρετον ἐγκαλλώπισμα! οὗτος γὰρ ἐν σώματι ἄγγελος, καὶ ἄσαρκος ἄνθρωπος δέδεικται τοῖς κατορθώμασιν. Ὃν ἐπαινοῦντες εἴπωμεν· Ἀντιλαβοῦ ἡμῶν σοφέ, ἐν τῇ ἡμέρᾳ τῆς κρίσεως."

meVE.Lity2.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Lity2.melody = ""
meVE.Lity2.incipit = "Δαυϊτικῶς σήμερον πιστοί, τὸν Προφήτην…"
meVE.Lity2.text = "Δαυϊτικῶς σήμερον πιστοί, τὸν Προφήτην Κυρίου ὕμνοις τιμήσωμεν, Ἠλίαν τὸν Θεσβίτην, καὶ ζηλωτὴν τὸν ὑπέρλαμπρον· οὗτος γὰρ ἐν τῇ γλώσσῃ τὸν οὐρανὸν ὡς σίδηρον ἐχάλκευσε, καὶ τὴν γῆν τὴν ἔγκαρπον, ἄκαρπον ἐποίησεν. Ὢ τοῦ θαύματος! ὁ πήλινος ἄνθρωπος, οὐρανοὺς τοῦ δοῦναι ὑετὸν οὐκ εἴασεν. Ὢ τοῦ θαύματος! ὁ φθαρτός ἄνθρωπος, ἀφθαρσίαν ἐνδέδυται, καὶ οὐρανοὺς ἀνατρέχει ἐν πυρίνῳ ἅρματι, τῇ μηλωτῇ Ἐλισσαίῳ διπλῆς τὴν χάριν χαριζόμενος, Βασιλεῖς ἐλέγχει, καὶ λαὸν ἀπειθῆ λιμῷ διαφθείρει. Τοὺς ἱερεῖς τῆς αἰσχύνης πάντας κατῄσχυνε, καὶ τῆς χήρας τὸν υἱὸν λόγῳ ἀνέστησεν. Αὐτοῦ ταῖς ἱκεσίαις, Χριστὲ ὁ Θεὸς ἡμῶν, ἐν εἰρήνῃ διαφύλαξον τοὺς ὀρθοδόξους Βασιλεῖς ἡμῶν, καὶ τὰ τῆς νίκης τρόπαια κατὰ βαρβάρων αὐτοῖς δώρησαι."

meVE.Lity3.poet = poets_gr_GR_cog.po.Germanou
meVE.Lity3.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Lity3.melody = ""
meVE.Lity3.incipit = "Πνευματικοῖς ᾄσμασι τοὺς Προφήτας τοῦ…"
meVE.Lity3.text = "Πνευματικοῖς ᾄσμασι τοὺς Προφήτας τοῦ Χριστοῦ ἅπαντες εὐφημήσωμεν· Ἠλίας γὰρ ὁ Θεσβίτης, οὐρανοδρόμος γέγονε, καὶ μηλωτῇ Ἐλισσαῖος, τὴν χάριν ἐδέξατο διπλῆν παρὰ Θεοῦ, καὶ φωστῆρες φαιδροὶ τῇ οἰκουμένῃ ἀνεδείχθησαν, πρεσβεύοντες ἀπαύστως ὑπὲρ τῶν ψυχῶν ἡμῶν."

meVE.Lity4.poet = poets_gr_GR_cog.po.IoannouMonachou
meVE.Lity4.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Lity4.melody = ""
meVE.Lity4.incipit = "Φωστῆρες ἀνέτειλαν τῇ οἰκουμένῃ δύο…"
meVE.Lity4.text = "Φωστῆρες ἀνέτειλαν τῇ οἰκουμένῃ δύο παμφαεῖς Ἠλίας καὶ Ἐλισσαῖος, ὁ μὲν θείῳ λόγῳ, οὐρανίους σταγόνας ἀπέκλεισε, καὶ βασιλεῖς διήλεγξεν, ἅρματι δὲ πυρίνῳ εἰς οὐρανοὺς ἀνῆλθεν, ὁ δέ, ἀτεκνοῦντα ἰάσατο ὕδατα, καὶ διπλῆν δεξάμενος χάριν, Ἰορδάνου τὰ ῥεῖθρα ἐπέζευσε, καὶ νῦν μετʼ Ἀγγέλων χορεύοντες, ὑπὲρ ἡμῶν πρεσβεύουσι, σωθῆναι τὰς ψυχὰς ἡμῶν."

meVE.Lity5.poet = poets_gr_GR_cog.po.IoannouMonachou
meVE.Lity5.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Lity5.melody = ""
meVE.Lity5.incipit = "Τὸ ἐξᾶραν ἅρμα σε πυρφόρον…"
meVE.Lity5.text = "Τὸ ἐξᾶραν ἅρμα σε πυρφόρον, ὡς ἐν συσσεισμῷ εἰς οὐρανούς, τὴν πυρίπνοον χάριν σοι παρέσχετο, Ἠλία Θεσβῖτα, τοῦ μὴ ἰδεῖν θάνατον, ἕως ἂν κηρύξῃς τὴν τῶν πάντων συντέλειαν· διὸ πάρεσο διδοὺς ἡμῖν, τῶν σῶν κατορθωμάτων τὴν μύησιν."

meVE.LityGlory.poet = poets_gr_GR_cog.po.Arseniou
meVE.LityGlory.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.LityGlory.melody = ""
meVE.LityGlory.incipit = "Ἐν πυρίνῳ ἅρματι ἐπιδίφριος ἀρθείς…"
meVE.LityGlory.text = "Ἐν πυρίνῳ ἅρματι ἐπιδίφριος ἀρθείς, εἰς χώραν φωτοειδῆ μετετέθης, ὦ Θεσβῖτα Ἠλιού, αἰσχύνης δὲ προφήτας κατῄσχυνας, ὁ τὸν οὐρανὸν λόγῳ δεσμεύσας, ὡσαύτως λῦσον καὶ ἡμῶν τὰ πταίσματα, ταῖς πρὸς Κύριον πρεσβείαις σου, καὶ σῶσον τὰς ψυχὰς ἡμῶν."

meVE.LityBoth.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.LityBoth.melody = ""
meVE.LityBoth.incipit = oc.m4.d2_gr_GR_cog.ocMA.AposTheotokion.incipit
meVE.LityBoth.text = oc.m4.d2_gr_GR_cog.ocMA.AposTheotokion.text

meVE.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha1.greekmelody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.greekname
meVE.Aposticha1.melody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.name
meVE.Aposticha1.incipit = "Ὁ πρὸ συλλήψεως ὢν ἡγιασμένος…"
meVE.Aposticha1.text = "Ὁ πρὸ συλλήψεως ὢν ἡγιασμένος, ὁ ἔνσαρκος Ἄγγελος, ὁ νοῦς ὁ πύρινος, ὁ ἐπουράνιος ἄνθρωπος, ὁ τῆς δευτέρας, Χριστοῦ ἐλεύσεως θεῖος πρόδρομος, Ἠλίας ὁ ἔνδοξος, τῶν Προφητῶν ἡ κρηπίς, πνευματικῶς συνεκάλεσε, τοὺς φιλέορτους, πανηγυρίσαι τὴν θείαν μνήμην αὐτοῦ. Οὗ ταῖς πρέσβείαις διαφύλαξον, τὸν λαόν σου Χριστὲ ὁ Θεὸς ἡμῶν, ἀπὸ βλάβης παντοίας, τοῦ δολίου ἀνενόχλητον."

meVE.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha2.melody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.name
meVE.Aposticha2.incipit = "Ὁ οὐρανόφρων Ἠλίας ὁ Προφήτης…"
meVE.Aposticha2.text = "Ὁ οὐρανόφρων Ἠλίας ὁ Προφήτης, θεώμενος ἅπαντα ἀπὸ Κυρίου Θεοῦ, τὸν Ἰσραὴλ ἐκπορνεύσαντα, καὶ τοῖς εἰδώλοις, προστετηκότα ζήλῳ πυρούμενος, νεφέλας συνέστειλε, καὶ γῆν ἐξήρανε, καὶ οὐρανοὺς λόγῳ ἔκλεισεν, εἰπών, οὐκ ἔσται, σταγὼν ἐν γῇ, εἰ μὴ ἐμοῦ διὰ στόματος. Αὐτὸς ὑπάρχει ἑστιάτωρ νῦν, ὡς ἀφθόνως ἡμῖν παρεχόμενος, ἀνεκλάλητον χάριν, τοῖς πιστῶς αὐτὸν γεραίρουσι."

meVE.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha3.melody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.name
meVE.Aposticha3.incipit = "Ὁ τῶν ἀῤῥήτων ἐπόπτης μυστηρίων…"
meVE.Aposticha3.text = "Ὁ τῶν ἀῤῥήτων ἐπόπτης μυστηρίων, σὺ τὰ Ἰορδάνια ῥεῖθρα διέῤῥηξας, σὺ τὴν ἀπάτην ἐτέφρωσας, τὴν τῶν εἰδώλων, τῇ ἀστραπῇ τῶν θείων ῥημάτων σου, σὺ παρανομήσαντα ἤλεγξας ἄνακτα, καὶ ἱερεῖς ἐθανάτωσας, τῆς ἀνομίας, καὶ τὴν θυσίαν εὐχῇ ἐνέπρησας, καὶ τοὺς φλογώδεις, τοῦ λαοῦ σου νῦν, τῶν παθημάτων καὶ θλίψεων ἄνθρακας, Ἠλιοὺ σῆς πρεσβείας τῷ πυρὶ ἐναπομάρανον."

meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Προφῆτα κήρυξ Χριστοῦ, τοῦ θρόνου…"
meVE.AposGlory.text = "Προφῆτα κήρυξ Χριστοῦ, τοῦ θρόνου τῆς μεγαλωσύνης οὐδέποτε χωρίζῃ, καὶ ἑκάστῳ ἀσθενοῦντι ἀεὶ παρίστασαι, ἐν τοῖς ὑψίστοις λειτουργῶν, τὴν οἰκουμένην εὐλογεῖς, πανταχοῦ δοξαζόμενος. Αἴτησαι ἱλασμὸν ταῖς ψυχαῖς ἡμῶν."

meVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.AposTheotokion.melody = he.o_gr_GR_cog.heOT.TheotokeSyEi.name
meVE.AposTheotokion.incipit = he.o_gr_GR_cog.heOT.TheotokeSyEi.incipit
meVE.AposTheotokion.text = he.o_gr_GR_cog.heOT.TheotokeSyEiProfitou.text

meVE.Apolytikion1.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Apolytikion1.greekmelody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.greekname
meVE.Apolytikion1.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
meVE.Apolytikion1.incipit = "Ὁ ἔνσαρκος ἄγγελος…"
meVE.Apolytikion1.text = "Ὁ ἔνσαρκος Ἄγγελος, τῶν Προφητῶν ἡ κρηπίς, ὁ δεύτερος Πρόδρομος, τῆς παρουσίας Χριστοῦ, Ἠλίας ὁ ἔνδοξος, ἄνωθεν καταπέμψας, Ἐλισσαίῳ τὴν χάριν, νόσους ἀποδιώκει, καὶ λεπροὺς καθαρίζει· διὸ καὶ τοῖς τιμῶσιν αὐτὸν βρύει ἰάματα."

meMA.Kathisma11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kathisma11.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meMA.Kathisma11.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Kathisma11.incipit = "Φωστῆρα παμφαῆ, διφρηλάτην πυρφόρον, καὶ…"
meMA.Kathisma11.text = "Φωστῆρα παμφαῆ, διφρηλάτην πυρφόρον, καὶ ἄγγελον σαρκί, ζήλου πνέοντα θείου, δυσσέβειαν τρέποντα, παρανόμους ἐλέγχοντα, κορυφαῖόν τε, τῶν Προφητῶν σε συμφώνως καταγγέλλομεν, μάκαρ θεόπτα Ἠλία· διὸ ἡμᾶς φρούρησον."

meMA.Kathisma1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kathisma1T.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Kathisma1T.incipit = oc.m1.d1_gr_GR_cog.ocMA.Kathisma13.incipit
meMA.Kathisma1T.text = oc.m1.d1_gr_GR_cog.ocMA.Kathisma13.text

meMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kathisma21.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meMA.Kathisma21.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Kathisma21.incipit = "Θεῷ διʼ ἀρετῆς, ἀκραιφνοῦς ᾠκειώθης…"
meMA.Kathisma21.text = "Θεῷ διʼ ἀρετῆς, ἀκραιφνοῦς ᾠκειώθης, οὐράνιον ζωήν, ἐπὶ γῆς βιωτεύσας, ζωὴν δὲ τῆς χάριτος, κεκτημένος μακάριε, σοῖς φυσήμασι, παῖδα θανόντα ἐγείρεις, μένεις δʼ ἄφθαρτος, κρείττων εἰσέτι θανάτου, Ἠλία θεόπνευστε."

meMA.Kathisma2T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kathisma2T.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Kathisma2T.incipit = oc.m1.d1_gr_GR_cog.ocMA.Kathisma23.incipit
meMA.Kathisma2T.text = oc.m1.d1_gr_GR_cog.ocMA.Kathisma23.text

meR01 = "Τὸ Μηναῖον δὲν προβλέπει Εὐαγγέλιον τοῦ Ὄρθρου."

meMA.C1.acrostic.title = "Ὁ πρῶτος Κανών,"
meMA.C1.acrostic.notice1 = "φέρων Ἀκροστιχίδα τήν δε ἄνευ τῶν Θεοτοκίων·"
meMA.C1.acrostic.text = "Αἰνῶ χορεύων Ἠλιοὺ τὰ θαύματα."
meMA.C1.poet = poets_gr_GR_cog.po.IoannouMonachou
meMA.C1.title = titles_gr_GR_cog.ti.Canon1Prophet
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_Prophet.text

meMA.C2.acrostic.title = "Δεύτερος Κανών,"
meMA.C2.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C2.acrostic.text = "Νέμοις μάκαρ μοι θείαν Ἠλιοὺ χάριν. Ἰωσήφ."
meMA.C2.title = titles_gr_GR_cog.ti.Canon2Prophet
meMA.C2.verse = prayers_gr_GR_cog.pr.verse_Prophet.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode1C11.greekmelody = he.h.m2_gr_GR_cog.heHE.AsomenToKyrio.greekname
meMA.Ode1C11.melody = he.h.m2_gr_GR_cog.heHE.AsomenToKyrio.name
meMA.Ode1C11.incipit = "ᾌδειν προῃρημένοι, τῶν Ἠλιοὺ θαυμάτων…"
meMA.Ode1C11.text = "ᾌδειν προῃρημένοι, τῶν Ἠλιοὺ θαυμάτων, τὴν πυρίπνοον δύναμιν, τῆς πυρομόρφου καὶ σεπτῆς, γλώσσης τῆς τοῦ Πνεύματος, τὸ σθένος ἐπαξίως ἐπικεκλήμεθα."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode1C12.melody = he.h.m2_gr_GR_cog.heHE.AsomenToKyrio.name
meMA.Ode1C12.incipit = "Ἵλαθι θεοφόρε, καὶ τῆς ἀπόρου…"
meMA.Ode1C12.text = "Ἵλαθι θεοφόρε, καὶ τῆς ἀπόρου γλώσσης, τὸ στενόν τε καὶ δύσηχον, τῇ ἐνεργείᾳ τοῦ ἐν σοί, Πνεύματος διάνοιξον, καὶ τράνωσον, πρὸς ὕμνον τῶν θαυμασίων σου."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode1C13.melody = he.h.m2_gr_GR_cog.heHE.AsomenToKyrio.name
meMA.Ode1C13.incipit = "Νέμεις τὰ ὑπὲρ φύσιν, τοῖς…"
meMA.Ode1C13.text = "Νέμεις τὰ ὑπὲρ φύσιν, τοῖς πειθαρχοῦσι Λόγε, τοῖς σεπτοῖς σου προστάγμασι, καὶ ὑποτάττεις ὑετοῦ, πύλας διὰ Πνεύματος, σθενούμενον τὸν λόγον ἀπεργαζόμενος."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode1C1T.melody = he.h.m2_gr_GR_cog.heHE.AsomenToKyrio.name
meMA.Ode1C1T.incipit = "Μόνη εὐλογημένη, τὸ καθαρὸν καὶ…"
meMA.Ode1C1T.text = "Μόνη εὐλογημένη, τὸ καθαρὸν καὶ θεῖον, τῆς ἁγνείας κειμήλιον, τῆς ἀκαθάρτου τῶν παθῶν, κάθαρον ἰλύος με, αἰτοῦσα συγχώρησιν τῶν πταισμάτων μου."

meMA.Ode1C21.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C21.greekmelody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.greekname
meMA.Ode1C21.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C21.incipit = "Νενεκρωμένην τὴν ψυχήν μου ζώωσον…"
meMA.Ode1C21.text = "Νενεκρωμένην τὴν ψυχήν μου ζώωσον, ὡς τὸν τῆς χήρας υἱόν, καὶ ἀρεταῖς θείαις, Μάκαρ καταλάμπρυνον, καὶ πρὸς ζωὴν ὁδήγησον, καὶ τῆς αἰωνιζούσης, τρυφῆς ἀνάδειξον μέτοχον, σοῦ κατατρυφᾶν ἐφιέμενον."

meMA.Ode1C22.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C22.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C22.incipit = "Ἐν τῷ σὲ τίκτεσθαι ὁ…"
meMA.Ode1C22.text = "Ἐν τῷ σὲ τίκτεσθαι ὁ σὸς μεμύηται, γεννήτωρ μέγιστον, ὡς ἀληθῶς θαῦμα· πῦρ γὰρ σιτιζόμενον, φλογί τε σπαργανούμενον, σὲ τεθέαται μάκαρ· διὸ ταῖς σαῖς παρακλήσεσι, ῥῦσαί με πυρὸς αἰωνίζοντος."

meMA.Ode1C23.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C23.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C23.incipit = "Μεγαλυνθεὶς ταῖς πρὸς Θεόν σου…"
meMA.Ode1C23.text = "Μεγαλυνθεὶς ταῖς πρὸς Θεόν σου νεύσεσι, ζηλῶν ἐζήλωσας, ὡς ἀληθῶς Μάκαρ, τῷ Κυρίῳ πάντοτε· διό με ἐνδυνάμωσον, ζήλου θείου πλησθέντα, τὸ ἔνθεον πράττειν βούλημα, ἵνα σε γεραίρω σῳζόμενος."

meMA.Ode1C2T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C2T.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C2T.incipit = "Ὁ ὑπερούσιος Θεὸς Πανάμωμε, ἐκ…"
meMA.Ode1C2T.text = "Ὁ ὑπερούσιος Θεὸς Πανάμωμε, ἐκ σοῦ σεσάρκωται, καὶ διʼ ἡμᾶς ὤφθη, καθʼ ἡμᾶς ὡς ἄνθρωπος, ὃν ἐκτενῶς ἱκέτευε, ὑπὲρ πάντας ἀνθρώπους, ἡμαρτηκότα με πάναγνε, σῶσαι καὶ κολάσεως ῥύσασθαι."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode3C11.greekmelody = he.h.m2_gr_GR_cog.heHE.EnPetraMeTisPisteos.greekname
meMA.Ode3C11.melody = he.h.m2_gr_GR_cog.heHE.EnPetraMeTisPisteos.name
meMA.Ode3C11.incipit = "Ὡς ἄριστος προφῆτα ὁ ἑστιάτωρ…"
meMA.Ode3C11.text = "Ὡς ἄριστος προφῆτα ὁ ἑστιάτωρ, ὁ κόραξι τελῶν σοι τὴν πανδαισίαν, ὁ μόνος ἐμπιπλῶν πᾶν ζῶον εὐδοκίας, ᾧ πάντες κράζομεν· Σὺ εἶ Θεὸς ἡμῶν, καὶ οὐκ ἔστιν Ἅγιος πλήν σου Κύριε."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode3C12.melody = he.h.m2_gr_GR_cog.heHE.EnPetraMeTisPisteos.name
meMA.Ode3C12.incipit = "Χάρις τῷ εὐεργέτῃ καὶ κηδεμόνι…"
meMA.Ode3C12.text = "Χάρις τῷ εὐεργέτῃ καὶ κηδεμόνι, τῷ χήραν καὶ Προφήτην ἀλληλοτρόφους, ἀῤῥήτῳ ἐκτελέσαντι προμηθείᾳ, ᾧ πάντες κράζομεν· Σὺ εἶ Θεὸς ἡμῶν, καὶ οὐκ ἔστιν Ἅγιος πλήν σου Κύριε."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode3C13.melody = he.h.m2_gr_GR_cog.heHE.EnPetraMeTisPisteos.name
meMA.Ode3C13.incipit = "Ὁ κλείσας ὀμβροτόκους νεφέλας ὕειν…"
meMA.Ode3C13.text = "Ὁ κλείσας ὀμβροτόκους νεφέλας ὕειν, τροφῆς ἠπορημένῃ τῇ Σαραφθίᾳ, τὰ λείψανα τῆς βρώσεως ἀνενδότως, ψεκάζειν ἔδρασας· διὸ καὶ ἔκραζες· Ὡς οὐκ ἔστιν, Ἅγιος πλήν σου Κύριε."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode3C1T.melody = he.h.m2_gr_GR_cog.heHE.EnPetraMeTisPisteos.name
meMA.Ode3C1T.incipit = "Σὺ μόνη παρὰ πάντας τοὺς…"
meMA.Ode3C1T.text = "Σὺ μόνη παρὰ πάντας τοὺς ἀπʼ αἰῶνος, μεγάλων ἠξιώθης καὶ ὑπὲρ φύσιν· Θεὸν γὰρ τὸν ἀχώρητον πάσῃ κτίσει, ἐν μήτρᾳ ἤνεγκας, καὶ ἐσωμάτωσας· ὅθεν Θεοτόκον σε πίστει σέβομεν."

meMA.Ode3C21.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C21.greekmelody = he.h.m8_gr_GR_cog.heHE.OuraniasApsidos.greekname
meMA.Ode3C21.melody = he.h.m8_gr_GR_cog.heHE.OuraniasApsidos.name
meMA.Ode3C21.incipit = "Ἱερεῖς τῆς αἰσχύνης, ὡς δυσμενεῖς…"
meMA.Ode3C21.text = "Ἱερεῖς τῆς αἰσχύνης, ὡς δυσμενεῖς ἔκτεινας, ἔνδοξε Προφῆτα, ζήλῳ Θεοῦ πυρπολούμενος· ὅθεν κραυγάζω σοι· Τῶν τῆς αἰσχύνης με ἔργων, καὶ διαιωνίζοντος πυρός ἐξάρπασον."

meMA.Ode3C22.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C22.melody = he.h.m8_gr_GR_cog.heHE.OuraniasApsidos.name
meMA.Ode3C22.incipit = "Σὲ προβάλλομαι πρέσβυν, πρὸς τὸν…"
meMA.Ode3C22.text = "Σὲ προβάλλομαι πρέσβυν, πρὸς τὸν Θεὸν μέγιστον, σῴζειν με δυνάμενον, πάσης Μάκαρ κακώσεως, προσεπικάμφθητι, τῇ ταπεινῇ μου δεήσει, καὶ μὴ ὑπερίδῃς με, παρακαλοῦντά σε."

meMA.Ode3C23.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C23.melody = he.h.m8_gr_GR_cog.heHE.OuraniasApsidos.name
meMA.Ode3C23.incipit = "Μεγαλύνει Θεός σε, ὁ παντουργὸς…"
meMA.Ode3C23.text = "Μεγαλύνει Θεός σε, ὁ παντουργὸς ἔνδοξε, πάλαι Ἠλιού, διʼ ὀρνέου τρέφων Προφῆτά σε, ὃν ἐκδυσώπησον, τῆς αἰωνίου τρυφῆς με, καὶ φωτὸς τοῦ μέλλοντος, ποιῆσαι μέτοχον."

meMA.Ode3C2T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C2T.melody = he.h.m8_gr_GR_cog.heHE.OuraniasApsidos.name
meMA.Ode3C2T.incipit = "Ἀδιόδευτε πύλη, ἡ πρὸς Θεὸν…"
meMA.Ode3C2T.text = "Ἀδιόδευτε πύλη, ἡ πρὸς Θεὸν φέρουσα, πύλας μετανοίας μοι Κόρη, ἄνοιξον δέομαι, ἀποκαθαίρουσα, ἁμαρτιῶν μου τὸν ῥύπον, ὄμβροις τοῦ ἐλέους σου, θεοχαρίτωτε."

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3Kathisma1.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Ode3Kathisma1.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3Kathisma1.incipit = "Ὡς Προφήτης τοῦ ὄντως θείου…"
meMA.Ode3Kathisma1.text = "Ὡς Προφήτης τοῦ ὄντως θείου φωτός, τοὺς προφήτας τοῦ ψεύδους καταβαλών, ἐν τούτῳ διήλεγξας, Ἀχαὰβ ἀνομήσαντα, μὴ προσκυνεῖν διδάξας, τῷ Βάαλ πανένδοξε, καὶ εὐχῇ αἰτήσας, ἐξ ὕψους τὰ νάματα· ὅθεν καὶ πυρίνῳ, ἀνελήφθης Ἠλία, ὀχήματι μετάρσιος, διφρηλάτης πρὸς Κύριον· διὰ τοῦτο βοῶμέν σοι· Πρέσβευε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ, τὴν ἁγίαν μνήμην σου."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3KathismaT.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3KathismaT.incipit = "Ὡς Παρθένον καὶ μόνην ἐν…"
meMA.Ode3KathismaT.text = "Ὡς Παρθένον καὶ μόνην ἐν γυναιξί, σὲ ἀσπόρως τεκοῦσαν Θεὸν σαρκί, πᾶσαι μακαρίζομεν, γενεαὶ τῶν ἀνθρώπων· τὸ γὰρ πῦρ ἐσκήνωσεν, ἐν σοὶ τῆς Θεότητος, καὶ ὡς βρέφος θηλάζεις, τὸν Κτίστην καὶ Κύριον· ὅθεν τῶν Ἀγγέλων, καὶ ἀνθρώπων τὸ γένος, ἀξίως δοξάζουσι, τὸν πανάγιον τόκον σου, καὶ συμφώνως βοῶμέν σοι· Πρέσβευε τῷ σῷ Υἱῷ καὶ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς προσκυνοῦσιν ἐν πίστει, τὸν ἄσπορον τόκον σου."

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode4C11.greekmelody = he.h.m2_gr_GR_cog.heHE.EisakikoaKyrieTinAkoin.greekname
meMA.Ode4C11.melody = he.h.m2_gr_GR_cog.heHE.EisakikoaKyrieTinAkoin.name
meMA.Ode4C11.incipit = "Ῥιζοτόμος μὲν ὤφθης, κακίας σαφῶς…"
meMA.Ode4C11.text = "Ῥιζοτόμος μὲν ὤφθης, κακίας σαφῶς Προφῆτα, ἀρετῆς δὲ φυτοκόμος· διὸ τιμῶμέν σε."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode4C12.melody = he.h.m2_gr_GR_cog.heHE.EisakikoaKyrieTinAkoin.name
meMA.Ode4C12.incipit = "Ἐλοιδορεῖτο λόγοις σε, χήρα τροφός…"
meMA.Ode4C12.text = "Ἐλοιδορεῖτο λόγοις σε, χήρα τροφός, τὸν θάνατον Προφῆτα, τοῦ παιδὸς τὴν ἔγερσιν ἐπισπεύδουσα."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode4C13.melody = he.h.m2_gr_GR_cog.heHE.EisakikoaKyrieTinAkoin.name
meMA.Ode4C13.incipit = "Ὑπεσημήνω δόξαν Τριάδος σαφῶς, ἐμπνεύσει…"
meMA.Ode4C13.text = "Ὑπεσημήνω δόξαν Τριάδος σαφῶς, ἐμπνεύσει τρισαρίθμῳ τῇ μητρὶ τὸν παῖδα ζῶντα δωρούμενος."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode4C1T.melody = he.h.m2_gr_GR_cog.heHE.EisakikoaKyrieTinAkoin.name
meMA.Ode4C1T.incipit = "Ὡς κατάκαρπος ἄμπελος, βότρυν Ἁγνή…"
meMA.Ode4C1T.text = "Ὡς κατάκαρπος ἄμπελος, βότρυν Ἁγνή, τῆς σωτηρίας οἶνον, πᾶσιν ἀναβλύζειν ἐκυοφόρησας."

meMA.Ode4C21.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C21.greekmelody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.greekname
meMA.Ode4C21.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C21.incipit = "Κάμπει τὸν σόν, ζῆλον Θεὸς…"
meMA.Ode4C21.text = "Κάμπει τὸν σόν, ζῆλον Θεὸς πυρακτούμενον, καὶ πρὸς χήραν, πέμπει διατρέφεσθαι, τὸν γυναικός, πάλαι ἀπειλῇ, Ἠλιοὺ φυγάδα, γεγενημένον θεσπέσιε· διό σε ἱκετεύω, τὴν ψυχήν μου πεινῶσαν, διαθρέψαι ἐνθέοις χαρίσμασιν."

meMA.Ode4C22.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C22.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C22.incipit = "Ἁμαρτιῶν, νέφη δεινὰ συγκαλύπτει με…"
meMA.Ode4C22.text = "Ἁμαρτιῶν, νέφη δεινὰ συγκαλύπτει με, τρικυμίαι, βίου με χειμάζουσι, καὶ ἐπιπνέουσι χαλεπῶς, κατὰ τῆς ψυχῆς μου, τῆς πονηρίας τὰ πνεύματα, Προφῆτα θεηγόρε, κυβερνήτης γενοῦ μοι, σωτηρίας πρὸς ὅρμον ἰθύνων με."

meMA.Ode4C23.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C23.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C23.incipit = "Ῥῶσιν ψυχῆς, ῥῶσιν παράσχου μοι…"
meMA.Ode4C23.text = "Ῥῶσιν ψυχῆς, ῥῶσιν παράσχου μοι σώματος, τὸν τὰς νόσους, πάντων ἀφαιρούμενον, ἐκδυσωπῶν, μάκαρ Ἠλιού, Κύριον τῆς δόξης, καὶ ἀβλαβῶς διατρέχειν με, τὰ σκάνδαλα τοῦ βίου, κατευόδωσον· σὲ γάρ, ἀγαθόν μου προστάτην προβάλλομαι."

meMA.Ode4C2T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C2T.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C2T.incipit = "Μετὰ πασῶν, τῶν οὐρανίων Δυνάμεων…"
meMA.Ode4C2T.text = "Μετὰ πασῶν, τῶν οὐρανίων Δυνάμεων, μετὰ πάντων, Δέσποινα πανάμωμε, τῶν Προφητῶν, καὶ τῶν Ἀθλητῶν, καὶ τῶν Ἀποστόλων καὶ τῶν Ὁσίων ἱκέτευε, τυχεῖν με σωτηρίας, τὸν πολλὰ ἁμαρτόντα, καὶ ῥυσθῆναι μελλούσης κολάσεως."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode5C11.greekmelody = he.h.m2_gr_GR_cog.heHE.OTouFotosChorigos.greekname
meMA.Ode5C11.melody = he.h.m2_gr_GR_cog.heHE.OTouFotosChorigos.name
meMA.Ode5C11.incipit = "Νόμος πατρῷός σε, ὡς πρεσβευτὴν…"
meMA.Ode5C11.text = "Νόμος πατρῷός σε, ὡς πρεσβευτὴν παναληθῆ ἔδειξε, τερατουργόν, ἐκτρέποντα φύσεις, στοιχείων Ἠλιού, καὶ ὅσιον θῦμα, φλογίζοντα νάμασιν."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode5C12.melody = he.h.m2_gr_GR_cog.heHE.OTouFotosChorigos.name
meMA.Ode5C12.incipit = "ᾜσχυνας ἄριστα, ὡς ἀληθείας λατρευτὴς…"
meMA.Ode5C12.text = "ᾜσχυνας ἄριστα, ὡς ἀληθείας λατρευτὴς Ὅσιε, τῆς ἐναγοῦς προφήτας αἰσχύνης, παμμάκαρ Ἠλιού, σαφῶς ὑπογράψας, Τριάδος τὴν δύναμιν."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode5C13.melody = he.h.m2_gr_GR_cog.heHE.OTouFotosChorigos.name
meMA.Ode5C13.incipit = "Λόγῳ τῆς χάριτος, ἱερατεύων Ἠλιοὺ…"
meMA.Ode5C13.text = "Λόγῳ τῆς χάριτος, ἱερατεύων Ἠλιοὺ τέθυκας, τοὺς ἱερεῖς, τῶν προσοχθισμάτων, ἀθώοις σου χερσί, καθάπερ ποδήρει, τῷ ζήλῳ κοσμούμενος."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode5C1T.melody = he.h.m2_gr_GR_cog.heHE.OTouFotosChorigos.name
meMA.Ode5C1T.incipit = "Σοὶ τῇ τεκούσῃ Χριστόν, τὸν…"
meMA.Ode5C1T.text = "Σοὶ τῇ τεκούσῃ Χριστόν, τὸν τοῦ παντὸς Δημιουργὸν κράζομεν· Χαῖρε ἁγνή, Χαῖρε ἡ τὸ φῶς ἀνατείλασα ἡμῖν, Χαῖρε ἡ χωρήσασα Θεὸν τὸν ἀχώρητον."

meMA.Ode5C21.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C21.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
meMA.Ode5C21.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C21.incipit = "Ὀμβροτόκους νεφέλας, εἴργεις πυρακτούμενος ζήλῳ…"
meMA.Ode5C21.text = "Ὀμβροτόκους νεφέλας, εἴργεις πυρακτούμενος ζήλῳ τῆς πίστεως, ἀλλὰ δέομαί σου· Ἠλιοὺ ἱεραῖς μεσιτείαις σου, τὴν φλογμῷ τακεῖσαν τῶν ἡδονῶν ψυχήν μου θείαις, ἑπομβρίαις ἀρδεῦσαι καὶ σῶσαί με."

meMA.Ode5C22.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C22.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C22.incipit = "Ἱερεὺς δεδειγμένος τέθυκας, ἀθώοις σου…"
meMA.Ode5C22.text = "Ἱερεὺς δεδειγμένος τέθυκας, ἀθώοις σου χερσὶ πανόλβιε, τῶν προσοχθισμάτων, ἱερεῖς ἐνεργοῦντας τὰ ἄτοπα, ἀλλὰ δέομαί σου, πάσης ἀτόπου ἁμαρτίας ἀβλαβῆ με Προφῆτα συντήρησον."

meMA.Ode5C23.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C23.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C23.incipit = "Θαυμαστοῦσαι Προφῆτα, θείαις ἐπικλήσεσι φλέγων…"
meMA.Ode5C23.text = "Θαυμαστοῦσαι Προφῆτα, θείαις ἐπικλήσεσι φλέγων τὰ θύματα, ἐκτελέσας πίστει· διὰ τοῦτο ἀπαύστως σου δέομαι, τῇ ἐμῇ καρδίᾳ, τὸν ἱερὸν ἀνάψαι πόθον, τὰ ὑλώδη μου πάθη συμφλέγοντα."

meMA.Ode5C2T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C2T.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C2T.incipit = "Ἐπὶ σὲ ὥσπερ ὄμβρος, Λόγος…"
meMA.Ode5C2T.text = "Ἐπὶ σὲ ὥσπερ ὄμβρος, Λόγος καταβέβηκεν ὁ ὑπερούσιος, ὃν δυσώπει Κόρη, ἑπομβρίσαι μοι νῦν κατανύξεως, καθαρὰς σταγόνας, ἀποπλυνούσας πάντα ῥύπον, τῶν ἀμέτρων κακῶν μου πανάμωμε."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode6C11.greekmelody = he.h.m2_gr_GR_cog.heHE.AvyssosAmartimaton.greekname
meMA.Ode6C11.melody = he.h.m2_gr_GR_cog.heHE.AvyssosAmartimaton.name
meMA.Ode6C11.incipit = "Ἴνδαλμα θεοσεβείας, καὶ βίου ἀκραιφνεστάτου…"
meMA.Ode6C11.text = "Ἴνδαλμα θεοσεβείας, καὶ βίου ἀκραιφνεστάτου, φυτουργὸς ἁγνείας ἐγένου, Ἀγγέλων τε μίμημα θεσπέσιε, Ἠλιοὺ θεοφόρε."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode6C12.melody = he.h.m2_gr_GR_cog.heHE.AvyssosAmartimaton.name
meMA.Ode6C12.incipit = "Οἶστρός σε προφητοκτόνου, γυναίου ἐκδειματώσας…"
meMA.Ode6C12.text = "Οἶστρός σε προφητοκτόνου, γυναίου ἐκδειματώσας, τὸν δεσμεῖν καὶ λύειν λαχόντα, ὄμβρων ἐπίβλυσιν θεσπέσιε, Ἠλιοὺ φυγαδεύει."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode6C13.melody = he.h.m2_gr_GR_cog.heHE.AvyssosAmartimaton.name
meMA.Ode6C13.incipit = "Ὕψωσας γονυπετήσας, νοὸς μετάρσιον ὄμμα…"
meMA.Ode6C13.text = "Ὕψωσας γονυπετήσας, νοὸς μετάρσιον ὄμμα, διʼ ἱκετηρίας ἱερᾶς, λύσιν ποιούμενος, καὶ αὔλακας, γῆς ἐμέθυσας ὄμβρῳ."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode6C1T.melody = he.h.m2_gr_GR_cog.heHE.AvyssosAmartimaton.name
meMA.Ode6C1T.incipit = "Βάτος σε ἐν τῷ Σιναίῳ…"
meMA.Ode6C1T.text = "Βάτος σε ἐν τῷ Σιναίῳ, ἀφλέκτως προσομιλοῦσα, τῷ πυρὶ προγράφει Μητέρα, τὴν ἀειπάρθενον, ἀνύμφευτε Θεοτόκε Μαρία."

meMA.Ode6C21.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C21.greekmelody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.greekname
meMA.Ode6C21.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C21.incipit = "Ἱλάσθητί μοι Σωτήρ, πολλὰ σοι…"
meMA.Ode6C21.text = "Ἱλάσθητί μοι Σωτήρ, πολλά σοι ἀφρόνως πταίσαντι, καὶ τῆς μενούσης ἐκεῖ, κολάσεως λύτρωσαι, ἔχων δυσωποῦντά σε, Ἠλιοὺ τὸν μέγαν, καὶ τὴν ἄχραντον Μητέρα σου."

meMA.Ode6C22.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C22.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C22.incipit = "Ἁγνείας ὡς φυτουργός, ἁγνὸν ψυχῇ…"
meMA.Ode6C22.text = "Ἁγνείας ὡς φυτουργός, ἁγνὸν ψυχῇ με συντήρησον, ὡς ζηλωτὴς Ἠλιού, ζήλου θείου πλήρωσον, τὴν ἐμὴν διάνοιαν, ὅπως τῆς κακίας, τὰς ἐφόδους ἀποκρούσωμαι."

meMA.Ode6C23.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C23.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C23.incipit = "Νηστεύεις βρώσει μιᾷ, ὁδὸν τεσσαρακονθήμερον…"
meMA.Ode6C23.text = "Νηστεύεις βρώσει μιᾷ, ὁδὸν τεσσαρακονθήμερον, ἀνύων θείᾳ ῥοπῇ· διὸ ἱκετεύω σε, πάσης παραβάσεως, ἐγκρατεῦσθαί με, θεοφόρε ἐνδυνάμωσον."

meMA.Ode6C2T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C2T.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C2T.incipit = "Ἡ πύλη ἡ τοῦ Θεοῦ…"
meMA.Ode6C2T.text = "Ἡ πύλη ἡ τοῦ Θεοῦ, εἰσόδους θείας ὑπάνοιξον, τῇ ταπεινῇ μου ψυχῇ, ἐν αἷς εἰσελεύσομαι, ἐξομολογούμενος, καὶ κακῶν τὴν λύσιν, Θεοτόκε ἀπολήψομαι."

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Kontakion1.melody = "Αὐτόμελον."
meMA.Kontakion1.incipit = "Προφῆτα καὶ προόπτα τῶν μεγαλουργιῶν…"
meMA.Kontakion1.text = "Προφῆτα καὶ προόπτα τῶν μεγαλουργιῶν τοῦ Θεοῦ, Ἠλία μεγαλώνυμε, ὁ τῷ φθέγματί σου στήσας τὰ ὑδατόῤῥυτα νέφη, πρέσβευε ὑπὲρ ἡμῶν, πρὸς τὸν μόνον φιλάνθρωπον."

meMA.Oikos1.text = "Τὴν πολλὴν τῶν ἀνθρώπων ἀνομίαν, Θεοῦ δὲ τὴν ἄμετρον φιλανθρωπίαν, θεασάμενος ὁ Προφήτης Ἠλίας, ἐταράπτετο θυμούμενος, καὶ λόγους ἀσπλαγχνίας πρὸς τὸν εὔσπλαγχνον ἐκίνησεν. Ὀργίσθητι βοήσας, ἐπὶ τοὺς ἀθετήσαντάς σε, Κριτὰ δικαιότατε. Ἀλλὰ τὰ σπλάγχνα τοῦ ἀγαθοῦ, οὐδόλως παρεκίνησε πρὸς τὸ τιμωρήσασθαι τοὺς αὐτὸν ἀθετήσαντας· ἀεὶ γὰρ τὴν μετάνοιαν πάντων ἀναμένει, ὁ μόνος φιλάνθρωπος."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode7C11.greekmelody = he.h.m2_gr_GR_cog.heHE.VatosEnOrei.greekname
meMA.Ode7C11.melody = he.h.m2_gr_GR_cog.heHE.VatosEnOrei.name
meMA.Ode7C11.incipit = "Τὴν παραδόξως θεόθεν σοι, σχεδιασθεῖσαν…"
meMA.Ode7C11.text = "Τὴν παραδόξως θεόθεν σοι, σχεδιασθεῖσαν δύναμιν ἐνδεδυκώς, τροφῇ μιᾷ τεσσαρακονθήμερον, Ἠλιοὺ θεσπέσιε, τὴν δολιχὴν καταλέλυκας ὁδόν· διὸ ἐν Χωρὴβ χορεύων ἔψαλλες· Εὐλογητὸς ὁ Θεὸς ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode7C12.melody = he.h.m2_gr_GR_cog.heHE.VatosEnOrei.name
meMA.Ode7C12.incipit = "Αὔρα πραεῖα ὑπέδειξε, καὶ λεπτοτάτη…"
meMA.Ode7C12.text = "Αὔρα πραεῖα ὑπέδειξε, καὶ λεπτοτάτη Κύριον σοι Ἠλιού, Θεῷ ζηλοῦντι παντοκράτορι, οὐχὶ πνεῦμα βίαιον, οὐ συσσεισμός, οὐδὲ πῦρ ἐκδειματοῦν· διὸ Ἰησοῦ τῷ πράῳ ψάλλομεν· Εὐλογητὸς ὁ Θεὸς ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode7C13.melody = he.h.m2_gr_GR_cog.heHE.VatosEnOrei.name
meMA.Ode7C13.incipit = "Θεοφανείας ἠξίωσαι, καὶ προφητείας ὥσπερ…"
meMA.Ode7C13.text = "Θεοφανείας ἠξίωσαι, καὶ προφητείας ὥσπερ ὁ μέγας Μωσῆς, προφήτας χρίων διὰ Πνεύματος, Ἠλιοὺ θεσπέσιε καὶ βασιλεῖς, καὶ τῆς δόξης ἐν Θαβώρ, Χριστοῦ θεατής γενόμενος βοᾷς· Εὐλογητὸς ὁ Θεὸς ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode7C1T.melody = he.h.m2_gr_GR_cog.heHE.VatosEnOrei.name
meMA.Ode7C1T.incipit = "Μήτραν τὴν σὴν ὁ πανάγαθος…"
meMA.Ode7C1T.text = "Μήτραν τὴν σὴν ὁ πανάγαθος, Λόγος οἰκήσας Ἄχραντε ὑπερφυῶς, Θεοῦ Πατρός, ἡμᾶς ἀνέπλασε, καὶ ζωῆς ἠξίωσε τῆς ἐν Ἐδέμ· διὸ Θεοτόκον σε πάντες πιστοί, προσκυνοῦντες ἀναμέλπομεν· Εὐλογητὸς ὁ Θεὸς ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C21.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C21.greekmelody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.greekname
meMA.Ode7C21.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C21.incipit = "Λαὸν ἀπολλύμενον, κατοικτιρήσας, ζήλῳ τῆς…"
meMA.Ode7C21.text = "Λαὸν ἀπολλύμενον, κατοικτιρήσας, ζήλῳ τῆς πίστεως, ἐπικλήσεσι θείαις, πῦρ κατηγάγου φλογίζον Ἔνδοξε, ὅσιον θῦμα· διὸ ἱκετεύω σε· τῆς αἰωνίου φλογός, ῥῦσαι καὶ σῶσόν με."

meMA.Ode7C22.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C22.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C22.incipit = "Ἰδεῖν κατηξίωσαι, Θαβὼρ ἐν ὄρει…"
meMA.Ode7C22.text = "Ἰδεῖν κατηξίωσαι, Θαβὼρ ἐν ὄρει, Θεοῦ τὸ πρόσωπον, ὃν δυσώπει Προφῆτα, τοῦ παραβλέψαι τὰς ἁμαρτίας μου, καὶ ἐν ἡμέρᾳ τῆς δίκης θεάσασθαι, ἀκαταγνώστῳ ψυχῇ, αὐτοῦ τὸ πρόσωπον."

meMA.Ode7C23.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C23.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C23.incipit = "Ὁδὸν πορευόμενος, τοῦ βίου πλάνας…"
meMA.Ode7C23.text = "Ὁδὸν πορευόμενος, τοῦ βίου πλάνας πολλὰς ὑφίσταμαι, Ἀγαθέ μου προστάτα, κυβέρνησόν με τῇ προστασίᾳ σου, ἐπιστηρίζων γνώμῃ σαλευόμενον, καὶ πρὸς σαρκὸς ἡδονάς Ἠλιοὺ νεύοντα."

meMA.Ode7C2T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C2T.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C2T.incipit = "Ὑμνῶ σὲ Πανύμνητε, καὶ μεγαλύνω…"
meMA.Ode7C2T.text = "Ὑμνῶ σὲ Πανύμνητε, καὶ μεγαλύνω θεοχαρίτωτε, τὴν ἁγνήν σου λοχείαν, βοήθησόν μοι βίου τοῖς κύμασι, χειμαζομένῳ, καὶ δίδου κατάνυξιν, τῇ ταπεινῇ μου ψυχῇ, καθαρτικὴν μολυσμῶν."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode8C11.greekmelody = he.h.m2_gr_GR_cog.heHE.EfrixePaidonEvagon.greekname
meMA.Ode8C11.melody = he.h.m2_gr_GR_cog.heHE.EfrixePaidonEvagon.name
meMA.Ode8C11.incipit = "Ἄριστα εὗρεν Ἀχαάβ, τὴν τοῦ…"
meMA.Ode8C11.text = "Ἄριστα εὗρεν Ἀχαάβ, τὴν τοῦ γένους εὐπρεπῆ πανωλεθρίαν, Προφήτου ἐλεγμῷ, μιαιφόνου μύσους ἀντέκτισιν· ὁ Θεσβίτης δὲ ἐκ πυριπνόου φρενός, τῷ Ζωοδότῃ ὕμνον ἀνεμέλπετο· Τὸν Κύριον ὑμνεῖτε τὰ ἔργα, καὶ ὑπερυψοῦτε εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode8C12.melody = he.h.m2_gr_GR_cog.heHE.EfrixePaidonEvagon.name
meMA.Ode8C12.incipit = "Ὕει σοι πῦρ ἐξ οὐρανοῦ…"
meMA.Ode8C12.text = "Ὕει σοι πῦρ ἐξ οὐρανοῦ, καταφλέγον Ἠλιοὺ ἐπιθεμένους, πεντήκοντα δισσούς, ὡς Θεοῦ ἀρίστῳ θεράποντι· τῷ κρατοῦντι γάρ τῆς ἀειζώου ζωῆς, θεοπρεπῶς τὸν ὕμνον ἀνεκραύγαζες· Τὸν Κύριον ὑμνεῖτε τὰ ἔργα, καὶ ὑπερυψοῦτε εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode8C1T.melody = he.h.m2_gr_GR_cog.heHE.EfrixePaidonEvagon.name
meMA.Ode8C1T.incipit = "Μύστην σε ἔδειξε Χριστός, ὡς…"
meMA.Ode8C1T.text = "Μύστην σε ἔδειξε Χριστός, ὡς ἁγνείας φυτουργὸν ὁ τῆς Παρθένου, ὑπέρθεος βλαστός, ἐν Θαβὼρ τῆς θείας σαρκώσεως, τῆς Θεότητος τὸ ἀκατάληπτον φῶς, ἐν τῇ αὐτοῦ σαρκὶ δεικνύς σοι κράζοντι· Τὸν Κύριον ὑμνεῖτε τὰ ἔργα, καὶ ὑπερυψοῦτε εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C21.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
meMA.Ode8C21.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C21.incipit = "Χωρητικὸν δοχεῖόν σε, θείου Πνεύματος…"
meMA.Ode8C21.text = "Χωρητικὸν δοχεῖόν σε, θείου Πνεύματος ἔγνωμεν, ἄγγελον ἐν γῇ, πῦρ ζήλου θείου πνέοντα, δυσσέβειαν τρέποντα, καὶ βασιλεῖς ἐλέγχοντα, χρίοντα προφήτας, Ἠλιοὺ καὶ αἰσχύνης, συγκόπτοντα μαχαίρᾳ ἱερεῖς· διὰ τοῦτο, βοῶμέν σοι· Μελλούσης ἡμᾶς αἰσχύνης ῥῦσαι."

meMA.Ode8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C22.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C22.incipit = "Ἅρμα πυρός σε ἔλαβεν, ἀπὸ…"
meMA.Ode8C22.text = "Ἅρμα πυρός σε ἔλαβεν, ἀπὸ γῆς πυρακτούμενον, ζήλῳ Ἠλιού, τῷ θεϊκῷ θεόπνευστε· διὸ ἱκετεύω σε, τῶν ἐν τῇ γῇ με πάντων κακῶν τῶν σῶν ἀρετῶν, ἐπικουφίζειν τὸν νοῦν μου, τεθρίππῳ, καὶ πρὸς νύσσαν, οὐρανίαν με φθάσαι, τὸν πάντων ἐκδυσώπει, Θεὸν καὶ Βασιλέα."

meMA.Ode8C23.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C23.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C23.incipit = "Ῥήματι ζῶντι ἔκλεισας, οὐρανὸν ὑετίζοντα…"
meMA.Ode8C23.text = "Ῥήματι ζῶντι ἔκλεισας, οὐρανὸν ὑετίζοντα, ῥήματί σου νῦν, πνευματικῷ διάνοιξον, τὰς πύλας μοι δέομαι, τῆς μετανοίας Ἅγιε, πέμπων τῇ ψυχῇ μου, κατανύξεως ὄμβρους, καὶ σῶσόν με βοῶντα· Ἱερεῖς εὐλογεῖτε, λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

meMA.Ode8C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C2Tr.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C2Tr.incipit = "Ἰσοσθενῆ ὁμότιμον, ὁμοούσιον, σύνθρονον, σέβοντες…"
meMA.Ode8C2Tr.text = "Ἰσοσθενῆ ὁμότιμον, ὁμοούσιον, σύνθρονον, σέβοντες Τριάδα, ἐν μιᾷ Θεότητι, Πατέρα δοξάζομεν, Υἱὸν καὶ Πνεῦμα, Ἅγιον, ἄδυτον αὐγήν, ὁμοβασίλειον κράτος, καὶ μέλπομεν συμφώνως· Ἱερεῖς εὐλογεῖτε, λαὸς ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C2T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C2T.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C2T.incipit = "Νομοθετῶν εὐσέβειαν, καὶ διδάσκων μετάνοιαν…"
meMA.Ode8C2T.text = "Νομοθετῶν εὐσέβειαν, καὶ διδάσκων μετάνοιαν, ὁ Ἐμμανουήλ, ἐκ σοῦ τεχθεὶς ἐπέφανεν, ὃν νῦν ἐκδυσώπησον, ὑπεραγία Δέσποινα, τῆς δικαιοσύνης, ὑπανοῖξαί μοι πύλας, καὶ σῶσαί με βοῶντα· Ἱερεῖς εὐλογεῖτε, λαὸς ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode9C11.greekmelody = he.h.m2_gr_GR_cog.heHE.ITonProIliouFostira.greekname
meMA.Ode9C11.melody = he.h.m2_gr_GR_cog.heHE.ITonProIliouFostira.name
meMA.Ode9C11.incipit = "Ἄτρεπτον ἀνθρώποις πορείαν ἐπὶ γῆς…"
meMA.Ode9C11.text = "Ἄτρεπτον ἀνθρώποις πορείαν ἐπὶ γῆς πολιτευσάμενος, τῇ μηλωτῇ τὸν ῥοῦν τὸν Ἰορδάνιον, ὁ Θεσβίτης περαιωθείς, διφρηλάτης αἰθέριος, οὐρανοδρόμον ἤνυσε, ξένην πορείαν διὰ Πνεύματος."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode9C12.melody = he.h.m2_gr_GR_cog.heHE.ITonProIliouFostira.name
meMA.Ode9C12.incipit = "Τῆς θεοσεβείας τῷ ζήλῳ, ὁ…"
meMA.Ode9C12.text = "Τῆς θεοσεβείας τῷ ζήλῳ, ὁ Θεσβίτης πυρπολούμενος, ἐν πυριμόρφῳ ἅρματι ἐπαίρεται, μηλωτὴν δὲ ἐπιβαλών, ὃν λαθεῖν οὐ δεδύνηται, Ἐλισαιὲ δισσούμενον, καταλιμπάνει θείᾳ χάριτι."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode9C13.melody = he.h.m2_gr_GR_cog.heHE.ITonProIliouFostira.name
meMA.Ode9C13.incipit = "Ἀποδεδειγμένος θεόπτης, ὁ Θεσβίτης σὺν…"
meMA.Ode9C13.text = "Ἀποδεδειγμένος θεόπτης, ὁ Θεσβίτης σὺν Μωσῇ καθορᾷ, ἃ ὀφθαλμὸς οὐκ εἶδε, καὶ οὓς οὐκ ἤκουσε, καὶ ἀνθρώπων τῶν γηγενῶν, καρδία οὐ λελόγισται, σεσαρκωμένον Κύριον, ἐν τῷ Θαβὼρ τὸν παντοκράτορα."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Ode9C1T.melody = he.h.m2_gr_GR_cog.heHE.ITonProIliouFostira.name
meMA.Ode9C1T.incipit = "Τὴν τῆς ἀποτόμου ἀρχαίας, ἀναιρέτιν…"
meMA.Ode9C1T.text = "Τὴν τῆς ἀποτόμου ἀρχαίας, ἀναιρέτιν ἀποφάσεως, καὶ τῆς προμήτορος τὴν ἐπανόρθωσιν, τὴν τοῦ γένους τῆς πρὸς Θεὸν αἰτίαν οἰκειώσεως, τὴν πρὸς τὸν Κτίστην γέφυραν, σὲ Θεοτόκε μεγαλύνομεν."

meMA.Ode9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C21.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9C21.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C21.incipit = "Ἰδεῖν ἐν λεπτοτάτῃ αὔρᾳ Θεόν…"
meMA.Ode9C21.text = "Ἰδεῖν ἐν λεπτοτάτῃ αὔρᾳ Θεόν, ὡς ἰδεῖν δυνατὸν κατηξίωσαι, ἀσκητικαῖς, πρότερον τὸ σῶμα διαγωγαῖς, καταλεπτύνας Ἔνδοξε· ὅθεν δυσωπῶ σε σαῖς προσευχαῖς, τὸ πάχος τοῦ νοός μου, λεπτύνας μετανοίας, μαρμαρυγαῖς θείαις καταύγασον."

meMA.Ode9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C22.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C22.incipit = "Ὡς πάλαι Ἰορδάνην τῇ μηλωτῇ…"
meMA.Ode9C22.text = "Ὡς πάλαι Ἰορδάνην τῇ μηλωτῇ, διαῤῥήξας διέβης πανόλβιε· οὕτω κἀμοῦ, τῶν ἁμαρτημάτων τῶν χαλεπῶν, τὰς διεκχύσεις ξήρανον, ὄμβρους ἐπιπέμπων μου τῇ ψυχῇ, δακρύων καθʼ ἑκάστην, Προφῆτα θεηγόρε, τρυφῆς χειμάῤῥουν προξενοῦντάς μοι."

meMA.Ode9C23.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C23.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C23.incipit = "Σκανδάλων τῶν ἐν βίῳ πολυειδῶν…"
meMA.Ode9C23.text = "Σκανδάλων τῶν ἐν βίῳ πολυειδῶν, ἀνομούντων ἐχθρῶν πάσης θλίψεως, σωματικῆς, νόσου ψυχικῆς τε παρατροπῆς, ταῖς προσευχαῖς σου ῥῦσαί με, ἔνδοξε Προφῆτα ὡς ἀγαθός, προστάτης μου βοῶ σοι, καὶ τῆς ἐν τῇ γεέννῃ, αἰωνιζούσης κατακρίσεως."

meMA.Ode9C24.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C24.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C24.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C24.incipit = "Ἡρπάγης πρὸς τὸ ὕψος Ἐλισαιέ…"
meMA.Ode9C24.text = "Ἡρπάγης πρὸς τὸ ὕψος Ἐλισαιέ, δισσουμένην τὴν χάριν τοῦ Πνεύματος, καταλιπών, ἔνδοξε αἰτήσαντι Ἠλιού, μεθʼ οὗ ἀπαύστως αἴτησαι, νίκην οὐρανόθεν τῷ Βασιλεῖ, καὶ ἄφεσιν πταισμάτων, προστάτην σε πλουτοῦντι, πρὸς τὸν Δεσπότην ἀκαταίσχυντον."

meMA.Ode9C2T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C2T.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C2T.incipit = "Φωνὰς τῶν οἰκετῶν σου ὡς…"
meMA.Ode9C2T.text = "Φωνὰς τῶν οἰκετῶν σου ὡς ἀγαθή, μὴ παρίδῃς πανάμωμε Δέσποινα, ἀλλʼ ἐκτενῶς, αἴτησαι τὸν πάντων Δημιουργόν, τῷ Βασιλεῖ τὰ τρόπαια, καὶ τὴν εὐρωστίαν τὴν ψυχικήν, δωρήσασθαι Παρθένε, καὶ θείας βασιλείας, τὴν μετουσίαν καὶ λαμπρότητα."

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.greekname
meMA.Exaposteilarion1.melody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.name
meMA.Exaposteilarion1.incipit = "Φῶς ἐν πυρίνῳ τεθρίππῳ, οὐρανοδρόμον…"
meMA.Exaposteilarion1.text = "Φῶς ἐν πυρίνῳ τεθρίππῳ, οὐρανοδρόμον σε δεῖξαν, ἁρματηλάτην Ἠλία, οὐ κατηνάλωσεν ὅλως· πῦρ γὰρ ἐν γλώσσῃ πηλίνῃ, εἵλκυσας κάτω, καὶ ἀνεξήρανας ὄμβρους."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.ExapTheotokion.melody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.name
meMA.ExapTheotokion.incipit = "Φῶς ἡ τεκοῦσα Παρθένε, δυσώπησον…"
meMA.ExapTheotokion.text = "Φῶς ἡ τεκοῦσα Παρθένε, δυσώπησον σαῖς πρεσβείαις, τὸν σὸν Υἱὸν Θεοτόκε, τοῦ οἰκτιρῆσαι καὶ σῶσαι, τοῦ αἰωνίου με σκότους, τὸν πεποιθότα, τῇ σῇ σεπτῇ ἀντιλήψει."

meMA.Lauds1.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Lauds1.greekmelody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.greekname
meMA.Lauds1.melody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.name
meMA.Lauds1.incipit = "Ὅτε σὺ Προφῆτα θεσπέσιε, τῷ…"
meMA.Lauds1.text = "Ὅτε σὺ Προφῆτα θεσπέσιε, τῷ Θεῷ διʼ ἀρετῆς, καὶ πολιτείας ἀκραιφνοῦς, συνεκράθης παρʼ αὐτοῦ, τὴν ἐξουσίαν εἰληφώς, τὴν κτίσιν, κατὰ γνώμην μετεῤῥύθμισας, καὶ πύλας, ὑετοῦ θέλων ἀπέκλεισας, καὶ ἄνωθεν πῦρ κατήγαγες, καὶ δυσσεβεῖς κατηνάλωσας, ἱκέτευε, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν."

meMA.Lauds2.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Lauds2.melody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.name
meMA.Lauds2.incipit = "Ζήλῳ τοῦ Κυρίου πυρούμενος, παρανόμους…"
meMA.Lauds2.text = "Ζήλῳ τοῦ Κυρίου πυρούμενος, παρανόμους βασιλεῖς σὺ διεξήλεγξας σφοδρῶς, τῆς αἰσχύνης ἱερεῖς, σὺ ἐθανάτωσας θερμῶς· ἀνῆψας, πῦρ ἐν ὕδατι παράδοξον, τροφήν δέ, ἀγεώργητον ἐπήγασας, καὶ νάματα Ἰορδάνια, τῇ μηλωτῇ σου διέτεμες· Ἱκέτευε, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν."

meMA.Lauds3.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Lauds3.melody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.name
meMA.Lauds3.incipit = "Ὅτε σὺ Προφῆτα κατέδειξας, ἐπὶ…"
meMA.Lauds3.text = "Ὅτε σὺ Προφῆτα κατέδειξας, ἐπὶ γῆς ὡς ἀληθῶς, τὴν ἐπουράνιον ζωήν, τὴν ζωὴν ἐν σεαυτῷ, τὴν ἐνυπόστατον πλουτῶν, θανόντα, σοῖς φυσήμασιν ἀνέστησας, θανάτου, κρείττων ἔτι σὺ διέμεινας, ἅρμα πυρὸς ἐπιβέβηκας, αἰθέριος ἀνυψούμενος, ἱκέτευε, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν."

meMA.LaudsGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.LaudsGlory.melody = ""
meMA.LaudsGlory.incipit = "Τῶν Προφητῶν τοὺς ἀκραίμονας…"
meMA.LaudsGlory.text = "Τῶν Προφητῶν τοὺς ἀκραίμονας, καὶ παμφαεῖς φωστῆρας τῆς οἰκουμένης, ἐν ὕμνοις τιμήσωμεν πιστοί, Ἠλίαν καὶ Ἐλισσαῖον, καὶ Χριστῷ ἐκβοήσωμεν χαρμονικῶς. Εὔσπλαγχνε Κύριε, παράσχου τῷ λαῷ σου, ἱκεσίαις τῶν Προφητῶν σου, ἄφεσιν ἁμαρτιῶν, καὶ τὸ μέγα ἔλεος."

meMA.LaudsTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.LaudsTheotokion.melody = ""
meMA.LaudsTheotokion.incipit = oc.m8.d5_gr_GR_cog.ocMA.AposTheotokion.incipit
meMA.LaudsTheotokion.text = oc.m8.d5_gr_GR_cog.ocMA.AposTheotokion.text

meMA.MM.Lauds1123as5678.text = properties_gr_GR_cog.media.key

meLI.MM.Beatitudes.Ode3C1as5678.text = properties_gr_GR_cog.media.key
meLI.MM.Beatitudes.Ode6C2as910GB.text = properties_gr_GR_cog.media.key

meLI.Kontakion1.mode = me.m07.d20_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.melody = me.m07.d20_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m07.d20_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m07.d20_gr_GR_cog.meMA.Kontakion1.text

meLI.MM.CommunionHymn.text = properties_gr_GR_cog.media.key

meLI.Megalynarion.text = "Ζήλῳ οὐρανίῳ πυρποληθείς, φλέγεις τὴν ἀπάτην, ὡς πυρίπνους καὶ ζηλωτής· ὅθεν ἀνυψώθης ἐν ἅρματι πυρίνῳ, ὦ Ἠλιοὺ Προφῆτα, πρὸς βίον ἄφθαρτον."

//supplemental hymns

alt1.meVE.Stichera04.poet = poets_gr_GR_cog.po.NikodimouAgioreitou
alt1.meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode1
alt1.meVE.Stichera04.greekmelody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.greekname
alt1.meVE.Stichera04.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
alt1.meVE.Stichera04.incipit = "Ἐν τῷ Χωρὴβ μὲν τοπρώην…"
alt1.meVE.Stichera04.text = "Ἐν τῷ Χωρὴβ μὲν τοπρώην, ἐν Θαβὼρ δʼ ὕστερον, τὴν τοῦ Θεοῦ κατεῖδες, θεωρίαν Προφῆτα· ἐκεῖ μὲν ἐν τῇ αὔρᾳ· ἐνταῦθα δέ, ἐν φωτὶ τῆς Θεότητος· καὶ ἐδοξάσθης δισσῶς ἐν τῇ Παλαιᾷ, Ἠλιοὺ κιὰ Νέᾳ χάριτι."

alt1.meVE.Stichera05.poet = poets_gr_GR_cog.po.NikodimouAgioreitou
alt1.meVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meVE.Stichera05.greekmelody = he.a.m2_gr_GR_cog.heAU.PoioisEffimionStemmasin.greekname
alt1.meVE.Stichera05.melody = he.a.m2_gr_GR_cog.heAU.PoioisEffimionStemmasin.name
alt1.meVE.Stichera05.incipit = "Ποίοις ὑμνῳδιῶν κάλλεσιν, ἀναδήσωμεν τὸν…"
alt1.meVE.Stichera05.text = "Ποίοις ὑμνῳδιῶν κάλλεσιν, ἀναδήσωμεν τὸν διφρηλάτην; τὸν Οὐρανοδρόμον Ἱέρακα; Ἠλιοὺ τὸν πῦρ ὅλως πνέοντα; τὸν πυρίνου ἅρματος ἱππέα; τὸν ῥεῖθρα, τοῦ Ἰορδάνου διαῤῥήξαντα; καὶ ὄμβρους, τοῦ οὐρανοῦ λόγῳ πεδήσαντα; τὸν ἐν πυρὶ θυηφόρον; τὸν Χριστῷ λαλοῦντα; τὸν καὶ Πρόδρομον τῆς αὐτοῦ, δευτέρας ἐλεύσεως; τὸν φωστῆρα τὸν φαεινότατον;"

alt1.meVE.Stichera06.poet = poets_gr_GR_cog.po.NikodimouAgioreitou
alt1.meVE.Stichera06.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meVE.Stichera06.melody = he.a.m2_gr_GR_cog.heAU.PoioisEffimionStemmasin.name
alt1.meVE.Stichera06.incipit = "Ποίοις εὐφημιῶν ᾄσμασι, τὸν Θεσβίτην…"
alt1.meVE.Stichera06.text = "Ποίοις εὐφημιῶν ᾄσμασι, τὸν Θεσβίτην ἀνυμνήσωμεν Ἠλίαν; τὸν ζήλῳ Θεοῦ πυρπολούμενον; καὶ τοὺς ἀσεβεῖς πυρπολήσαντα; τὸν τοὺς μύστας σφάξαντα τῆς Βάαλ; τὸν μύστην, ἧς προεώρακε τῷ Πνεύματι, ἐν αὔρα, λεπτῇ Χριστοῦ θείας σαρκώσεως; τὸν ξενοτρόφον τῆς χήρας; τοῦ πυρὸς τὸν στύλον; τὸν πνέοντα τοῖς νεκροῖς, ζωὴν θείᾳ χάριτι; τὸ τοῦ Πνεύματος ἐνδιαίτημα;"

alt1.meVE.Stichera07.poet = poets_gr_GR_cog.po.NikodimouAgioreitou
alt1.meVE.Stichera07.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meVE.Stichera07.melody = he.a.m2_gr_GR_cog.heAU.PoioisEffimionStemmasin.name
alt1.meVE.Stichera07.incipit = "Ποίοις πνευματικοῖς ἄνθεσι, τὸ τοῦ…"
alt1.meVE.Stichera07.text = "Ποίοις πνευματικοῖς ἄνθεσι, τὸ τοῦ Πνεύματος στέψωμεν σκεῦος; τὸν φλογὶ πυρὸς σιτιζόμενον, καὶ τὸ πυρὶ σπαργανούμενον; τὸ μιᾶς τροφῆς ἐν τῇ ἰσχύϊ, ὁδόν, τεσσαρακονθήμερον ἀνύσαντα; τροφήν, τὸν διὰ τοῦ κόρακος δεχόμενον; τῶν Προφητῶν τὴν κρηπίδα; Ἠλιοὺ τὸν μέγαν, διʼ οὗ δαιμόνων ὀφρῦν, καθεῖλεν ὁ Κύριος; ὁ ἔχων τὸ μέγα ἔλεος."

alt1.meVE.Stichera08.poet = poets_gr_GR_cog.po.NikodimouAgioreitou
alt1.meVE.Stichera08.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meVE.Stichera08.melody = he.a.m2_gr_GR_cog.heAU.PoioisEffimionStemmasin.name
alt1.meVE.Stichera08.incipit = "Πάντες οἱ εὐτελεῖς δοῦλοί σου…"
alt1.meVE.Stichera08.text = "Πάντες οἱ εὐτελεῖς δοῦλοί σου, σοὶ προσπίπτομεν Θεοῦ Προφῆτα, δώρησαι ἡμῖν ἀνακράζονες, χάριν τὴν τοῦ Πνεύματος ἔνδοξε, ὥπερ Ἐλισσαίῳ ἐδωρήσω, διπλῆν, ταύτην μάκαρ ἐξαιτήσαντι· καὶ δός, εὑρεῖν λύσιν ταῖς πρεσβείαις σου, ὀφλημάτων πάντων, ὅτε Πρόδρομος τοῦ Χριστοῦ, δευτέρας ἐλεύσεως, Ἠλιοὺ ἥξεις θεώνυμε."

alt1.meMA.Kathisma22.poet = poets_gr_GR_cog.po.NikodimouAgioreitou
alt1.meMA.Kathisma22.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Kathisma22.greekmelody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.greekname
alt1.meMA.Kathisma22.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
alt1.meMA.Kathisma22.incipit = "Τεσσαρακονθήμερον, ὁδὸν ἀνύεις, μιᾷ βρώσει…"
alt1.meMA.Kathisma22.text = "Τεσσαρακονθήμερον, ὁδὸν ἀνύεις, μιᾷ βρώσει ἔνδοξε, ῥωσθεὶς Ἀγγέλου τῇ ἁφῇ· διὸ τοῖς πίστει τιμῶσί σε, ῥῶσιν παράσχου, ψυχῆς τε καὶ σώματος."

alt1.meMA.Kathisma2T.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Kathisma2T.greekmelody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.greekname
alt1.meMA.Kathisma2T.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
alt1.meMA.Kathisma2T.incipit = me.m06.d14_gr_GR_cog.meMA.Ode3KathismaT.incipit
alt1.meMA.Kathisma2T.text = me.m06.d14_gr_GR_cog.meMA.Ode3KathismaT.text

alt1.meMA.Kathisma31.poet = poets_gr_GR_cog.po.NikodimouAgioreitou
alt1.meMA.Kathisma31.mode = miscellanea_gr_GR_cog.misc.Mode8
alt1.meMA.Kathisma31.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
alt1.meMA.Kathisma31.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
alt1.meMA.Kathisma31.incipit = "Ἠλιοὺ τὸν πυρίπνουν καὶ ζηλωτήν…"
alt1.meMA.Kathisma31.text = "Ἠλιοὺ τὸν πυρίπνουν καὶ ζηλωτήν, τὸν θεόπτην καὶ Πρόδρομον τοῦ Χριστοῦ, δευτέρας ἐλεύσεως, καὶ τῆς πρώτης συνόμιλον· τὸν διʼ ὀρνέου ἕωθεν καὶ δείλης τρεφόμενον· καὶ ξενοτρόπῳ βρώσει τὴν χήραν ἐκτρέφοντα, καὶ τὸν ταύτης παῖδα ἐκ νεκρῶν ἀνιστῶντα· τὸν θῦμα καὶ σχίδακας, πυρὶ θείῳ ἀμπρήσαντα, ἐν ᾠδαῖς εὐφημήσωμεν, κραυγάζοντες αὐτῷ ἐκ ψυχῆς· Τῶν πταισμάτων δωρηθῆναι ἄφεσιν, ἡμῖν πρεσβεύοις Προφῆτα, τοῖς πόθῳ τιμῶσί σε."

alt1.meMA.Kathisma32.poet = poets_gr_GR_cog.po.NikodimouAgioreitou
alt1.meMA.Kathisma32.mode = miscellanea_gr_GR_cog.misc.Mode3
alt1.meMA.Kathisma32.greekmelody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.greekname
alt1.meMA.Kathisma32.melody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.name
alt1.meMA.Kathisma32.incipit = "Τὰ Ἰορδάνεια, διῆλθες ὕδατα…"
alt1.meMA.Kathisma32.text = "Τὰ Ἰορδάνεια, διῆλθες ὕδατα, Ἠλία πρότερον, καὶ τότε ἅρματι, ἀνῆλθες ὡς εἰς οὐρανόν, ἐμφαίνων τι μυστήριον· ὅτι οὐδεὶς δύναται, ἀνελθεῖν εἰς οὐράνια, ἐκτὸς εἰμὴ πρότερον, μετανοίας τὰ ὕδατα, διέλθῃ καὶ ψυχὴν ἐκκαθάρῃ· ἧς σύμβολον ὁ Ἰορδάνης."

alt1.meMA.Kathisma3T.poet = poets_gr_GR_cog.po.NikodimouAgioreitou
alt1.meMA.Kathisma3T.mode = miscellanea_gr_GR_cog.misc.Mode3
alt1.meMA.Kathisma3T.greekmelody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.greekname
alt1.meMA.Kathisma3T.melody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.name
alt1.meMA.Kathisma3T.incipit = "Κατατιτρώσκει με, βέλος γλυκύτατον, τῆς…"
alt1.meMA.Kathisma3T.text = "Κατατιτρώσκει με, βέλος γλυκύτατον, τῆς ἀγαπήσεως, τῆς σῆς Πανύμνητε· καὶ καταθέλγει με πυκνῶς, βοᾶν σοι εὐλογημένη· Χαῖρε ἡλιόμορφον, Βασιλέως παλάτιον! Χαῖρε θρόνε πύρινε, ἡ Θεὸν ἀναδείξασα, ἄνθρωπον φύσει τῷ τεκετῷ σου, ἀνθρώπους δὲ θεοὺς κατὰ χάριν!"

//Not in Menaion, optional Matins Gospel

alt1.meMA.PostGospelGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
