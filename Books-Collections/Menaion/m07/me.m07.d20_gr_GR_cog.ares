alt1.meMA.PostGospelGlory.text = ho.ho03_gr_GR_cog.hoMA.PostGospelProphet.text

alt1.meMA.PostGospelBoth.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meMA.PostGospelBoth.melody = ""
alt1.meMA.PostGospelBoth.incipit = ho.ho03_gr_GR_cog.hoMA.PostGospelTheotokos.incipit
alt1.meMA.PostGospelBoth.text = ho.ho03_gr_GR_cog.hoMA.PostGospelTheotokos.text

alt1.meMA.PostGospelIdiomelon.poet = poets_gr_GR_cog.po.NikodimouAgioreitou
alt1.meMA.PostGospelIdiomelon.mode = miscellanea_gr_GR_cog.misc.Mode6
alt1.meMA.PostGospelIdiomelon.melody = ""
alt1.meMA.PostGospelIdiomelon.incipit = "Τοῦ θείου ζήλου τὸ πῦρ…"
alt1.meMA.PostGospelIdiomelon.text = "Τοῦ θείου ζήλου τὸ πῦρ, ἐν σῇ καρδίᾳ δεξάμενος, Ἠλία θεώνυμε, ὅλον τῆς ζωῆς σου τὸν δίαυλον, ἐν πυρὶ διετέλεσας· ἐν γὰρ τῇ γεννήσει σου μάκαρ, παρὰ Ἀγγέλων πῦρ ἐσιτίσθης, ἐν δὲ τῇ ζωῇ σου, τρισσάκις ἐξ οὐρανοῦ πῦρ κατήνεγκας, καὶ ἐν τῷ τέλει σου, ἅρμα πυρὸς ἐξαρπάσαν, ὡς εἰς οὐρανὸν ἀνεβίβασεν. Ὢ τοῦ θαύματος! Πῶς ὁ πύλινος ἀνδριάς, χαλκευθεὶς ἐν τῇ δυνάμει του Πνεύματος, πύρινος ὅλος ἐγένετο! Καὶ νῦν τῷ ἀΰλῳ πυρὶ τῆς Θεότητος ἡνωμένος, πρεσβεύει ὑπὲρ τῶν ψυχῶν ἡμῶν."

alt1.meLI.Megalynarion.poet = poets_gr_GR_cog.po.NikodimouAgioreitou
alt1.meLI.Megalynarion.text = "Δεῦτε τὸν πυρίπνουν καὶ ζηλωτήν, τὸν διὰ τεθρίππου, ἁρπαγέντα ἀπὸ τῆς γῆς, τῆς Χριστοῦ δευτέρας, Πρόδρομον παρουσίας, Ἠλίαν τὸν Θεσβίτην, ὕμνοις τιμήσωμεν."
