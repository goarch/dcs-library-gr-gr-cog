meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera01.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
meVE.Stichera01.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.Stichera01.incipit = "Μάρτυς θεόφρον Καλλίνικε…"
meVE.Stichera01.text = "Μάρτυς θεόφρον Καλλίνικε, ὑπὲρ τὸ ζῆν τὸ θανεῖν, εὐσεβῶς προελόμενος, τοῦ Χριστοῦ τὸν θάνατον, ἀληθῶς ἐξεικόνισας· ἀθανασίας ὅθεν ἐπέτυχες, καὶ ἀνεσπέρου μακαριότητος, ἔνθα τὰ τάγματα, τῶν Ἀγγέλων πέφυκε, καὶ ἀθλητῶν, πάντων ἀγαλλόμενος, σκηνώσας ἔνδοξε."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera02.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.Stichera02.incipit = "Μάρτυς παμμάκαρ…"
meVE.Stichera02.text = "Μάρτυς παμμάκαρ Καλλίνικε, πρὸς ἀοράτους ἐχθρούς, τὸν ἀόρατον Κύριον, συμμαχίαν ἄμαχον, κεκτημένος ἀνέστησας, ἀθανασίας μεγάλα τρόπαια, τὸν ἐξαλείφειν γῆν τε καὶ θάλασσαν, κατακαυχώμενον, τῇ πυγμῇ τῶν ἄθλων σου, καταβαλών, καὶ τῇ τῶν αἱμάτων σου, καταποντίσας ῥοῇ."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera03.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.Stichera03.incipit = "Τὸν τῆς εὐσεβείας…"
meVE.Stichera03.text = "Τὸν τῆς εὐσεβείας πρόμαχον, καὶ καθαιρέτην ἐχθροῦ, καὶ Μαρτύρων συνόμιλον, καὶ ναὸν τοῦ Πνεύματος, τοῦ Ἁγίου γενόμενον, τὸν στρατιώτην τοῦ Βασιλέως Χριστοῦ, τῶν ἰαμάτων τὸ ἀδαπάνητον, ὄντως θησαύρισμα, τῶν πιστῶν τὸ στήριγμα, τὸν θαυμαστόν, σήμερον Καλλίνικον, ὕμνοις τιμήσωμεν."

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera04.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera04.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera04.incipit = "Ὡς παρθένον καὶ Μάρτυρα…"
meVE.Stichera04.text = "Ὡς παρθένον καὶ Μάρτυρα, ὡς Θεοῦ νύμφην ἄφθορον, ὡς τῷ θείῳ Πνεύματι διαλάμπουσαν, ὡς τὸν Χριστὸν ἀγαπήσασαν, ἐχθρὸν δὲ αἰσχύνασαν, ὡς ἀθλήσασαν στεῤῥῶς, καὶ πολύπλοκα βάσανα, ὑπομείνασαν, εὐφημοῦμέν σε πίστει Θεοδότη, καὶ τὴν μνήμην σου τελοῦμεν, τὴν φωταυγῆ καὶ σωτήριον."

meVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera05.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera05.incipit = "Νυμφευθεῖσα ἐν Πνεύματι…"
meVE.Stichera05.text = "Νυμφευθεῖσα ἐν Πνεύματι, τῷ Χριστῷ διὰ πίστεως, ὥσπερ προῖκα πάνσεμνε προσενήνοχας, τῶν σῶν μελῶν τὴν κατάφλεξιν, τοὺς πόνους τὴν ἄθλησιν, τοὺς ἀπείρους αἰκισμούς, τὴν τοῦ αἵματος πρόσχυσιν, καὶ πρὸς θάλαμον, εἰσῳκίσθης τὸν θεῖον στεφηφόρος, Θεοδότη ὑπὲρ πάντων, τῶν σὲ τιμώντων πρεσβεύουσα."

meVE.Stichera06.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera06.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera06.incipit = "Ὡς γενναῖον ἀδάμαντα…"
meVE.Stichera06.text = "Ὡς γενναῖον ἀδάμαντα, ὡς θεόφρονα Μάρτυρα, ὡς τὴν πλάνην λύσασαν τοῦ ἀλάστορος, καὶ τὸν τῆς Εὔας πολέμιον, γενναίῳ φρονήματι, συμπατήσασαν εἰς γῆν, εὐφημοῦμέν σε ἔνδοξε, καὶ χωρήσασαν, Παραδείσου πρὸς πλάτος Θεοδότη, θεωθεῖσαν καὶ τυχοῦσαν, ἐπιτηδείου μεθέξεως."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticTheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.SticTheotokion.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.SticTheotokion.incipit = "Φωτοφόρον παλάτιον, τοῦ Θεοῦ χαῖρε…"
meVE.SticTheotokion.text = "Φωτοφόρον παλάτιον, τοῦ Θεοῦ χαῖρε Δέσποινα· καὶ Ἀγγέλων χαῖρε τὸ ἀγαλλίαμα. Χαῖρε Ἀδὰμ ἡ ἀνάκλησις, καὶ Εὔας ἡ λύτρωσις. Χαῖρε κλῖμαξ νοητή, τοὺς θνητούς ἡ μετάγουσα, πρὸς οὐράνιον, καὶ ἀκήρατον δόξαν. Χαῖρε κράτος, ὀρθοδόξων βασιλέων, καὶ ἀῤῥαγὲς φυλακτήριον."

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticStavrotheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.SticStavrotheotokion.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.SticStavrotheotokion.incipit = me.m02.d11_gr_GR_cog.meVE.AposStavrotheotokion.incipit
meVE.SticStavrotheotokion.text = me.m02.d11_gr_GR_cog.meVE.AposStavrotheotokion.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.Apolytikion1ger.greekmelody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.greekname
meVE.Apolytikion1ger.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meVE.Apolytikion1ger.incipit = "Κλῆσιν σύνδρομον…"
meVE.Apolytikion1ger.text = "Κλῆσιν σύνδρομον, ἔχων τῷ βίῳ, νῖκος κάλλιστον, ἧρας ἐν ἄθλοις, καταλλήλως γεγονὼς ὃ προκέκλησαι· σὺ γὰρ καλῶς τὸν ἀγῶνα τελέσας σου, ὡς νικητὴς ἐδοξάσθης Καλλίνικε. Μάρτυς ἔνδοξε, Χριστὸν τὸν Θεὸν ἱκέτευε, δωρήσασθαι ἡμῖν τὸ μέγα ἔλεος."

meVE.Apolytikion2ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion2ger.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Apolytikion2ger.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meVE.Apolytikion2ger.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meVE.Apolytikion2ger.incipit = "Ὡς δῶρον ἐκλεκτόν…"
meVE.Apolytikion2ger.text = "Ὡς δῶρον ἐκλεκτόν, Θεοδότη θεόφρον, προσήγαγες Θεῷ, τοὺς ἐνθέους βλαστούς σου· σὺν τούτοις γὰρ ἠγώνισαι, ἱερῶς ἐναθλήσασα, μεθʼ ὧν πρέσβευε, ὑπὲρ ἡμῶν τῷ Κυρίῳ, δοῦναι ἄφεσιν, ἁμαρτιῶν ἡμῖν πᾶσι, καὶ βίου διόρθωσιν."

meMA.C1.acrostic.title = "Κανὼν τοῦ Ἁγίου Καλλινίκου,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Ἀθλητὰ Καλλίνικε, τὴν ᾠδὴν δέχου εὐμενῶς."
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaintM
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.C2.acrostic.title = "Κανὼν τῆς Ἁγίας Θεοδότης,"
meMA.C2.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C2.acrostic.text = "Τὴν πρὸς Θεόν μοι, Μάρτυς, ἴθυνον τρίβον."
meMA.C2.title = titles_gr_GR_cog.ti.CanonSaintW
meMA.C2.verse = prayers_gr_GR_cog.pr.verse_SaintW.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ArmataFarao.greekname
meMA.Ode1C11.melody = he.h.m4_gr_GR_cog.heHE.ArmataFarao.name
meMA.Ode1C11.incipit = "Ἅρματι νοητῷ, ἐπιβὰς ὡς ἀληθῶς…"
meMA.Ode1C11.text = "Ἅρματι νοητῷ, ἐπιβὰς ὡς ἀληθῶς, τριστάτας ἐπόντισας, τοῦ νοητοῦ Αἰγυπτίου, ἐν τῇ τῶν αἱμάτων σου ἐρυθρᾷ, Μαρτύρων κλέος Καλλίνικε."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C12.melody = he.h.m4_gr_GR_cog.heHE.ArmataFarao.name
meMA.Ode1C12.incipit = "Θείαν περιβολήν, ἐνδυσάμενος, Σοφέ, στολὴν…"
meMA.Ode1C12.text = "Θείαν περιβολήν, ἐνδυσάμενος, Σοφέ, στολὴν τὴν ἐπίγειον, ἀπεξεδύσω παμμάκαρ, καὶ πρὸς τὸν ἀγῶνα ὥρμησας, καὶ τὸν ἐχθρὸν ἐθριάμβευσας."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C13.melody = he.h.m4_gr_GR_cog.heHE.ArmataFarao.name
meMA.Ode1C13.incipit = "Λύσας τὰς τοῦ ἐχθροῦ, πολυπλόκους…"
meMA.Ode1C13.text = "Λύσας τὰς τοῦ ἐχθροῦ, πολυπλόκους μηχανάς, δεσμεῖς ἐν τοῖς ἄθλοις σου, καὶ ἀνενέργητον τοῦτον, ἔῤῥιψας εἰς γῆν Καλλίνικε, καὶ τοῖς ποσί σου συνέτριψας."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C1T.melody = he.h.m4_gr_GR_cog.heHE.ArmataFarao.name
meMA.Ode1C1T.incipit = "Ἥνπερ τῶν Προφητῶν, προεώρακε χορός…"
meMA.Ode1C1T.text = "Ἥνπερ τῶν Προφητῶν, προεώρακε χορός, ὡς πύλην οὐράνιον, καὶ βάτον ἀκατάφλεκτον, σὲ Παρθενομῆτορ ἄχραντε, Θεὸν τεκοῦσαν ἐπέγνωμεν."

meMA.Ode1C21.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C21.greekmelody = he.h.m4_gr_GR_cog.heHE.ThalassisToErythraion.greekname
meMA.Ode1C21.melody = he.h.m4_gr_GR_cog.heHE.ThalassisToErythraion.name
meMA.Ode1C21.incipit = "Τῆς θείας, φωτοδοσίας χάριτι, καταλαμπρύνεσθαι…"
meMA.Ode1C21.text = "Τῆς θείας, φωτοδοσίας χάριτι, καταλαμπρύνεσθαι, τοὺς ὑμνητάς σου μάρτυς τοῦ Χριστοῦ, Θεοδότη δυσώπησον, μαρτυρικῇ λαμπρότητι, καὶ παρθενίᾳ διαλάμπουσα."

meMA.Ode1C22.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C22.melody = he.h.m4_gr_GR_cog.heHE.ThalassisToErythraion.name
meMA.Ode1C22.incipit = "Ἡ θείῳ, δυναμωθεῖσα Πνεύματι, καὶ…"
meMA.Ode1C22.text = "Ἡ θείῳ, δυναμωθεῖσα Πνεύματι, καὶ καταισχύνασα, τῶν πονηρῶν πνευμάτων τὴν πληθύν, Θεοδότη πανεύφημε, πνευματικαῖς φαιδρότησι, τοὺς σὲ ὑμνοῦντας καταφαίδρυνον."

meMA.Ode1C23.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C23.melody = he.h.m4_gr_GR_cog.heHE.ThalassisToErythraion.name
meMA.Ode1C23.incipit = "Νομίμως, πρὸς τοὺς ἀγῶνας ἔνδοξε…"
meMA.Ode1C23.text = "Νομίμως, πρὸς τοὺς ἀγῶνας ἔνδοξε, Μάρτυς ἐχώρησας, τῶν θεοπνεύστων λόγων διδαχαῖς, κοσμουμένη λαμπρότατα, καὶ τὰς βουλὰς ἐμώρανας, τῶν ἀσεβούντων παναοίδιμε."

meMA.Ode1C2T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C2T.melody = he.h.m4_gr_GR_cog.heHE.ThalassisToErythraion.name
meMA.Ode1C2T.incipit = "Παρθένος, τῷ Βασιλεῖ παρίστασθαι, σὺ…"
meMA.Ode1C2T.text = "Παρθένος, τῷ Βασιλεῖ παρίστασθαι, σὺ ἀπηνέχθης Χριστῷ, τῆς ἐκλεκτῆς ὀπίσω καὶ σεπτῆς, ὑπὲρ νοῦν Θεομήτορος, καὶ ἱερὸν ἀνάθημα, ἐπουρανίου ναοῦ γέγονας."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.greekname
meMA.Ode3C11.melody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.name
meMA.Ode3C11.incipit = "Τῇ τοῦ Χριστοῦ ἀγάπῃ τετρωμένος…"
meMA.Ode3C11.text = "Τῇ τοῦ Χριστοῦ ἀγάπῃ τετρωμένος, ὁ Μάρτυς ἀνέκραζεν, ἐν τοῖς ἀγῶσιν ἐγκαρτερῶν· Εἰς ὀσμὴν δραμοῦμαι μύρων, ἀκολουθῶν τῷ Πάθει σου, τῇ ἀθλήσει τῇ διʼ αἵματος."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C12.melody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.name
meMA.Ode3C12.incipit = "Ἀνεπιβούλευτος διετηρήθης, ἐκ τῶν βελῶν…"
meMA.Ode3C12.text = "Ἀνεπιβούλευτος διετηρήθης, ἐκ τῶν βελῶν τοῦ ὄφεως· τὴν σὴν γὰρ πτέρναν ὁ σοφιστής, ἐν τοῖς ἥλοις διατρήσας, τὴν κεφαλὴν συντρίβεται, Καλλίνικε τοῖς ἄθλοις σου."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C13.melody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.name
meMA.Ode3C13.incipit = "Κατατεμὼν τῆς πλάνης τὰς ἀκάνθας…"
meMA.Ode3C13.text = "Κατατεμὼν τῆς πλάνης τὰς ἀκάνθας, μαχαίρᾳ τῇ τοῦ Πνεύματος, τὴν τοῦ Χριστοῦ πίστιν ἀπλανῶς, ἐγεώργησας Παμμάκαρ, εἰς ἑκατὸν τοὺς πόνους, προσάξας τῷ Δεσπότῃ σου."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C1T.melody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.name
meMA.Ode3C1T.incipit = "Ἀνερμηνεύτου τόκου καὶ λοχείας, σὺ…"
meMA.Ode3C1T.text = "Ἀνερμηνεύτου τόκου καὶ λοχείας, σὺ μόνη μήτηρ γέγονας, ἐν τῇ νηδύϊ σου τὸν πρὸ σοῦ, συλλαβοῦσα Θεὸν Λόγον, καὶ γαλουχοῦσα Παρθένος, ὡς βρέφος τὸν προάναρχον."

meMA.Ode3C21.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C21.greekmelody = he.h.m4_gr_GR_cog.heHE.EffrainetaiEpiSoi.greekname
meMA.Ode3C21.melody = he.h.m4_gr_GR_cog.heHE.EffrainetaiEpiSoi.name
meMA.Ode3C21.incipit = "Ῥημάτων σου ταῖς πλοκαῖς, περισχεθεὶς…"
meMA.Ode3C21.text = "Ῥημάτων σου ταῖς πλοκαῖς, περισχεθεὶς ὁ δυσσεβὴς τύραννος, ταῖς φυλακαῖς ᾤετο, ἀντικατασχεῖν τὴν ἀνδρείαν σου."

meMA.Ode3C22.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C22.melody = he.h.m4_gr_GR_cog.heHE.EffrainetaiEpiSoi.name
meMA.Ode3C22.incipit = "Ὁ πόθος ὁ τοῦ Θεοῦ…"
meMA.Ode3C22.text = "Ὁ πόθος ὁ τοῦ Θεοῦ, τὴν προθυμίαν τῆς ψυχῆς εὔτονον, Μάρτυς Χριστοῦ ἔδειξε, καὶ ἡ τοῦ Σωτῆρος ἐπίπνοια."

meMA.Ode3C23.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C23.melody = he.h.m4_gr_GR_cog.heHE.EffrainetaiEpiSoi.name
meMA.Ode3C23.incipit = "Σαρκὸς μὲν περιφρονεῖν, ἐπιμελεῖσθαι δὲ…"
meMA.Ode3C23.text = "Σαρκὸς μὲν περιφρονεῖν, ἐπιμελεῖσθαι δὲ ψυχῆς ἔσπευσας· ὅθεν δειναῖς μάστιξι, κατατεμνομένη ὑπέφερες."

meMA.Ode3C2T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C2T.melody = he.h.m4_gr_GR_cog.heHE.EffrainetaiEpiSoi.name
meMA.Ode3C2T.incipit = "Θυμίαμα προσηνές, ἐπιτεθὲν μαρτυρικοῖς ἄνθραξι…"
meMA.Ode3C2T.text = "Θυμίαμα προσηνές, ἐπιτεθὲν μαρτυρικοῖς ἄνθραξι, τῷ νοητῷ ἄνθρακι, τῷ ἐκ τῆς Παρθένου σὺ γέγονας."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3H.greekmelody = he.h.m4_gr_GR_cog.heHE.EffrainetaiEpiSoi.greekname
meMA.Ode3H.melody = he.h.m4_gr_GR_cog.heHE.EffrainetaiEpiSoi.melody
meMA.Ode3H.incipit = he.h.m4_gr_GR_cog.heHE.EffrainetaiEpiSoi.incipit
meMA.Ode3H.text = he.h.m4_gr_GR_cog.heHE.EffrainetaiEpiSoi.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3Kathisma1.greekmelody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.greekname
meMA.Ode3Kathisma1.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meMA.Ode3Kathisma1.incipit = "Ζῆλον ἔνθεον, ἐν τῇ ψυχῇ…"
meMA.Ode3Kathisma1.text = "Ζῆλον ἔνθεον, ἐν τῇ ψυχῇ σου, ἔχων ἔνδοξε, τοὺς ἀνομοῦντας, διακενῆς καρτερικῶς διήλεγξας, καὶ ὁμιλήσας βασάνοις διήνυσας, τὸν σὸν ἀγῶνα γενναίῳ φρονήματι, Μάρτυς Καλλίνικε, Χριστὸν τὸν Θεὸν ἱκέτευε, δωρήσασθαι ἡμῖν τὸ μέγα ἔλεος."

meMA.Ode3Kathisma2.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3Kathisma2.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
meMA.Ode3Kathisma2.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Ode3Kathisma2.incipit = "Τὸν ὡραιότατον Χριστὸν ἀγαπήσασα, καὶ…"
meMA.Ode3Kathisma2.text = "Τὸν ὡραιότατον Χριστὸν ἀγαπήσασα, καὶ διʼ ἁγνείας τὴν ψυχὴν ὡραΐσασα, διὰ παντοίων πόνων τε καὶ θλίψεων, τούτῳ κατηγγύησαι, ὥσπερ ἄμωμος νύμφη· ὅθεν σε ἠξίωσεν, οὐρανίων θαλάμων, ὑπὲρ ἡμῶν πρεσβεύουσαν αὐτῷ, τῶν σὲ τιμώντων σεμνὴ Παμμακάριστε."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaT.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Ode3KathismaT.incipit = oc.m4.d3_gr_GR_cog.ocVE.ApolTheotokionVM.incipit
meMA.Ode3KathismaT.text = oc.m4.d3_gr_GR_cog.ocVE.ApolTheotokionVM.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaSt.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Ode3KathismaSt.incipit = "Ἡ παναμώμητος ἀμνὰς καὶ Παρθένος…"
meMA.Ode3KathismaSt.text = "Ἡ παναμώμητος ἀμνὰς καὶ Παρθένος, ὃν ἀπεκύησεν Υἱὸν ἡπλωμένον, ἐπὶ Σταυροῦ ὡς ἔβλεψεν ὀδύναις τὴν ψυχήν, καιρίαις κατεπλήττετο, καὶ ἐβόα θρηνοῦσα· Ποῦ σου Τέκνον φίλτατον, δωρεῶν καὶ θαυμάτων, μνήμη ὧν ἀπήλαυσεν, ὁ ἀχάριστος δῆμος; Ἀλλʼ εἰς τὸ σῶσαι γένος τῶν βροτῶν, ταῦτα νῦν πάσχεις· Ὑμνῶ σου τὸ εὔσπλαγχνον."

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C11.greekmelody = he.h.m4_gr_GR_cog.heHE.EisakikoaOTheos.greekname
meMA.Ode4C11.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaOTheos.name
meMA.Ode4C11.incipit = "Λελουμένος ἐν ταῖς ῥοαῖς, τῶν…"
meMA.Ode4C11.text = "Λελουμένος ἐν ταῖς ῥοαῖς, τῶν σῶν αἱμάτων, παμμάκαρ ὤφθης, καθαρώτατος τῷ πνεύματι, καὶ εἰς λῆξιν ἔφθασας, τῶν Ἀσωμάτων Μάρτυς Καλλίνικε."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C12.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaOTheos.name
meMA.Ode4C12.incipit = "Λίθος ἔντιμος ἀληθῶς, ᾠκοδομήθης τῇ…"
meMA.Ode4C12.text = "Λίθος ἔντιμος ἀληθῶς, ᾠκοδομήθης τῇ Ἐκκλησίᾳ, καὶ ναοὺς εἰδώλων ἔσεισας, καὶ εἰς γῆν κατέβαλες, τῇ ἀκλινεῖ ἐνστάσει τῶν ἄθλων σου."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C13.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaOTheos.name
meMA.Ode4C13.incipit = "Ἰοβόλους τὰς τῶν ἐχθρῶν, θωπείας…"
meMA.Ode4C13.text = "Ἰοβόλους τὰς τῶν ἐχθρῶν, θωπείας ὄντως ἀπώσω Μάρτυς, ἐν τοῖς λόγοις δὲ τοῦ Πνεύματος, τὴν ψυχὴν ῥωννύμενος, κατὰ τῆς πλάνης ἔστησας τρόπαιον."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C1T.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaOTheos.name
meMA.Ode4C1T.incipit = "Νῦν σε βάτον τὴν ἐν…"
meMA.Ode4C1T.text = "Νῦν σε βάτον τὴν ἐν Σινᾷ, προδιαγράφων Μωσῆς ὁ μέγας, ἀκατάφλεκτον ἑώρακε, τὸ πῦρ τῆς Θεότητος, ἐν τῇ νηδὺϊ φέρουσαν Ἄχραντε."

meMA.Ode4C21.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C21.greekmelody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.greekname
meMA.Ode4C21.melody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.name
meMA.Ode4C21.incipit = "Ἐπτερωμένη τῷ ἔρωτι τοῦ Δεσπότου…"
meMA.Ode4C21.text = "Ἐπτερωμένη τῷ ἔρωτι τοῦ Δεσπότου, τῶν ἀλγεινῶν βασάνων, οὐκ ᾐσθάνου θεόφρον, τὸν νοῦν μεταστήσασα, πρὸς τὸν σοὶ ποθούμενον."

meMA.Ode4C22.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C22.melody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.name
meMA.Ode4C22.incipit = "Ὁ ἀπατήσας τὴν Εὔαν ἐν…"
meMA.Ode4C22.text = "Ὁ ἀπατήσας τὴν Εὔαν ἐν Παραδείσῳ, καταπατεῖται Κόρης, ὑπὸ πόδας ὡραίους, Θεοδότης μάρτυρος ὡς οὔσης θεόφρονος."

meMA.Ode4C23.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C23.melody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.name
meMA.Ode4C23.incipit = "Νενυμφευμένη Νυμφίῳ τῷ ἀθανάτῳ, διὰ…"
meMA.Ode4C23.text = "Νενυμφευμένη Νυμφίῳ τῷ ἀθανάτῳ, διὰ σαρκὸς θανάτου, πρὸς ζωὴν μετετέθης, αἰωνίας λήξεως τυχοῦσα Πανεύφημε."

meMA.Ode4C2T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C2T.melody = he.h.m4_gr_GR_cog.heHE.DiAgapisinOiktirmon.name
meMA.Ode4C2T.incipit = "Μεμυημένη τὰ θεῖα τῷ ἐκ…"
meMA.Ode4C2T.text = "Μεμυημένη τὰ θεῖα τῷ ἐκ Παρθένου, καὶ Θεοτόκου Κόρης, σαρκωθέντι ἐβόας· Σύ μου εἶ φιλάνθρωπε, ἰσχύς τε καὶ ὕμνησις."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C11.greekmelody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.greekname
meMA.Ode5C11.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
meMA.Ode5C11.incipit = "Ἰλὺϊ περιέπεσον, ἀνυποστάτῳ Κύριε, καὶ…"
meMA.Ode5C11.text = "Ἰλὺϊ περιέπεσον, ἀνυποστάτῳ Κύριε, καὶ ἐν βυθῷ τῆς ἁμαρτίας τε, καὶ τῇ καταιγίδι τῶν δεινῶν μου πράξεων, ἐμπαγεὶς κραυγάζω σοι· Σὺ γενοῦ μοι βοηθός."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C12.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
meMA.Ode5C12.incipit = "Κρηπῖσι καθηλούμενος, τοὺς πόδας Μάρτυς…"
meMA.Ode5C12.text = "Κρηπῖσι καθηλούμενος, τοὺς πόδας Μάρτυς ἔψαλλες· Ἐν τῇ ὁδῷ τῶν μαρτυρίων σου, πλουσίως κατετέρφθην, ἀθλοθέτα Δέσποτα, ὑπομένων στίγματα, τῇ ἐλπίδι τῶν μισθῶν."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C13.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
meMA.Ode5C13.incipit = "Ἐλαίῳ σῷ τὸν ἔλεον, καλῶς…"
meMA.Ode5C13.text = "Ἐλαίῳ σῷ τὸν ἔλεον, καλῶς ἐμπορευσάμενος, τοῦ μαρτυρίου τὴν λαμπάδα σου, ἐφαίδρυνας Παμμάκαρ, διʼ ἧς ὅλος γέγονας, ἱερεῖον ἄμωμον, ὁλοκαύτωμα δεκτόν."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C1T.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
meMA.Ode5C1T.incipit = "Τῶν Προφητῶν τὸ κήρυγμα, καὶ…"
meMA.Ode5C1T.text = "Τῶν Προφητῶν τὸ κήρυγμα, καὶ Ἀποστόλων καύχημα, καὶ τῶν Μαρτύρων ἐγκαλλώπισμα, ὑπάρχεις Θεοτόκε, Θεὸν Λόγον φέρουσα, ὑπὲρ λόγον Πάναγνε, τὸν πρὸ αἰώνων ἐκ Πατρός."

meMA.Ode5C21.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C21.greekmelody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.greekname
meMA.Ode5C21.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C21.incipit = "Ὁ νοῦς σου εὐσεβῶς, τῇ…"
meMA.Ode5C21.text = "Ὁ νοῦς σου εὐσεβῶς, τῇ ἀγάπῃ τοῦ Κτίσαντος, ἑνούμενος Θεοδότη, τῶν τοῦ κόσμου ἡδέων, εὐτόνως κατεφρόνησεν."

meMA.Ode5C22.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C22.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C22.incipit = "Ἰθύνουσα τὸν σόν, λογισμὸν πρὸς…"
meMA.Ode5C22.text = "Ἰθύνουσα τὸν σόν, λογισμὸν πρὸς τὴν μέλλουσαν, αἰώνιον εὐφροσύνην, ἀθυμίας βασάνων, καὶ πόνων οὐκ ἐφρόντισας."

meMA.Ode5C23.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C23.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C23.incipit = "Μακρότης ἡμερῶν, καὶ τερπνὴ ἀγαλλίασις…"
meMA.Ode5C23.text = "Μακρότης ἡμερῶν, καὶ τερπνὴ ἀγαλλίασις, δεδώρηταί σοι θεόφρον, ἀντὶ κόπων ὧν εἶδες, καὶ πόνων τῶν κολάσεων."

meMA.Ode5C2T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C2T.melody = he.h.m4_gr_GR_cog.heHE.SyKyrieMouFos.name
meMA.Ode5C2T.incipit = "Αἱ θεῖαι δωρεαί, ταῖς παρθένοις…"
meMA.Ode5C2T.text = "Αἱ θεῖαι δωρεαί, ταῖς παρθένοις καὶ μάρτυσι, πηγάζουσιν ἐκ Παρθένου, τοῦ Χριστοῦ γεννηθέντος, τῆς μόνης Θεομήτορος."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TonPtaismatonTiZali.greekname
meMA.Ode6C11.melody = he.h.m4_gr_GR_cog.heHE.TonPtaismatonTiZali.name
meMA.Ode6C11.incipit = "Ἡ τῆς ποίμνης σου μάνδρα…"
meMA.Ode6C11.text = "Ἡ τῆς ποίμνης σου μάνδρα ἀνεπίβατος, ἐκ τῶν θηρίων ἐτηρήθη τῶν αἱρέσεων· τῶν σῶν γὰρ ἄθλων Ἔνδοξε, κατέχουσα τὴν στεῤῥὰν βακτηρίαν, τῶν λύκων ὤφθη διώκτρια."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C12.melody = he.h.m4_gr_GR_cog.heHE.TonPtaismatonTiZali.name
meMA.Ode6C12.incipit = "Νὺξ ἠλάθη τῆς πλάνης τῇ…"
meMA.Ode6C12.text = "Νὺξ ἠλάθη τῆς πλάνης τῇ ἀθλήσει σου, καὶ τὸ τῆς πίστεως κάλλος ἐξανέτειλεν, ἐν τῇ ὁμολογίᾳ σου Πανένδοξε, τῆς Τριάδος ὁπλῖτα, ὡς ἥλιος ἐν τοῖς πέρασιν."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C13.melody = he.h.m4_gr_GR_cog.heHE.TonPtaismatonTiZali.name
meMA.Ode6C13.incipit = "Ὡς τῆς πίστεως κήρυξ ἀκριβέστατος…"
meMA.Ode6C13.text = "Ὡς τῆς πίστεως κήρυξ ἀκριβέστατος, τῷ ἀσεβοῦντι ἐβόας ἑτοιμότατα· Τί ἀπειλεῖς τῷ ἔχοντι ἀδάμαντος, τὴν ψυχὴν στεῤῥοτέραν· τὰ βέλη γὰρ τῶν ἀθέων κοῦφα."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C1T.melody = he.h.m4_gr_GR_cog.heHE.TonPtaismatonTiZali.name
meMA.Ode6C1T.incipit = "Διαμένεις ἐκ τόκου ἀπειρόγαμος, ὡς…"
meMA.Ode6C1T.text = "Διαμένεις ἐκ τόκου ἀπειρόγαμος, ὡς πρὸ τοῦ τόκου καὶ ἀνέπαφος· τὸ γὰρ ἐν σοὶ μυστήριον Θεόνυμφε, ὑπὲρ ἔννοιαν πᾶσαν, καὶ πάντα λόγον γνωρίζεται."

meMA.Ode6C21.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C21.greekmelody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.greekname
meMA.Ode6C21.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C21.incipit = "Ῥομφαῖαι, αἱ τοῦ ἐχθροῦ εἰς…"
meMA.Ode6C21.text = "Ῥομφαῖαι, αἱ τοῦ ἐχθροῦ εἰς τέλος ἐξέλιπον· νῦν γὰρ νεάνιδες τοῦτον, καὶ παρθένοι κόραι καταπατοῦσι, τῇ δυνάμει, τῇ τοῦ Σταυροῦ προδήλως ῥωννύμεναι."

meMA.Ode6C22.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C22.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C22.incipit = "Τὴν πτῶσιν, τῆς προμήτορος Εὔας…"
meMA.Ode6C22.text = "Τὴν πτῶσιν, τῆς προμήτορος Εὔας ἀνώρθωσαν, αἱ θυγατέρες αἱ ταύτης, τοῖς τῆς νίκης ἄθλοις στεφανωθεῖσαι, καὶ ποικίλα, περιφανῶς ἐγείρασαι τρόπαια."

meMA.Ode6C23.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C23.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C23.incipit = "Ὑπέστης, τὴν τοῦ πυρὸς δριμύτητα…"
meMA.Ode6C23.text = "Ὑπέστης, τὴν τοῦ πυρὸς δριμύτητα πάνσοφε, τοῦ σοῦ νυμφίου τῷ πόθῳ, Θεοδότη μάρτυς πυρπολουμένη, καὶ τὴν φλόγα, τῆς ἀπάτης ἀνδρείως κατέσβεσας."

meMA.Ode6C2T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C2T.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C2T.incipit = "Στόματι, θεολόγῳ καὶ γλώσσῃ θεόφρονι…"
meMA.Ode6C2T.text = "Στόματι, θεολόγῳ καὶ γλώσσῃ θεόφρονι, τὰς τῶν τυράννων θωπείας, ἀπεκρούσω Μάρτυς τὸν ἐκ Παρθένου, σαρκωθέντα, θεολογοῦσα τῆς Θεομήτορος."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6H.greekmelody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.greekname
meMA.Ode6H.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.melody
meMA.Ode6H.incipit = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.incipit
meMA.Ode6H.text = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.text

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C11.greekmelody = he.h.m4_gr_GR_cog.heHE.PyrFlegonEnKamino.greekname
meMA.Ode7C11.melody = he.h.m4_gr_GR_cog.heHE.PyrFlegonEnKamino.name
meMA.Ode7C11.incipit = "Ἡδονῆς μοι πρόξενα, τὰ τῶν…"
meMA.Ode7C11.text = "Ἡδονῆς μοι πρόξενα, τὰ τῶν κολάσεων ὑπάρχουσι φόβητρα· οὐ γὰρ πῦρ οὐ, μάστιγες, τοῦ ἀληθοῦς ἐραστοῦ μου, ὁ Μάρτυς ἐβόα, χωρίσει με."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C12.melody = he.h.m4_gr_GR_cog.heHE.PyrFlegonEnKamino.name
meMA.Ode7C12.incipit = "Νευρούμενος Ἔνδοξε, τῇ συμμαχίᾳ Χριστοῦ…"
meMA.Ode7C12.text = "Νευρούμενος Ἔνδοξε, τῇ συμμαχίᾳ Χριστοῦ, εἰς γῆν τὸν ἀντίπαλον, ἐκπαλαίσας ἔῤῥιψας, καὶ φερωνύμως ἐδείχθης, κατὰ τῶν τυράννων καλλίνικος."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C13.melody = he.h.m4_gr_GR_cog.heHE.PyrFlegonEnKamino.name
meMA.Ode7C13.incipit = "Διάβολον ᾔσχυνας, Ἀγγέλους εὔφρανας, τοῖς…"
meMA.Ode7C13.text = "Διάβολον ᾔσχυνας, Ἀγγέλους εὔφρανας, τοῖς ἄθλοις σου, Ἔνδοξε, καὶ Χριστῷ ἐκραύγαζες· Εὐλογητὸς εἶ ὁ μόνος, ὑπάρχων Θεὸς τῶν Πατέρων ἡμῶν."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C1T.melody = he.h.m4_gr_GR_cog.heHE.PyrFlegonEnKamino.name
meMA.Ode7C1T.incipit = "Ἔλυσας τῷ τόκῳ σου, Παρθένε…"
meMA.Ode7C1T.text = "Ἔλυσας τῷ τόκῳ σου, Παρθένε ἄχραντε, Εὔας της προμήτορος, τὴν ἀράν· ὑπάρχεις γάρ, Μήτηρ τοῦ πάντων Δεσπότου, τοῖς πᾶσι χαρὰν προξενήσασα."

meMA.Ode7C21.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C21.greekmelody = he.h.m4_gr_GR_cog.heHE.EnTiKaminoAvramiaioi.greekname
meMA.Ode7C21.melody = he.h.m4_gr_GR_cog.heHE.EnTiKaminoAvramiaioi.name
meMA.Ode7C21.incipit = "Ἰμειρομένη τῆς Βασιλείας Μάρτυς τῶν…"
meMA.Ode7C21.text = "Ἰμειρομένη τῆς Βασιλείας Μάρτυς τῶν οὐρανῶν, τρίβον, τὴν στενὴν διώδευσας ἀκλινῶς, διʼ ἀθλήσεως κραυγάζουσα· Εὐλογημένος εἶ ἐν τῷ ναῷ τῆς δόξης σου Κύριε."

meMA.Ode7C22.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C22.melody = he.h.m4_gr_GR_cog.heHE.EnTiKaminoAvramiaioi.name
meMA.Ode7C22.incipit = "Θηριωδίας τῆς ὠμοτάτης ἀπεδείξατο, ἔργον…"
meMA.Ode7C22.text = "Θηριωδίας τῆς ὠμοτάτης ἀπεδείξατο, ἔργον, Θεοδότη μάρτυς ὁ δυσσεβής, κατατέμνων σε ταῖς μάστιξιν· Εὐλογημένος εἶ ἀναβοῶσα· Θεέ μου καὶ Κύριε."

meMA.Ode7C23.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C23.melody = he.h.m4_gr_GR_cog.heHE.EnTiKaminoAvramiaioi.name
meMA.Ode7C23.incipit = "Ὑπομονῆς σου, καὶ καρτερίας τε…"
meMA.Ode7C23.text = "Ὑπομονῆς σου, καὶ καρτερίας τε ἐπίχειρα, δόξαν, καὶ τρυφὴν ἀνώλεθρον ὁ Χριστός, Θεοδότη ἐδωρήσατο· Εὐλογημένος εἶ ἀναβοώσῃ, Θεέ μου καὶ Κύριε."

meMA.Ode7C2T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C2T.melody = he.h.m4_gr_GR_cog.heHE.EnTiKaminoAvramiaioi.name
meMA.Ode7C2T.incipit = "Νενεκρωμένην, τὴν ἀνθρωπίνην φύσιν ἥγειρας…"
meMA.Ode7C2T.text = "Νενεκρωμένην, τὴν ἀνθρωπίνην φύσιν ἥγειρας, μόνη, σὺ ζωὴν ἀθάνατον τὸν Χριστόν, Θεονύμφευτε γεννήσασα· Εὐλογημένη σὺ ἐν γυναιξίν, ὑπάρχεις πανάμωμε Δέσποινα."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.greekname
meMA.Ode8C11.melody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.name
meMA.Ode8C11.incipit = "Χαίροις ἐντρύφημα, τῶν ἀθλητῶν τῆς…"
meMA.Ode8C11.text = "Χαίροις ἐντρύφημα, τῶν ἀθλητῶν τῆς ἀληθείας, Χαίροις τὸ καλλώπισμα τῆς πίστεως καὶ κλέος, Χαίροις ὁ λαμπρότατος τῶν μαρτύρων φωσφόρος, ὁ τὴν πλάνην σκεδάσας τῇ ἀθλήσει σου, καὶ τὸ φῶς ἀναλάμψας τῷ κόσμῳ, Καλλίνικε πάνσοφε."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C12.melody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.name
meMA.Ode8C12.incipit = "Ὁ τύραννος ᾐσχύνθη, τῇ τῶν…"
meMA.Ode8C12.text = "Ὁ τύραννος ᾐσχύνθη, τῇ τῶν ἀγώνων σου ἐνστάσει, ἡττήθησαν δήμιοι τοῖς μώλωψί σου Μάκαρ, τοῖς ἥλοις τῆς πτέρνης σου κατετρώθη ἡ πλάνη, κατεφλέχθη δὲ πάντα καὶ ἠφάνισται, τῶν εἰδώλων τεμένη, πυρὶ ἐναθλοῦντός σου."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C13.melody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.name
meMA.Ode8C13.incipit = "Ὑπὲρ τῶν τιμώντων σε, τῇ…"
meMA.Ode8C13.text = "Ὑπὲρ τῶν τιμώντων σε, τῇ πρὸς Θεόν σου παῤῥησίᾳ, Καλλίνικε χρώμενος, ἱκέτευε ἀπαύστως, τῆς ποίμνης σου πρόστηθι, ἐξαιρούμενος ταύτην, τῶν ποικίλων παγίδων τοῦ ἀλάστορος, καὶ στηρίζων τῇ πίστει· ἐν σοὶ γὰρ αὐχεῖ καὶ κρατύνεται."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C1T.melody = he.h.m4_gr_GR_cog.heHE.TaSympantaDespota.name
meMA.Ode8C1T.incipit = "Ἐν Πνεύματι Προφῆται, σὲ τὴν…"
meMA.Ode8C1T.text = "Ἐν Πνεύματι Προφῆται, σὲ τὴν Παρθένον προτυποῦσι, σκηνήν τε καὶ τράπεζαν, καὶ στάμνον καὶ λυχνίαν, καὶ ὄρος πανάγιον, καὶ νεφέλην καὶ πλάκα, κιβωτὸν τε καὶ ῥάβδον, πύλην ἔνθεον, διʼ ἧς πᾶσιν ἀνθρώποις, ἠνοίχθη ὁ πάλαι Παράδεισος."

meMA.Ode8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C21.greekmelody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.greekname
meMA.Ode8C21.melody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.name
meMA.Ode8C21.incipit = "Οὐδὲν ἀθληφόρε τῶν δεινῶν, οὐ…"
meMA.Ode8C21.text = "Οὐδὲν ἀθληφόρε τῶν δεινῶν, οὐ πῦρ οὐ μάστιγες, οὐδὲ στρεβλώσεις μελῶν, ἀλλʼ οὐδὲ θάνατος ἴσχυσε, διαῤῥῆξαι τὴν συνάφειαν, πρὸς τὸν Δεσπότην καὶ στοργήν, διʼ ἧς ἐκραύγαζες· Εὐλογεῖτε, πάντα τὰ ἔργα Κυρίου τὸν Κύριον."

meMA.Ode8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C22.melody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.name
meMA.Ode8C22.incipit = "Νυμφῶνα τερπνὸν καὶ καθαρόν, ὁ…"
meMA.Ode8C22.text = "Νυμφῶνα τερπνὸν καὶ καθαρόν, ὁ σὸς νυμφίος Χριστός, σοὶ νῦν δεδώρηται, διπλαῖς ἐκλάμπουσαν χάρισι, καθορῶν σε πανσεβάσμιε, ὄνπερ ποθήσασα θερμῶς, χαίρουσα ἔψαλλες· Εὐλογεῖτε, πάντα τὰ ἔργα Κυρίου τὸν Κύριον."

meMA.Ode8C23.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C23.melody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.name
meMA.Ode8C23.incipit = "Τῷ πόθῳ κατάλληλον ἰσχύν, ὁ…"
meMA.Ode8C23.text = "Τῷ πόθῳ κατάλληλον ἰσχύν, ὁ ἐραστής σου Χριστός, σαφῶς ἐνέπνευσε, διʼ ἧς τὴν ἄστεκτον ἤλεγξας, ἀθεότητα Πανόλβιε, καὶ τοὺς ποικίλους πειρασμούς, ἔφερες ψάλλουσα· Εὐλογεῖτε, πάντα τὰ ἔργα Κυρίου τὸν Κύριον."

meMA.Ode8C2T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C2T.melody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.name
meMA.Ode8C2T.incipit = "Ῥήμασιν ἑπόμενοι τοῖς σοῖς, σὲ…"
meMA.Ode8C2T.text = "Ῥήμασιν ἑπόμενοι τοῖς σοῖς, σὲ μακαρίζομεν θεομακάριστε, μακαριότητος ἔνθεον, εὑρηκότες σε ὑπόθεσιν, τὴν τὸν μακάριον ἡμῖν, Λόγον γεννήσασαν, ᾧ βοῶμεν· Πάντα τὰ ἔργα ὑμνεῖτε τὸν Κύριον."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8H.greekmelody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.greekname
meMA.Ode8H.melody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.melody
meMA.Ode8H.incipit = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.incipit
meMA.Ode8H.text = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TonAsporonTokonSou.greekname
meMA.Ode9C11.melody = he.h.m4_gr_GR_cog.heHE.TonAsporonTokonSou.name
meMA.Ode9C11.incipit = "Ὑφάνθη σοι ἄνωθεν, ὁ χιτὼν…"
meMA.Ode9C11.text = "Ὑφάνθη σοι ἄνωθεν, ὁ χιτὼν τῆς πίστεως, διʼ οὗ ἀπεγύμνωσας τὸν ἐχθρὸν ἐν σταδίῳ, Μάρτυς ἔνδοξε."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C12.melody = he.h.m4_gr_GR_cog.heHE.TonAsporonTokonSou.name
meMA.Ode9C12.incipit = "Μεμηνὼς ὁ τύραννος, ὑπεκλύειν ᾤετο…"
meMA.Ode9C12.text = "Μεμηνὼς ὁ τύραννος, ὑπεκλύειν ᾤετο, θωπείαις τὸν Μάρτυρα, ἀλλʼ αὐτὸς τῇ πίστει ἐστερέωτο."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C13.melody = he.h.m4_gr_GR_cog.heHE.TonAsporonTokonSou.name
meMA.Ode9C13.incipit = "Εὐθὲς ὁλοκαύτωμα, καὶ δεκτὸν θυμίαμα…"
meMA.Ode9C13.text = "Εὐθὲς ὁλοκαύτωμα, καὶ δεκτὸν θυμίαμα, Καλλίνικε ἔνδοξε, τῷ πυρὶ τῶν ἀγώνων προσηνέχθης Θεῷ."

meMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C14.melody = he.h.m4_gr_GR_cog.heHE.TonAsporonTokonSou.name
meMA.Ode9C14.incipit = "Ὡραῖοι οἱ πόδες σου, ἀθλητὰ…"
meMA.Ode9C14.text = "Ὡραῖοι οἱ πόδες σου, ἀθλητὰ Καλλίνικε, τοῖς ἥλοις πειρώμενοι, καὶ πρὸς κήρυγμα θεῖον πορευόμενοι."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C1T.melody = he.h.m4_gr_GR_cog.heHE.TonAsporonTokonSou.name
meMA.Ode9C1T.incipit = "Σκέπην σε κεκτήμεθα, καὶ λιμένα…"
meMA.Ode9C1T.text = "Σκέπην σε κεκτήμεθα, καὶ λιμένα Πάναγνε καὶ ὅπλον καὶ ἄγκυραν, καὶ βεβαίαν ἐλπίδα ἐν κινδύνοις ἀεί."

meMA.Ode9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C21.greekmelody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.greekname
meMA.Ode9C21.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C21.incipit = "Ἵλεων γενέσθαι θεόφρον, τὸν σὸν…"
meMA.Ode9C21.text = "Ἵλεων γενέσθαι θεόφρον, τὸν σὸν ἀθάνατον Νυμφίον, ὑπὲρ τῶν ὑμνούντων σε πόθῳ, δυσώπει Μάρτυς ἀξιοθαύμαστε, διὰ παντὸς ἐκλάμπουσα, ταῖς λαμπηδόσι ταῖς τῆς χάριτος."

meMA.Ode9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C22.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C22.incipit = "Βήματι παρέστηκας ὄντως, σὺν παῤῥησίᾳ…"
meMA.Ode9C22.text = "Βήματι παρέστηκας ὄντως, σὺν παῤῥησίᾳ τοῦ Δεσπότου, οἷα εὐσεβής τε καὶ Μάρτυς, διʼ ἀμφοτέρων εὐαρεστήσασα, τῷ τὴν ἰσχύν σοι πνεύσαντι, καὶ πλουτοδότως στεφανώσαντι."

meMA.Ode9C23.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C23.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C23.incipit = "Ὅλη εἶ καλὴ Θεοδότη, πεποθημένη…"
meMA.Ode9C23.text = "Ὅλη εἶ καλὴ Θεοδότη, πεποθημένη τῷ Δεσπότῃ· ὅλη φωτοφόρος ὑπάρχεις, καὶ μῶμος ὅλως Μάρτυς οὐκ ἔστιν ἐν σοί· σὺ γὰρ διπλαῖς ταῖς χάρισι, διαφερόντως κεχαρίτωσαι."

meMA.Ode9C2T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C2T.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C2T.incipit = "Νύμφη καὶ γεννήτρια ὤφθης, τοῦ…"
meMA.Ode9C2T.text = "Νύμφη καὶ γεννήτρια ὤφθης, τοῦ ἁπάντων Βασιλέως· σὺ γάρ τῶν ἀπʼ αἰῶνος ἐφάνης, ἁγιωτέρα πάσης τῆς κτίσεως, καὶ διὰ σοῦ σῳζόμενοι, σὲ Θεοτόκε μεγαλύνομεν."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9H.greekmelody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.greekname
meMA.Ode9H.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.melody
meMA.Ode9H.incipit = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.incipit
meMA.Ode9H.text = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.text

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_gr_GR_cog.heAU.EpeskepsatoImas.greekname
meMA.Exaposteilarion1.melody = he.a.m3_gr_GR_cog.heAU.EpeskepsatoImas.name
meMA.Exaposteilarion1.incipit = "Καὶ θανοῦσα ζωηρόν, αἱμάτων μύρον…"
meMA.Exaposteilarion1.text = "Καὶ θανοῦσα ζωηρόν, αἱμάτων μύρον ἔβλυσας, ὡς ἐν Θεῷ ζῶντι ζῶσα· καὶ διαθήκης τῆς αὐτοῦ, κληρονόμος ἠξίωσαι, Θεοδότη φρουροῦσα, τοὺς πόθῳ ὑμνοῦντάς σε."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.ExapTheotokion.melody = he.a.m3_gr_GR_cog.heAU.EpeskepsatoImas.name
meMA.ExapTheotokion.incipit = "Ἡ πλατυτέρα οὐρανῶν, πρὸς οὐρανὸν…"
meMA.ExapTheotokion.text = "Ἡ πλατυτέρα οὐρανῶν, πρὸς οὐρανὸν ἀπάρασα, μὴ καταλίπῃς ἀγαθή, ἡμᾶς τοὺς κάτω γηγενεῖς· πρὸς τὸν εὔσπλαγχνον Κύριον, χεῖρας εἰς μεσιτείαν, τοῦ Κόσμου ἐφάπλωσον."

