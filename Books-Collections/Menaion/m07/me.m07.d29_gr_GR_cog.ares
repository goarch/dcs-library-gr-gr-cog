meDA.pdfheaderdate = "τῆς 29ης Ἰουλίου"
meDA.fordate = "διὰ τὴν 29ην Ἰουλίου"
meLE.commemoration1 = "Τοῦ Ἁγίου Μάρτυρος Καλλινίκου."
meLE.commemoration2 = ""
