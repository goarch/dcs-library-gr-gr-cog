meDA.date = "Τῌ ΚΘʹ ΙΟΥΛΙΟΥ"
meDA.commemoration.full = "Μνήμη τοῦ Ἁγίου Μάρτυρος Καλλινίκου, καὶ τῆς Ἁγίας Μάρτυρος Θεοδότης" // full title of day
meDA.commemoration.first = "Μνήμη τοῦ Ἁγίου Μάρτυρος Καλλινίκου"
meDA.commemoration.first_short = "Μνήμη τοῦ Ἁγίου Μάρτυρος Καλλινίκου"
meDA.commemoration.first_title = titles_gr_GR_cog.ti.SaintM
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = titles_gr_GR_cog.ti.SaintW
meDA.commemoration.second_name = ""
