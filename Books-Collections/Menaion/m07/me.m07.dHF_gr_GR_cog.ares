A_Resource_Whose_Name = me.m07.dHF_gr_GR_cog

meDA.date = "Τῌ ΙΓʹ - ΙΘʹ ΙΟΥΛΙΟΥ"
meDA.commemoration.full = "Κυριακὴ τῶν Ἁγίων Πατέρων τῆς Δʹ Οἰκουμενικῆς Συνόδου τῶν ἐν Χαλκηδόνι συνελθόντων." // full title of day
meDA.commemoration.first = "Κυριακὴ τῶν Ἁγίων Πατέρων"
meDA.commemoration.first_short = "Κυριακὴ τῶν Ἁγίων Πατέρων"
meDA.commemoration.first_title = titles_gr_GR_cog.ti.Fathers
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = ""
meDA.commemoration.second_name = ""
meDA.insert1 = "καὶ τῶν ἁγίων Πατέρων τῆς Δʹ Οἰκουμενικῆς Συνόδου," // for use in petitions and dismissal
meDA.insert2 = "ὧν καὶ τὴν μνήμην ἐπιτελοῦμεν·" // for use in petitions and dismissal
meDA.note = ""
meDA.pdfcoverdate = ""
meDA.pdfdatebefore = ""
meDA.pdfheaderdate = ""
meDA.fordate = ""
meLE.commemoration1 = "Κυριακὴ τῶν Ἁγίων Πατέρων τῆς Δʹ Οἰκουμενικῆς Συνόδου."
meLE.commemoration2 = ""
meHO.number = ""
meHO.rank = ""
meHO.commemorations = ""
meHO.note1 = ""
meHO.note2 = ""
meTY.note1 = "Εἰς τό ΤΜΕ, § 1, σελ. 289, καίτοι ἀναγράφονται: «… ἀναστάσιμα Στιχηρά Ϛʹ καί τῶν Πατέρων δʹ», δέον ὅπως ἀκολουθηθῇ ἡ ἐν τῇ Προθεωρίᾳ, § 7, σελ. 8, διατυπουμένη τάξις· «… τῶν Ἁγίων Πατέρων τῆς Δʹ  καί Ζʹ  Συνόδου… ψάλλονται κατ’ ἐξαίρεσιν Ἀναστάσιμα δʹ καί τῶν Ἁγίων Ϛʹ»."

meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera01.greekmelody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.greekname
meVE.Stichera01.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meVE.Stichera01.incipit = "Σὲ τὸν ἀπερίγραπτονήνευτον…"
meVE.Stichera01.text = "Σὲ τὸν ἀπερίγραπτον, καὶ ἀνερμήνευτον Λόγον, σάρκα χρηματίσαντα, διʼ ἡμᾶς φιλάνθρωπε ἀνεκήρυξε, τὸ σεπτὸν σύστημα, τῶν σοφῶν Πατέρων, Θεὸν τέλειον καὶ ἄνθρωπον, διπλοῦν ταῖς φύσεσι, καὶ ταῖς ἐνεργείαις ὑπάρχοντα, διπλοῦν καὶ ταῖς θελήσεσιν, ἕνα τὸν αὐτὸν καθʼ ὑπόστασιν· ὅθεν σὺν Πατρί τε, καὶ Πνεύματι γινώσκοντες Θεόν, ἕνα πιστῶς προσκυνοῦμέν σε, τούτους μακαρίζοντες."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera02.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meVE.Stichera02.incipit = "Πύῤῥον τε καὶ Σέργιον…"
meVE.Stichera02.text = "Πύῤῥον τε καὶ Σέργιον, καὶ τὸν Ὀνώριον ἅμα, Εὐτυχῆ Διόσκορον, καὶ δεινὸν Νεστόριον κατεστρέψατε, τῶν κρημνῶν ἔνδοξοι, τὸ Χριστοῦ ποίμνιον, ἑκατέρων διασώσαντες, διπλοῦν ταῖς φύσεσιν, ἕνα τὸν Χριστὸν καθʼ ὑπόστασιν, λαμπρῶς ἀνακηρύξαντες, μόναις ἐνεργείαις δεικνύμενον· ὃν καὶ προσκυνοῦντες, ὡς ἄνθρωπον, καὶ τέλειον Θεόν, σὺν τῷ Πατρὶ καὶ τῷ Πνεύματι, νῦν ὑμᾶς δοξάζομεν."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera03.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meVE.Stichera03.incipit = "Ἄκτιστον ἐκήρυξαν…"
meVE.Stichera03.text = "Ἄκτιστον ἐκήρυξαν, οἱ θεοφόροι συμφώνως, τὴν θείαν ἐνέργειαν, καὶ τὴν θείαν θέλησιν τοῦ πτωχεύσαντος, τὸν ἐμὸν ἄνθρωπον, τῇ σαρκὶ νείμαντες, τὸ κτιστὸν τῆς ἐνεργείας τε, καὶ τῆς θελήσεως, φύσεως φυγόντες τὴν σύγχυσιν, ἐμφρόνως οἱ μακάριοι, ὑποστατικήν τε διαίρεσιν· οὓς ἐν ἐτησίοις, τιμῶντες οἱ πιστοὶ ταῖς ἑορταῖς, Χριστὸν συμφώνως δοξάζομεν, τὸν αὐτοὺς δοξάσαντα."

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.Stichera04.greekmelody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.greekname
meVE.Stichera04.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meVE.Stichera04.incipit = "Τριάδα τὴν ἄκτιστον…"
meVE.Stichera04.text = "Τριάδα τὴν ἄκτιστον, οἱ θεοφόροι Πατέρες, Θεὸν ἕνα Κύριον, ὁμοφρόνως σήμερον ἀνεκήρυξαν, τὸ ἁπλοῦν ἅπασι, τῆς μιᾶς φύσεως, καταλλήλως ὑποδείξαντες, κοινῷ θελήματι, καὶ τῆς ἐνεργείας ἁπλότητι, ἄναρχον ἀτελεύτητον, τοῦτον διὰ πάντων γνωρίσαντες· ὅθεν ἀνυμνοῦμεν, αὐτοὺς ὡς Ἀποστόλων μιμητάς, καὶ τὸ ἐκείνων διδάξαντας, πάντας Εὐαγγέλιον."

meVE.MM.Stichera123as567.text = properties_gr_GR_cog.media.key

meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Τὰς μυστικὰς σήμερον…"
meVE.SticGlory.text = "Τὰς μυστικὰς σήμερον τοῦ Πνεύματος σάλπιγγας, τοὺς θεοφόρους Πατέρας ἀνευφημήσωμεν· τοὺς μελῳδήσαντας ἐν μέσῳ τῆς ἐκκλησίας, μέλος ἐναρμόνιον Θεολογίας, Τριάδα μίαν ἀπαράλλακτον, οὐσίαν τε καὶ Θεότητα· τοὺς καθαιρέτας τῆς πλάνης, καὶ Ὀρθοδόξων προμάχους· τοὺς πρεσβεύοντας πάντοτε Κυρίῳ, ἐλεηθῆναι τὰς ψυχάς ἡμῶν."

meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Ἀποστολικῶν παραδόσεων…"
meVE.AposGlory.text = "Ἀποστολικῶν παραδόσεων, ἀκριβεῖς φύλακες γεγόνατε, Ἅγιοι Πατέρες· τῆς γὰρ Ἁγίας Τριάδος τὸ ὁμοούσιον, ὀρθοδόξως δογματίσαντες, Ἀρείου τὸ βλάσφημον συνοδικῶς κατεβάλετε. Μεθʼ ὃν καὶ Μακεδόνιον πνευματομάχον ἀπελέγξαντες, κατεκρίνατε Νεστόριον, Εὐτυχέα καὶ Διόσκορον, Σαβέλλιόν τε, καὶ Σεβῆρον τὸν Ἀκέφαλον. Ὧν τῆς πλάνης αἰτήσασθε ῥυσθέντας ἡμᾶς, ἀκηλίδωτον ἡμῶν τὸν βίον, διατηρεῖν ἐν τῇ πίστει δεόμεθα."

meVE.AposBoth.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.AposBoth.melody = ""
meVE.AposBoth.incipit = oc.m3.d1_gr_GR_cog.ocVE.AposTheotokion.incipit
meVE.AposBoth.text = oc.m3.d1_gr_GR_cog.ocVE.AposTheotokion.text

meVE.Apolytikion1.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Apolytikion1.melody = ""
meVE.Apolytikion1.incipit = "Ὑπερδεδοξασμένος εἶ…"
meVE.Apolytikion1.text = "Ὑπερδεδοξασμένος εἶ, Χριστὲ ὁ Θεὸς ἡμῶν, ὁ φωστῆρας ἐπὶ γῆς, τοὺς Πατέρας ἡμῶν θεμελιώσας, καὶ διʼ αὐτῶν, πρὸς τὴν ἀληθινὴν πίστιν, πάντας ἡμᾶς ὁδηγήσας. Πολυεύσπλαγχνε δόξα σοι."

meVE.Apolytikion2.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Apolytikion2.greekmelody = he.a.m1_gr_GR_cog.heAU.TisErimouPolitis.greekname
meVE.Apolytikion2.melody = he.a.m1_gr_GR_cog.heAU.TisErimouPolitis.name
meVE.Apolytikion2.incipit = "Τὸν ἑπτάριθμον δῆμον τῶν Συνόδων…"
meVE.Apolytikion2.text = "Τὸν ἑπτάριθμον δῆμον τῶν Συνόδων τιμήσωμεν, διʼ ὧν τὴν καλὴν παραυήκην, ἀσινῆ έπλουτήσαμεν· ὡς στύλοθς γὰρ ὑπήρεισεν ἑπτά, αὐτὰς τῇ Ἐκκλησίᾳ ὁ Χριστός, ὧν τὰ δόγματα ὡς ἂγκυραν ἀσφαλῆ, κρατοῦσα μέλπει πάντοτε· δόξα τῷ καταυγάσαντι ὑμᾶς, δόξα τῷ μεγαλύναντι, δόξα τῷ βεβαιοῦντι διʼ ὑμῶν πίστιν τὴν Ὀρθόδοξον."

meMA.C1.acrostic.title = "Ὁ πρῶτος Κανὼν τῶν Πατέρων,"
meMA.C1.acrostic.notice1 = "ἔχων Ἀκροστιχίδα·"
meMA.C1.acrostic.text = "Πλάνης ἀνυμνῶ δεξιοὺς καθαιρέτας."
meMA.C1.acrostic.notice2 = "Ἐν δὲ τοῖς Θεοτοκίοις· Φιλόθεος."
meMA.C1.title = titles_gr_GR_cog.ti.Canon1Fathers
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintsM.text

meMA.C2.title = titles_gr_GR_cog.ti.Canon2Fathers
meMA.C2.verse = prayers_gr_GR_cog.pr.verse_SaintsM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C11.greekmelody = he.h.m1_gr_GR_cog.heHE.SouITropaiouchos.greekname
meMA.Ode1C11.melody = he.h.m1_gr_GR_cog.heHE.SouITropaiouchos.name
meMA.Ode1C11.incipit = "Πλάνης καθαιρέτας…"
meMA.Ode1C11.text = "Πλάνης καθαιρέτας δεξιούς, νῦν ἀνυμνῆσαι προθέμενος Δέσποτα, χάριν τὴν σὴν ἄνωθεν, τὴν πανσθενῆ καλῶ καὶ τὴν ἐνέργειαν· δεξιὰ γὰρ ὄντως, σὺ τοῦ Πατρός τε καὶ δύναμις."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C12.melody = he.h.m1_gr_GR_cog.heHE.SouITropaiouchos.name
meMA.Ode1C12.incipit = "Λόγοις Προφητῶν…"
meMA.Ode1C12.text = "Λόγοις Προφητῶν τῶν ἱερῶν, Εὐαγγελίων τε νόμοις ἑπόμενοι, τοῦ Θεοῦ τὸ ἄγνωστον, καὶ τὸ γνωστὸν σαφῶς ἡμᾶς ἐδίδαξαν, οἱ σοφοὶ Πατέρες, τῆς πλάνης πάντας ῥυσάμενοι."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C13.melody = he.h.m1_gr_GR_cog.heHE.SouITropaiouchos.name
meMA.Ode1C13.incipit = "Ἄνωθεν χορὸς προφητικός…"
meMA.Ode1C13.text = "Ἄνωθεν χορὸς προφητικός, καὶ Ἀποστόλων ὁ θεῖος κατάλογος, ἕνα τρισυπόστατον, Θεὸν τρανῶς καὶ πανσθενῆ ἐδίδαξαν· ὃν σεπτοὶ Πατέρες, σαφῶς ἡμῖν ἐξεκάλυψαν."

meMA.Ode1C14.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C14.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C14.melody = he.h.m1_gr_GR_cog.heHE.SouITropaiouchos.name
meMA.Ode1C14.incipit = "Νόμοις πειθαρχοῦντες…"
meMA.Ode1C14.text = "Νόμοις πειθαρχοῦντες θεϊκοῖς, οἱ θεοφόροι Πατέρες ἐδίδαξαν, κατʼ οὐσίαν ἄγνωστον, τὸν ποιητὴν ἁπάντων χρηματίζοντα, ἐνεργείαις μόναις, καλῶς νοεῖσθαι τοῖς βλέπουσι."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C1T.melody = he.h.m1_gr_GR_cog.heHE.SouITropaiouchos.name
meMA.Ode1C1T.incipit = "Φῶς τὸ τριλαμπὲς…"
meMA.Ode1C1T.text = "Φῶς τὸ τριλαμπὲς θεουργικῶς, ἐν τῇ γαστρί σου χωρήσασα Δέσποινα, τὰς καρδίας φώτισον, ὡς ἀγαθὴ τῶν εὐσεβῶς ὑμνούντων σε· φῶς γὰρ σὺ καὶ δόξα, καὶ σωτηρία αἰώνιος."

meMA.Ode1C21.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C21.greekmelody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.greekname
meMA.Ode1C21.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C21.incipit = "Ἡ τῶν Πατέρων, εὐσεβὴς ὁμήγυρις…"
meMA.Ode1C21.text = "Ἡ τῶν Πατέρων, εὐσεβὴς ὁμήγυρις, ἡ κροτηθεῖσα ποτέ, κατʼ Εὐτυχοῦς ὄντως, τὸν Σωτῆρα ὥρισεν, ἀδιαιρέτοις φύσεσιν, ἐν δυσὶ τοῖς τοῦ θείου Πατρὸς Κυρίλλου διδάγμασι, βαίνουσα σαφῶς καὶ ἐμμένουσα."

meMA.Ode1C22.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C22.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C22.incipit = "Ἑξακοσίων, ὁ ἀριθμὸς τριάκοντα, εὐσεβεστάτων…"
meMA.Ode1C22.text = "Ἑξακοσίων, ὁ ἀριθμὸς τριάκοντα, εὐσεβεστάτων ἀνδρῶν, τὴν Εὐτυχοῦς πλάνην, καὶ Σεβήρου αἵρεσιν, καταβαλόντες ἔφασαν. Ἐν δυσὶ ταῖς οὐσίαις, Χριστὸν κηρύττομεν, βαίνοντες ἔπεσι Κυρίλλου τοῦ μάκαρος."

meMA.Ode1C23.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C23.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C23.incipit = "Ὁ μὴ κηρύττων, ἐν δυσὶ…"
meMA.Ode1C23.text = "Ὁ μὴ κηρύττων, ἐν δυσὶ ταῖς φύσεσι, καὶ ἐνεργείαις Χριστόν, τὸν τοῦ Πατρὸς Λόγον, σχοίη τὸ ἀνάθεμα· ἡ γὰρ τετάρτη Σύνοδος, τῶν Ἁγίων Πατέρων, ἐμφρόνως οὕτως ἐθέσπισε. Πάντες οὖν αὐτοὺς μακαρίσωμεν."

meMA.Ode1C2T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C2T.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C2T.incipit = "Δεδοξασμένα, περὶ σοῦ λελάληνται, ἐν…"
meMA.Ode1C2T.text = "Δεδοξασμένα, περὶ σοῦ λελάληνται, ἐν γενεαῖς γενεῶν, ἡ τὸν Θεὸν Λόγον, ἐν γαστρὶ χωρήσασα, ἁγνὴ δὲ διαμείνασα, Θεοτόκε Μαρία· διό σε πάντες γεραίρομεν, τὴν μετὰ Θεὸν προστασίαν ἡμῶν."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C11.greekmelody = he.h.m1_gr_GR_cog.heHE.OMonosEidos.greekname
meMA.Ode3C11.melody = he.h.m1_gr_GR_cog.heHE.OMonosEidos.name
meMA.Ode3C11.incipit = "Ἡ πρώτη πηγὴ…"
meMA.Ode3C11.text = "Ἡ πρώτη πηγὴ τῶν ἀγαθῶν, ἡ χάρις ἡ τοῦ Πνεύματος, ὡς ποταμοὺς ὑμᾶς ἀνεστόμωσε, τὴν πλάνην Ἔνδοξοι κατασύροντας, καὶ πιστοὺς ποτίζοντας, εὐσεβείας νάματα, Προφητῶν Ἀποστόλων τὸ κήρυγμα."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C12.melody = he.h.m1_gr_GR_cog.heHE.OMonosEidos.name
meMA.Ode3C12.incipit = "Σέργιον καὶ Πύῤῥον…"
meMA.Ode3C12.text = "Σέργιον καὶ Πύῤῥον τοὺς δεινούς, προστάτας τῆς αἱρέσεως, Παῦλον καὶ Πέτρον καὶ τὸν Θεόδωρον, γενναίως ἅμα σοφοὶ καθείλετε, τὴν σεπτὴν στηρίξαντες, Ἐκκλησίαν ἔνδοξοι, Ἀποστόλων Πατέρων τοῖς δόγμασιν."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C13.melody = he.h.m1_gr_GR_cog.heHE.OMonosEidos.name
meMA.Ode3C13.incipit = "Ἀνάρχου Θεότητος…"
meMA.Ode3C13.text = "Ἀνάρχου Θεότητος τρανῶς, ἐνέργειαν συνάναρχον, οἱ θεοφόροι ἀνακηρύξαντες, κτιστὴν ἐδίδαξαν τὴν ἐνέργειαν, τοῦ κτιστοῦ προσλήμματος, ἐν διπλόῃ φύσεων, Υἱόν ἕνα Χριστὸν καταγγείλαντες."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C1T.melody = he.h.m1_gr_GR_cog.heHE.OMonosEidos.name
meMA.Ode3C1T.incipit = "Ἰδεῖν οἱ ποθοῦντες…"
meMA.Ode3C1T.text = "Ἰδεῖν οἱ ποθοῦντες τὰς αὐγάς, τῆς χάριτος τοῦ Πνεύματος, καὶ τὴν ἀνέσπερον θείαν ἔλλαμψιν, πηγῇ προσδράμωμεν τῇ τῆς χάριτος, τῇ Μητρὶ τοῦ κτίσαντος· ἐν αὐτῇ γὰρ ἅπαντα, τοῖς πιστοῖς χορηγεῖται τὰ βέλτιστα."

meMA.Ode3C21.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C21.greekmelody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.greekname
meMA.Ode3C21.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C21.incipit = "Οἱ τῆς Σεβήρου ἀναιδῶς…"
meMA.Ode3C21.text = "Οἱ τῆς Σεβήρου ἀναιδῶς ἐναβρυνόμενοι λόγοις, τοῖς ἰοῦ θανατηφόρου ἐμπλέοις, καταισχύνθητε ἀεί, ἀποχωροῦντες ἅπαντες, τῆς Ἐκκλησίας ὥσπερ λύκοι καὶ κύνες ἁρπάκτορες."

meMA.Ode3C22.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C22.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C22.incipit = "Οἱ θιασῶται καὶ πιστοί, τὸν…"
meMA.Ode3C22.text = "Οἱ θιασῶται καὶ πιστοί, τὸν παντουργὸν καὶ Σωτῆρα, ἐν δυσὶν ἀδιαιρέτοις οὐσίαις, καὶ θελήσεσι διτταῖς, καὶ ἐνεργείαις σέβομεν, τὴν τοῦ Σεβήρου πλάνην· ὅθεν εἰς τέλος τροπούμεθα."

meMA.Ode3C23.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C23.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C23.incipit = "Δεῦτε Σεβήρου Εὐτυχοῦς, καὶ Ἰακώβου…"
meMA.Ode3C23.text = "Δεῦτε Σεβήρου Εὐτυχοῦς, καὶ Ἰακώβου τὴν πλάνην, Θεοδώρου Διοσκόρου σὺν τούτοις, ἀποθώμεθα τρανῶς, τὴν δὲ τετάρτην Σύνοδον, τῶν εὐσεβῶν Πατέρων, μέλψωμεν θείοις ἐν ᾄσμασι."

meMA.Ode3C2T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C2T.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C2T.incipit = "Τῶν Χερουβὶμ καὶ Σεραφίμ, ἐδείχθης…"
meMA.Ode3C2T.text = "Τῶν Χερουβὶμ καὶ Σεραφίμ, ἐδείχθης ὑψηλοτέρα, Θεοτόκε· σὺ γὰρ μόνη ἐδέξω, τὸν ἀχώρητον Θεόν, ἐν σῇ γαστρὶ ἀμόλυντε· διὸ πιστοί σε πάντες, ὕμνοις ἁγνὴ μακαρίζομεν."

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3Kathisma1.greekmelody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.greekname
meMA.Ode3Kathisma1.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
meMA.Ode3Kathisma1.incipit = "Φωστῆρες ὑπέρλαμπροι…"
meMA.Ode3Kathisma1.text = "Φωστῆρες ὑπέρλαμπροι, τῆς ἀληθείας Χριστοῦ, τῷ κόσμῳ ἐδείχθητε, ἐπὶ τῆς γῆς ἀληθῶς, Πατέρες μακάριοι, τήξαντες τὰς αἱρέσεις, τῶν δυσφήμων γλωσσάλγων, σβέσαντες τὰς φλογώδεις, τῶν βλασφήμων συγχύσεις· διὸ ὡς Ἱεράρχαι Χριστοῦ, πρεσβεύσατε σωθῆναι ἡμᾶς."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3KathismaT.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
meMA.Ode3KathismaT.incipit = me.m03.d28_gr_GR_cog.meMA.Ode3KathismaT.incipit
meMA.Ode3KathismaT.text = me.m03.d28_gr_GR_cog.meMA.Ode3KathismaT.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C11.greekmelody = he.h.m1_gr_GR_cog.heHE.OrosSeTiChariti.greekname
meMA.Ode4C11.melody = he.h.m1_gr_GR_cog.heHE.OrosSeTiChariti.name
meMA.Ode4C11.incipit = "Νόμους τοὺς τοῦ Πνεύματος…"
meMA.Ode4C11.text = "Νόμους τοὺς τοῦ Πνεύματος, μελέτην ποιούμενοι, τοὺς πρακτικοὺς νόμους σοφοί, καταπεμφθέντας πρὸς ὑμᾶς, ἐκ Ῥώμης ἐδέξασθε, καὶ ἀναπτύξαντες φωτὶ τῷ τοῦ Πνεύματος, τὴν Ἐκκλησίαν καλῶς ἐστηρίξατε."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C12.melody = he.h.m1_gr_GR_cog.heHE.OrosSeTiChariti.name
meMA.Ode4C12.incipit = "Ὕμνοις καταστέψωμεν…"
meMA.Ode4C12.text = "Ὕμνοις καταστέψωμεν, τὴν θείαν ὁμήγυριν, τῶν θεοφόρων οἱ πιστοί· τὸν σαρκωθέντα Λόγον γάρ, Θεόν τε καὶ ἄνθρωπον, ταῖς ἐνεργείαις ἅμα καὶ τοῖς θελήμασι, τοῖς καταλλήλοις ἡμῖν ἀνεκήρυξαν."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C13.melody = he.h.m1_gr_GR_cog.heHE.OrosSeTiChariti.name
meMA.Ode4C13.incipit = "Μέγιστα φυσώμενον…"
meMA.Ode4C13.text = "Μέγιστα φυσώμενον, Ὁνώριον πάνσοφοι, ἐπὶ τῷ θρόνῳ καὶ ἀρχῇ, Ῥώμης ποτὲ τῆς παλαιᾶς, καλῶς κατεστρέψατε, καὶ μετὰ τέλος τοῦτον ἀποκηρύξαντες, ὡς τῆς ἀρχῆς καὶ τοῦ θρόνου ἀνάξιον."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C1T.melody = he.h.m1_gr_GR_cog.heHE.OrosSeTiChariti.name
meMA.Ode4C1T.incipit = "Λόγον ἐνυπόστατον…"
meMA.Ode4C1T.text = "Λόγον ἐνυπόστατον, Παρθένε γεννήσασα, Θεοῦ καὶ φῶς ἀληθινόν, τοὺς ὀφθαλμούς μου τῆς ψυχῆς, διάνοιξον δέομαι, καὶ τῆς ἐκεῖθεν αἴγλης μέτοχον ποίησον· σὺ γὰρ μεσῖτις αὐτοῦ τε καὶ πρύτανις."

meMA.Ode4C21.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C21.greekmelody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.greekname
meMA.Ode4C21.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C21.incipit = "Φράσον ἡμῖν, ἄφρον Σεβῆρε καὶ…"
meMA.Ode4C21.text = "Φράσον ἡμῖν, ἄφρον Σεβῆρε καὶ μάταιε, μίαν φύσιν, σύνθετον τὸν ἄναρχον, φῶς τοῦ Πατρὸς Λόγον καὶ Υἱόν· εἰ γὰρ οὕτως εἴποις, καὶ ἄλλην φύσιν ἐσήμανας· ἡ σάρξ γὰρ καὶ ὁ Λόγος, οὐχὶ μία οὐσία, ἀλλὰ δύο ὑπάρχουσιν ἄθλιε."

meMA.Ode4C22.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C22.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C22.incipit = "Μίαν εἰπών, φύσιν τοῦ Λόγου…"
meMA.Ode4C22.text = "Μίαν εἰπών, φύσιν τοῦ Λόγου ἐπήγαγε, σαρκωθεῖσαν, φύσιν ἀνθρωπότητος, ἄνευ τροπῆς, ὅλως καὶ φυρμοῦ, ὁ Ἀλεξανδρέων, διδάσκαλός τε καὶ πρόεδρος, τρανῶς τὰς δύο φύσεις, καὶ θελήσεις διδάσκων, τοὺς φρονεῖν ὀρθοδόξως ἐθέλοντας."

meMA.Ode4C23.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C23.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C23.incipit = "Δύο Χριστοῦ, ἅπαντες φύσεις κηρύττομεν…"
meMA.Ode4C23.text = "Δύο Χριστοῦ, ἅπαντες φύσεις κηρύττομεν, ἀσυγχύτως, πᾶσαν τὴν δυσσέβειαν, τοῦ Εὐτυχοῦς, ἄρδην οἱ πιστοί, καὶ τοῦ Διοσκόρου, τοῦ ἄφρονος στηλιτεύοντες, ἑπόμενοι τῷ ὅρῳ, τῶν Ἁγίων Πατέρων, καὶ Κυρίλλου τοῦ θείου τοῖς ἔπεσι."

meMA.Ode4C2T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C2T.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C2T.incipit = "Χερουβικόν, ὄχημα σὺ Θεομῆτορ ἁγνή…"
meMA.Ode4C2T.text = "Χερουβικόν, ὄχημα σὺ Θεομῆτορ ἁγνή, σὺ χωρίον, σὺ καὶ ἐνδιαίτημα, τοῦ πατρικοῦ, Λόγου καὶ Θεοῦ, τοῦ ἐκ σῶν ἀχράντων, λαγόνων σάρκα φορέσαντος· διὸ διτταῖς οὐσίαις, τὸν ἐκ σοῦ σαρκωθέντα, προσκυνοῦντες ἀπαύστως δοξάζομεν."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C11.greekmelody = he.h.m1_gr_GR_cog.heHE.OFotisasTiEllampsei.greekname
meMA.Ode5C11.melody = he.h.m1_gr_GR_cog.heHE.OFotisasTiEllampsei.name
meMA.Ode5C11.incipit = "Νομοθέτας θεοφόροι…"
meMA.Ode5C11.text = "Νομοθέτας θεοφόροι Χριστὸς ὑμᾶς ἔδειξεν, ὁδηγοῦντας ὡς Μωσῆς Ἰσραὴλ νέον ἄριστα, Φαραὼ τὸν ἔχθιστον, βυθῷ δεινῷ τῆς ἀπωλείας, ὥσπερ ἐκεῖνος ποντίσαντας."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C12.melody = he.h.m1_gr_GR_cog.heHE.OFotisasTiEllampsei.name
meMA.Ode5C12.incipit = "Ὡς καλλίστη καὶ λαμπρὰ…"
meMA.Ode5C12.text = "Ὡς καλλίστη καὶ λαμπρὰ τῶν Πατέρων ἡ Σύνοδος· τὸν ἁπλοῦν γὰρ Ἰησοῦν ἐκμαθοῦσα καὶ σύνθετον, ὡς Θεὸν καὶ ἄνθρωπον, διπλᾶς αὐτοῦ τὰς ἐνεργείας, πᾶσι κηρύττει τοῖς πέρασι."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C13.melody = he.h.m1_gr_GR_cog.heHE.OFotisasTiEllampsei.name
meMA.Ode5C13.incipit = "Δῶρον θεῖον…"
meMA.Ode5C13.text = "Δῶρον θεῖον τὰς ἐκ Ῥώμης γραφὰς λογισάμενοι, ἐπʼ ἐκείναις εὐσεβείας τὸν πύργον ἐστήριξαν, οἱ σοφοὶ Διδάσκαλοι, διττὰς Χριστοῦ τὰς ἐνεργείας, ὡς καὶ τὰς φύσεις κηρύξαντες."

meMA.Ode5C14.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C14.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C14.melody = he.h.m1_gr_GR_cog.heHE.OFotisasTiEllampsei.name
meMA.Ode5C14.incipit = "Ἐξηλέγχθη Παῦλος…"
meMA.Ode5C14.text = "Ἐξηλέγχθη Παῦλος Πέτρος ὁμοῦ καὶ Θεόδωρος, σὺν τῷ Πύῤῥῳ καὶ Σεργίῳ Ὁνώριος σύγχυσιν, τοῦ Χριστοῦ τῶν φύσεων, τῆς ἐνεργείας τῇ συγχύσει, κατασκευάζοντες αἴσχιστα."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C1T.melody = he.h.m1_gr_GR_cog.heHE.OFotisasTiEllampsei.name
meMA.Ode5C1T.incipit = "Ὅλη Κόρη φωτισμὸς…"
meMA.Ode5C1T.text = "Ὅλη Κόρη φωτισμὸς σὺ ὑπάρχεις καὶ ἔλλαμψις, τοῦ ἀδύτου φωτισμοῦ χρηματίσασα τέμενος· διὰ τοῦτο δέομαι, φωτὶ τῷ σῷ Θεογεννῆτορ, ψυχῆς τὰς κόρας μου φώτισον."

meMA.Ode5C21.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C21.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
meMA.Ode5C21.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C21.incipit = "Ὦ Σεβῆρε τὰς φύσεις, τοῦ…"
meMA.Ode5C21.text = "Ὦ Σεβῆρε τὰς φύσεις, τοῦ Χριστοῦ μὴ συγχέῃς δεινῶς παράνομε· οἱ γὰρ θιασῶται, καὶ παμμάκαρες πάντες Διδάσκαλοι, ἐν δυσὶν οὐσίαις, καὶ ἐν ἑνὶ Χριστὸν προσώπῳ, καταγγείλαντες πᾶσιν ἐξέθεντο."

meMA.Ode5C22.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C22.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C22.incipit = "Προσελάβετο φύσιν, τὴν τῆς ἀνθρωπότητος…"
meMA.Ode5C22.text = "Προσελάβετο φύσιν, τὴν τῆς ἀνθρωπότητος σαφῶς ὁ ἄναρχος, τοῦ Πατρὸς ὁ Λόγος, ὡς φιλάνθρωπος, θέλων οἰκτῖραι ἡμᾶς, τοὺς ἀπολωλότας· ὅθεν αὐτὸν ἀνακηρύττω, ἐν οὐσίαις δυσὶ καὶ θελήμασι."

meMA.Ode5C23.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C23.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C23.incipit = "Τὸν Σεβῆρον καθεῖλεν, ἡ τετάρτη…"
meMA.Ode5C23.text = "Τὸν Σεβῆρον καθεῖλεν, ἡ τετάρτη Σύνοδος καὶ τὸν Διόσκορον, Χριστὸν βλασφημοῦντας, βεβαιοῦσα τὸν τόμον τοῦ Λέοντος, τοῦ Προέδρου Ῥώμης, πάνυ καλῶς τὰς δύο φύσεις, τοῦ Σωτῆρος ἀτμήτως ὁρίζοντα."

meMA.Ode5C2T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C2T.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C2T.incipit = "Μητρικὴν παῤῥησίαν, τὴν πρὸς τὸν…"
meMA.Ode5C2T.text = "Μητρικὴν παῤῥησίαν, τὴν πρὸς τὸν Υἱόν σου κεκτημένη Πάναγνε, συγγενοῦς προνοίας, τῆς ἡμῶν μὴ παρίδῃς δεόμεθα, ὅτι σὲ καὶ μόνην, Χριστιανοὶ πρὸς τὸν Δεσπότην, ἱλασμὸν εὐμενῆ προβαλλόμεθα."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C11.greekmelody = he.h.m1_gr_GR_cog.heHE.SplanchnonIonan.greekname
meMA.Ode6C11.melody = he.h.m1_gr_GR_cog.heHE.SplanchnonIonan.name
meMA.Ode6C11.incipit = "Ξένην καὶ καινήν…"
meMA.Ode6C11.text = "Ξένην καὶ καινήν, σύγχυσιν τῶν φύσεων, Χριστοῦ τὸ δεινόν, ὄντως συνέδριον, ἐξηρεύξαντο, τὰς διττὰς ἐνεργείας συγχέαντες, εἰς ἐνέργειαν, τὴν μίαν καὶ ἀλλόκοτον· ἥνπερ, ὀρθοδόξων πλήρωμα, ἱερῶν περιβόλων ἀπήλασεν."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C12.melody = he.h.m1_gr_GR_cog.heHE.SplanchnonIonan.name
meMA.Ode6C12.incipit = "Ἵνα τὸν δεινόν…"
meMA.Ode6C12.text = "Ἵνα τὸν δεινόν, ἐκφύγῃ Νεστόριον, δυάδα υἱῶν, κακῶς εἰσάγοντα, τὸ συνέδριον, τὸ τῆς πλάνης ἐκ βόθρου εἰς βάραθρον, ἐξωλίσθησε, θελήσεων καὶ φύσεων, μάτην δογματίζον σύγχυσιν· ἀλλὰ θείοις Πατράσι διήλεγκται."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C13.melody = he.h.m1_gr_GR_cog.heHE.SplanchnonIonan.name
meMA.Ode6C13.incipit = "Ὅνπερ τῷ Πατρί…"
meMA.Ode6C13.text = "Ὅνπερ τῷ Πατρί, Υἱὸν ὁμοούσιον, Πατέρες τὸ πρίν, τρανῶς ἐκήρυξαν, σὺν τῷ Πνεύματι, Διδασκάλων ἐνθέων ὁ σύλλογος, ἐνεργείαις, θεϊκαῖς πάντας ἐδίδαξαν, μίαν φυσικὴν γνωρίσαντες, τὴν ἐνέργειαν ἅμα καὶ θέλησιν."

meMA.Ode6C14.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C14.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C14.melody = he.h.m1_gr_GR_cog.heHE.SplanchnonIonan.name
meMA.Ode6C14.incipit = "Ὑποστατικήν, φρονοῦντες…"
meMA.Ode6C14.text = "Ὑποστατικήν, φρονοῦντες τὴν θέλησιν, εἰσῆγον κακῶς, σὺν ταῖς θελήσεσι, καὶ τὰ πρόσωπα, τῶν θελόντων τῆς πλάνης οἱ πρόμαχοι· οὕς περ, κάλλιστα Πατέρες ἐξελέγξαντες, φύσει συμφυῆ διδάσκουσι, τὴν κατάλληλον ταύτης ἐνέργειαν."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C1T.melody = he.h.m1_gr_GR_cog.heHE.SplanchnonIonan.name
meMA.Ode6C1T.incipit = "Θύρα θεϊκῆς…"
meMA.Ode6C1T.text = "Θύρα θεϊκῆς, ἀκτῖνος σὺ Δέσποινα, πηγή τε φωτός, ἀδύτου γέγονας· τὸ γὰρ πλήρωμα, τῆς Θεότητος ἅπαν ἐσκήνωσεν, ἀποῤῥήτως, ἐν τῇ μήτρᾳ σου πανάμωμε· οὗπερ, φυσικὴν ἐνέργειαν, καὶ τὴν αἴγλην βραβεύεις τοῖς χρῄζουσιν."

meMA.Ode6C21.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C21.greekmelody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.greekname
meMA.Ode6C21.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C21.incipit = "Αἱ δύο ἐπιστολαί, Κυρίλλου αἱ…"
meMA.Ode6C21.text = "Αἱ δύο ἐπιστολαί, Κυρίλλου αἱ πρὸς τὸν Σούκενσον, ἀποσταλεῖσαι ποτέ, Ἑῴας τὸν πρόεδρον, ἐλέγχουσιν ἅπασαν, τὴν Σεβήρου πλάνην, εὐσεβῶς Χριστὸν κηρύττουσαι."

meMA.Ode6C22.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C22.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C22.incipit = "Ὁ Κύριλλος τὸν Χριστόν, κηρύττει…"
meMA.Ode6C22.text = "Ὁ Κύριλλος τὸν Χριστόν, κηρύττει ἐν δύο φύσεσι, καὶ ἐνεργείαις διτταῖς, Σεβήρου τὴν αἵρεσιν, τοῦ ἄνου τρεπόμενος· διὸ πάντες τούτου, τοῖς διδάγμασιν ἐμμένομεν."

meMA.Ode6C2T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C2T.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C2T.incipit = "Παρθένον σε καὶ ἁγνήν, Θεογεννήτορα…"
meMA.Ode6C2T.text = "Παρθένον σε καὶ ἁγνήν, Θεογεννήτορα ἔνδοξον, Μαρία οἱ εὐσεβεῖς, κυρίως κηρύττομεν, ἐμφράττοντες δύσφημον Νεστορίου στόμα, Διοσκόρου τε κακόνοιαν."

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Kontakion1.melody = "Αὐτόμελον."
meMA.Kontakion1.incipit = "Τῶν Ἀποστόλων τὸ κήρυγμα…"
meMA.Kontakion1.text = "Τῶν Ἀποστόλων τὸ κήρυγμα, καὶ τῶν Πατέρων τὰ δόγματα, τῇ Ἐκκλησίᾳ μίαν τὴν πίστιν ἐκράτυνεν· ἣ καὶ χιτῶνα φοροῦσα τῆς ἀληθείας, τὸν ὑφαντὸν ἐκ τῆς ἄνω θεολογίας, ὀρθοτομεῖ καὶ δοξάζει, τῆς εὐσεβείας τὸ μέγα μυστήριον."

meMA.Oikos1.text = "Ἐν ὑψηλῷ κηρύγματι, τῆς τοῦ Θεοῦ Ἐκκλησίας, ἀκούσωμεν βοώσης· Ὁ διψῶν, ἐρχέσθω καὶ πινέτω· ὁ κρατήρ, ὃν φέρω, κρατήρ ἐστι σοφίας. Τούτου τὸ πόμα, ἀληθείας λόγῳ κεκέρακα, ὕδωρ οὐ προχέω ἀντιλογίας, ἀλλʼ ὁμολογίας, ἧς πίνων ὁ νῦν Ἰσραήλ, Θεὸν ὁρᾷ φθεγγόμενον· Ἴδετε ἴδετε, ὅτι αὐτὸς ἐγώ εἰμι, καὶ οὐκ ἠλλοίωμαι. Ἐγὼ Θεὸς πρῶτος, ἐγὼ καὶ μετὰ ταῦτα, καὶ πλήν μου ἄλλος οὐκ ἔστιν ὅλως. Ἐντεύθεν οἱ μετέχοντες πλησθήσονται, καὶ αἰνέσουσι τῆς εὐσεβείας τὸ μέγα μυστήριον."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C11.greekmelody = he.h.m1_gr_GR_cog.heHE.SeNoitin.greekname
meMA.Ode7C11.melody = he.h.m1_gr_GR_cog.heHE.SeNoitin.name
meMA.Ode7C11.incipit = "Σὲ τὸν Υἱόν…"
meMA.Ode7C11.text = "Σὲ τὸν Υἱόν, τοῦ Θεοῦ καὶ ἄνθρωπον, κατανοήσαντες χοροί, θεολόγων Δέσποτα πρίν, κόσμῳ σε ἐκήρυξαν, διπλοῦν ταῖς θελήσεσι, καὶ ἐνεργείαις φιλάνθρωπε, σοῦ τὸ διπλοῦν ἑκατέρας, τῶν φύσεων πιστούμενοι."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C12.melody = he.h.m1_gr_GR_cog.heHE.SeNoitin.name
meMA.Ode7C12.incipit = "Κόσμος λαμπρός…"
meMA.Ode7C12.text = "Κόσμος λαμπρός, Ἐκκλησίας ὤφθητε· τῶν Ἀποστόλων γὰρ καλῶς, ἐκδεξάμενοι τὰ θεσμά, πάντας ἐδιδάξατε, λόγον τὸν τῆς πίστεως, τριαδικὸν ἕνα Κύριον, δημιουργὸν ἐνεργόν, θελητικὸν παντοδύναμον."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C13.melody = he.h.m1_gr_GR_cog.heHE.SeNoitin.name
meMA.Ode7C13.incipit = "Ἄκτιστον φῶς…"
meMA.Ode7C13.text = "Ἄκτιστον φῶς, καὶ ζωὴν ἀθάνατον, κατανοήσαντες Θεόν, ὑπὲρ ταῦτα τοῦτον καλῶς, πᾶσιν ἐκηρύξατε, φύσεως κατώτερα, τὰ φυσικὰ ἰδιώματα, τὰ συμφυῆ ἐγνωκότες, ὁμοῦ καὶ ἀδιαίρετα."

meMA.Ode7C14.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C14.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C14.melody = he.h.m1_gr_GR_cog.heHE.SeNoitin.name
meMA.Ode7C14.incipit = "Θείου φωτός…"
meMA.Ode7C14.text = "Θείου φωτός, ἀστραπὰς ἐξέπεμψεν, ὑμᾶς εἰς κόσμον ὁ Χριστός, τοὺς τῆς πλάνης δημιουργούς, ἄρδην καταφλέγοντας· πᾶσαν δὲ φωτίζοντας, τὴν Ἐκκλησίαν μακάριοι, τὸν αἰνετὸν ἀνυμνοῦντας, Θεὸν καὶ παντοδύναμον."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C1T.melody = he.h.m1_gr_GR_cog.heHE.SeNoitin.name
meMA.Ode7C1T.incipit = "Ἔλαμψε φῶς…"
meMA.Ode7C1T.text = "Ἔλαμψε φῶς, ὁ Χριστὸς ἀνέσπερον, ἐκ σῆς νηδύος προελθών, καὶ τὸν κόσμον ἔσωσε πρίν, ὁ ὑπερυψούμενος· ὅν περ καθικέτευε, Θεογεννῆτορ φωτίσαι μου, τῆς σκοτισθείσης καρδίας, τὰ νοούμενα ὄμματα."

meMA.Ode7C21.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C21.greekmelody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.greekname
meMA.Ode7C21.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C21.incipit = "Δυσὶ μὲν ἐν φύσεσι…"
meMA.Ode7C21.text = "Δυσὶ μὲν ἐν φύσεσι, καὶ ἐνεργείαις ὁμολογοῦντες Χριστόν, ἀσυγχύτως ἀτρέπτως, τὴν τοῦ Σεβήρου πλάνην τροπούμεθα· ὅθεν τὸ πάθος προσλήψει ὑποίσαντι σαρκός, βοῶμεν αὐτῷ· Εὐλογητὸς ὁ Θεὸς ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C22.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C22.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C22.incipit = "Ἕνα ἐπιστάμεθα, τὸν ἐπὶ ξύλου…"
meMA.Ode7C22.text = "Ἕνα ἐπιστάμεθα, τὸν ἐπὶ ξύλου καὶ ἐν τοῖς κόλποις Πατρός, ὡς Θεὸν ἐν ὑψίστοις, καὶ ἐν μνημείῳ ὡς συνημμένον σαρκί, ᾧ μελῳδοῦμεν, συμφώνως κραυγάζοντες· Εὐλογητὸς ὁ Θεὸς ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C23.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C23.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C23.incipit = "Ἀρείου τὴν κένωσιν, κατατομήν τε…"
meMA.Ode7C23.text = "Ἀρείου τὴν κένωσιν, κατατομήν τε τοῦ σμικροθέου, πιστοὶ τὴν συναίρεσιν αὖθις, τοῦ Σαβελλίου, τῶν τῆς Τριάδος ἐχθρῶν μεμισηκότες, Τριάδι κραυγάζομεν· Εὐλογητός ὁ Θεὸς ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C2Tr.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C2Tr.incipit = "Ἁπάντων μὲν Κύριον, ἑνὸς δὲ…"
meMA.Ode7C2Tr.text = "Ἁπάντων μὲν Κύριον, ἑνὸς δὲ μόνου μονογενοῦς Υἱοῦ, ὀρθοδόξως Πατέρα, θεολογοῦντές σε καταγγέλλομεν, καὶ ἓν εἰδότες, σοῦ ἐκπορευόμενον, Πνεῦμα εὐθὲς συμφυές, καὶ συναΐδιον."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C11.greekmelody = he.h.m1_gr_GR_cog.heHE.EnKaminoPaides.greekname
meMA.Ode8C11.melody = he.h.m1_gr_GR_cog.heHE.EnKaminoPaides.name
meMA.Ode8C11.incipit = "Ἀποστόλων τε καὶ Προφητῶν…"
meMA.Ode8C11.text = "Ἀποστόλων τε καὶ Προφητῶν, ὡς ἐξ ὁρμητηρίου, Πατέρες κεκινημένοι, τῆς ἐνθέου διδαχῆς, ἐκήρυξαν λέγοντες· Εἷς ὑπάρχει Κύριος πάντων, Χριστὸς ἐν ὑποστάσει, διπλοῦς τὰς φύσεις, ὁμοῦ καὶ ἐνεργείας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C12.melody = he.h.m1_gr_GR_cog.heHE.EnKaminoPaides.name
meMA.Ode8C12.incipit = "Ἵνα πλάνην πᾶσαν…"
meMA.Ode8C12.text = "Ἵνα πλάνην πᾶσαν ἀναιδῆ, καλῶς καὶ βλασφημίαν, Πατέρες τῆς Ἐκκλησίας, ἐξορίσωσιν ὁμοῦ, ἐνέργειαν θέλησιν οὐσιώδη, ἄκτιστον φέρειν τὸν Κύριον ἀνεῖπον, τὴν κτιστὴν δὲ πάλιν, ὡς Ἄνθρωπον καὶ Κτίστην."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C13.melody = he.h.m1_gr_GR_cog.heHE.EnKaminoPaides.name
meMA.Ode8C13.incipit = "Ῥῆμα θεῖον σχόντες…"
meMA.Ode8C13.text = "Ῥῆμα θεῖον σχόντες ἐν χερσί, Πατέρες ὥς περ ξίφος, ἐχθροὺς τοὺς τῆς εὐσεβείας κατεπλήξατε καλῶς, ἐνέργειαν θέλησιν τοῦ Σωτῆρος, πάντα τε τούτου τὰ φυσικὰ προσφόρως, διπλᾶ προσειπόντες, καθάπερ καὶ τὰς φύσεις."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C1T.melody = he.h.m1_gr_GR_cog.heHE.EnKaminoPaides.name
meMA.Ode8C1T.incipit = "Ὅλη Κόρη ὅλη εἶ καλή…"
meMA.Ode8C1T.text = "Ὅλη Κόρη ὅλη εἶ καλή, ὅλη φωτοειδής τε φωσφόρος καὶ θεοφόρος, ὅλη μόνη καὶ λαμπρά· διό μου τὰ ὄμματα τῆς καρδίας φώτισον, πνέοντος Δέσποινα, τὴν δόξαν σου καὶ τετρωμένου, τῷ πρὸς ἐκείνην πόθῳ."

meMA.Ode8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C21.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
meMA.Ode8C21.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C21.incipit = "Καταισχυνέσθω πρόσωπα, καὶ φιμούσθω τὰ…"
meMA.Ode8C21.text = "Καταισχυνέσθω πρόσωπα, καὶ φιμούσθω τὰ στόματα, τῶν μὴ κηρυττόντων, ἐν δυσὶ ταῖς φύσεσιν, ἀτμήτως ἀτρέπτως τε, καὶ ἀσυγχύτως ἕνα Υἱόν· οἱ γὰρ εὐσεβεῖς, πάντες κοινῶς συμφρονοῦμεν, κατʼ ἄλλο μὲν καὶ ἄλλο, ἐνεργεῖν τε καὶ θέλειν, Χριστὸν οὐ μὴν προσώποις, κατʼ ἄμφω δὲ τὰς φύσεις."

meMA.Ode8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C22.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C22.incipit = "Οἱ Ἰακώβου ἔχοντες τοῦ Κεντόνου…"
meMA.Ode8C22.text = "Οἱ Ἰακώβου ἔχοντες τοῦ Κεντόνου ἐπίκλησιν, ὄνομά τε τούτου, ἑαυτοῖς ἐγγράφοντες, ἡμῖν ἀποφήνατε. Εἰ ἐν τῇ κλήσει τούτου ὑμεῖς, ἐν τῇ κολυμβήθρᾳ, ἐβαπτίσθητε πάλαι· διὸ αὐτοῦ πρὸς χάριν, τοῦ Χριστοῦ ἀποστάντες, ληρεῖτε ὡς ἐκεῖνος, σαφῶς ἀναισχυντοῦντες."

meMA.Ode8C23.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C23.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C23.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C23.incipit = "Ἐν Χαλκηδόνι Σύνοδος, ἡ τετάρτη…"
meMA.Ode8C23.text = "Ἐν Χαλκηδόνι Σύνοδος, ἡ τετάρτη Διόσκορον, Εὐτυχῆ Σεβῆρον, τοὺς δεινοὺς κατέβαλεν, εἰς τέλος ἐξώσασα, τὴν ἀκανθώδη πλάνην αὐτῶν, τὴν συγχυτικήν, τῶν οὐσιῶν τοῦ Σωτῆρος, τῆς θείας Ἐκκλησίας, τοῦ Χριστοῦ καὶ Δεσπότου, μεθʼ ἧς ὀρθοδοξοῦντες, μισήσωμεν δὴ τούτους."

meMA.Ode8C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C2Tr.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C2Tr.incipit = "Τρισσοφαῆ Θεότητα, ἑνιαίαν ἐκλάμπουσαν, αἴγλην…"
meMA.Ode8C2Tr.text = "Τρισσοφαῆ Θεότητα, ἑνιαίαν ἐκλάμπουσαν, αἴγλην ἐκ μιᾶς, τρισυποστάτου φύσεως, Γεννήτορα ἄναρχον, ὁμοφυᾶ τε Λόγον Πατρός, καὶ συμβασιλεῦον, ὁμοούσιον Πνεῦμα· οἱ παῖδες εὐλογεῖτε, ἱερεῖς ἀνυμνεῖτε, λαὸς ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C11.greekmelody = he.h.m1_gr_GR_cog.heHE.TyponTisAgnis.greekname
meMA.Ode9C11.melody = he.h.m1_gr_GR_cog.heHE.TyponTisAgnis.name
meMA.Ode9C11.incipit = "Ἔχοντες Χριστὸν μακάριοι…"
meMA.Ode9C11.text = "Ἔχοντες Χριστὸν μακάριοι, ἐν ἑαυτοῖς τὰ θεῖα πάλαι λαλήσαντα· καὶ νῦν καθαρῶς, τῷ καθαρῷ συναπτόμενοι, τὴν αὐτοῦ Ἐκκλησίαν στηρίξατε, ἣν πόνοις καὶ ἱδρῶσι, μεγίστοις ὄντως παρεστήσατε."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C12.melody = he.h.m1_gr_GR_cog.heHE.TyponTisAgnis.name
meMA.Ode9C12.incipit = "Τύπος καὶ κανὼν…"
meMA.Ode9C12.text = "Τύπος καὶ κανὼν γεγόνατε, τῇ Ἐκκλησίᾳ πάσῃ Θεοῦ τρισόλβιοι, σάρκωσιν Χριστοῦ, θεολογεῖν ἐκδιδάξαντες, τῆς ἀκτίστου μιᾶς τε Θεότητος, τὴν νῦν τε γλωσσαλγίαν, προφητικῶς ἀποκρουσάμενοι."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C13.melody = he.h.m1_gr_GR_cog.heHE.TyponTisAgnis.name
meMA.Ode9C13.incipit = "Ἅπαν δυσσεβείας πρόβλημα…"
meMA.Ode9C13.text = "Ἅπαν δυσσεβείας πρόβλημα, προφητικῶς Πατέρες καλῶς ἐλύσατε, τὴν διαφοράν, τῆς ἐνεργείας διδάξαντες, φυσικὴν ἀδιαίρετον ἄκτιστον, ἀξίως προσειπόντες, καὶ παντουργὸν καὶ παντοδύναμον."

meMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C14.melody = he.h.m1_gr_GR_cog.heHE.TyponTisAgnis.name
meMA.Ode9C14.incipit = "Στόμα τοῦ Θεοῦ…"
meMA.Ode9C14.text = "Στόμα τοῦ Θεοῦ γενόμενοι, ταῖς ἐνεργείαις μόναις καὶ ταῖς ἐκλάμψεσι, μεθεκτὸν αὐτόν, ὡς ἀγαθὸν ἐκηρύξατε, τὸν τῇ φύσει ἀπρόσιτον Ἅγιοι· ὅθεν ὑμᾶς ἀξίως, ὡς εὐεργέτας μακαρίζομεν."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C1T.melody = he.h.m1_gr_GR_cog.heHE.TyponTisAgnis.name
meMA.Ode9C1T.incipit = "Σύ μου τῆς ᾠδῆς…"
meMA.Ode9C1T.text = "Σύ μου τῆς ᾠδῆς πανύμνητε, καὶ κορωνὶς χρυσῆ καὶ θεῖον συμπέρασμα· ἥν περ τῆς φυγῆς, ἐπανελθὼν νῦν ἀνέθηκα, τῷ Υἱῷ σου σεμνὴ εὐχαριστήριον, τὸν ὕμνον σοι συνάγων, ὡς τῶν καλῶν αἰτίᾳ Πάναγνε."

meMA.Ode9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C21.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C21.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9C21.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C21.incipit = "Διῆλθεν ὁ Σεβῆρος τὴν τοῦ…"
meMA.Ode9C21.text = "Διῆλθεν ὁ Σεβῆρος τὴν τοῦ Χριστοῦ, εὐαγῆ Ἐκκλησίαν ὁ δόλιος, καὶ τὴν ποινήν, ψήφῳ τῶν Πατέρων τῶν εὐσεβῶν, της βλασφημίας ἕνεκα, καὶ τῆς στωμυλίας τῆς ἑαυτοῦ, ἐδέξατο δικαίως, καὶ ἔῤῥιπται συλλόγου, τῶν Διδασκάλων ὁ κατάκριτος."

meMA.Ode9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C22.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C22.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C22.incipit = "Τὰς φύσεις τί συγχέεις τὰς…"
meMA.Ode9C22.text = "Τὰς φύσεις τί συγχέεις τὰς τοῦ Χριστοῦ, καὶ φυρμὸν ἀντεισάγεις καὶ σύγκρασιν, τὸ τοῦ Σταυροῦ, πάθος προσαρμόττων καὶ τὴν ταφήν, τῇ ἀπαθεῖ Θεότητι, τοῦ μονογενοῦς Λόγου τοῦ Θεοῦ, ὦ δείλαιε Σεβῆρε; διόπερ τὴν μεγίστην, σοῦ βλασφημίαν βδελυττόμεθα."

meMA.Ode9C2T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C2T.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C2T.incipit = "Ὀφρὺν καὶ θράσος ἅμα τῶν…"
meMA.Ode9C2T.text = "Ὀφρὺν καὶ θράσος ἅμα τῶν δυσμενῶν, ὁ τεχθεὶς ἐκ Παρθένου κατάβαλε, καὶ τὰς βουλάς, τῶν κακοδοξούντων Δημιουργέ, τῶν δὲ πιστῶν τὸ σύστημα, στήριξον ἀκράδαντον ὡς Θεός, τὸ κέρας ἀνυψώσας, καὶ πίστει κραταιώσας, ἵνα σε πάντες μεγαλύνωμεν."

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Exaposteilarion1.greekmelody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.greekname
meMA.Exaposteilarion1.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
meMA.Exaposteilarion1.incipit = "Πατέρων θείων σήμερον…"
meMA.Exaposteilarion1.text = "Πατέρων θείων σήμερον, τὴν μνήμην ἑορτάζοντες, ταῖς παρακλήσεσι τούτων, δεόμεθα πανοικτίρμον· Πάσης βλάβης αἱρέσεων, ρῦσαι λαόν σου, Κύριε, καὶ πάντας καταξίωσον, Πατέρα, Λόγον δοξάζειν, καὶ τὸ πανάγιον Πνεῦμα"

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.ExapTheotokion.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
meMA.ExapTheotokion.incipit = "Ἐν δύο ταῖς θελήσεσι…"
meMA.ExapTheotokion.text = "Ἐν δύο ταῖς θελήσεσι, καὶ φύσεσι Πανάμωμε, μιᾷ δὲ τῇ ὑποστάσει, τίκτεις Θεὸν ἀποῤῥήτως, τὸν διʼ ἡμᾶς πτωχεύσαντα, μέχρι Σταυροῦ θελήματι, καὶ ἡμῖν χαρισάμενον, τὸν τῆς θεότητος πλοῦτον, τῇ ἐκ νεκρῶν Ἀναστάσει."

meMA.Lauds1.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Lauds1.greekmelody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.greekname
meMA.Lauds1.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meMA.Lauds1.incipit = "Ὅλην συγκροτήσαντες…"
meMA.Lauds1.text = "Ὅλην συγκροτήσαντες, τὴν τῆς ψυχῆς ἐπιστήμην, καὶ τῷ θείῳ Πνεύματι, συνδιασκεψάμενοι, τὸ μακάριον, καὶ σεπτὸν Σύμβολον, οἱ σεπτοὶ Πατέρες, θεογράφως διεχάραξαν, ἐν ᾧ σαφέστατα, τῷ Γεγεννηκότι συνάναρχον, τὸν Λόγον ἐκδιδάσκουσι, καὶ παναληθῶς ὁμοούσιον, ταῖς τῶν Ἀποστόλων, ἑπόμενοι προδήλως διδαχαῖς, οἱ εὐκλεεῖς καὶ πανόλβιοι, ὄντως καὶ θεόφρονες."

meMA.Lauds2.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Lauds2.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meMA.Lauds2.incipit = "Ὅλην εἰσδεξάμενοι…"
meMA.Lauds2.text = "Ὅλην εἰσδεξάμενοι, τὴν νοητὴν λαμπηδόνα, τοῦ Ἁγίου Πνεύματος, τὸ ὑπερφυέστατον χρησμολόγημα, τὸ βραχὺ ρήματι, καὶ πολὺ συνέσει, θεοπνεύστως ἀπεφθέγξαντο, ὡς Χριστοκήρυκες, εὐαγγελικῶν προϊστάμενοι, δογμάτων οἱ μακάριοι, καὶ τῶν εὐσεβῶν παραδόσεων, ἄνωθεν λαβόντες, τὴν τούτων ἀποκάλυψιν σαφῶς, καὶ φωτισθέντες ἐξέθεντο, ὅρον θεοδίδακτον."

meMA.Lauds3.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Lauds3.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meMA.Lauds3.incipit = "Ὅλην συλλεξάμενοι…"
meMA.Lauds3.text = "Ὅλην συλλεξάμενοι, ποιμαντικὴν ἐπιστήμην, καὶ θυμὸν κινήσαντες, νῦν τὸν δικαιότατον ἐνδικώτατα, τοὺς βαρεῖς ἤλασαν, καὶ λοιμώδεις λύκους, τῇ σφενδόνῃ τῇ τοῦ Πνεύματος, ἐκσφενδονήσαντες, τοῦ τῆς Ἐκκλησίας πληρώματος, πεσόντας ὡς πρὸς θάνατον, καὶ ὡς ἀνιάτως νοσήσαντας, οἱ θεῖοι Ποιμένες, ὡς δοῦλοι γνησιώτατοι Χριστοῦ, καὶ τοῦ ἐνθέου κηρύγματος, μύσται ἱερώτατοι."

meMA.MM.Lauds123as345.text = properties_gr_GR_cog.media.key

meMA.LaudsGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.LaudsGlory.melody = ""
meMA.LaudsGlory.incipit = "Τῶν ἁγίων Πατέρων ὁ χορός…"
meMA.LaudsGlory.text = "Τῶν ἁγίων Πατέρων ὁ χορός, ἐκ τῶν τῆς οἰκουμένης περάτων συνδραμών, Πατρὸς καὶ Υἱοῦ καὶ Πνεύματος Ἁγίου, μίαν οὐσίαν ἐδογμάτισε καὶ φύσιν· καὶ τὸ μυστήριον τῆς θεολογίας, τρανῶς παρέδωκε τῇ Ἐκκλησίᾳ. Οὓς εὐφημοῦντες ἐν πίστει, μακαρίσωμεν λέγοντες· Ὦ θεία παρεμβολή, θεηγόροι ὁπλῖται, παρατάξεως Κυρίου· ἀστέρες πολύφωτοι, τοῦ νοητοῦ στερεώματος· τῆς μυστικῆς Σιών, οἱ ἀκαθαίρετοι πύργοι· τὰ μυρίπνοα ἄνθη τοῦ Παραδείσου· τὰ πάγχρυσα στόματα τοῦ Λόγου· Ἐκκλησίας τὸ καύχημα, οἰκουμένης ἀγλάϊσμα· ἐκτενῶς πρεσβεύσατε, ὑπὲρ τῶν ψυχῶν ἡμῶν."

meLI.Kontakion1.mode = me.m07.dHF_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.melody = me.m07.dHF_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m07.dHF_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m07.dHF_gr_GR_cog.meMA.Kontakion1.text

meLI.Megalynarion.text = "Βάσεις Ἐκκλησίας θεοπαγεῖς, καὶ τῆς εὐσεβείας, ἑδραιώματα ἀρραγῆ, αἱ τῶν ἑπταρίθμων, Συνόδων συνελεύσεις, ἐδείχθησαν τῷ κόσμῳ· ἃς μεγαλύνομεν."
