alt1.meMA.C1.poet = poets_gr_GR_cog.po.NikiforouChiou
alt1.meMA.C1.title = titles_gr_GR_cog.ti.CanonMartyrW
alt1.meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintW.text

alt1.meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
alt1.meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode1C11.greekmelody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.greekname
alt1.meMA.Ode1C11.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
alt1.meMA.Ode1C11.incipit = "Ἀνόσιον βούλημα, ἀπωσαμένη ἀοίδιμε, πατρὸς…"
alt1.meMA.Ode1C11.text = "Ἀνόσιον βούλημα, ἀπωσαμένη ἀοίδιμε, πατρὸς καὶ παμβέβηλον, ἔλαβες θάνατον, ὅθεν εἴληφας, στεφάνους τοὺς τῆς νίκης παρὰ τοῦ θεσπίσαντος, ὅρους τῆς φύσεως."

alt1.meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
alt1.meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode1C12.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
alt1.meMA.Ode1C12.incipit = "Βαφεῖσα πανεύφημε, τῆς τῶν αἱμάτων…"
alt1.meMA.Ode1C12.text = "Βαφεῖσα πανεύφημε, τῆς τῶν αἱμάτων ῥαντίσμασι, τῷ Κτίστῃ προσήνεξαι, ὡς νύμφη ἄσπιλος, καὶ ἀμώμητος, Μαρκέλλα καλλιμάρτυς, εἰς τὰ ὑπερκόσμια αὐτοῦ βασίλεια."

alt1.meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
alt1.meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode1C13.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
alt1.meMA.Ode1C13.incipit = "Γνοῦσα τὴν ἀθέμιτον, τοῦ σου…"
alt1.meMA.Ode1C13.text = "Γνοῦσα τὴν ἀθέμιτον, τοῦ σου τεκόντος διάνοιαν, Μαρκέλλα πανθαύμαστε, καὶ ψυχολέτηρα, ἔξω ἔφυγες, τοῦ οἴκου καὶ ηὐλίξου ἐρήμοις ἐν ὅρεσι, Θεῷ σχολάζουσα."

alt1.meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
alt1.meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode1C1T.melody = he.h.m4_gr_GR_cog.heHE.AnoixoToStomaMou.name
alt1.meMA.Ode1C1T.incipit = "Σαρκὸς ὁμοιώματι, ἐπιφανεῖς ὁ φιλάνθρωπος…"
alt1.meMA.Ode1C1T.text = "Σαρκὸς ὁμοιώματι, ἐπιφανεῖς ὁ φιλάνθρωπος, ἐκ σοῦ παναμώμητε κόσμον διέσωσεν, ἀπολλύμενον, καὶ πλάνη ὑπαχθέντα ὅθεν σὲ γεραίρομεν καὶ μακαρίζομεν."

alt1.meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
alt1.meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode3C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.greekname
alt1.meMA.Ode3C11.melody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.name
alt1.meMA.Ode3C11.incipit = "Δολίως, σατᾶν συλήσαι θέλων, τὸν…"
alt1.meMA.Ode3C11.text = "Δολίως, σατᾶν συλήσαι θέλων, τὸν πλοῦτον ψυχῆς σου ὦ σεμνή, τὸν σὸν τοκέα ἦγειρε, τῆς Παρθενίας φθεῖραί σου, ἄνθος Μαρκέλλα ἔνδοξε, ἀλλὰ ἡττήθη, καὶ πέπτωκεν."

alt1.meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
alt1.meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode3C12.melody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.name
alt1.meMA.Ode3C12.incipit = "Ἐνδέδειξαι Νύμφη τῷ Κυρίῳ, ὡραία…"
alt1.meMA.Ode3C12.text = "Ἐνδέδειξαι Νύμφη τῷ Κυρίῳ, ὡραία Μαρκέλλα τῇ στολῇ, τῇ πορφυρᾷ τοῦ αἵματος, ὅπερ ἁγνῶς ἐκκέχυται, ἐκ τοῦ σεμνοῦ σαρκίου σου, παρθενομάρτυς ἀείμνηστε."

alt1.meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
alt1.meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode3C13.melody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.name
alt1.meMA.Ode3C13.incipit = "Ζωὴν τὴν ἀΐδιον ποθούσα, προέκρινας…"
alt1.meMA.Ode3C13.text = "Ζωὴν τὴν ἀΐδιον ποθούσα, προέκρινας θάνατον ζωῆς, ἡ μὲν γὰρ τάχος λύεται, ὁ δὲ τὴν αἰωνίζουσαν, μάρτυς ζωὴν προξένησε, καὶ ἀφθαρσίας τὸν στέφανον."

alt1.meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
alt1.meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode3C1T.melody = he.h.m4_gr_GR_cog.heHE.TousSousYmnologous.name
alt1.meMA.Ode3C1T.incipit = "Νεφέλη ὑπάρχεις λευκότατη, σταγόνας πιστοῖς…"
alt1.meMA.Ode3C1T.text = "Νεφέλη ὑπάρχεις λευκότατη, σταγόνας πιστοῖς ἐξ οὐρανοῦ, ὀμβρούσα καὶ ἀνίσχουσα, δικαιοσύνης ἥλιον, ὅστις τὸ σὸν ἀξίωμα, πάντων ὑπέρτερον ἔδειξε."

alt1.meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode3Kathisma1.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
alt1.meMA.Ode3Kathisma1.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
alt1.meMA.Ode3Kathisma1.incipit = "Τῶν ἰαμάτων χορηγὸς σὺ ὑπάρχεις…"
alt1.meMA.Ode3Kathisma1.text = "Τῶν ἰαμάτων χορηγὸς σὺ ὑπάρχεις, Παρθενομάρτυς τοῦ Κυρίου Μαρκέλλα, ἀποδιώκουσα πνευμάτων χαλεπῶν, καὶ ἀεὶ φυλάττουσα ἐκ παντοίων κινδύνων, τοὺς ἐπικαλουμένους σὲ ἐν πολλῇ προθυμίᾳ, καὶ εὐλαβῶς προστρέχοντας τῷ σῷ, τεμένει Μάρτυς, Χριστοῦ ἀξιάγαστε."

alt1.meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode3KathismaT.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
alt1.meMA.Ode3KathismaT.incipit = me.m04.d22_gr_GR_cog.meMA.Ode3KathismaT.incipit
alt1.meMA.Ode3KathismaT.text = me.m04.d22_gr_GR_cog.meMA.Ode3KathismaT.text

alt1.meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
alt1.meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode4C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.greekname
alt1.meMA.Ode4C11.melody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.name
alt1.meMA.Ode4C11.incipit = "Τὴν ἐπανθούσαν Μαρκέλλα σεμνή, ἔχουσα…"
alt1.meMA.Ode4C11.text = "Τὴν ἐπανθούσαν Μαρκέλλα σεμνή, ἔχουσα ἀθλήσεως ἤνυσας, δρόμον διόπερ, νῦν παρίστασαι, Θεῷ οὑ ἐρως σὴν κατέφλεξεν ψυχὴν καὶ καρδίαν ἀοίδιμε."

alt1.meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
alt1.meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode4C12.melody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.name
alt1.meMA.Ode4C12.incipit = "Θάλλασαν ἐξέφυγες τὴν τῶν παθῶν…"
alt1.meMA.Ode4C12.text = "Θάλλασαν ἐξέφυγες τὴν τῶν παθῶν, τῶν πολυταράχων καὶ ἔδραμες ἐν τῷ λιμένι, τῷ ἀκλύστῳ τοῦ Θεοῦ, ἔνθα μαρτύρων τάγματα, πέλουσι Μαρκέλλα πανέντιμε."

alt1.meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
alt1.meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode4C13.melody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.name
alt1.meMA.Ode4C13.incipit = "Ἰὸν τὸν τοῦ ὄφεως, ὅπερ…"
alt1.meMA.Ode4C13.text = "Ἰὸν τὸν τοῦ ὄφεως, ὅπερ Ἀδάμ, πόθῳ τῆς θεώσεως πέποκε, Μάρτυς Μαρκέλλα, μὴ πιοῦσα ὡς σοφή, αὐτὸν πανσόφως ᾔσχυνας, ὅθεν σοῦ τὴν μνήμην γεραίρομεν."

alt1.meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
alt1.meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode4C1T.melody = he.h.m4_gr_GR_cog.heHE.TinAnexichniaston.name
alt1.meMA.Ode4C1T.incipit = "Ἡ πανυπερθαύμαστος μήτηρ Θεοῦ, λάμψον…"
alt1.meMA.Ode4C1T.text = "Ἡ πανυπερθαύμαστος μήτηρ Θεοῦ, λάμψον μετανοίας ἀκτῖνα μοι, λῦσον τὸν ζόφον, τῶν ἀμέτρων μου κακῶν, τοὺς πονηροὺς ἀπέλασον, κόρη λογισμοὺς τῆς καρδίας μου."

alt1.meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
alt1.meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode5C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.greekname
alt1.meMA.Ode5C11.melody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.name
alt1.meMA.Ode5C11.incipit = "Κρήνη σὲ γινώσκομεν, Μαρκέλλα παμμακάριστε…"
alt1.meMA.Ode5C11.text = "Κρήνη σὲ γινώσκομεν, Μαρκέλλα παμμακάριστε, σῴζουσα τοὺς δίψει ἐκκαέντας, ὅθεν σὺν πόθῳ τῇ σῇ σορῷ ἑστηκώς, δέχομαι τὴν ἴασιν παθῶν, ψυχῆς τε καὶ σώματος, ὡς γλυκύῤῥοα νάματα."

alt1.meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
alt1.meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode5C12.melody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.name
alt1.meMA.Ode5C12.incipit = "Λιμένα ἀτάραχον οἱ ἐν πελάγει…"
alt1.meMA.Ode5C12.text = "Λιμένα ἀτάραχον οἱ ἐν πελάγει πάνσεμνε, ὄντες τῆς ζωῆς τῆς ἐπικηροῦ, ἔχομεν πάντες, τὸν σὸν Μαρκέλλα ναόν, ὅνπερ σοι ἐδείματο λαός, πόθῳ, ὁ χριστώνυμος, εἰς σὴν δόξαν καὶ αἴνεσιν."

alt1.meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
alt1.meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode5C13.melody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.name
alt1.meMA.Ode5C13.incipit = "Μώμους ἀπεδίωξας, ὁλοτελὼς ἀοίδιμε, ἐκ…"
alt1.meMA.Ode5C13.text = "Μώμους ἀπεδίωξας, ὁλοτελὼς ἀοίδιμε, ἐκ τῆς καθαρᾶς σοῦ διανοίας, οὓς ὁ ἀντάρτης αὕτη ἀνέβαλε, καὶ γέγονας, ἔμψυχος ναός, ὅνπερ εἰσωκίσατο, ἡ Τριὰς ἡ ἀείφωτος."

alt1.meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
alt1.meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode5C1T.melody = he.h.m4_gr_GR_cog.heHE.ExestiTaSympanta.name
alt1.meMA.Ode5C1T.incipit = "Ἑώρακε πάλαι σε, ὡς θεῖον…"
alt1.meMA.Ode5C1T.text = "Ἑώρακε πάλαι σε, ὡς θεῖον τόμον Ἄχραντε, ἔνθεος προφήτης, ἐν ᾧ λόγος, ἐγράφη ἔνδον, πατρὸς εἰς κόσμου χαρὰν καὶ ἔσωσε πάντας ὡς Θεός, πίστει προσκυνοῦντάς σου τὴν ἀπόῤῥητον γέννησιν."

alt1.meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
alt1.meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode6C11.greekmelody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.greekname
alt1.meMA.Ode6C11.melody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.name
alt1.meMA.Ode6C11.incipit = "Νικᾶται δύναμις ἅπασα, δαιμόνων καὶ…"
alt1.meMA.Ode6C11.text = "Νικᾶται δύναμις ἅπασα, δαιμόνων καὶ ἐχθρῶν τῇ ἰσχύϊ σου, ὅθεν δεόμεθα τὴν νῆσον πᾶσαν περισῷζε, ἡμῶν Μαρκέλλα ἔνδοξε, ταῖς πρεσβείαις σου."

alt1.meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
alt1.meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode6C12.melody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.name
alt1.meMA.Ode6C12.incipit = "Ξενίζει πάντας ἀοίδιμε, τὸ ὕδωρ…"
alt1.meMA.Ode6C12.text = "Ξενίζει πάντας ἀοίδιμε, τὸ ὕδωρ τὸ ἐκ πέτρας χεόμενον, ἥ σε ἐδέξατο, καὶ νῦν τὸ σῶμα καλύπτει σου, τέρατα καὶ σημεῖα τελοῦν ἑκάστοτε."

alt1.meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
alt1.meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode6C13.melody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.name
alt1.meMA.Ode6C13.incipit = "Ὁ διαῤῥήξας καὶ σώσας σε…"
alt1.meMA.Ode6C13.text = "Ὁ διαῤῥήξας καὶ σώσας σε, τὴν πέτραν ἐκ τοῦ ἄγους ἀμόλυντον, πατρῴας μίξεως, Θεὸς Μαρκέλλα ἐδόξασε, θαυμάτων ἐνεργείαις καὶ ἐμεγάλυνεν."

alt1.meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
alt1.meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode6C1T.melody = he.h.m4_gr_GR_cog.heHE.TinTheianTaftin.name
alt1.meMA.Ode6C1T.incipit = "Ἡ μόνη πάντων βοήθεια, βοήθησον…"
alt1.meMA.Ode6C1T.text = "Ἡ μόνη πάντων βοήθεια, βοήθησον ἡμῖν κινδυνεύουσι, καὶ χεῖρα ὄρεξον, καὶ πρὸς λιμένα ἐμβίβασον, τῆς σωτηρίας Κόρη θεοχαρίτωτε."

alt1.meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode3
alt1.meMA.Kontakion1.greekmelody = he.a.m3_gr_GR_cog.heAU.IParthenosSimeron.greekname
alt1.meMA.Kontakion1.melody = he.a.m3_gr_GR_cog.heAU.IParthenosSimeron.name
alt1.meMA.Kontakion1.incipit = "Ἡ λαμπρὰ σοῦ ἄθλησις, ὦ…"
alt1.meMA.Kontakion1.text = "Ἡ λαμπρὰ σοῦ ἄθλησις, ὦ καλλιμάρτυς Μαρκέλλα, τῶν πιστῶν ἐφαίδρυνε τὰς διανοίας ἐνθέως, θάνατον τοῦ ζῆν ἀνόμως προκρίνει πάντας, πείθουσα καὶ γὰρ ἐτμήθης ξίφει τὴν κάραν, σὺν μαστοῖς ὑπὸ πατρῴας, χειρὸς ὦ δράμα ὑπὲρ τοῦ νόμου Χριστοῦ."

alt1.meMA.Oikos1.text = "Δεῦτε οἱ φιλήκοοι, ἀκούσατε καινοὺς καὶ δυσαντήτους ἄθλους τε καὶ οὓς περ ἡ τοῦ Χριστοῦ ἄμωμος νύμφη Μαρκέλλα, παρὰ τοῦ ἀνοσίου αὐτῆς πατρός, ἐν τῇ Χίῳ ἐν κώμῃ Βολισσῷ ἠγώνισται, ἔνθα μέχρι τοῦ νῦν ἐρυθρὸς ὁ τῆς θαλάσσης ἀφρὸς ἐν ταῖς ἀκταῖς ὁρᾶται, εἰς δήλωσιν τοῦ ἐκχυθέντος παρθενικοῦ αὐτῆς αἵματος· θέλοντος γὰρ τοῦ ἐναγοῦς καὶ ἀνοσίου πατρὸς παρανόμως συμμίγνυσθαι αὐτῇ οὐκ ἠνείχετο ἡ ἀοίδιμος, ὅθεν φεύγουσα καὶ ὑπ᾿ αὐτοῦ διωκομένη, ἔλαβε θάνατον ὑπὲρ σωφροσύνης, χερσὶ πατρικαῖς ἀποτμηθεῖσα σὺν τοῖς μαστοῖς, καὶ τὴν ἐρίτιμον αὐτῆς κεφαλήν, διὸ στέφει οὐρανίῳ ἐστέφθη, ὡς ἀθλήσασα ὑπὲρ τοῦ νόμου Χριστοῦ."

alt1.meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
alt1.meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode7C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.greekname
alt1.meMA.Ode7C11.melody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.name
alt1.meMA.Ode7C11.incipit = "Πόθῳ ἅπαντες, γεραίρομεν τὴν μνήμη…"
alt1.meMA.Ode7C11.text = "Πόθῳ ἅπαντες, γεραίρομεν τὴν μνήμη σου, Μαρκέλλα πάνσεμνε, ὅτι ἀντέστης πατρί, τῷ μίξιν ἀθέμιτον ἀφρόνως θέλοντι, ὅθεν ψάλλομεν, εὐλογητός, εἰ Κύριε, ὁ Θεὸς εἰς τοὺς αἰῶνας."

alt1.meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
alt1.meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode7C12.melody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.name
alt1.meMA.Ode7C12.incipit = "Ῥωμαλέαν, τὴν διάνοιαν ἐκέκτητο, παρὰ…"
alt1.meMA.Ode7C12.text = "Ῥωμαλέαν, τὴν διάνοιαν ἐκέκτητο, παρὰ τοῦ πλάσαντος, τὸν οὐρανὸν καὶ τὴν γῆν, Μαρκέλλα ἡ πάντιμος, ὅθεν νενίκηκε, τὸν ἀντίπαλον, καὶ συγχωρεύει χαίρουσα, τοῖς ἀγγέλοις εἰς αἰῶνας."

alt1.meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
alt1.meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode7C13.melody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.name
alt1.meMA.Ode7C13.incipit = "Σῶμα ἔλιπες, Μαρκέλλα παμμακάριστε, καὶ…"
alt1.meMA.Ode7C13.text = "Σῶμα ἔλιπες, Μαρκέλλα παμμακάριστε, καὶ ἀνελήλυθας, εἰς οὐρανίους σκηνάς, ἐν αἷς πάντες δίκαιοι χαίρουσι ψάλλοντες, ὑπερύμνητε, ὁ τῶν πατέρων Κύριος καὶ Θεὸς εὐλογητὸς εἶ."

alt1.meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
alt1.meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode7C1T.melody = he.h.m4_gr_GR_cog.heHE.OukElatrefsan.name
alt1.meMA.Ode7C1T.incipit = "Βασίλισσα τοῦ κόσμου ἡ κυήσασα…"
alt1.meMA.Ode7C1T.text = "Βασίλισσα τοῦ κόσμου ἡ κυήσασα, τὸν Βασιλέα Χριστόν, ῥῦσαι φθορᾶς καὶ σεισμοῦ, ἐθνῶν ἐπηρείας τε τοὺς πίστει ψάλλοντας, ὑπερύμνητε, εὐλογημένος πάναγνε, ὁ καρπὸς τῆς σῆς κοιλίας."

alt1.meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
alt1.meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode8C11.greekmelody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.greekname
alt1.meMA.Ode8C11.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
alt1.meMA.Ode8C11.incipit = "Τέτρωσαι Μαρκέλλα ἀθλοφόρε, τῷ πόθῳ…"
alt1.meMA.Ode8C11.text = "Τέτρωσαι Μαρκέλλα ἀθλοφόρε, τῷ πόθῳ τῷ τοῦ Δεσπότου σου καὶ ἔρωτι, ὅθεν τῷ γεννήτορι, ἔλεγες πανεύφημε, τὴν τοῦ Κυρίου ἐντολὴν οὐ παραβαίνω ποτέ, ὑπάρχω γὰρ ἱκέτης ἐκείνου ὅν περ ἀνυμνούσι, χοροὶ πάντες ἀγγέλων."

alt1.meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
alt1.meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode8C12.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
alt1.meMA.Ode8C12.incipit = "Ὕμνους καὶ δεήσεις τῇ Μαρκέλλῃ…"
alt1.meMA.Ode8C12.text = "Ὕμνους καὶ δεήσεις τῇ Μαρκέλλῃ, προσάξωμεν μετὰ πόθου ταύτῃ κράζοντες· σῶσον ἡμᾶς ἅπαντας, μάρτυς πολυύμνητε, δοξάζοντας τὴν μνήμην σου, τὴν ἀεισέβαστον, ὑπάρχομεν γὰρ πάντες σοι δοῦλοι, οἱ περιεστῶτες ἐν τῷ σεπτῷ ναῷ σου."

alt1.meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
alt1.meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode8C13.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
alt1.meMA.Ode8C13.incipit = "Φωτεινὸν ἀνάκτορον Χριστοῦ σύ, ἐγένου…"
alt1.meMA.Ode8C13.text = "Φωτεινὸν ἀνάκτορον Χριστοῦ σύ, ἐγένου τῶν ἀθλοφόρων ἐγκαλώπισμα, λίθοις τῆς ἀθλήσεως, ἐν ὥσπερ κατῴκησεν, ὁ τῶν ἁπάντων Κύριος, ὅν περ ἠγάπησας, ἐκ βρέφους ὡς Νυμφίον Μαρκέλλα, ᾧ νῦν ἐνωθεῖσα, συγχαίρεις εἰς αἰῶνας."

alt1.meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
alt1.meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode8C1T.melody = he.h.m4_gr_GR_cog.heHE.PaidasEvageis.name
alt1.meMA.Ode8C1T.incipit = "Πολλαῖς προσβολαῖς ἁμαρτημάτων, κλονούμενοι, σοῦ…"
alt1.meMA.Ode8C1T.text = "Πολλαῖς προσβολαῖς ἁμαρτημάτων, κλονούμενοι, σοῦ πρὸς τὴν ἀκλόνητον, σκέπην καταφεύγομεν, στήριξον τοὺς δούλους σου, κατὰ παθῶν ἐνίσχυσον, καὶ ἐκ σεισμοῦ καὶ λοιμοῦ, ἐθνῶν ἐπιδρομῆς τε Παρθένε, τοὺς σὲ ἀνυμνοῦντας ὡς ὄντως Θεοτόκον."

alt1.meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
alt1.meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode9C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.greekname
alt1.meMA.Ode9C11.melody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.name
alt1.meMA.Ode9C11.incipit = "Χλόης τῆς ζωῆς, ζητοῦσα πανύμνητε…"
alt1.meMA.Ode9C11.text = "Χλόης τῆς ζωῆς, ζητοῦσα πανύμνητε τὴν ἐπουράνιον, βίον τὸν ἐπίκηρον οὐδὲν ἡγήσω, ὅθεν ἐνήθλησας, τῇ κραταιᾷ τοῦ κτίστου σου, δυνάμει πάνσεμνε, ὃν νῦν βλέπεις, πρόσωπον πρὸς πρόσωπον, ὦ Μαρκέλλα Χριστοῦ δούλη πάνσεμνε."

alt1.meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
alt1.meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode9C12.melody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.name
alt1.meMA.Ode9C12.incipit = "Ψάλλων ὁ Δαβίδ, προφήτης ἐν…"
alt1.meMA.Ode9C12.text = "Ψάλλων ὁ Δαβίδ, προφήτης ἐν πνεύματι ὦ παμμακάριστε, θυγατέρα λέγει σε, τὸ κατ’ εἰκόνα Θεοῦ τηρήσασαν, Μαρκέλλα καὶ ὁμοίωσιν, ὃν νῦν δυσώπησον, τοῦ ῥυσθῆναι, ἡμᾶς τῆς κολάσεως, ταῖς ἐνθέοις λιταῖς σου πανεύφημε."

alt1.meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
alt1.meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode9C13.melody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.name
alt1.meMA.Ode9C13.incipit = "Ὡραία Χριστοῦ, Νύμφη ἀναδέδειξαι, τῷ…"
alt1.meMA.Ode9C13.text = "Ὡραία Χριστοῦ, Νύμφη ἀναδέδειξαι, τῷ τῆς ἀθλήσεως, αἵματι τιμίῳ σου, ᾧ ἐῤῥαντίσθης Μαρκέλλα πάνσεμνε, διό περ εἰς σκηνώματα τοῦ σου Νυμφίου Χριστοῦ, ἀνηνέχθης ἐντρυφώσα τέρψεως, τῆς ἐκείνου ὡς μάρτυς καλλίνικος."

alt1.meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
alt1.meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meMA.Ode9C1T.melody = he.h.m4_gr_GR_cog.heHE.ApasGigenis.name
alt1.meMA.Ode9C1T.incipit = "Φώτισον Ἁγνή, ψυχῆς μου τὰ…"
alt1.meMA.Ode9C1T.text = "Φώτισον Ἁγνή, ψυχῆς μου τὰ ὄμματα, παῦσον τὸν κλύδωνα, τὸν ἐπιγινόμενον, ἐκ τῆς δαιμόνων παρενοχλήσεως, καὶ εἰς ὁδὸν κατεύθυνον, τῶν θελημάτων Χριστοῦ, τοῦ νοός μου, πάναγνε τὴν ζόφωσιν, ὅπως πίστει ἀεὶ μακαρίζω σε."

alt1.meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meMA.Exaposteilarion1.greekmelody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.greekname
alt1.meMA.Exaposteilarion1.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
alt1.meMA.Exaposteilarion1.incipit = "Ἡ νῆσος Χῖος τέρπεται, παλαίσμασι…"
alt1.meMA.Exaposteilarion1.text = "Ἡ νῆσος Χῖος τέρπεται, παλαίσμασι τῆς μάρτυρος, καὶ πανευφήμου Μαρκέλλης, ἥ περ Χριστὸς καταστέφει, σὺν τοῖς προδιαλάμψασι, τισίν Ἁγίοις πρότερον, Ἰσιδώρω τῷ μάρτυρι, Μυρόπῃ τῇ ἀθληφόρῳ, καὶ τῇ ὁσία Ματρώνῃ"

alt1.meMA.Exaposteilarion2.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meMA.Exaposteilarion2.greekmelody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.greekname
alt1.meMA.Exaposteilarion2.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
alt1.meMA.Exaposteilarion2.incipit = "Ῥωσθεῖσα τῇ τοῦ Πνεύματος, ἰσχύϊ…"
alt1.meMA.Exaposteilarion2.text = "Ῥωσθεῖσα τῇ τοῦ Πνεύματος, ἰσχύϊ τάχος ἔφυγες, πατρὸς τοῦ σοῦ τὴν μανίαν, Μαρκέλλα δούλη Κυρίου, ἐν θαλασσίοις ὕδασιν, ἐν οἷς τὴν κάραν τέτμησαι· δι’ ὅπερ καὶ ἀνέδραμες, εἰς οὐρανίους θαλάμους, ὑπὲρ ἡμῶν δυσωποῦσα."

alt1.meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meMA.ExapTheotokion.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
alt1.meMA.ExapTheotokion.incipit = me.m06.d11_gr_GR_cog.meMA.ExapTheotokion.incipit
alt1.meMA.ExapTheotokion.text = me.m06.d11_gr_GR_cog.meMA.ExapTheotokion.text

alt1.meMA.Lauds1.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meMA.Lauds1.greekmelody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.greekname
alt1.meMA.Lauds1.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
alt1.meMA.Lauds1.incipit = "Ξίφει τὸν αὐχένα σου σεμνή…"
alt1.meMA.Lauds1.text = "Ξίφει τὸν αὐχένα σου σεμνή, ἔτεμε τοκεὺς καὶ γεννήτωρ, ὁ σὸς καὶ ἔδραμες, μάρτυς εἰς Μητρόπολιν τῶν πρωτοτόκων χαρᾷ καὶ τὰ κάλλη ἐμβλέπεις νῦν, Τριάδος τῆς θείας, δυσωποῦμέν σε, ἐκλιπαρεῖν ἐκτενῶς, ἵνα σοὺς ἱκέτας λυτρώσῃ, τῆς φρικτῆς ἐκείνης Μαρκέλλα, αἰωνιζούσης κατακρίσεως."

alt1.meMA.Lauds2.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meMA.Lauds2.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
alt1.meMA.Lauds2.incipit = "Ἐπὶ τῆς θαλάσσης οἱ ἀφροί…"
alt1.meMA.Lauds2.text = "Ἐπὶ τῆς θαλάσσης οἱ ἀφροί, ἐρυθροί, ὤ θαῦμα! ὁρῶνται, Μαρκέλλα πάνσεμνε, ἔνθα σου τὸ πάντιμον, αἷμα ἐκκέχυται, οἷς πιστῶς οἱ χριώμενοι, παθῶν ἐκλυτροῦνται, διὰ τῆς σῆς χάριτος ἀνευφημοῦντές σε, ὡς Χριστοῦ ἀκήρατον Νύμφην, τοῦ σὲ ἐνεργείαις θαυμάτων, ἔνδοξον τοῖς πᾶσιν ἀναδείξαντος."

alt1.meMA.Lauds3.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meMA.Lauds3.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
alt1.meMA.Lauds3.incipit = "Θῦμα τῷ Δεσπότῃ σου Χριστῷ…"
alt1.meMA.Lauds3.text = "Θῦμα τῷ Δεσπότῃ σου Χριστῷ, ἤχθης ὢ Μαρκέλλα εὐῶδες καὶ παναμώμητον, πάσας ὅθεν ηὔφρανας, τὰς οὐρανίους ἀρχάς, καὶ μακάρων ἀοίδιμε ψυχὰς διὸ πάντες πρέσβυν πρὸς τὸν Κύριον πιστοὶ προβάλλομεν, σῶσον ἐκβοῶντες κινδύνων, καὶ παντοδαπῶν ἐναντίων, μάρτυς τοῦ Χριστοῦ τοὺς ἀνυμνοῦντάς σε."

alt1.meMA.LaudsGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meMA.LaudsGlory.melody = ""
alt1.meMA.LaudsGlory.incipit = "Τὴν τετράχορδον λύραν, τῆς φιλοχρίστου…"
alt1.meMA.LaudsGlory.text = "Τὴν τετράχορδον λύραν, τῆς φιλοχρίστου Χίου, τῶν φιλεόρτων τὸ σύστημα· Ἰσίδωρον τὸν Ἀθλητήν, σὺν τῇ συνάθλῳ Μυρόπῃ, καὶ Ματρώνῃ ἱερωτάτη Ὁσία, μετὰ Μαρκέλλης τῆς Παρθενομάρτυτρος· ᾗς τὴν θείαν μνήμην ἐπιτελοῦμεν σήμερον· θείῳ γὰρ πόθῳ πυρποληθεῖσα, τῷ ἀντάρτῃ ἀντέστη, ὥσπερ ἀσώματος ἡ ἀοίδιμος, καὶ τὰς ἐκείνου μηχανάς, ὡς ἱστὸν ἀράχνης, πανσόφως διέλυσε· διὰ γὰρ Χριστὸν τὸν Νυμφίον, αὐτῆς, τῆς οἰκείας ζωῆς μὴ φεισαμένη, ἀνδριοφόνως σφαγὴν παρὰ πατρὸς ἀκολάστου ἐδέξατο· ὅθεν τῇ ἑαυτῆς πατρίδι προστάτις γενέσθαι, σὺν τοῖς λοιποῖς Ἁγίοις, τοῖς ἐν αὐτῇ διαπρέψασι κατηξίωται, μεθ’ ὧν πρεσβεύει πρὸς Κύριον, ὑπὲρ τῶν ψυχῶν ἡμῶν."

alt1.meMA.MM.LaudsSunday.text = properties_gr_GR_cog.media.key

alt1.meLI.Kontakion1.mode = alt1.meMA.Kontakion1.mode
alt1.meLI.Kontakion1.melody = alt1.meMA.Kontakion1.melody
alt1.meLI.Kontakion1.incipit = alt1.meMA.Kontakion1.incipit
alt1.meLI.Kontakion1.text = alt1.meMA.Kontakion1.text

alt1.meLI.Megalynarion.text = "Χαίροις νύμφη ἄσπιλε τοῦ Χριστοῦ, ἔνδοξε Μαρκέλλα, καλλιμάρτυς νοεφανής, βλάστημα τῆς Χίου καὶ δόξα καὶ προστάτις, πάντων παθῶν ἀπάλλαξον τοὺς τιμῶντάς σε."

alt1.meLI.Megalynarion2.text = "Πορφύραν ἐξ αἵματος τὴν στολήν, ὡς περικειμένη, καὶ τὸ στέφος ἐν κορυφῇ, ἔχουσα τὸ θεῖον, καὶ τὴν τῆς παρθενίας, λευκοφανῆ λαμπάδα, κρατοῦσα γέγηθας."

alt1.meLI.Megalynarion3.text = "Χαίροις τὸ τῆς Χίου κρίνον σεπτόν· χαίροις τῶν Παρθένων, ἐγκαλλώπισμα ἱερόν· χαίροις καλλιμάρτυς, Μαρκέλλα ἡ τμηθεῖσα, χειρὶ τῇ τοῦ πατρός σου, ἁγνείας ἔρωτι."

alt1.meLI.Megalynarion4.text = "Χλαῖναν παρθενίας πορφυραυγῆ, αἵμασιν οἰκείοις, βεβαμμένην ἀθλητικῶς, φέρουσα Μαρκέλλα, τῷ Λόγῳ ἐνυμφεύθης, τμηθεῖσα τῇ πατρῴᾳ χειρὶ ὡς πάνσεμνος."
