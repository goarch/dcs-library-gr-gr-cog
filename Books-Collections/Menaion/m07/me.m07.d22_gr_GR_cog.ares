alt1.meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode1
alt1.meVE.Stichera01.greekmelody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.greekname
alt1.meVE.Stichera01.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
alt1.meVE.Stichera01.incipit = "Τῆς ἀθλοφόρου Μαρκέλλης, τὴν μνήμη…"
alt1.meVE.Stichera01.text = "Τῆς ἀθλοφόρου Μαρκέλλης, τὴν μνήμη σήμερον, ἐν ἐτησίοις ὕμνοις, ἑορτάσωμεν πάντες, φιλέορτοι ἐνδόξως, ἥτις Χριστῷ τῷ Κυρίῳ παρίσταται, ἐκδυσωποῦσα ἀπαύστως ὑπὲρ ἡμῶν, τῶν ἐκ πόθου εὐφημούντων αὐτήν."

alt1.meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode1
alt1.meVE.Stichera02.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
alt1.meVE.Stichera02.incipit = "Ἡ νῆσος Χῖος καυχάσθω, ὅτι…"
alt1.meVE.Stichera02.text = "Ἡ νῆσος Χῖος καυχάσθω, ὅτι ἐξήνθησε, τὸ Παρθενίας ἄνθος, τὸ θεόβλαστον ὄντως, τὴν ἔνδοξον Μαρκέλλαν ἥπερ ἀεί, τῷ Κυρίῳ παρίσταται, ἐκδυσωπούσα ἀπαύστως ὑπὲρ αὐτῆς, παῤῥησίᾳ καὶ τοῦ κόσμου παντός."

alt1.meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode1
alt1.meVE.Stichera03.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
alt1.meVE.Stichera03.incipit = "Τὴν ἱερὰν καὶ λαμπράν σου…"
alt1.meVE.Stichera03.text = "Τὴν ἱερὰν καὶ λαμπράν σου, μνήμην δοξάζοντες, Μαρκέλλα μακαρία, καὶ πιστῶς ἐκτελοῦντες, βοῶμέν σοι σὺν πόθῳ ῥῦσαι ἡμᾶς, τῆς φλογὸς τῆς κολάσεως, καὶ τῶν βελῶν τοῦ βελίαρ ταῖς πρὸς Χριστόν, ἱκεσίαις σου πανεύφημε."

alt1.meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode1
alt1.meVE.Stichera04.greekmelody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.greekname
alt1.meVE.Stichera04.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
alt1.meVE.Stichera04.incipit = "Χορὸς Ἁγίων ἐν Χίῳ, πανηγυρίζει…"
alt1.meVE.Stichera04.text = "Χορὸς Ἁγίων ἐν Χίῳ, πανηγυρίζει φαιδρῶς, κατέχων ἐν τῷ μέσῳ, τὸ μακάριον πνεῦμα, Μαρκέλλης τῆς παρθένου καὶ εὐκλεοῦς, ἡ γενναίῳ φρονήματι, τὸν πολυμήχανον ὄφιν ὁλοσχερῶς, τῇ ἀθλήσει κατεπάτησεν."

alt1.meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode5
alt1.meVE.SticGlory.melody = ""
alt1.meVE.SticGlory.incipit = "Δεῦτε λαοί, ἀσματικοῖς στέμμασι, τὴν…"
alt1.meVE.SticGlory.text = "Δεῦτε λαοί, ἀσματικοῖς στέμμασι, τὴν τοῦ Χριστοῦ, καὶ ἄμωμον Νύμφην Μαρκέλλαν σήμερον καταστέψωμεν, τὴν τὸν ἀρχέκακον ὄφιν καταπατήσασαν· ταῖς γὰρ παρὰ τοῦ ἀσελγοῦς αὐτῆς πατρός, ἀλγειναῖς μαστιγώσεσιν, ὡς ἀδάμας στεῤῥὸς μὴ ἐνδοῦσα, καὶ τὴν αὐτοῦ ἀνόσιόν τε καὶ ἄθεσμον μίξιν ἀποβαλοῦσα, τοὺς μαστοὺς ἀφῄρηται, καὶ τὴν θεόφρονα κεφαλὴν αὐτῆς ἐκτέτμηται· ὅθεν ἐκ δεξιῶν τοῦ Σωτῆρος παρέστη, ὡς παρθένος φρονίμη, σὺν Ἰσιδώρῳ τῷ θείῳ, καὶ Μυρόπῃ τῇ ἐνδόξῳ, καὶ τῇ Ὁσίᾳ Ματρώνῃ, τοῖς πρὸ αὐτῆς ἐν Χίῳ διαλάμψασι, καὶ προστάταις αὐτῆς γενομένοις, διηνεκῶς, πρεσβεύουσα ὑπὲρ τῶν ψυχῶν ἡμῶν."

alt1.meVE.Lity1.mode = miscellanea_gr_GR_cog.misc.Mode1
alt1.meVE.Lity1.melody = ""
alt1.meVE.Lity1.incipit = "Πηγὴ χαρίτων, ἡ σορὸς τῆς…"
alt1.meVE.Lity1.text = "Πηγὴ χαρίτων, ἡ σορὸς τῆς θείας Μαρκέλλης, ὄντως ἀναδέδεικται· πολλοῖς γὰρ ἐν ποικίλοις πάθεσιν οὖσι, προσέτι καὶ ἀβλεψίαν νοσοῦσι, τῇ τοῦ ἑαυτῆς αἵματος χρίσει, τὴν θεραπείαν δεδώρηται, ὅπερ ἄχρι τοῦ νῦν ἐν ταῖς τῆς θαλάσσης ἀκταῖς ὁρᾶται, κυματοῦν καὶ τὴν ἐκείνης ἄδικον, τοῖς ἀγνοοῦσιν ἐναργῶς δεικνύον σφαγήν· ὅθεν καὶ ἡμεῖς, οἱ ἐν ἀσθενείαις ψυχῶν κατακείμενοι, προσέλθωμεν αὐτῇ μετὰ πίστεως καὶ τῆς πνευματικῆς θεραπείας τευξόμεθα δι᾿ αὐτῆς· ποιεῖ γὰρ ὁ Κύριος τὸ θέλημα τῶν φοβουμένων αὐτόν."

alt1.meVE.LityGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
alt1.meVE.LityGlory.melody = ""
alt1.meVE.LityGlory.incipit = "Δεῦτε φιλέορτοι πάντες, ἐν τῷ…"
alt1.meVE.LityGlory.text = "Δεῦτε φιλέορτοι πάντες, ἐν τῷ Ναῷ τῆς Ἀθλοφόρου Μαρκέλλης, σήμερον ἀθροισθέντες πνευματικῶς πανηγυρίσωμεν εὐοχούμενοι· μυστικὴν γὰρ ἡμῖν τράπεζαν, τὰς ἀριστείας καὶ τοὺς ἄθλους αὐτῆς πᾶσι προτίθεται, ὡς ἔδεσμα τερπνὸν καὶ ἐξαίρετον. Ἐνθέως οὖν κορεσθέντες, δοξάσωμεν τὸν παντοδύναμον Κύριον, τὸν ἰσχὺν αὐτῇ δόντα, ἀντιστῆναι τῷ ἀρχεκάκῳ δαίμονι, καὶ σὺν τοῖς μαστοῖς, τὴν τῆς κάρας ἐκτομήν, προθύμως δέξασθαι, παρὰ τοῦ ἰδίου πατρός. Ἦς ταῖς πρεσβείαις δώρησαι ἡμῖν ὁ Θεός, τὸ μέγα σου ἔλεος."

alt1.meVE.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meVE.Aposticha1.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
alt1.meVE.Aposticha1.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
alt1.meVE.Aposticha1.incipit = "Τοῖς χοροῖς συνηρίθμησαι, τῶν Μαρτύρων…"
alt1.meVE.Aposticha1.text = "Τοῖς χοροῖς συνηρίθμησαι, τῶν Μαρτύρων ἀοίδιμε, Μαρκέλλα πολύαθλε καὶ πανέντιμε· τοῦ γὰρ πατρός σου τὴν ἄθεσμον, βουλὴν καὶ ἀνόσιον, βδελυχθεῖσα ὡς ἁγνή, τὸν αὐχένα ὑπέκλινας, καὶ τὴν κάραν σου, ἀπετμήθῃς καὶ εἴληφας ἀξίως, τῆς ἀθλήσεως τὸ στέφος, ἅ τε νομίμως ἀθλήσασα."

alt1.meVE.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meVE.Aposticha2.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
alt1.meVE.Aposticha2.incipit = "Τῶν βασάνων αἱ λαίλαπες, τῆς…"
alt1.meVE.Aposticha2.text = "Τῶν βασάνων αἱ λαίλαπες, τῆς ψυχῆς σου οὐκ ἔσεισαν, τὸν πύργον τὸν ἄσειστον καὶ ἀκλόνητον, Μάρτυς Μαρκέλλα στεῤῥόψυχε, ἀλλʼ ἔμεινας ἄτρεπτος, ἐπὶ πέτραν τὴν στεῤῥάν, τοῦ τὰ πάντα ἰσχύοντος καὶ συνέχοντος, θερμὴν ὄντως διό σε πανολβία, πρέσβυν εἰς Θεὸν πλουτοῦμεν, οἱ σὲ τιμῶντες ἐν ᾄσμασι."

alt1.meVE.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode4
alt1.meVE.Aposticha3.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
alt1.meVE.Aposticha3.incipit = "Ἐφοινίχθη τοῖς αἵμασι, τῆς σαρκός…"
alt1.meVE.Aposticha3.text = "Ἐφοινίχθη τοῖς αἵμασι, τῆς σαρκός σου ἀοίδιμε, ἅπερ ἐξεχύθησαν καὶ γεγόνασι, τῶν ἀσθενούντων ὡς φάρμακα, ποικίλας ἰώμενα, ἀσθενείας τῶν βροτῶν, ὦ Μαρκέλλα πανεύφημε, ὅθεν ἵσταμαι, τῇ σορῷ τῶν λειψάνων καὶ βοῶ σοι· Καλλιμάρτυς τοῦ Κυρίου, κᾀμοὶ τὴν ἴασιν δώρησαι."

alt1.meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meVE.AposGlory.melody = ""
alt1.meVE.AposGlory.incipit = "Παρθενικοῖς αἵμασιν, Ἀθληφόρε Μαρκέλλα φοινιχθεῖσα…"
alt1.meVE.AposGlory.text = "Παρθενικοῖς αἵμασιν, Ἀθληφόρε Μαρκέλλα φοινιχθεῖσα, τῷ οὐρανίῳ Νυμφίῳ πάγκαλλος Νύμφη ἀνεδείχθης, ὑπὲρ οὗ τὰς αἰκίας, παρὰ τοῦ σοῦ ἀνοσίου πατρός, ὑπήνεγκας πανθαύμαστε, καὶ τὴν ἐρίτιμόν σου κεφαλήν, ὑπὲρ τηρήσεως ἀκριβοῦς τοῦ θείου νόμου σὺν τοῖς μαστοῖς ἀπετμήθης, ἐλέγχουσα αὐτοῦ τὸ τῆς ἀκολασίας ξενήκουστον τόλμημα· ὅθεν ὡς παρθένος, μετὰ τῶν φρονίμων συναγάλλῃ παρθένων, καὶ ὡς τοῦ νόμου φύλαξ ἀκριβής, μετὰ τῶν Μακκαβαίων καὶ τοῦ θείου Προδρόμου συνδοξάζῃ, μεθ’ ὧν πρέσβευε ὑπὲρ τῶν ψυχῶν ἡμῶν."

alt1.meVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meVE.AposTheotokion.melody = ""
alt1.meVE.AposTheotokion.incipit = oc.m2.d3_gr_GR_cog.ocMA.AposTheotokion.incipit
alt1.meVE.AposTheotokion.text = oc.m2.d3_gr_GR_cog.ocMA.AposTheotokion.text

alt1.meVE.Apolytikion1.mode = miscellanea_gr_GR_cog.misc.Mode1
alt1.meVE.Apolytikion1.greekmelody = he.a.m1_gr_GR_cog.heAU.TisErimouPolitis.greekname
alt1.meVE.Apolytikion1.melody = he.a.m1_gr_GR_cog.heAU.TisErimouPolitis.name
alt1.meVE.Apolytikion1.incipit = "Τοῦ Κυρίου τοῖς νόμοις…"
alt1.meVE.Apolytikion1.text = "Τοῦ Κυρίου τοῖς νόμοις, καὶ τοῖς θείοις διδάγμασι, πειθομένη Μαρκέλλα, καὶ ἀμέμπτως φυλάττουσα, τὴν βίαν πτοηθεῖσα τοῦ πατρός, ὦ Νύμφη ἀκήρατε Χριστοῦ, ἐν τοῖς ὄρεσιν ηὐλίζου, ἐν οἷς διώκων εὑρίσκει καὶ ἐκτείνει σε· δόξα τῷ δεδωκότι σοι ἰσχύν, δόξα τῷ σὲ στεφανώσαντι, δόξα τῷ ἐνεργοῦντι διὰ σοῦ πᾶσιν ἰάματα."

alt1.meMA.Kathisma11.mode = miscellanea_gr_GR_cog.misc.Mode1
alt1.meMA.Kathisma11.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
alt1.meMA.Kathisma11.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
alt1.meMA.Kathisma11.incipit = "Ῥανίσι τῶν σεπτῶν καὶ παναγνῶν…"
alt1.meMA.Kathisma11.text = "Ῥανίσι τῶν σεπτῶν καὶ παναγνῶν αἱμάτων, ἀπέπνιξας σοφὴ ἀθληφόρε Μαρκέλλα, Βελίαρ τὸν κάκιστον, ἐκχυθέντων σαρκίου σου· ὅθεν εἴληφας παρὰ Θεοῦ στέφος δόξης, διὸ πρέσβευε, ὑπὲρ ἡμῶν πρὸς τὸν κτίστην, Μαρτύρων ὁμότροπε."

alt1.meMA.Kathisma1T.mode = miscellanea_gr_GR_cog.misc.Mode1
alt1.meMA.Kathisma1T.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
alt1.meMA.Kathisma1T.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
alt1.meMA.Kathisma1T.incipit = "Ἀνύμφευτε ἁγνή, Θεοτόκε Παρθένε, ἡ…"
alt1.meMA.Kathisma1T.text = "Ἀνύμφευτε ἁγνή, Θεοτόκε Παρθένε, ἡ μόνη τῶν πιστῶν προστασία καὶ σκέπη, κινδύνων καὶ θλίψεων καὶ δεινῶν περιστάσεων, πάντας λύτρωσαι, τοὺς ἐπὶ σοὶ τὰς ἐλπίδας, Κόρη ἔχοντας, καὶ τὰς ψυχὰς ὑμῶν σώσαι, ταῖς θείαις πρεσβείαις σου."

alt1.meMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode8
alt1.meMA.Kathisma21.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
alt1.meMA.Kathisma21.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
alt1.meMA.Kathisma21.incipit = "Τῆς Μαρκέλλης τὴν πάλην ἀναπολῶν…"
alt1.meMA.Kathisma21.text = "Τῆς Μαρκέλλης τὴν πάλην ἀναπολῶν, καὶ τοὺς ἄθλους ἐκπλήττομαι κατὰ νοῦν, πῶς τὸ θῆλυ ἴσχυσε καὶ γεναίως ἠνδρίσατο, τοῦ Σατὰν τὸ θράσος, νικήσαι καὶ φρύαγμα, τοῦ Χριστοῦ τῇ χάριτι, τοῦ πλάστου τῆς φύσεως· ὅθεν ἀνυμνοῦντες, τὴν αὐτῆς πάντες νίκην, συμφώνως βοήσωμεν, πρὸς αὐτὴν μετὰ πίστεως, ἀθλοφόρε πανεύφημε, πρέσβευε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρηθήσασθαι, τοῖς ἑορτάζουσι πόθῳ τὴν ἁγίαν μνήμην σου."

alt1.meMA.Kathisma2T.mode = miscellanea_gr_GR_cog.misc.Mode8
alt1.meMA.Kathisma2T.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
alt1.meMA.Kathisma2T.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
alt1.meMA.Kathisma2T.incipit = me.m02.d17_gr_GR_cog.meMA.Ode3KathismaT.incipit
alt1.meMA.Kathisma2T.text = me.m02.d17_gr_GR_cog.meMA.Ode3KathismaT.text

alt1.meMA.Kathisma31.mode = miscellanea_gr_GR_cog.misc.Mode1
alt1.meMA.Kathisma31.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
alt1.meMA.Kathisma31.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
alt1.meMA.Kathisma31.incipit = "Μαρκέλλης τῆς σεπτῆς ἑορτάσωμεν μνήμην…"
alt1.meMA.Kathisma31.text = "Μαρκέλλης τῆς σεπτῆς ἑορτάσωμεν μνήμην, ἀπήμβλυνε καὶ γάρ, τοῦ βελίαρ τὰ κέντρα, καὶ στέφος ἀπείληφεν, ἐκ Θεοῦ τῆς ἀθλήσεως, ᾧ παρίσταται μετὰ ἀγγέλων ἐν δόξῃ, καὶ πρεσβεύουσα, οὑ διαλείπει σωθῆναι, τοὺς πόθῳ τιμῶντας αὐτήν."

alt1.meMA.Kathisma3T.mode = miscellanea_gr_GR_cog.misc.Mode1
alt1.meMA.Kathisma3T.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
alt1.meMA.Kathisma3T.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
alt1.meMA.Kathisma3T.incipit = "Φώτισον ἀγαθή, τὴν ἐν σκότει…"
alt1.meMA.Kathisma3T.text = "Φώτισον ἀγαθή, τὴν ἐν σκότει ψυχήν μου, καταύγασον ἁγνή, καὶ τὴν πώρωσιν λῦσον, καὶ δίδαξον πράττειν με, τοῦ Υἱοῦ σου τὸ θέλημα, ὅπως ἄφεσιν τῶν πολλῶν μου πταισμάτων, εὕρω Πάναγνε, καὶ τοῦ πυρὸς τοῦ ἀσβέστου, εὐχαῖς σου ῥυσθῆναί με."

alt1.meMA.PostGospelGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
alt1.meMA.PostGospelGlory.melody = ""
