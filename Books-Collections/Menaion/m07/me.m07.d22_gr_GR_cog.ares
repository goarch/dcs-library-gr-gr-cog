alt1.meDA.insert1 = "τῆς ἁγίας ἐνδόξου Παρθενομάρτυρος Μαρκέλλης τῆς Χιοπολίτιδος," //for use in petitions and dismissal
alt1.meDA.insert2 = "ἧς καὶ τὴν μνήμην ἐπιτελοῦμεν·" //for use in petitions and dismissal
