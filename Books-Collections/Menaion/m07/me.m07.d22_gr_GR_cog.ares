meLI.Kontakion1.text = me.m07.d22_gr_GR_cog.meMA.Kontakion1.text

meLI.MM.CommunionHymn.text = properties_gr_GR_cog.media.key

meLI.Megalynarion.text = "Τάφῳ προσελθοῦσα τῷ Ἰησοῦ, τοῦτον ἐθεάσω, ἀναστάντα ἐκ τῶν νεκρῶν· ὅθεν Ἀποστόλοις, Μαγδαληνὴ Μαρία, χαρᾶς εὐηγγελίσω τὰ εὐαγγέλια."

alt1.meDA.date = "Τῌ ΚΒʹ ΙΟΥΛΙΟΥ"
alt1.meDA.commemoration.full = "Μνήμη τῆς Παρθενομάρτυρος Μαρκέλλης τῆς Χιοπολίτιδος" //full title of day
alt1.meDA.commemoration.second = "" //full title of day
alt1.meDA.commemoration.first_short = "Μνήμη τῆς Ἁγίας Μαρκέλλης τῆς Χιοπολίτιδος"
alt1.meDA.commemoration.first_title = "Τῆς Ἁγ. Μαρκέλλης."
alt1.meDA.commemoration.first_name = "Ἁγία Μαρκέλλα"
alt1.meDA.commemoration.second_title = ""
