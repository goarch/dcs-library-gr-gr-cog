meDA.commemoration.first = "Μνήμη τῆς Ἁγίας Μαρίας τῆς Μαγδαληνῆς"
meDA.commemoration.first_short = "Μνήμη τῆς Ἁγίας Μαρίας τῆς Μαγδαληνῆς"
