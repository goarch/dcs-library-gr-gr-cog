meDA.commemoration.first = "Μνήμη τῆς Ἁγίας Μεγαλομάρτυρος Εὐφημίας"
meDA.commemoration.first_short = "Μνήμη τῆς Ἁγίας Μεγαλομάρτυρος Εὐφημίας"
