meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera01.greekmelody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.greekname
meVE.Stichera01.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera01.incipit = "Θεοφεγγῆ σε φωστῆρα…"
meVE.Stichera01.text = "Θεοφεγγῆ σε φωστῆρα Πάτερ ἐπέγνωμεν, ταῖς νοηταῖς ἀκτῖσι, καταυγάζοντα κόσμον, καὶ σκότος ἐκμειοῦντα τῆς πονηρᾶς, τῶν δαιμόνων συγχύσεως· τὴν φωτοφόρον σου μνήμην ὅθεν πιστῶς, ἑορτάζομεν μακάριε."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera02.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera02.incipit = "Περιφανὴς ἐν τῷ βίῳ…"
meVE.Stichera02.text = "Περιφανὴς ἐν τῷ βίῳ πάλαι γενόμενος, πλούτῳ καὶ δυναστείᾳ, Μοναζόντων τὸ σχῆμα, ὁσίως ἠμφιάσω Πάτερ Θωμᾶ, τὴν πτωχείαν μιμούμενος, τοῦ διʼ ἡμᾶς σαρκωθέντος· ὅθεν πολλοῖς σε χαρίσμασιν ἐπλούτισε."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera03.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera03.incipit = "Στύλῳ πυρὸς ὁρατῶς…"
meVE.Stichera03.text = "Στύλῳ πυρὸς ὁρατῶς σε Θεὸς ὡδήγησε, πρὸς σωτηρίαν Πάτερ, πρὸς γαλήνης λιμένα, πρὸς ὅρμον ἀπαθείας· ὕδωρ τῇ σῇ, προσευχῇ δὲ ἀνέβλυσε· καὶ ἀβλεπτοῦσι τὸ βλέπειν καὶ τοῖς χωλοῖς, εὐδρομίαν ἐδωρήσατο."

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Stichera04.greekmelody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.greekname
meVE.Stichera04.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
meVE.Stichera04.incipit = "Μάρτυς, ἀθληφόρε…"
meVE.Stichera04.text = "Μάρτυς, ἀθληφόρε τοῦ Χριστοῦ, ἔστης πρὸ βημάτων ἀνδρείως, Χριστὸν κηρύττουσα, σταύρωσιν ἑκούσιον καταδεξάμενον· καὶ δεσμοῖς ὁμιλήσασα, καὶ πάσαις αἰκίαις, χαίρουσα ἀνέδραμες πρὸς τὰ οὐράνια, δήμοις ἀπʼ αἰῶνος Μαρτύρων, συναριθμηθεῖσα καὶ δόξης, διαιωνιζούσης ἀπολαύουσα."

meVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Stichera05.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
meVE.Stichera05.incipit = "Λόγου, τοῦ φανέντος…"
meVE.Stichera05.text = "Λόγου, τοῦ φανέντος ἐπὶ γῆς, νύμφη ἐκλεκτὴ ἀνεδείχθης, Κυριακὴ ἀληθῶς, κάλλει διαλάμπουσα, ἐνθέων πράξεων, καὶ τῆς θείας ἀθλήσεως, φαιδραῖς ἀγλαΐαις· ὅθεν τὸν οὐράνιον θάλαμον ᾤκησας, ἔνθα, ὡς παρθένος καὶ Μάρτυς, πάντοτε χορεύουσα πάντων, τῶν μνημονευόντων σου μνημόνευε."

meVE.Stichera06.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.Stichera06.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
meVE.Stichera06.incipit = "Ῥίζης, εὐκλεοῦς Κυριακή…"
meVE.Stichera06.text = "Ῥίζης, εὐκλεοῦς Κυριακή, κλάδος ὡραιότατος ὤφθης, καρπὸν σωτήριον, φέρων τῆς ἀθλήσεως, τὰ κατορθώματα, καὶ μαραίνων ἐν χάριτι, φυτὰ ἀσεβείας· ὅθεν τὴν πανίερον, μνήμην σου σέβομεν, πόθῳ καὶ λειψάνων τὴν θήκην, νῦν περιπτυσσόμεθα χάριν, ἐξ αὐτῆς ἰάσεων λαμβάνοντες."

meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Ἐκ δεξιῶν τοῦ Σωτῆρος…"
meVE.SticGlory.text = "Ἐκ δεξιῶν τοῦ Σωτῆρος, παρέστη ἡ παρθένος καὶ ἀθληφόρος καὶ Μάρτυς, περιβεβλημένη ταῖς ἀρεταῖς τὸ ἀήττητον, καὶ πεποικιλμένη ἐλαίῳ τῆς ἁγνείας, καὶ τῷ αἵματι τῆς ἀθλήσεως, καὶ βοῶσα πρὸς αὐτόν, ἐν ἀγαλλιάσει τὴν λαμπάδα κατέχουσα. Εἰς ὀσμὴν μύρου σου ἔδραμον, Χριστὲ ὁ Θεός, ὅτι τέτρωμαι τῆς σῆς ἀγάπης ἐγώ· μὴ χωρίσῃς με νυμφίε ἐπουράνιε. Αὐτῆς ταῖς ἱκεσίαις κατάπεμψον ἡμῖν, παντοδύναμε Σωτὴρ τὰ ἐλέη σου."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticTheotokion.greekmelody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.greekname
meVE.SticTheotokion.melody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.name
meVE.SticTheotokion.incipit = "Πανύμνητε κατάβαλε…"
meVE.SticTheotokion.text = "Πανύμνητε κατάβαλε, ἐχθρῶν μιαιφονούντων ἰσχύν, καὶ τὴν λύπην, τοῦ λαοῦ σου εἰς χαράν, μετάβαλε Παρθένε, καὶ ἔλεος παράσχου, ὅπως σωθέντες ἀνυμνῶμέν σε."

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticStavrotheotokion.greekmelody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.greekname
meVE.SticStavrotheotokion.melody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.name
meVE.SticStavrotheotokion.incipit = me.m01.d16_gr_GR_cog.meVE.SticStavrotheotokion.incipit
meVE.SticStavrotheotokion.text = me.m01.d16_gr_GR_cog.meVE.SticStavrotheotokion.text

meVE.Aposticha.notice = "Τὰ Ἀπόστιχα τροποποιημένα ἐλήφθησαν ἐκ τῆς 26ης Ἰουλίου."

meVE.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha1.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.Aposticha1.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Aposticha1.incipit = me.m07.d26_gr_GR_cog.meVE.Aposticha1.incipit
meVE.Aposticha1.text = me.m07.d26_gr_GR_cog.meVE.Aposticha1.text

meVE.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha2.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Aposticha2.incipit = me.m07.d26_gr_GR_cog.meVE.Aposticha2.incipit
meVE.Aposticha2.text = me.m07.d26_gr_GR_cog.meVE.Aposticha2.text

meVE.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha3.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Aposticha3.incipit = "Καθαρότητα σώματος…"
meVE.Aposticha3.text = "Καθαρότητα σώματος, καὶ ψυχῆς τὴν λαμπρότητα, κτησαμένη πάντοτε ὤφθης ἄμωμος· σὺ γὰρ νυμφίον ποθήσασα, κατʼ ἴχνος ἐβάδισας, νοητοῦ μύρου σεμνή, Κυριακὴ ἀοίδιμε· καὶ νῦν πρέσβευε, τὸν Σωτῆρα τῶν ὅλων λύσιν δοῦναι, ὀφλημάτων τοῖς ἐν πίστει, ἐπιτελοῦσι τὴν μνήμην σου."

meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Ἐν πόλει τοῦ Θεοῦ ἡμῶν…"
meVE.AposGlory.text = "Ἐν πόλει τοῦ Θεοῦ ἡμῶν, ἐν ὄρει ἁγίῳ αὐτοῦ, ἐκεῖ κατεσκήνωσεν ἡ Ἁγία, τὴν λαμπάδα ἄσβεστον τηρήσασα. Ἀκούσωμεν τῆς παρθένου ἐγκώμιον· Ὦ Παρθενία, ναός Θεοῦ! ὦ Παρθενία, Μαρτύρων δόξα! ὦ Παρθενία, Ἀγγέλων συνόμιλε."

meVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.AposTheotokion.melody = ""
meVE.AposTheotokion.incipit = oc.m2.d3_gr_GR_cog.ocVE.AposTheotokion.incipit
meVE.AposTheotokion.text = oc.m2.d3_gr_GR_cog.ocVE.AposTheotokion.text

meVE.AposStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
meVE.AposStavrotheotokion.greekmelody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.greekname
meVE.AposStavrotheotokion.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
meVE.AposStavrotheotokion.incipit = oc.m2.d4_gr_GR_cog.ocVE.AposTheotokion.incipit
meVE.AposStavrotheotokion.text = oc.m2.d4_gr_GR_cog.ocVE.AposTheotokion.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.Apolytikion1ger.greekmelody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.greekname
meVE.Apolytikion1ger.melody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.name
meVE.Apolytikion1ger.incipit = "Τὴν διαῤῥέουσαν δόξαν…"
meVE.Apolytikion1ger.text = "Τὴν διαῤῥέουσαν δόξαν ἀπέῤῥιψας, καὶ τὸν τοῦ Κτίσαντος, ζυγὸν ἠγάπησας, ἀγγελικὴν ἐπὶ τῆς γῆς, ἑλόμενος πολιτείαν· ὅθεν χαρισμάτων σε, δωρεαῖς κατεπλούτισε, Χριστὸς ὁ Φιλάνθρωπος, ὁ δοξάσας τὸν βίον σου· ᾧ πρέσβευε Θωμᾶ θεοφόρε, ῥῦσαι ἡμᾶς πάσης ἀνάγκης."

meVE.Apolytikion2ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion2ger.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Apolytikion2ger.greekmelody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.greekname
meVE.Apolytikion2ger.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
meVE.Apolytikion2ger.incipit = "Κυρίων τὸν Κύριον…"
meVE.Apolytikion2ger.text = "Κυρίων τὸν Κύριον, καὶ Βασιλέα Χριστόν, ἐξ ὅλης ἠγάπησας, Κυριακὴ τῆς ψυχῆς, καὶ χαίρουσα ἤθλησας· ὅθεν Παρθενομάρτυς, παρʼ αὐτοῦ δοξασθεῖσα, βρύεις τοῖς σὲ τιμῶσιν, ἱαμάτων τὴν χάριν, τοῖς πᾶσιν αἰτουμένη, πταισμάτων συγχώρησιν."

meVE.Apolytikion3.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Apolytikion3.greekmelody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.greekname
meVE.Apolytikion3.melody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.name
meVE.Apolytikion3.incipit = "Καλλιέρημα ὤφθης…"
meVE.Apolytikion3.text = "Καλλιέρημα ὤφθης καὶ θῦμα ἅγιον, προσενεγκοῦσα τῷ Πλάστῃ τὴν καθαράν σου ψυχήν, ἣν ἐδόξασε Χριστός, ὦ καρτερόψυχε. Ὅθεν καὶ βρύει διὰ σοῦ, τοῖς τιμῶσί σε πιστοῖς, τὰς χάριτας ὑπὲρ ψάμμον, Κυριακὴ ἀθληφόρε, ὡς ἐλεήμων καὶ φιλάνθρωπος."

meMA.Kathisma1.notice = "Τὸ παρὸν Κάθισμα τροποποιημένον ἐλήφθη ἐκ τῆς 26ης Ἰουλίου."

meMA.Kathisma11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Kathisma11.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
meMA.Kathisma11.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Kathisma11.incipit = "Τὸν ὡραιότατον Χριστὸν ἀγαπήσασα, καὶ…"
meMA.Kathisma11.text = "Τὸν ὡραιότατον Χριστὸν ἀγαπήσασα, καὶ διʼ ἁγνείας τὴν ψυχὴν ὡραΐσασα, διὰ παντοίων πόνων τε καὶ θλίψεων, τούτῳ κατηγγύησαι, ὥσπερ ἄμωμος νύμφη· ὅθεν σε ἠξίωσεν, οὐρανίων θαλάμων, ὑπὲρ ἡμῶν πρεσβεύουσαν αὐτῷ, τῶν σὲ τιμώντων Κυριακὴ πανεύφημε."

meMA.Kathisma1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Kathisma1T.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meMA.Kathisma1T.incipit = ho.ho23_gr_GR_cog.hoCA.Apolytikion2.incipit
meMA.Kathisma1T.text = ho.ho23_gr_GR_cog.hoCA.Apolytikion2.text

meMA.Kathisma2.notice = "Τὸ παρὸν Κάθισμα εἶναι τὸ αὐτὸ τῆς Ἁγ. Παρασκευῆς (26 Ἰουλίου)."

meMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Kathisma21.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meMA.Kathisma21.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
