meDA.commemoration.first = "Μνήμη τοῦ Ἁγίου καὶ Ἐνδόξου Μεγαλομάρτυρος Προκοπίου"
meDA.commemoration.first_short = "Μνήμη τοῦ Ἁγίου καὶ Ἐνδόξου Μεγαλομάρτυρος Προκοπίου"
