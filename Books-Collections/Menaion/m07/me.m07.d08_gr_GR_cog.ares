meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera01.greekmelody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.greekname
meVE.Stichera01.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera01.incipit = "Ἀφωρισμένος ὑπάρχων, ἀπὸ κοιλίας μητρός…"
meVE.Stichera01.text = "Ἀφωρισμένος ὑπάρχων, ἀπὸ κοιλίας μητρός, ὑπὸ Θεοῦ πανσόφως, οὐρανόθεν τὴν κλῆσιν, ἔσχες κατὰ Παῦλον· ὅθεν μαθών, τὰ ἑκούσια πάθη Χριστοῦ, κήρυξ αὐτοῦ ἀνεδείχθης καὶ ζηλωτής, ἀληθῶς Μάρτυς Προκόπιε."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera02.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera02.incipit = "Τῇ μυστικῇ παντευχίᾳ, καθωπλισμένος σοφέ…"
meVE.Stichera02.text = "Τῇ μυστικῇ παντευχίᾳ, καθωπλισμένος σοφέ, νικοποιῷ τροπαίῳ, τοῦ Χριστοῦ τῷ σημείῳ, Προκόπιε θεόφρον, θράση ἐχθρῶν, δυσμενῶν ἐξηφάνισας, καὶ τῶν εἰδώλων τὰ ξόανα καθελών, μέχρις αἵματος ἐνήθλησας."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Stichera03.melody = he.a.m1_gr_GR_cog.heAU.TonOuranionTagmaton.name
meVE.Stichera03.incipit = "Ὡς τὸ στρατόπεδον πάλαι, σὺν…"
meVE.Stichera03.text = "Ὡς τὸ στρατόπεδον πάλαι, σὺν ταῖς πισταῖς γυναιξί, τῷ οὐρανίῳ Μάρτυς, Βασιλεῖ καὶ Δεσπότῃ, προσήγαγες Κυρίῳ, οὕτω καὶ νῦν, τοὺς τελοῦντας τὴν μνήμην σου, ταῖς σαῖς πρεσβείαις προσάγαγε τῷ Χριστῷ, ὦ Μαρτυρων ἐγκαλλώπισμα."

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera04.greekmelody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.greekname
meVE.Stichera04.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera04.incipit = "Ἄστρον, ἀνατέταλκας, ἐκ τῆς Ἑῴας…"
meVE.Stichera04.text = "Ἄστρον, ἀνατέταλκας, ἐκ τῆς Ἑῴας πολύφωτον, καταυγάζων Προκόπιε, τοῦ κόσμου τὰ πέρατα, ταῖς θεοσημίαις, καὶ τῇ καρτερίᾳ, τῶν ἀλγεινῶν ὡς ἀληθῶς, καὶ ταῖς τῶν ἄθλων μεγίσταις λάμψεσι· διό σου τὴν πανέορτον, καὶ φωτοφόρον πανήγυριν, ἑορτάζομεν σήμερον, ἀθλοφόρε Προκόπιε."

meVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera05.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera05.incipit = "Σῶμά σου Προκόπιε, καταξεόμενον ἔνδοξε…"
meVE.Stichera05.text = "Σῶμά σου Προκόπιε, καταξεόμενον ἔνδοξε, καὶ πυρὶ δαπανώμενον, εἱρκταῖς συγκλειόμενον, ὁμιλοῦν παντοίαις, ἰδέαις βασάνων, ξίφει τεμνόμενον σοφέ, τὴν βασιλείαν σοι προεξένησε, παμμάκαρ τὴν οὐράνιον, ἐν ᾗ χορεύεις γηθόμενος, ἀθλοφόρε πολύαθλε, τῶν Ἀγγέλων συμμέτοχε."

meVE.Stichera06.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera06.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meVE.Stichera06.incipit = "Δῆμον προσενήνοχας τῷ Ποιητῇ διὰ…"
meVE.Stichera06.text = "Δῆμον προσενήνοχας τῷ Ποιητῇ διὰ πίστεως, ἱερῶς ἐναθλήσαντα, θεόφρον Προκόπιε, μεθʼ ὧν τῶν Μαρτύρων, χοροῖς ἠριθμήθης, καταβαλὼν τὸν δυσμενῆ, ἀνδρειοφρόνως ἀξιοθαύμαστε· διό σε μακαρίζομεν, ὡς στρατιώτην ἀήττητον, ὡς γενναῖον ἀδάμαντα, ὡς τῆς πίστεως πρόμαχον."

meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Ἐξέλαμψε σήμερον, ἡ ἔνδοξος μνήμη…"
meVE.SticGlory.text = "Ἐξέλαμψε σήμερον, ἡ ἔνδοξος μνήμη σου, Προκόπιε πολύαθλε, συγκαλοῦσα ἡμᾶς τοὺς φιλεόρτους, πρὸς εὐφημίαν καὶ δόξαν, Χριστοῦ τοῦ Θεοῦ ἡμῶν. Ὅθεν καὶ προστρέχοντες, ἐν τῇ σορῷ τῶν λειψάνων σου, ἰαμάτων χαρίσματα λαμβάνομεν· καὶ τὸν σὲ στεφανώσαντα Σωτῆρα Χριστόν, ἀνυμνοῦμεν εἰς αἰῶνας, ἀκαταπαύστως δοξάζοντες."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticTheotokion.greekmelody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.greekname
meVE.SticTheotokion.melody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.name
meVE.SticTheotokion.incipit = "Τὸ ὄμμα τῆς καρδίας μου…"
meVE.SticTheotokion.text = "Τὸ ὄμμα τῆς καρδίας μου, ἐκτείνω πρὸς σὲ Δέσποινα, μὴ παρίδῃς, τὸν πικρόν μου στεναγμόν. Ἐν ὥρᾳ ὅταν κρίνῃ, ὁ σὸς Υἱὸς τὸν κόσμον, γενοῦ μοι σκέπη καὶ βοήθεια."

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticStavrotheotokion.greekmelody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.greekname
meVE.SticStavrotheotokion.melody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.name
meVE.SticStavrotheotokion.incipit = me.m01.d16_gr_GR_cog.meVE.SticStavrotheotokion.incipit
meVE.SticStavrotheotokion.text = me.m01.d16_gr_GR_cog.meVE.SticStavrotheotokion.text

meVE.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha1.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.Aposticha1.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Aposticha1.incipit = "Οὐρανόθεν ἡ κλῆσίς σου, ὡς…"
meVE.Aposticha1.text = "Οὐρανόθεν ἡ κλῆσίς σου, ὡς τοῦ κήρυκος γέγονε, τῶν ἐθνῶν Προκόπιε παναοίδιμε, καὶ φωτισθεὶς τὴν διάνοιαν, τὸ σκότος κατέλιπες, τῶν εἰδώλων καὶ φωστήρ, τῶν πιστῶν ἐχρημάτισας, θείαις λάμψεσι, τῶν σεπτῶν σου ἀγώνων καταυγάζων, τὰ πληρώματα τοῦ κόσμου, κλέος μαρτύρων καὶ καύχημα."

meVE.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha2.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Aposticha2.incipit = "Ἐγκρατείᾳ τὸ πρότερον, τῆς σαρκὸς…"
meVE.Aposticha2.text = "Ἐγκρατείᾳ τὸ πρότερον, τῆς σαρκὸς τὰ κινήματα, χαλινώσας ὕστερον πρὸς τὴν ἄθλησιν, ἀνδρειοφρόνως ἐχώρησας, παμμάκαρ Προκόπιε, ἀφειδήσας τῆς σαρκός, τῇ δυνάμει τοῦ Πνεύματος· ὅθεν ἅπασαν, ὑπομείνας ἰδέαν τῶν βασάνων, στεφηφόρος πρὸς τὰς ἄνω, χοροστασίας ἀνέδραμες."

meVE.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha3.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Aposticha3.incipit = "Στρατηγὸς ὡς ἀήττητος, τῷ Σταυρῷ…"
meVE.Aposticha3.text = "Στρατηγὸς ὡς ἀήττητος, τῷ Σταυρῷ ὁπλισάμενος, ταῖς ῥοαῖς τοῦ αἵματος πᾶσαν δύναμιν, τῶν ἐναντίων ἐβύθισας, καὶ ὄμβρους ἀνέβλυσας, ἰαμάτων δαψιλῶς, ἐκ πηγῶν ἀρυόμενος, ἀξιάγαστε, τοῦ σωτῆρος καὶ πάντας καταρδεύων, τοὺς φλογμῷ τῶν παθημάτων, συνεχομένους θεόπνευστε."

meVE.AposGlory.poet = poets_gr_GR_cog.po.ProkopiouChartofylakos
meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Ταῖς μυστικαῖς λαμπηδόσι, τῆς ὑπερφώτου…"
meVE.AposGlory.text = "Ταῖς μυστικαῖς λαμπηδόσι, τῆς ὑπερφώτου Τριάδος καταυγαζόμενος, Μάρτυς Προκόπιε γενναιόφρον, θέσει θεὸς χρηματίζεις, θεούμενος ἐν μεθέξει· ὅθεν τοὺς πίστει τελοῦντάς σου, τὴν φωσφόρον ἑορτήν, ἐκ πειρασμῶν πολυτρόπων, περίσῳζε σαῖς πρεσβείαις."

meVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.AposTheotokion.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
meVE.AposTheotokion.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.AposTheotokion.incipit = "Χαῖρε πυρίμορφον ὄχημα…"
meVE.AposTheotokion.text = "Χαῖρε πυρίμορφον ὄχημα· χαῖρε αὐγὴ μυστική, ἡ τῷ κόσμῳ εἰσάξασα, τὸν λαμπρὸν καὶ ἄδυτον, καὶ ἀνέσπερον ἥλιον· χαῖρε κογχύλη, πορφύραν βάψασα, ἐκ τῶν αἱμάτων, τῷ βασιλεῖ τοῦ παντός· χαῖρε πανάχραντε· χαῖρε φυλακτήριον, πάντων πιστῶν τῶν προσκαλουμένων σε, ἐν πεποιθήσει ψυχῆς."

meVE.AposStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.AposStavrotheotokion.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
meVE.AposStavrotheotokion.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
meVE.AposStavrotheotokion.incipit = me.m01.d15_gr_GR_cog.meMA.AposStavrotheotokion.incipit
meVE.AposStavrotheotokion.text = me.m01.d15_gr_GR_cog.meMA.AposStavrotheotokion.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Apolytikion1ger.greekmelody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.greekname
meVE.Apolytikion1ger.melody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.name
meVE.Apolytikion1ger.incipit = "Ἀγρευθεῖς οὐρανόθεν πρὸς τὴν εὐσέβειαν…"
meVE.Apolytikion1ger.text = "Ἀγρευθεῖς οὐρανόθεν πρὸς τὴν εὐσέβειαν, κατηκολούθησας χαίρων ὥσπερ ὁ Παῦλος Χριστῷ, τῶν Μαρτύρων καλλονὴ Μάρτυς Προκόπιε, ὅθεν δυνάμει τοῦ Σταυροῦ, ἀριστεύσας εὐκλεῶς, κατήσχυνας τὸν Βελίαρ, οὐ τῆς κακίας ἄτρωτους, σῷζε τοὺς πόθω σὲ γεραίροντας."

meVE.Apolytikion2ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion2ger.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Apolytikion2ger.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
meVE.Apolytikion2ger.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
meVE.Apolytikion2ger.incipit = "Ὡς τοῦ Σωτῆρος γνησιώτατν φίλον…"
meVE.Apolytikion2ger.text = "Ὡς τοῦ Σωτῆρος γνησιώτατν φίλον, καὶ τῶν ἐν Ἄθῳ εὐωδέστατον κρίνον, καὶ νοητὸν ἀλαβαστρον ὁσίων ἀρετῶν, ἱεροῖς ἐν ᾄσμασιν, εὐφημοῦμέν σε Πάτερ, εἰς ὀσμὴν τῶν μύρων σου, εὐλαβῶς συνδραμόντες, διʼ ὧν εὐφραίνεις πάντοτε ἡμᾶς, τοὺς σὲ τιμῶντας, Θεόφιλε Ὅσιε."

meMA.C1.poet = poets_gr_GR_cog.po.Theofanous
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaintM
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ThalassisToErythraion.greekname
meMA.Ode1C11.melody = he.h.m4_gr_GR_cog.heHE.ThalassisToErythraion.name
meMA.Ode1C11.incipit = "Πλουσίαις, μαρμαρυγαῖς τοῦ Πνεύματος, περιχεόμενος…"
meMA.Ode1C11.text = "Πλουσίαις, μαρμαρυγαῖς τοῦ Πνεύματος, περιχεόμενος, τοὺς τὴν φωσφόρον ταύτην καὶ σεπτήν, ἑορτήν σου γεραίροντας, παθῶν ἀχλύος λύτρωσαι, καὶ πειρασμῶν Μάρτυς Προκόπιε."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C12.melody = he.h.m4_gr_GR_cog.heHE.ThalassisToErythraion.name
meMA.Ode1C12.incipit = "Ἡ κλῆσις, οὐκ ἀπʼ ἀνθρώπων…"
meMA.Ode1C12.text = "Ἡ κλῆσις, οὐκ ἀπʼ ἀνθρώπων γέγονεν, ἡ σὴ Προκόπιε, ἀλλʼ οὐρανόθεν Παῦλον ὡς τὸ πρίν, ὁ Χριστὸς ἐσαγήνευσε, παθῶν οἰκείων Μάρτυρα, παναληθῆ σε ἐργαζόμενος."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C13.melody = he.h.m4_gr_GR_cog.heHE.ThalassisToErythraion.name
meMA.Ode1C13.incipit = "Στρατείας, τῆς ἐπικήρου πάνσοφε, τὴν…"
meMA.Ode1C13.text = "Στρατείας, τῆς ἐπικήρου πάνσοφε, τὴν αἰωνίζουσαν, ὡς νουνεχὴς ἠλλάξω καὶ θνητοῦ, βασιλέως ἀθάνατον, καὶ βασιλείαν ἄφθορον, σοὶ παρεχόμενον Προκόπιε."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C1T.melody = he.h.m4_gr_GR_cog.heHE.ThalassisToErythraion.name
meMA.Ode1C1T.incipit = "Τὸν φύσει, Δημιουργὸν ἐκύησας, ἡμᾶς…"
meMA.Ode1C1T.text = "Τὸν φύσει, Δημιουργὸν ἐκύησας, ἡμᾶς θεώσαντα, τῇ ὑπὲρ νοῦν ἑνώσει ἀληθῶς, Θεοτόκε πανύμνητε, ὃν ἐκτενῶς ἱκέτευε, φωταγωγῆσαι τοὺς ὑμνοῦντάς σε."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.greekname
meMA.Ode3C11.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C11.incipit = "Σταυροῦ ἐν μέσῳ, παραδόξως Χριστὸς…"
meMA.Ode3C11.text = "Σταυροῦ ἐν μέσῳ, παραδόξως Χριστός σοι ὀπτάνεται, ἐκδιδάσκων ἐμφανῶς, τὴν πρὸς ἡμᾶς συγκατάβασιν, καὶ σὲ πρὸς τὴν ἄθλησιν, προσεκκαλούμενος."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C12.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C12.incipit = "Ναὸν καὶ στήλην, ἀνεγείρας σαυτὸν…"
meMA.Ode3C12.text = "Ναὸν καὶ στήλην, ἀνεγείρας σαυτὸν θείου Πνεύματος, ζήλου πνέων θεϊκοῦ, ναοὺς καὶ ἄψυχα ξόανα, δαιμόνων κατέαξας, Μάρτυς Προκόπιε."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C13.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C13.incipit = "Συναπεβάλου, δερματίνους χιτῶνας τῷ, ξέεσθαι…"
meMA.Ode3C13.text = "Συναπεβάλου, δερματίνους χιτῶνας τῷ, ξέεσθαι, ἀφθαρσίας δὲ στολήν, περιεβάλου Προκόπιε, καὶ τὸν πολυμήχανον, Μάρτυς ἐγύμνωσας."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C1T.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.name
meMA.Ode3C1T.incipit = "Ῥῦσαί με πάσης, προσβολῆς ἐναντίας…"
meMA.Ode3C1T.text = "Ῥῦσαί με πάσης, προσβολῆς ἐναντίας του ὄφεως, Μητροπάρθενε ἁγνή, καὶ τὴν καρδίαν μου φώτισον, πίστει σε δοξάζοντος, τὴν παναμώμητον."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3H.greekmelody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.greekname
meMA.Ode3H.melody = he.h.m4_gr_GR_cog.heHE.OukEnSofia.melody
meMA.Ode3H.incipit = he.h.m4_gr_GR_cog.heHE.OukEnSofia.incipit
meMA.Ode3H.text = he.h.m4_gr_GR_cog.heHE.OukEnSofia.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3Kathisma1.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
meMA.Ode3Kathisma1.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Ode3Kathisma1.incipit = "Τὸν Παῦλον ὡς τὸ πρίν…"
meMA.Ode3Kathisma1.text = "Τὸν Παῦλον ὡς τὸ πρίν, ὁ Χριστὸς οὐρανόθεν, Προκόπιε σοφέ, σὲ καλεῖ πρὸς τὴν πίστιν, τὸ κάλλος τὸ ἔνθεον, προειδὼς τῆς καρδίας σου· ὅθεν ἤθλησας, ἀνδρειοτάτως κηρύττων, τὰ παθήματα, καὶ τὴν αὐτοῦ πρὸς ἀνθρώπους, παμμάκαρ ἐπέλευσιν."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3KathismaT.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Ode3KathismaT.incipit = me.m03.d03_gr_GR_cog.meMA.Ode3KathismaT.incipit
meMA.Ode3KathismaT.text = me.m03.d03_gr_GR_cog.meMA.Ode3KathismaT.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3KathismaSt.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
meMA.Ode3KathismaSt.incipit = me.m06.d21_gr_GR_cog.meMA.Ode3KathismaSt.incipit
meMA.Ode3KathismaSt.text = me.m06.d21_gr_GR_cog.meMA.Ode3KathismaSt.text 

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C11.greekmelody = he.h.m4_gr_GR_cog.heHE.EparthentaSeIdousa.greekname
meMA.Ode4C11.melody = he.h.m4_gr_GR_cog.heHE.EparthentaSeIdousa.name
meMA.Ode4C11.incipit = "Ἐπαιρόμενον τῷ κράτει τῆς ἀσεβείας…"
meMA.Ode4C11.text = "Ἐπαιρόμενον τῷ κράτει τῆς ἀσεβείας, τὸν ἀλαζόνα Τύραννον, ταῖς πρὸς τὸν Δεσπότην, θείαις ἀνυψώσεσι, κραυγάζων κατέῤῥαξας, δόξα τῇ δυνάμει σου Κύριε."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C12.melody = he.h.m4_gr_GR_cog.heHE.EparthentaSeIdousa.name
meMA.Ode4C12.incipit = "Ἐπιφαίνεται φρουρᾷ σοι ἐγκεκλεισμένῳ ὁ…"
meMA.Ode4C12.text = "Ἐπιφαίνεται φρουρᾷ σοι ἐγκεκλεισμένῳ ὁ Λυτρωτὴς Προκόπιε, θάρσους ἐμπιπλῶν σε, φέγγει τε λαμπρύνων σε, καὶ κλῆσιν κατάλληλον, σοῦ τῇ προκοπῇ παρεχόμενος."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C13.melody = he.h.m4_gr_GR_cog.heHE.EparthentaSeIdousa.name
meMA.Ode4C13.incipit = "Τὸ τῇ χάριτι τῇ θείᾳ…"
meMA.Ode4C13.text = "Τὸ τῇ χάριτι τῇ θείᾳ λελαμπρυσμένον, σοῦ κατιδόντες πρόσωπον, οἱ τῆς ἀπιστίας, ζόφῳ καλυπτόμενοι, τὸ φέγγος τῆς πίστεως, θείᾳ ἐπινεύσει κομίζονται."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C1T.melody = he.h.m4_gr_GR_cog.heHE.EparthentaSeIdousa.name
meMA.Ode4C1T.incipit = "Βεβαρυμμένον τῷ ὕπνῳ τῆς ῥαθυμίας…"
meMA.Ode4C1T.text = "Βεβαρυμμένον τῷ ὕπνῳ τῆς ῥαθυμίας, πρὸς μετανοίας ὄρθρον με, τῇ σῇ ἀκοιμήτῳ, Δέσποινα ἐξέγειρον, πρεσβείᾳ καὶ σῶσόν με, μόνη τὸν Σωτῆρα κυήσασα."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C11.greekmelody = he.h.m4_gr_GR_cog.heHE.AseveisOukOpsontai.greekname
meMA.Ode5C11.melody = he.h.m4_gr_GR_cog.heHE.AseveisOukOpsontai.name
meMA.Ode5C11.incipit = "Τῷ φωτὶ τῶν λόγων σου…"
meMA.Ode5C11.text = "Τῷ φωτὶ τῶν λόγων σου, στρατὸν θεοπειθῆ προσενήνοχας τῷ Χριστῷ, μαρτυρίου αἵματι, κληρονομήσαντα, μετὰ σοῦ Προκόπιε, βασιλείαν τὴν ἀσάλευτον."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C12.melody = he.h.m4_gr_GR_cog.heHE.AseveisOukOpsontai.name
meMA.Ode5C12.incipit = "Τῆς συγκλήτου ὤφθησαν, τῆς ἄνω…"
meMA.Ode5C12.text = "Τῆς συγκλήτου ὤφθησαν, τῆς ἄνω κοινωνοί, γυναικῶν αἱ Συγκλητικαί, γένους περιφάνειαν, ἀπαρνησάμεναι, καὶ θανεῖν ἑλόμεναι, ὑπὲρ σοῦ Λόγε ἀθάνατε."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C13.melody = he.h.m4_gr_GR_cog.heHE.AseveisOukOpsontai.name
meMA.Ode5C13.incipit = "Τῷ πυρὶ φλεγόμεναι, τῷ θείῳ…"
meMA.Ode5C13.text = "Τῷ πυρὶ φλεγόμεναι, τῷ θείῳ τὴν ψυχήν, φλεγομένου καὶ ἀφειδῶς, ξεομένου σώματος περιεφρόνησαν, αἱ τὴν σὴν ποθήσασαι, βασιλείαν πολυέλεε."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C1T.melody = he.h.m4_gr_GR_cog.heHE.AseveisOukOpsontai.name
meMA.Ode5C1T.incipit = "Συλλαβοῦσα τέτοκας, Θεὸν Ἐμμανουήλ, εἰς…"
meMA.Ode5C1T.text = "Συλλαβοῦσα τέτοκας, Θεὸν Ἐμμανουήλ, εἰς ἀνάπλασιν τῶν βροτῶν, Παναγία ἄχραντε, σάρκα γενόμενον, ὃν ἀεὶ ἱκέτευε, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν"

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C11.greekmelody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.greekname
meMA.Ode6C11.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C11.incipit = "Ἔῤῥει σου, ἡ μελίῤῥυτος γλῶσσα…"
meMA.Ode6C11.text = "Ἔῤῥει σου, ἡ μελίῤῥυτος γλῶσσα διδάγματα, μελισταγῆ καὶ πικρίας, ἀθεΐας ὄντως ἀπελυτροῦτο, εὐπειθῶς σοι, τοὺς προστρέχοντας Μάρτυς Προκόπιε."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C12.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C12.incipit = "Μητέρα, τὴν εὐσέβειαν Μάρτυς κτησάμενος…"
meMA.Ode6C12.text = "Μητέρα, τὴν εὐσέβειαν Μάρτυς κτησάμενος, τῆς δυσσεβείας ἐξαίρεις, σοῦ τὴν κατὰ σάρκα σεμνὴν μητέρα, καὶ προσάγεις, οὐρανίῳ Πατρὶ διʼ ἀθλήσεως."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C13.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C13.incipit = "Τὰς ὄψεις, ἀποξέων σιδήρῳ ὁ…"
meMA.Ode6C13.text = "Τὰς ὄψεις, ἀποξέων σιδήρῳ ὁ Τύραννος, τοῦ λογισμοῦ σου τὸν τόνον, Μάρτυς οὐκ ἐσάλευσεν ἡδρασμένον τῇ ἀγάπῃ τοῦ τὰ πάθη σαρκὶ ὑπομείναντος."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C1T.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C1T.incipit = "Ἅγιον, τῶν Ἁγίων ἀῤῥήτως ἐκύησας…"
meMA.Ode6C1T.text = "Ἅγιον, τῶν Ἁγίων ἀῤῥήτως ἐκύησας, ὑπεραγία Παρθένε, τοὺς πιστοὺς ἀεὶ ἁγιάζοντα, καὶ μαρτύρων, τοὺς χοροὺς τοῖς Ἀγγέλοις συνάπτοντα."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6H.greekmelody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.greekname
meMA.Ode6H.melody = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.melody
meMA.Ode6H.incipit = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.incipit
meMA.Ode6H.text = he.h.m4_gr_GR_cog.heHE.ThysoSoiMetaFonis.text

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Kontakion1.greekmelody = he.a.m2_gr_GR_cog.heAU.TaAnoZiton.greekname
meMA.Kontakion1.melody = he.a.m2_gr_GR_cog.heAU.TaAnoZiton.name
meMA.Kontakion1.incipit = "Τῷ ζήλῳ Χριστοῦ, τῷ θείῳ…"
meMA.Kontakion1.text = "Τῷ ζήλῳ Χριστοῦ, τῷ θείῳ πυρπολούμενος, καὶ ἐν τῷ Σταυρῷ, τῷ τιμίῳ φρουρούμενος, τῶν ἐχθρῶν τὸ φρύαγμα, καὶ τὰ θράση καθεῖλες Προκόπιε, καὶ τὴν σεπτὴν Ἐκκλησίαν ὕψωσας, τῇ πίστει προκόπτων, καὶ φωτίζων ἡμᾶς."

meMA.Oikos1.text = "Στόμα συνέσεώς μοι παράσχου ὁ προάναρχος Λόγος, βουλομένῳ ὑμνεῖν τὸν σὸν ὁπλίτην Προκόπιον· ἔχεις γὰρ πλοῦτον τῆς εὐσπλαγχνίας, ἐν ἀπείρῳ Χριστέ μου πελάγει τῶν σῶν κριμάτων, ἵνα κἀγὼ τῆς ψυχῆς τὸ ζοφῶδες καθαρθῶ, τοῦ νοῦ δὲ πᾶσαν κηλῖδα ἀποσμήξας, καὶ ναὸς ἁγιάσματος τοῖς θείοις ἔργοις γενόμενος, ἐπάξια μέλψω τῷ Μάρτυρι, ὃς τὴν σεπτὴν Ἐκκλησίαν ὕψωσε, τῇ πίστει προκόπτων καὶ φωτίζων ἡμᾶς."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C11.greekmelody = he.h.m4_gr_GR_cog.heHE.EnTiKaminoAvramiaioi.greekname
meMA.Ode7C11.melody = he.h.m4_gr_GR_cog.heHE.EnTiKaminoAvramiaioi.name
meMA.Ode7C11.incipit = "Βάρει μολύβδου, τὸν σὸν αὐχένα…"
meMA.Ode7C11.text = "Βάρει μολύβδου, τὸν σὸν αὐχένα συντριβόμενος, μάρτυς οὐκ ᾐσθάνου· φέρειν γὰρ τὸν ζυγόν, ἐπαυχένιον ἐπόθησας, τὸν ἐλαφρότατον, τοῦ διʼ οἶκτον ὁμιλήσαντος."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C12.melody = he.h.m4_gr_GR_cog.heHE.EnTiKaminoAvramiaioi.name
meMA.Ode7C12.incipit = "Χάριν ἐξ ὕψους, τῶν ἰαμάτων…"
meMA.Ode7C12.text = "Χάριν ἐξ ὕψους, τῶν ἰαμάτων κομισαμενος, νόσους ἀπελαύνεις, Μάρτυς καὶ πονηρά, ἐκβοῶν διώκεις πνεύματα· Εὐλογητὸς εἶ ὁ Θεός μου, κραυγάζων καὶ Κύριος."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C13.melody = he.h.m4_gr_GR_cog.heHE.EnTiKaminoAvramiaioi.name
meMA.Ode7C13.incipit = "Τὰς νιφετώδεις, τῶν δυσμενῶν πληγὰς…"
meMA.Ode7C13.text = "Τὰς νιφετώδεις, τῶν δυσμενῶν πληγὰς δεχόμενος, Μάκαρ καὶ πυρί, φλεγόμενος καρτερῶς, τὴν ἀσέβειαν κατέφλεξας· Εὐλογητὸς εἶ ὁ Θεός μου, κραυγάζων, καὶ Κύριος."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C1T.melody = he.h.m4_gr_GR_cog.heHE.EnTiKaminoAvramiaioi.name
meMA.Ode7C1T.incipit = "Κόρης ἀφθόρου, ὑπερφυῶς ἀποτίκτεται, Λόγος…"
meMA.Ode7C1T.text = "Κόρης ἀφθόρου, ὑπερφυῶς ἀποτίκτεται, Λόγος ὁ τῷ λόγῳ πάντα δημιουργῶν, ἀλογίας θέλων ῥύσασθαι, τοὺς τὴν ἑκούσιον δοξολογοῦντας, αὐτοῦ συγκατάβασιν."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C11.greekmelody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.greekname
meMA.Ode8C11.melody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.name
meMA.Ode8C11.incipit = "Λαμπάσι φλεγόμενος δεινῶς, τοῖς ὀβελίσκοις…"
meMA.Ode8C11.text = "Λαμπάσι φλεγόμενος δεινῶς, τοῖς ὀβελίσκοις τε κατακεντούμενος, καὶ τοῖς χρονίοις σου μώλωψιν, ἀναξέσεις εἰσδεχόμενος, καὶ ἀλγεινόμενος σφοδρῶς, Μάρτυς ἐκραύγαζες· Εὐλογεῖτε πάντα τὰ ἔργα Κυρίου τὸν Κύριον."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C12.melody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.name
meMA.Ode8C12.incipit = "Τῇ σῇ δεξιᾷ τὰ ζοφερά…"
meMA.Ode8C12.text = "Τῇ σῇ δεξιᾷ τὰ ζοφερά, δαιμόνων πρόσωπα, Μάκαρ ἐῤῥάπισας· ταύτην γὰρ ἄνθραξιν ἔνδοξε, καταφλέγεσθαι ὑπέδειξας, παρανομοῦντι δικαστῇ, ἀντιταττόμενος καὶ κραυγάζων· Πάντα τὰ ἔργα, εὐλογεῖτε ὑμνεῖτε τὸν Κύριον."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C13.melody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.name
meMA.Ode8C13.incipit = "Τὴν πέτραν Χριστὸν τὴν ἀῤῥαγῆ…"
meMA.Ode8C13.text = "Τὴν πέτραν Χριστὸν τὴν ἀῤῥαγῆ, παμμάκαρ ἔνδοξε, ἔχων θεμέλιον, λίθοις Προκόπιε ἔχαιρες, ὠμοτάτως βαρυνόμενος, πρὸς ἀβαρῆ σε χαρμονὴν ἀνακουφίζουσαν, ἐκβοῶντα· Πάντα τὰ ἔργα, εὐλογεῖτε ὑμνεῖτε τὸν Κύριον."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C1T.melody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.name
meMA.Ode8C1T.incipit = "Ἰδοὺ πᾶσαι Κόρη γενεαί, ὡς…"
meMA.Ode8C1T.text = "Ἰδοὺ πᾶσαι Κόρη γενεαί, ὡς προεφήτευσας, σὲ μακαρίζουσι, Θεὸν μακάριον τέξασαν, μακαρίους ἐργαζόμενον, τοὺς τοῖς προστάγμασιν αὐτοῦ ἀκολουθοῦντας πιστῶς, καὶ βοῶντας· Πάντα τὰ ἔργα, εὐλογεῖτε ὑμνεῖτε τὸν Κύριον."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8H.greekmelody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.greekname
meMA.Ode8H.melody = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.melody
meMA.Ode8H.incipit = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.incipit
meMA.Ode8H.text = he.h.m4_gr_GR_cog.heHE.CheirasEkpetasasDaniil.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C11.greekmelody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.greekname
meMA.Ode9C11.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C11.incipit = "Τοῦ πεποθημένου σοι τέλους, ἐπιτυχὼν…"
meMA.Ode9C11.text = "Τοῦ πεποθημένου σοι τέλους, ἐπιτυχὼν μεγαλοφρόνως, ἔκλινας Θεῷ τὸν αὐχένα, κρουσθεὶς δὲ ξίφει ὥσπερ ἐν ἅρματι, τῷ σῷ ἐπέβης αἵματι, καὶ πρὸς αὐτὸν Μάρτυς ἀνέδραμες."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C12.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C12.incipit = "Βρύεις ποταμοὺς ἰαμάτων, πηγὴ γενόμενος…"
meMA.Ode9C12.text = "Βρύεις ποταμοὺς ἰαμάτων, πηγὴ γενόμενος θαυμάτων, παύεις δὲ φλογμοὺς παθημάτων, δαιμονικάς τε βυθίζεις φάλαγγας, τῇ πανσθενεῖ τοῦ Πνεύματος, θείᾳ δυνάμει Ἀξιάγαστε."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C13.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C13.incipit = "Τοὺς τὴν παναγίαν σου μνήμην…"
meMA.Ode9C13.text = "Τοὺς τὴν παναγίαν σου μνήμην, περιχαρῶς ἐπιτελοῦντας, πάσης ἀπειλῆς, πάσης νόσου, παντὸς κινδύνου σῷζε Προκόπιε, ταῖς πρὸς τὸν Κτίστην Κύριον, ἱερωτάταις σου δεήσεσι."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C1T.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.name
meMA.Ode9C1T.incipit = "Φῶς ἡμῖν ἀνέτειλε Κόρη, ἐκ…"
meMA.Ode9C1T.text = "Φῶς ἡμῖν ἀνέτειλε Κόρη, ἐκ φωτοφόρου σου νηδύος, ὁ δημιουργὸς τοῦ ἡλίου, καὶ τῶν ἀστέρων καὶ πάσης κτίσεως, ὃν ἐκτενῶς ἱκέτευε, φωταγωγῆσαι τοὺς ὑμνοῦντάς σε."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9H.greekmelody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.greekname
meMA.Ode9H.melody = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.melody
meMA.Ode9H.incipit = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.incipit
meMA.Ode9H.text = he.h.m4_gr_GR_cog.heHE.LithosAcheirotmitos.text

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.greekname
meMA.Exaposteilarion1.melody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.name
meMA.Exaposteilarion1.incipit = "Ἐξ οὐρανοῦ ὡς τῷ Παύλω…"
meMA.Exaposteilarion1.text = "Ἐξ οὐρανοῦ ὡς τῷ Παύλω, ἐγένετό σοι ἡ κλῆσις, ᾗ φερωνύμως προκόπτων, Προκόπιε τῷ Κυρίῳ, χοροὺς προσῆξας Μαρτύρων, μεθʼ ὧν πρεσβεύεις, ὑπὲρ τῶν σὲ εὐφημούντων."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.ExapTheotokion.melody = he.a.m3_gr_GR_cog.heAU.FosAnalloioton.name
meMA.ExapTheotokion.incipit = "Σοῦ τὸ πολίτευμα Λόγε, κραταίωσον…"
meMA.ExapTheotokion.text = "Σοῦ τὸ πολίτευμα Λόγε, κραταίωσον ἐν πολέμοις, τοῖς βασιλεῦσι τὸ νῖκος, κατὰ βαρβάρων παρέχων, τῆς Θεοτόκου πρεσβείαις, ἣν ἐδωρήσω, Χριστιανοῖς προστασίαν."

meMA.Lauds1.poet = poets_gr_GR_cog.po.Vyzantiou
meMA.Lauds1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Lauds1.melody = ""
meMA.Lauds1.incipit = "Ὡς προκόπτων ἐν Θεῷ πάντας…"
meMA.Lauds1.text = "Ὡς προκόπτων ἐν Θεῷ πάντας πρέσβευε ἀθλοφόρε, προκόπτειν ἐν αὐτῷ, Μαρτύρων κλέος μέγιστε Προκόπιε, ὡς παῤῥησίαν ἔχων πρὸς αὐτόν, καὶ τῷ τούτου θρόνῳ ἀεὶ παριστάμενος, ἐν θεαρέστοις ὁδοῖς καὶ θείαις πράξεσιν, εὐαρεστοῦντας αὐτῷ καὶ σὲ μακαρίζοντας."

meMA.Lauds2.poet = poets_gr_GR_cog.po.Germanou
meMA.Lauds2.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Lauds2.melody = ""
meMA.Lauds2.incipit = "Νεανικὴν ἄγων τὴν ἡλικίαν, ὥσπερ…"
meMA.Lauds2.text = "Νεανικὴν ἄγων τὴν ἡλικίαν, ὥσπερ ὁ θεσπέσιος Παῦλος, ἐκ τῶν ὑψίστων τὸ θεῖον χάρισμα ἐδέξω, καὶ τοῦ δεινοῦ πολεμήτορος τὰ θράση, τῇ πανοπλίᾳ τοῦ Σταυροῦ κατέβαλες, Μαρτύρων τὸ καύχημα, ἀθλοφόρε, Προκόπιε, ὑπὲρ ἡμῶν πρὸς Κύριον ἱκέτευε, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν."

meMA.Lauds3.poet = poets_gr_GR_cog.po.Kyprianou
meMA.Lauds3.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Lauds3.melody = ""
meMA.Lauds3.incipit = "Αἶνος τῷ Θεῷ ἐκ χοϊκῶν…"
meMA.Lauds3.text = "Αἶνος τῷ Θεῷ ἐκ χοϊκῶν χειλέων προσᾴδεται, ἐπὶ τῇ θείᾳ μνήμῃ σου, Προκόπιε πολύαθλε· σὺ γὰρ ὤφθης ἀκραιφνὴς στρατιώτης, τοῦ λόγου τῆς πίστεως, φαυλίσας ἐν τῷ σκάμματι εἰδώλων τὰς μορφάς, καὶ νῦν προσηρείσθης τῷ φέγγει τῆς Τριάδος, καταπυρσεύων ἡμῶν τὰς διανοίας ταῖς πρεσβείαις σου."

meMA.Lauds4.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Lauds4.melody = ""
meMA.Lauds4.incipit = "Ἡ Ἐκκλησία σήμερον, στολισαμένη τοῖς…"
meMA.Lauds4.text = "Ἡ Ἐκκλησία σήμερον, στολισαμένη τοῖς ἄθλοις σου, Μάρτυς τοῦ Χριστοῦ, εὐφραίνεται, καὶ τὴν σὴν παγγέραστον μνήμην, κατʼ ἀξίαν εὐφήμως κραυγάζει γεραίρουσα· Χαίροις ὁ τὸν Παῦλον ζηλώσας, καὶ τὸν Σταυρὸν τοῦ Χριστοῦ ἀράμενος, καὶ τὰς παγίδας συντρίψας τοῦ ἀντιπάλου· Χαίροις Μαρτύρων τὸ καύχημα, καὶ Βασιλέων κραταίωμα, Προκόπιε πολύαθλε, ὑπὲρ ἡμῶν πρὸς Κύριον, μὴ διαλίπῃς πρεσβεύων, ὡς παῤῥησίαν ἔχων, ἀθλοφόρων ἐγκαλλώπισμα."

meMA.LaudsGlory.poet = poets_gr_GR_cog.po.Anatoliou
meMA.LaudsGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.LaudsGlory.melody = ""
meMA.LaudsGlory.incipit = "Ὥσπερ ὁ Παῦλος τὴν κλῆσιν…"
meMA.LaudsGlory.text = "Ὥσπερ ὁ Παῦλος τὴν κλῆσιν, ἐκ τοῦ Θεοῦ δεξάμενος, Μάρτυς Προκόπιε, καὶ προκόπτων ἐν Θεῷ, τῇ τοῦ Σταυροῦ πεποιθήσει, τῶν τυῤῥάνων τὸ δυσσεβές, καὶ τῶν βασάνων τὸ ἀπηνές, ἀνδρείως κατῄσχυνας. Διὸ καὶ μέχρις αἵματος, ἀντικατέστης πρὸς τὴν ἁμαρτίαν, πρὸς ἀοράτους ἐχθροὺς ἀνταγωνισάμενος, καὶ πρεσβεύεις ἀπαύστως, τῷ λυτρωτῇ καὶ Θεῷ, δωρηθῆναι τῇ οἰκουμένῃ εἰρήνην, καὶ ταῖς ψυχαῖς ἡμῶν τὸ μέγα ἔλεος."

meMA.LaudsTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.LaudsTheotokion.melody = ""
meMA.LaudsTheotokion.incipit = oc.m8.d5_gr_GR_cog.ocMA.AposTheotokion.incipit
meMA.LaudsTheotokion.text = oc.m8.d5_gr_GR_cog.ocMA.AposTheotokion.text

meMA.MM.VeApos1123as3456.text = properties_gr_GR_cog.media.key
meMA.MM.VeApos1123as5678.text = properties_gr_GR_cog.media.key

meLI.Kontakion1.mode = me.m07.d08_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.greekmelody = me.m07.d08_gr_GR_cog.meMA.Kontakion1.greekmelody
meLI.Kontakion1.melody = me.m07.d08_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m07.d08_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m07.d08_gr_GR_cog.meMA.Kontakion1.text

meLI.Megalynarion.text = "Κλήσει οὐρανίῳ ἀκολουθῶν, φερωνύμως μάρτυς, καὶ προκόπτων ἀθλητικώς, σύμμορφος ἐδείχθης, τοῦ σοὶ καθοραθέντος, Προκόπιε θεόφρον, ἀθλήσας ἄριστα."
