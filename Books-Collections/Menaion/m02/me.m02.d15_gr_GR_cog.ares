meDA.commemoration.first = "Μνήμη τοῦ Ἁγίου Ἀποστόλου Ὀνησίμου"
meDA.commemoration.first_short = "Μνήμη τοῦ Ἁγίου Ἀποστόλου Ὀνησίμου"
