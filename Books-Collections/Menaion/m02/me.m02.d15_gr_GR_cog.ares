A_Resource_Whose_Name = me.m02.d15_gr_GR_cog

meDA.date = "Τῌ ΙΕʹ ΦΕΒΡΟΥΑΡΙΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
