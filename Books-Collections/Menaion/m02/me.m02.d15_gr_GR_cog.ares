meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera01.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera01.incipit = "Ποταμοῦ τὰ ὁρμήματα, τοῦ τῆς…"
meVE.Stichera01.text = "Ποταμοῦ τὰ ὁρμήματα, τοῦ τῆς χάριτος Κήρυκος, ὡς Θεοῦ φανέντα σε πόλιν ἔμψυχον, διαφερόντως εὐφραίνουσι, τὰ ἄῤῥητα ῥήματα, ἐπὶ γῆς τοῦ τῆς τρυφῆς, Παραδείσου πλουτήσαντος· οὗ καὶ γέγονας, δραστικὸς ὑπηρέτης ἐκμανθάνων τὰ οὐράνια παμμάκαρ, ἃ οὐκ ἐξὸν βροτοῖς φθέγξασθαι."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera02.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera02.incipit = "Τὸ τῆς γνώμης ἐλεύθερον, καὶ…"
meVE.Stichera02.text = "Τὸ τῆς γνώμης ἐλεύθερον, καὶ ψυχῆς αὐτεξούσιον, εὐγενείᾳ πίστεως κατελάμπρυνας· τῆς ἐπιγείου δὲ πάνσοφε, δουλείας ἀπήλλαξαι, καὶ τῇ ζεύγλῃ τοῦ Χριστοῦ, τὸν αὐχένα ὑπέκλινας· ὅθεν ἔδραμες, νοητῆς ἐκ δουλείας τοὺς ἀνθρώπους, ἀπαλλάττων καὶ προσάγων, ἐλευθερίᾳ τῆς χάριτος."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Stichera03.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Stichera03.incipit = "Ὡς ἀκτῖνά σε πάνσοφε, φεγγοβόλον…"
meVE.Stichera03.text = "Ὡς ἀκτῖνά σε πάνσοφε, φεγγοβόλον ἐξήστραψεν, ὁ τοῦ κόσμου Ἥλιος καὶ Διδάσκαλος, τὴν οἰκουμένην λαμπρύνουσαν, φωτὶ τοῦ κηρύγματος, καὶ ταῖς θείαις ἀστραπαῖς, τὴν τῆς πλάνης σκοτόμαιναν, ἀφανίζουσαν, καὶ ποικίλων θαυμάτων ἐνεργείας, τῶν πιστῶν τὰς διανοίας, καταφαιδρύνουσαν ἔνδοξε."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticTheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.SticTheotokion.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.SticTheotokion.incipit = "Κατακρίσεως λύτρωσαι…"
meVE.SticTheotokion.text = "Κατακρίσεως λύτρωσαι, Παναγία θεόνυμφε, καὶ δεινῶν πταισμάτων τὴν ταπεινήν μου ψυχήν· καὶ τοῦ θανάτου ἀπάλλαξον, εὐχαῖς σου καὶ δώρησαι, δικαιώσεως τυχεῖν, ἐν ἡμέρᾳ ἐτάσεως, ἧς ἐπέτυχον, τῶν Ἁγίων οἱ δῆμοι μετανοίᾳ, καθαρθέντα με πρὸ τέλους, καὶ τῶν δακρύων ταῖς χύσεσιν."

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.SticStavrotheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.SticStavrotheotokion.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.SticStavrotheotokion.incipit = me.m02.d11_gr_GR_cog.meVE.AposStavrotheotokion.incipit
meVE.SticStavrotheotokion.text = me.m02.d11_gr_GR_cog.meVE.AposStavrotheotokion.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode1
meVE.Apolytikion1ger.greekmelody = he.a.m1_gr_GR_cog.heAU.TisErimouPolitis.greekname
meVE.Apolytikion1ger.melody = he.a.m1_gr_GR_cog.heAU.TisErimouPolitis.name
meVE.Apolytikion1ger.incipit = "Ταῖς ἀκτῖσι τοῦ Παύλου φωτισθεὶς…"
meVE.Apolytikion1ger.text = "Ταῖς ἀκτῖσι τοῦ Παύλου φωτισθεὶς τὴν διάνοιαν, ὤφθης ὑπηερέτης τοῦ Λότου καὶ Ἀπόστολος ἔνθεος· καὶ ὄνησιν ἐβράβευσας ζωῆς, Ὀνήσιμε θεράπον τοῦ Χριστοῦ, διὰ λόγων καὶ θαυμάτων θεοπρεπῶν, τοῖς πίστει ἐκβοῶσί σοι· δόξα τῷ σὲ δοξάσαντι φαιδρῶς, δόξα τῷ σὲ στεφανώσαντι, δόξα τῷ ἐνεργοῦντι διὰ σοῦ, πᾶσιν ἰάματα."

meMA.C1.acrostic.title = "Κανὼν τοῦ Ἀποστόλου,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Παθῶν με δοῦλον ὄντα λύτρωσαι Μάκαρ."
meMA.C1.poet = poets_gr_GR_cog.po.Theofanous
meMA.C1.title = titles_gr_GR_cog.ti.CanonApostle
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_Apostle.text

meMA.Ode1C1H.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.greekname
meMA.Ode1C1H.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.melody
meMA.Ode1C1H.incipit = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.incipit
meMA.Ode1C1H.text = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C11.greekmelody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.greekname
meMA.Ode1C11.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C11.incipit = "Πεφωτισμένος τῇ θείᾳ καὶ φωταυγεῖ…"
meMA.Ode1C11.text = "Πεφωτισμένος τῇ θείᾳ καὶ φωταυγεῖ, τοῦ Σωτῆρος χάριτι, τὴν ζοφώδη μου ψυχήν, δυσωπῶν, Ὀνήσιμε Χριστόν, τὸν φιλάνθρωπον Θεόν, Μάκαρ διάσωσον."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C12.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C12.incipit = "Ἀκτινοβόλοις τοῦ Παύλου καταυγασθείς, λαμπηδόσιν…"
meMA.Ode1C12.text = "Ἀκτινοβόλοις τοῦ Παύλου καταυγασθείς, λαμπηδόσιν ἔνδοξε, τῆς ἀγνοίας τὴν ἀχλύν, εὐχερῶς διέφυγες, Χριστῷ, χαριστήριον ᾠδήν, βοῶν Πανόλβιε."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C13.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C13.incipit = "Θεῖος ἐδείχθης Παμμάκαρ ἱερουργός, καὶ…"
meMA.Ode1C13.text = "Θεῖος ἐδείχθης Παμμάκαρ ἱερουργός, καὶ τῷ θείῳ Πνεύματι, διαλάμπων τηλαυγῶς, πανταχοῦ διέδραμες Χριστόν, ἀναγγέλλων εὐσεβῶς, θεομακάριστε."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode1C1T.melody = he.h.m6_gr_GR_cog.heHE.OsEnIpeiroPezefsas.name
meMA.Ode1C1T.incipit = "Ὡραϊσμένη τῷ κάλλει τῶν ἀρετῶν…"
meMA.Ode1C1T.text = "Ὡραϊσμένη τῷ κάλλει τῶν ἀρετῶν, Θεομῆτορ ἄχραντε, τὸν Θεὸν τὸν ἀληθῆ, ὑπὲρ νοῦν συνέλαβες ἡμᾶς, τὸν ταῖς θείαις ἀρεταῖς, καταφαιδρύναντα."

meMA.Ode3C1H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.greekname
meMA.Ode3C1H.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.melody
meMA.Ode3C1H.incipit = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.incipit
meMA.Ode3C1H.text = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.text

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C11.greekmelody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.greekname
meMA.Ode3C11.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.name
meMA.Ode3C11.incipit = "Ναμάτων θείων τῇ πηγῇ, προσπελάσας…"
meMA.Ode3C11.text = "Ναμάτων θείων τῇ πηγῇ, προσπελάσας τὸ στόμα, καὶ τρυφῆς τὸν χειμάῤῥουν, ἐξ αὐτῆς ἀναλαβών, τὸ πρόσωπον τῆς σεπτῆς Ἐκκλησίας, Ἔνδοξε κατήρδευσας."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C12.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.name
meMA.Ode3C12.incipit = "Μεθέξει φέγγους νοητοῦ, φαεινότατος ὤφθης…"
meMA.Ode3C12.text = "Μεθέξει φέγγους νοητοῦ, φαεινότατος ὤφθης, εὐσεβείας λαμπάσι, τὰς καρδίας τῶν πιστῶν, καταφωτίζων λαμπρῶς, τῇ φωσφόρῳ, αἴγλῃ τοῦ κηρύγματος."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C13.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.name
meMA.Ode3C13.incipit = "Ἐλύθης Παύλου τοῖς δεσμοῖς, ἐκ…"
meMA.Ode3C13.text = "Ἐλύθης Παύλου τοῖς δεσμοῖς, ἐκ δουλείας τῆς πλάνης, καὶ τῇ ἐλευθερίᾳ, τῆς χάριτος τιμηθείς, Υἱὸς Θεοῦ γεγονώς, κληρονόμος, θεῖος ἀναδέδειξαι."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode3C1T.melody = he.h.m6_gr_GR_cog.heHE.OukEstinAgios.name
meMA.Ode3C1T.incipit = "Δολίως ὄφις με τὸ πρίν…"
meMA.Ode3C1T.text = "Δολίως ὄφις με τὸ πρίν, ὡς αἰχμάλωτον εἷλε, δι ἀπάτης ἑρπύσας, διὰ σοῦ δὲ τῆς αὐτοῦ, δουλείας ἀπαλλαγεὶς Θεομῆτορ, ὕμνοις μακαρίζω σε."

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3Kathisma1.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Ode3Kathisma1.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3Kathisma1.incipit = "Ἐκ δουλείας τῆς πλάνης ἀπαλλαγείς…"
meMA.Ode3Kathisma1.text = "Ἐκ δουλείας τῆς πλάνης ἀπαλλαγείς, ἀπελεύθερος ὤφθης ἐν τῷ Θεῷ, αὐτοῦ δοῦλος γνήσιος, χρηματίσας ἐν χάριτι, κοινωνὸς δεσμῶν δέ, τοῦ Παύλου γενόμενος, διὰ Χριστὸν ἐκτάνθης, ἀδίκως Ἀπόστολε· ὅθεν ἠξιώθης, μαρτυρήσας νομίμως, τῆς ἄνω λαμπρότητος, Ἱεράρχα Ὀνήσιμε· διὰ τοῦτο βοῶμέν σοι· Πρέσβευε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ, τὴν ἁγίαν μνήμην σου."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3KathismaT.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3KathismaT.incipit = me.m02.d07_gr_GR_cog.meMA.Ode3KathismaT.incipit
meMA.Ode3KathismaT.text = me.m02.d07_gr_GR_cog.meMA.Ode3KathismaT.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3KathismaSt.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3KathismaSt.incipit = me.m01.d24_gr_GR_cog.meMA.Ode3KathismaSt.incipit
meMA.Ode3KathismaSt.text = me.m01.d24_gr_GR_cog.meMA.Ode3KathismaSt.text

meMA.Ode4C1H.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.greekname
meMA.Ode4C1H.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.melody
meMA.Ode4C1H.incipit = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.incipit
meMA.Ode4C1H.text = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C11.greekmelody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.greekname
meMA.Ode4C11.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C11.incipit = "Ὁ θέλων ἅπαντας, σωθῆναι Κύριος…"
meMA.Ode4C11.text = "Ὁ θέλων ἅπαντας, σωθῆναι Κύριος, ἐκ ζυγοῦ σε δουλείας ἱερουργόν, Μάκαρ προχειρίζεται, ἱερουργοῦντα τὸ σεπτόν, θεοφάντορ Εὐαγγέλιον."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C12.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C12.incipit = "Υἱὸς σὺ γέγονας, Θεοῦ τῇ…"
meMA.Ode4C12.text = "Υἱὸς σὺ γέγονας, Θεοῦ τῇ χάριτι, τὸν αὐτοῦ καταγγέλλων μονογενῆ, Λόγον τὸν ἀΐδιον, μετὰ σαρκὸς τοῖς ἐπὶ γῆς, παραδόξως ὁμιλήσαντα."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C13.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C13.incipit = "Λογίῳ κρίσεως, καὶ θείῳ χρίσματι…"
meMA.Ode4C13.text = "Λογίῳ κρίσεως, καὶ θείῳ χρίσματι, τῷ τῆς ἱερωσύνης ὡς Ἱερεύς, Πάνσοφε διέπρεψας, καὶ καρτερίᾳ τῶν δεινῶν, Μάρτυς θεῖος ἐχρημάτισας."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode4C1T.melody = he.h.m6_gr_GR_cog.heHE.ChristosMouDynamis.name
meMA.Ode4C1T.incipit = "Ὁ φύσει ἄναρχος, Υἱὸς καὶ…"
meMA.Ode4C1T.text = "Ὁ φύσει ἄναρχος, Υἱὸς καὶ ἄχρονος, χρονικὴν ἐκ Παρθένου Κόρης ἀρχήν, θέλων καταδέχεται, τους ὑπὸ χρόνον ἐκ φθορᾶς, ἀναπλάσαι προμηθούμενος."

meMA.Ode5C1H.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.greekname
meMA.Ode5C1H.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.melody
meMA.Ode5C1H.incipit = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.incipit
meMA.Ode5C1H.text = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.text

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C11.greekmelody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.greekname
meMA.Ode5C11.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C11.incipit = "Νοὸς ὀξύτητι καὶ ψυχῆς, Μάκαρ…"
meMA.Ode5C11.text = "Νοὸς ὀξύτητι καὶ ψυχῆς, Μάκαρ καθαρότητι πάντας, τοῦ δυσμενοῦς ὑπεριπτάμενος, βρόχους ἀνυψώθης πρὸς οὐρανίους σκηνάς, πτεροῖς θεογνωσίας ἀναφερόμενος."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C12.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C12.incipit = "Ὁ σὸς Ἀπόστολος ἀγαθέ, τὴν…"
meMA.Ode5C12.text = "Ὁ σὸς Ἀπόστολος ἀγαθέ, τὴν διὰ σαρκός σου παρουσίαν πρὸς ἀνθρώπους ἐκήρυξε, τοὺς πεπλανημένους πρὸς σὴν ἐπίγνωσιν, ὁδηγῶν καὶ φωτίζων, αἴγλῃ τῆς πίστεως."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C13.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C13.incipit = "Ναὸς ἐδείχθης πανευπρεπής, ἔνδον κεκτημένος…"
meMA.Ode5C13.text = "Ναὸς ἐδείχθης πανευπρεπής, ἔνδον κεκτημένος ὡς λυχνίαν, τὸ φέγγος τῆς θείας χάριτος, τῇ οἰκοδομίᾳ τοῦ θείου Πνεύματος τεθεμελιωμένος Μάκαρ Ὀνήσιμε."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode5C1T.melody = he.h.m6_gr_GR_cog.heHE.ToTheioFengeiSou.name
meMA.Ode5C1T.incipit = "Τῆς ἁμαρτίας μου τὰς σειράς…"
meMA.Ode5C1T.text = "Τῆς ἁμαρτίας μου τὰς σειράς, τῇ σῇ μεσιτείᾳ, καὶ προστασίᾳ, Παρθένε διάῤῥηξον· τῶν ἀπεγνωσμένων σὺ γὰρ ὑπάρχεις ἐλπίς, τῶν πίστει προστρεχόντων, τῇ θείᾳ σκέπῃ σου."

meMA.Ode6C1H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.greekname
meMA.Ode6C1H.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.melody
meMA.Ode6C1H.incipit = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.incipit
meMA.Ode6C1H.text = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.text

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C11.greekmelody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.greekname
meMA.Ode6C11.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C11.incipit = "Ἀστράψας ὡς ἥλιος, οὐρανόθεν ὁ…"
meMA.Ode6C11.text = "Ἀστράψας ὡς ἥλιος, οὐρανόθεν ὁ κληθείς, τῷ φωτισμῷ τῆς χάριτος, ἐπαφῆκεν ἀκτῖνά σε τηλαυγῆ, εὐτόνως ἐλαύνουσαν, τῆς ἀγνοίας τὸν ζόφον Παμμακάριστε."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C12.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C12.incipit = "Λαμπρῶς ἐστηλίτευσας, τῶν ἀνόμων τὰ…"
meMA.Ode6C12.text = "Λαμπρῶς ἐστηλίτευσας, τῶν ἀνόμων τὰ σαθρά, καὶ δυσσεβῆ φρυάγματα, εὐσεβείας φθεγγόμενος εὐσεβῶς, τὰ θεῖα διδάγματα, Ἱεράρχα Κυρίου πανσεβάσμιε."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode6C1T.melody = he.h.m6_gr_GR_cog.heHE.TouViouTinThalassan.name
meMA.Ode6C1T.incipit = "Ὑπάρχων ὑπεύθυνος, ἁμαρτίαις καὶ δεινῶς…"
meMA.Ode6C1T.text = "Ὑπάρχων ὑπεύθυνος, ἁμαρτίαις καὶ δεινῶς, τραυματισθεὶς ὁ δείλαιος, ἐπὶ σὲ Θεομῆτορ τὴν συμπαθῆ, προσφεύγω δεόμενος, τὰς οὐλὰς ἐξαλεῖψαι τῶν πταισμάτων μου."

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Kontakion1.greekmelody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.greekname
meMA.Kontakion1.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
meMA.Kontakion1.incipit = "Ὡς ἀκτίς ἐξέλαμψας, τῇ οἰκουμένῃ…"
meMA.Kontakion1.text = "Ὡς ἀκτίς ἐξέλαμψας, τῇ οἰκουμένῃ, ταῖς βολαῖς λαμπόμενος, ἡλίου μάκαρ παμφαοῦς, Παύλου τοῦ κόσμον φωτίσαντος· διό σε πάντες, τιμῶμεν Ὀνήσιμε."

meMA.Oikos1.text = "Σὲ ὑπὸ Παύλου τοῦ σοφοῦ, τῆς σάλπιγγος τῆς θείας, τῇ πίστει προσαχθέντα, καὶ λόγῳ φωτισθέντα τῆς ἀληθείας μυστικῶς, καὶ μαρτυρηθέντα ἐπʼ ἐργασίᾳ ἀρετῆς, καὶ πίστεως στεῤῥότητι, τίς ἐγκωμιάσαι ἰσχύσει, ὡς ὄντως κατʼ ἀξίαν, ἢ τοὺς πόνους εὐφημῆσαι, ἐν οἷς στεῤῥῶς ἔπαυσας τὴν πλάνην; Χρισθεὶς γὰρ Ἱερεὺς ἐν Πνεύματι θείῳ, ἐκ δουλείας κοσμικῆς, καὶ Ἀποστόλων κήρυγμα λαβών, μετέσχες καὶ τῶν στεφάνων· διό σε πάντες τιμῶμεν Ὀνήσιμε."

meMA.Ode7C1H.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.greekname
meMA.Ode7C1H.melody = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.melody
meMA.Ode7C1H.incipit = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.incipit
meMA.Ode7C1H.text = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.text

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C11.greekmelody = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.greekname
meMA.Ode7C11.melody = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.name
meMA.Ode7C11.incipit = "Τὸ μακάριον ἀπείληφας Ὀνήσιμε, τέλος…"
meMA.Ode7C11.text = "Τὸ μακάριον ἀπείληφας Ὀνήσιμε, τέλος καὶ τὴν ἀνώλεθρον, ἀθανασίαν ἠξιώθης μάκαρ καθορᾶν καὶ μέλπεις γηθόμενος Χριστῷ· Εὐλογητὸς εἶ ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C12.melody = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.name
meMA.Ode7C12.incipit = "Ῥωμαλέῳ σου φρονήματι Ὀνήσιμε, πλάνης…"
meMA.Ode7C12.text = "Ῥωμαλέῳ σου φρονήματι Ὀνήσιμε, πλάνης τὰ μηχανήματα, κατεπάτησας, εὐσεβείας ταῦτα καθελών, ὀργάνοις θεόσοφε βοῶν· Εὐλογητὸς εἶ ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode7C1T.melody = he.h.m6_gr_GR_cog.heHE.DrosovolonMenTinKaminon.name
meMA.Ode7C1T.incipit = "Ὡς ὑπάρχουσα πανάμωμος Θεόνυμφε, Λόγον…"
meMA.Ode7C1T.text = "Ὡς ὑπάρχουσα πανάμωμος Θεόνυμφε, Λόγον Θεοῦ συνέλαβες, τὸν ἀχωρήτως ἐν τοῖς κόλποις ὄντα τοῦ Πατρός, χερσί τε κρατούμενον ταῖς σαῖς, εὐλογημένη Παναγία, Θεομῆτορ ἁγνή."

meMA.Ode8C1H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.greekname
meMA.Ode8C1H.melody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.melody
meMA.Ode8C1H.incipit = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.incipit
meMA.Ode8C1H.text = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.text

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C11.greekmelody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.greekname
meMA.Ode8C11.melody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.name
meMA.Ode8C11.incipit = "Σὺν Ἀγγέλοις χορεύων Μάκαρ Ὀνήσιμε…"
meMA.Ode8C11.text = "Σὺν Ἀγγέλοις χορεύων Μάκαρ Ὀνήσιμε, μαρτυρίου τε στέφει κατακοσμούμενος, θρόνῳ νῦν φαιδρῶς, τοῦ Δεσπότου παρίστασαι, ὃν ὑπερυψοῦμεν, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C12.melody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.name
meMA.Ode8C12.incipit = "Ἀποστόλῳ τῷ θείῳ διακονούμενος, ἀποῤῥήτων…"
meMA.Ode8C12.text = "Ἀποστόλῳ τῷ θείῳ διακονούμενος, ἀποῤῥήτων τῶν θείων ἔσχες ἐνέργειαν, κήρυξ ἀληθής, Χριστοῦ Μάκαρ γενόμενος, ὃν ὑπερυψοῦμεν εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C13.melody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.name
meMA.Ode8C13.incipit = "Ἰαμάτων τὴν χάριν ἐκ τῆς…"
meMA.Ode8C13.text = "Ἰαμάτων τὴν χάριν ἐκ τῆς ἀφθόνου πηγῆς, τοῦ Σωτῆρος πλουτήσας πᾶσι μετέδωκας, τούτου πειθαρχῶν, Μάκαρ θείοις προστάγμασιν, ὃν ὑπερυψοῦμεν, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode8C1T.melody = he.h.m6_gr_GR_cog.heHE.EkFlogosToisOsiois.name
meMA.Ode8C1T.incipit = "Μυηθέντες τὸ θαῦμα τῆς σῆς…"
meMA.Ode8C1T.text = "Μυηθέντες τὸ θαῦμα τῆς σῆς γεννήσεως, ἀνυμνοῦμεν τὸ μέγα καὶ ὑπὲρ ἔννοιαν, Πάναγνε σεμνή, Θεομῆτορ Μυστήριον, καὶ ὑπερυψοῦμεν, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode9C1H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1H.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C1H.greekmelody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.greekname
meMA.Ode9C1H.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.melody
meMA.Ode9C1H.incipit = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.incipit
meMA.Ode9C1H.text = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C11.greekmelody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.greekname
meMA.Ode9C11.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.name
meMA.Ode9C11.incipit = "Ἀστὴρ ὑπέρλαμπρος ἀναδέδειξαι, φωτιστικαῖς ἀκτῖσι διαλάμπων…"
meMA.Ode9C11.text = "Ἀστὴρ ὑπέρλαμπρος ἀναδέδειξαι, φωτιστικαῖς ἀκτῖσι διαλάμπων τοῦ Πνεύματος, καὶ τὰ τοῦ κόσμου πέρατα λαμπρύνων φωτί, τῷ τῆς θεογνωσίας, μάκαρ Ὀνήσιμε· ὅθεν Ἀποστόλων σὺν χοροῖς, σὲ μεγαλύνομεν."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C12.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.name
meMA.Ode9C12.incipit = "Καρποῖς τοῦ Πνεύματος ὢν κατάκοσμος…"
meMA.Ode9C12.text = "Καρποῖς τοῦ Πνεύματος ὢν κατάκοσμος, εἰς οὐρανούς ἐπήρθης Θεοφάντορ γηθόμενος, τοῦ Χριστοῦ Ἀπόστολος γενόμενος, πάνσοφος ἱεράρχης, Μάρτυς ἀήττητος, Κήρυξ Ἀληθὴς τῶν ὑπὲρ νοῦν, Θεομακάριστε."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C13.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.name
meMA.Ode9C13.incipit = "Ἀεὶ προΐστασο τῶν ὑμνούντων σε…"
meMA.Ode9C13.text = "Ἀεὶ προΐστασο τῶν ὑμνούντων σε, διὰ παντὸς τὴν σήν τε ἐκτελούντων πανήγυριν, τῷ Δεσπότῃ παρεστὼς Ὀνήσιμε, ὅλος πεφωτισμένος, ὅλος ὑπέρλαμπρος, ὅλος ταῖς ἐκεῖθεν ἀστραπαῖς καταλαμπόμενος."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode6
meMA.Ode9C1T.melody = he.h.m6_gr_GR_cog.heHE.TheonAnthropois.name
meMA.Ode9C1T.incipit = "Ῥυσθεὶς τῷ τόκῳ σου παναμώμητε…"
meMA.Ode9C1T.text = "Ῥυσθεὶς τῷ τόκῳ σου παναμώμητε, Μήτηρ Θεοῦ της πάλαι δερματίνης νεκρώσεως, καὶ κατάραν καὶ φθορὰν καὶ θάνατον, τὸν ἐκ τῆς ἁμαρτίας, ἀποσεισάμενος, σὺν ταῖς οὐρανίαις Στρατιαῖς, νῦν μεγαλύνω σε."

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Exaposteilarion1.greekmelody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.greekname
meMA.Exaposteilarion1.melody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.name
meMA.Exaposteilarion1.incipit = "Μαθητευθεὶς πανόλβιε, Παύλῳ τῷ Κορυφαίῳ…"
meMA.Exaposteilarion1.text = "Μαθητευθεὶς πανόλβιε, Παύλῳ τῷ Κορυφαίῳ, τῶν Ἀποστόλων πάνσοφε, σὺν αὐτῷ περιῆλθες, τὴν γῆν στηρίζων τῷ λόγῳ, παρειμένας καρδίας, τῇ πλάνῃ τοῦ ἀλάστορος, καὶ τελέσας τὸν δρόμον, ἐν οὐρανοῖς, τῷ Χριστῷ παρίστασαι σὺν Ἀγγέλοις, Ἀπόστολε Ὀνήσιμε, ὑπὲρ κόσμου πρεσβεύων."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.ExapTheotokion.melody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.name
meMA.ExapTheotokion.incipit = "Τῆς ὑπὲρ νοῦν λοχείας σου…"
meMA.ExapTheotokion.text = "Τῆς ὑπὲρ νοῦν λοχείας σου, τὸ παράδοξον θαῦμα, νοῦς οὐκ Ἀγγέλων δύναται, οὐ βροτῶν ἑρμηνεῦσαι, ἢ ἐννοῆσαι Παρθένε· τίκτεις γὰρ ἀποῤῥήτως, Θεὸν τὸν ὑπερούσιον, ὃν ὑμνεῖ πᾶσα κτίσις, ὡς Ποιητήν, σὺν Πατρὶ καὶ Πνεύματι τῷ Ἁγίῳ, οὗ τῆς χαρᾶς ἀξίωσον, καὶ ἡμᾶς Θεοτόκε."

meLI.Kontakion1.mode = me.m02.d15_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.greekmelody = me.m02.d15_gr_GR_cog.meMA.Kontakion1.greekmelody
meLI.Kontakion1.melody = me.m02.d15_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m02.d15_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m02.d15_gr_GR_cog.meMA.Kontakion1.text

meLI.Megalynarion.text = ""

