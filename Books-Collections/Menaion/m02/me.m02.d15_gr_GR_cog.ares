meDA.pdfheaderdate = "τῆς 15ης Φεβρουαρίου"
meDA.fordate = "διὰ τὴν 15ην Φεβρουαρίου"
meLE.commemoration1 = "Τοῦ Ἁγίου Ἀποστόλου Ὀνησίμου."
meLE.commemoration2 = ""
meHO.number = ""
meHO.rank = ""
