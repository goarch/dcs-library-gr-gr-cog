A_Resource_Whose_Name = me.m02.d03_gr_GR_cog

meDA.date = "Τῌ Γʹ ΦΕΒΡΟΥΑΡΙΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
meDA.commemoration.full = "Μνήμη τοῦ Ἁγίου καὶ Δικαίου Συμεὼν τοῦ Θεοδόχου, καὶ Ἄννης τῆς Προφήτιδος" // full title of day
meDA.commemoration.first = "Μνήμη τοῦ Ἁγίου Συμεὼν τοῦ Θεοδόχου, καὶ Ἄννης τῆς Προφήτιδος"
meDA.commemoration.first_short = "Μνήμη τοῦ Ἁγίου Συμεὼν τοῦ Θεοδόχου, καὶ Ἄννης τῆς Προφήτιδος"
meDA.commemoration.first_title = titles_gr_GR_cog.ti.Feast
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = titles_gr_GR_cog.ti.Saints
meDA.commemoration.second_name = ""
meDA.insert1 = "καὶ τοῦ Ἁγίου καὶ Δικαίου Συμεὼν τοῦ Θεοδόχου, καὶ Ἄννης τῆς Προφήτιδος," // for use in petitions and dismissal
meDA.insert2 = "ὧν καὶ τὴν μνήμην ἐπιτελοῦμεν·" // for use in petitions and dismissal
meDA.note = ""
meDA.pdfcoverdate = "τῆς 3ης Φεβρουαρίου,"
meDA.pdfdatebefore = "τῆς 3ης Φεβρουαρίου"
meDA.pdfheaderdate = "τῆς 3ης Φεβρουαρίου"
meDA.fordate = "διὰ τὴν 3ην Φεβρουαρίου"
meLE.commemoration1 = "Τοῦ Ἁγίου καὶ Δικαίου Συμεὼν τοῦ Θεοδόχου."
meLE.commemoration2 = ""
meHO.number = ""
meHO.rank = ""
meHO.commemorations = ""
meHO.note1 = ""
meHO.note2 = ""
meDA.dismissal = dismissals_gr_GR_cog.dis00.meeting
