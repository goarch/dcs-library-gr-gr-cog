meDA.fordate = "διὰ τὴν 21ην Φεβρουαρίου"
meLE.commemoration1 = "Μνήμη τοῦ Ὁσίου Πατρὸς ἡμῶν Τιμοθέου, τοῦ ἐν Συμβόλοις καὶ τοῦ Ἁγίου Πατρὸς ἡμῶν Εὐσταθίου, Πατριάρχου Ἀντιοχείας τῆς μεγάλης."
meLE.commemoration2 = ""
