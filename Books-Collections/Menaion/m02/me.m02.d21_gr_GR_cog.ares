meDA.date = "Τῌ ΚΑʹ ΦΕΒΡΟΥΑΡΙΟΥ" // date, e.g. Τῌ ΙϚʹ ΤΟΥ ΑΥΤΟΥ ΜΗΝΟΣ or July 16
meDA.commemoration.full = "Μνήμη τοῦ Ὁσίου Πατρὸς ἡμῶν Τιμοθέου, τοῦ ἐν Συμβόλοις, καὶ τοῦ Ἁγίου Πατρὸς ἡμῶν Εὐσταθίου, Πατριάρχου Ἀντιοχείας τῆς μεγάλης." //full title of day
meDA.commemoration.first = "Μνήμη τοῦ Ὁσίου Τιμοθέου, τοῦ ἐν Συμβόλοις"
meDA.commemoration.first_short = "Μνήμη τοῦ Ὁσίου Τιμοθέου, τοῦ ἐν Συμβόλοις"
meDA.commemoration.first_title = titles_gr_GR_cog.ti.SaintM
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = ""
meDA.commemoration.second_name = ""
