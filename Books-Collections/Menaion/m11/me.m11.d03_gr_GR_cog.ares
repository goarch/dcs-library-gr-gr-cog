meVE.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha1.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meVE.Aposticha1.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Aposticha1.incipit = "Ἀθλοφόρε Γεώργιε, τῶν Ἀγγέλων συνόμιλε…"
meVE.Aposticha1.text = "Ἀθλοφόρε Γεώργιε, τῶν Ἀγγέλων συνόμιλε, τῶν Μαρτύρων σύσκηνε, καταφύγιον, τῶν θλιβομένων ἑκάστοτε, λιμὴν ἀναψύξεως, θαλαττεύοντι κἀμοί, ἐν τῷ βίῳ γενήθητι, καὶ κυβέρνησον, δυσωπῶ τὴν ζωήν μου, ὅπως πίστει, ἀδιστάκτῳ μακαρίζω, τοὺς ὑπὲρ φύσιν ἀγῶνάς σου."

meVE.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha2.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Aposticha2.incipit = me.m04.d23_gr_GR_cog.meVE.Stichera06.incipit
meVE.Aposticha2.text = me.m04.d23_gr_GR_cog.meVE.Stichera06.text

meVE.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Aposticha3.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meVE.Aposticha3.incipit = me.m04.d23_gr_GR_cog.meVE.Stichera04.incipit
meVE.Aposticha3.text = me.m04.d23_gr_GR_cog.meVE.Stichera04.text

meVE.AposGlory.poet = poets_gr_GR_cog.po.EfraimKarias
meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Προοίμιον τυπικῶς, τῆς τρισσοφεγγοῦς ὑμῶν…"
meVE.AposGlory.text = "Προοίμιον τυπικῶς, τῆς τρισσοφεγγοῦς ὑμῶν ὁμονοίας, καὶ ἐν Χριστῷ μαρτυρίας τῆς ἀκηράτου Τριάδος, καὶ ὑπερουσίου Μονάδος Ἀθληταί, οἱ ἐν Περσίδι ἄφλεκτοι συντηρηθέντες, τρεῖς Παῖδες γεγόνασιν· ὡς γὰρ ἐκεῖνοι φλογὸς κατετόλμησαν, εἰς Θεὸν μὴ ὑβρίσαντες, οὕτω καὶ ὑμεῖς θανεῖν οὐ παρητήσασθε, μὴ ὑπενδόντες τῇ τοῦ Χριστοῦ ἀγαπήσει. Ἀλλʼ ὡς ἐκείνους ὁ φανεὶς τέταρτος, ἐν τῇ φλογὶ ἐδρόσιζεν, οὕτω καὶ ὑμᾶς Χριστός, ὁ εἷς τῆς Τριάδος, προσεδέξατο ἐν τόπῳ ἀναψύξεως. Ἀκεψιμᾶ σὺν τῷ Ἰωσήφ, καὶ Ἀειθαλᾶ θεόληπτοι, πρεσβεύσατε ὑπὲρ τῶν ψυχῶν ἡμῶν."

meVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.AposTheotokion.melody = ""
meVE.AposTheotokion.incipit = me.m01.d28_gr_GR_cog.meVE.SticTheotokion.incipit
meVE.AposTheotokion.text = me.m01.d28_gr_GR_cog.meVE.SticTheotokion.text

