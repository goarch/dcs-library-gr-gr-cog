meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Stichera01.greekmelody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.greekname
meVE.Stichera01.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meVE.Stichera01.incipit = "Χαίροις ἡ τῆς Τριάδος τριάς…"
meVE.Stichera01.text = "Χαίροις ἡ τῆς Τριάδος τριάς, τῶν ἀρετῶν τὰ καθαρὰ καταγώγια, κρατῆρες τὸν θεῖον οἶνον, τῆς εὐσεβείας ἡμῶν, τὰς ψυχὰς εὐφραίνοντα οἱ προχέοντες· μαζοὶ οἱ τὸ γάλα, τῶν ἰαμάτων πηγάζοντες, ἄστρα τὸ φέγγος, ἀληθείας πυρσεύοντα, καὶ τὰ πέρατα, φωταυγίαις λαμπρύνοντα· Μάρτυρες μεγαλώνυμοι, οἱ νύκτα μειώσαντες, τῆς ἀγνωσίας καὶ πάντων, τὰς διανοίας φωτίσαντες· Χριστὸν δυσωπεῖτε, ταῖς ψυχαῖς ἡμῶν δοθῆναι, τὸ μέγα ἔλεος."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Stichera02.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meVE.Stichera02.incipit = "Χαίροις, Ἀκεψιμᾶ ἱερέ, Ἀειθαλᾶ καὶ…"
meVE.Stichera02.text = "Χαίροις, Ἀκεψιμᾶ ἱερέ, Ἀειθαλᾶ καὶ Ἰωσὴφ ἀξιάγαστοι, τῷ θείῳ πυρὶ τὴν πλάνην, πυρσολατρῶν δυσσεβῶν, ἐπιγνώσει θείᾳ κατασβέσαντες, διʼ ὧν οἱ θρησκεύοντες, παρανόμως τὸν ἥλιον, καὶ τοὺς ἀστέρας, παντελῶς ἠμαυρώθησαν, καὶ κατήργηται, ἡ τῶν μάγων ἐπίνοια. Μάρτυρες ἀεισέβαστοι, Τριάδος ὑπέρμαχοι, φῶς τοῖς ἐν σκότει ἀγνοίας, τοῦ ἀληθοῦς Ἀρχιποίμενος, Χριστοῦ τοῦ τυθέντος, καὶ παρέχοντος τῷ κόσμῳ, τὸ μέγα ἔλεος."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Stichera03.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meVE.Stichera03.incipit = "Πᾶσαν ἐπιφορὰν τῶν δεινῶν, ἀνδρειοτάτῳ…"
meVE.Stichera03.text = "Πᾶσαν ἐπιφορὰν τῶν δεινῶν, ἀνδρειοτάτῳ λογισμῷ ὑπηνέγκατε, ἀλόγοις τε ὥσπερ φόρτος, ἐπιτεθέντες σοφοί, πρὸς βασάνων πλείω πεῖραν ἥγεσθε· διὸ συγκοπτόμενοι, καὶ ῥοπάλοις τυπτόμενοι, καὶ ταῖς αἰκίαις, χαλεπῶς δαπανώμενοι, οὐκ ἐκάμφθητε, οὐ Θεὸν ἐξηρνήσασθε· ὅθεν προσαπηνέγκατε, τῆς νίκης τὸν στέφανον, καὶ ταῖς Μαρτύρων ἀγέλαις, περιφανῶς ἠριθμήθητε, μεθʼ ὧν ἐξαιτεῖσθε, ταῖς ψυχαῖς ἡμῶν δοθῆναι, τὸ μέγα ἔλεος."

meVE.Stichera04.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Stichera04.greekmelody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.greekname
meVE.Stichera04.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meVE.Stichera04.incipit = "Χαίρων αὐτοκινήτοις ὁρμαῖς, πρὸς τοὺς…"
meVE.Stichera04.text = "Χαίρων αὐτοκινήτοις ὁρμαῖς, πρὸς τοὺς ἀγῶνας ἀνδρικῶς προσεχώρησας, καὶ πᾶσαν ἐκπλήξας φρένα, τῇ καρτερίᾳ τῇ σῇ, τῶν τυράννων θράση κατεπάτησας, λαμπράν πρὸς Ἀγγέλων, διαγωγὴν μεταβέβηκας, περιχορεύων, σὺν αὐτοῖς καὶ γηθόμενος, σῴζων πάντοτε, τοὺς πιστῶς σε γεραίροντας· Μάρτυς ἐπιστασίαις σου, παμμάκαρ Γεώργιε, καὶ συμπαθείᾳ πενήτων, τοῖς ὀδυρμοῖς ἐπικλώμενος, Χριστὸν ἱκετεύεις, τὸν παρέχοντα τῷ κόσμῳ τὸ μέγα ἔλεος."

meVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Stichera05.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meVE.Stichera05.incipit = "Ἴθι τοῖς εὐφημοῦσιν ἡμῖν, καὶ…"
meVE.Stichera05.text = "Ἴθι τοῖς εὐφημοῦσιν ἡμῖν, καὶ θλιβομένοις ἀρωγὸς γενησόμενος, τὸν πόνον ἐπικουφίζων, τῶν χαλεπῶν πειρασμῶν, καὶ τὸ βάρος τούτων ἀφαιρούμενος, φρουρῶν καὶ φυλάττων, καὶ διασῴζων Γεώργιε, διαβιβάζων, πρὸς Θεὸν διὰ πίστεως, καὶ προστάγμασιν, ἐμβιβάζων τοῦ Κτίσαντος· ὅπως διʼ ἀγαθότητος, τῆς τούτου βιώσαντες, τύχωμεν πάντες τῶν θείων, ἐν οὐρανοῖς ἀντιδόσεων, Χριστὸν ἀνυμνοῦντες, τὸν παρέχοντα τῷ κόσμῳ, τὸ μέγα ἔλεος."

meVE.Stichera06.mode = miscellanea_gr_GR_cog.misc.Mode5
meVE.Stichera06.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meVE.Stichera06.incipit = "Μέγα καὶ θαυμαστὸν ἀληθῶς, τῆς…"
meVE.Stichera06.text = "Μέγα καὶ θαυμαστὸν ἀληθῶς, τῆς σῆς ἀῤῥήτου μαρτυρίας κηρύττεται, τὸ κλέος Ἔνδοξε Μάρτυς· ὡς γὰρ λαμπρὸς ἀριστεύς, διατρέχεις πᾶσαν ἀξιάγαστε, τὴν κτίσιν Γεώργιε, πλείσταις ὄντως κοσμούμενος, θαυματουργίαις, καὶ τὰς νόσους ἰώμενος, καὶ τοὺς πάσχοντας, θεραπεύων πρεσβείαις σου· ὅθεν ὡς ἀντιλήπτορα, θερμόν σε γινώσκομεν, καὶ εὐεργέτην παμμάκαρ, τοὺς αἰχμαλώτους ῥυόμενον, Χριστὸν οὖν δυσώπει, ταῖς ψυχαῖς ἡμῶν δοθῆναι, τὸ μέγα ἔλεος."

meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = me.m04.d23_gr_GR_cog.meVE.SticGlory.incipit
meVE.SticGlory.text = me.m04.d23_gr_GR_cog.meVE.SticGlory.text

