meMA.LaudsTheotokion.text = oc.m4.d4_gr_GR_cog.ocVE.Stichera6.text

meMA.MM.Lauds1123as5678.text = properties_gr_GR_cog.media.key

meLI.Kontakion1.mode = me.m11.d03_gr_GR_cog.meMA.Kontakion1.mode
meLI.Kontakion1.greekmelody = me.m11.d03_gr_GR_cog.meMA.Kontakion1.greekmelody
meLI.Kontakion1.melody = me.m11.d03_gr_GR_cog.meMA.Kontakion1.melody
meLI.Kontakion1.incipit = me.m11.d03_gr_GR_cog.meMA.Kontakion1.incipit
meLI.Kontakion1.text = me.m11.d03_gr_GR_cog.meMA.Kontakion1.text

meLI.Megalynarion.text = "Χαίροις ἀθλοφόρων τριὰς σεπτή, Ἀκεψιμᾶ πάτερ, Ἰωσὴφ καὶ Ἀειθαλᾶ, οἱ καταβαλόντες, πυρσολατρῶν τὴν πλάνην, καὶ μαρτυρίου δόξαν καρποφορήσαντες."
meLI.Megalynarion2.text = "Πλῆρες εὐωδίας ἁγιασμοῦ, δίκην μυροθήκης, ἐκ λαγόνων ὤφθη τῆς γῆς, τὸ σεπτόν σου σκῆνος, Γεώργιε παμμάκαρ, ἀρωματίζον κόσμῳ, θαυμάτων χάριτας."
