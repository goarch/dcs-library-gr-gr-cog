meMA.LaudsTheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.greekname
meMA.LaudsTheotokion.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
