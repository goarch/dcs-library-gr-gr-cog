meVE.AposStavrotheotokion.text = oc.m6.d4_gr_GR_cog.ocMA.AposTheotokion.text

meVE.Apolytikion1ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_gr_GR_cog.misc.Mode3
meVE.Apolytikion1ger.greekmelody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.greekname
meVE.Apolytikion1ger.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meVE.Apolytikion1ger.incipit = "Ὡς θεράποντες, τῆς εὐσεβείας, στῦλοι…"
meVE.Apolytikion1ger.text = "Ὡς θεράποντες, τῆς εὐσεβείας, στῦλοι ὤφθητε, τῆς Ἐκκλησίας, πυρσολατρῶν καθελόντες τὸ φρύαγμα, Ἀκεψιμᾶ Ἱεράρχα πολύαθλε, Ἀειθαλᾶ Ἰωσήφ τε μακάριοι. Ἀλλʼ αἰτήσασθε, Χριστὸν τὸν θεὸν πανεύφημοι, δωρήσασθαι ἡμῖν τὸ μέγα ἔλεος."

meVE.Apolytikion2ger.poet = poets_gr_GR_cog.po.Gerasimou
meVE.Apolytikion2ger.mode = miscellanea_gr_GR_cog.misc.Mode4
meVE.Apolytikion2ger.greekmelody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.greekname
meVE.Apolytikion2ger.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
meVE.Apolytikion2ger.incipit = "Ὡς ἥλιος ἔμψυχος, τῇ σῇ…"
meVE.Apolytikion2ger.text = "Ὡς ἥλιος ἔμψυχος, τῇ σῇ ἀθλήσει φανείς, θεσμῷ ἔδυς φύσεως, ἀλλʼ ἀνατλέλλεις ἐκ γῆς, διὰ τῶν λειψάνων σου, ὅλος λελαμπρυσμένος, τῇ τοῦ Πνεύματος αἴγλῃ, ἐκλάμπων τῇ οἰκουμένῃ, ἰαμάτων ἀκτῖνας, Γεώργιε μεγάλαθλε, πιστῶν ἡ ἀντίληψις."

meMA.C1.acrostic.title = "Ὁ Κανὼν τῶν Μαρτύρων,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Ἄνθη τὰ τερπνὰ Μαρτύρων ἐπαινέσω. Ἰωσήφ."
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaints
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintsM.text

meMA.C2.acrostic.title = "Ὁ Κανὼν τοῦ Ἁγίου Γεωργίου,"
meMA.C2.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C2.acrostic.text = "Τὸν σεπτὸν ἐν Μάρτυσιν ὑμνῶ προφρόνως."
meMA.C2.title = titles_gr_GR_cog.ti.CanonSaintM
meMA.C2.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C11.greekmelody = he.h.m1_gr_GR_cog.heHE.SouITropaiouchos.greekname
meMA.Ode1C11.melody = he.h.m1_gr_GR_cog.heHE.SouITropaiouchos.name
meMA.Ode1C11.incipit = "Αἴγλῃ τρισηλίου ἀστραπῆς, φωτιστικῶς αὐγαζόμενοι…"
meMA.Ode1C11.text = "Αἴγλῃ τρισηλίου ἀστραπῆς, φωτιστικῶς αὐγαζόμενοι Μάρτυρες, ταύτην τὴν πανίερον μνήμην ὑμῶν, τοὺς εὐσεβῶς γεραίροντας, σκότους ἁμαρτίας, καὶ παθημάτων λυτρώσασθε."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C12.melody = he.h.m1_gr_GR_cog.heHE.SouITropaiouchos.name
meMA.Ode1C12.incipit = "Νόμοις τοῦ Δεσπότου καὶ Θεοῦ…"
meMA.Ode1C12.text = "Νόμοις τοῦ Δεσπότου καὶ Θεοῦ, συμπεφραγμένοι τὸν νοῦν ἱερώτατοι, νόμους τοὺς κελεύοντας παρανομεῖν, ἀνδρείως ἐξεκλίνατε· ὅθεν ἐναθλοῦντες, νομίμως δόξης ἐτύχετε."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C13.melody = he.h.m1_gr_GR_cog.heHE.SouITropaiouchos.name
meMA.Ode1C13.incipit = "Θύματα προσήχθητε Χριστῷ, τῇ ἑκουσίῳ…"
meMA.Ode1C13.text = "Θύματα προσήχθητε Χριστῷ, τῇ ἑκουσίῳ σφαγῇ καθαρώτατα, Μάρτυρες πανόλβιοι, ἱερουργοί, καὶ θύται χρηματίσαντες, τοῦ ἐθελουσίῳ σφαγῇ τὸν κόσμον ζωώσαντος."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode1C1T.melody = he.h.m1_gr_GR_cog.heHE.SouITropaiouchos.name
meMA.Ode1C1T.incipit = "Ἡ τὸν ἀπερίληπτον Θεόν, περιγραφόμενον…"
meMA.Ode1C1T.text = "Ἡ τὸν ἀπερίληπτον Θεόν, περιγραφόμενον σώματι τέξασα, σάρκα χρηματίσαντα, ὑπερβολῇ Παρθένε ἀγαθότητος, τοῦτον ἐκδυσώπει, κινδύνων σῶσαι τοὺς δούλους σου."

meMA.Ode1C21.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C21.greekmelody = he.h.m4_gr_GR_cog.heHE.ToOdigisantiPalai.greekname
meMA.Ode1C21.melody = he.h.m4_gr_GR_cog.heHE.ToOdigisantiPalai.name
meMA.Ode1C21.incipit = "Τὸ δυσχερὲς τοῦ νοός μου…"
meMA.Ode1C21.text = "Τὸ δυσχερὲς τοῦ νοός μου, καὶ ἀδρανὲς Ἅγιε, τῷ διαπύρῳ τῆς σεπτῆς, σοῦ προσευχῆς μεταποίησον, εὐρυσθενῆ ἐργαζόμενος, ὅπως σου τὴν παναγίαν, ἑορτὴν ἐγκωμιάσαιμι."

meMA.Ode1C22.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C22.melody = he.h.m4_gr_GR_cog.heHE.ToOdigisantiPalai.name
meMA.Ode1C22.incipit = "Ὁ ὑψιβάμων ἐν ἄμφω, καὶ…"
meMA.Ode1C22.text = "Ὁ ὑψιβάμων ἐν ἄμφω, καὶ τῶν πολλῶν ὕπερθεν, ἔργῳ καὶ λόγῳ πεφηνώς, σοῦ οὐκ ἰσχύει Γεώργιε, ἀνευφημεῖν τὰ τεράστια· πέλεις γὰρ παγκρατιάρχης ἀκραιφνής, καὶ αἰχμητὴς κραταιός."

meMA.Ode1C23.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C23.melody = he.h.m4_gr_GR_cog.heHE.ToOdigisantiPalai.name
meMA.Ode1C23.incipit = "Νόμοις ἐπαίνων οὐδόλως, ἡ σὴ…"
meMA.Ode1C23.text = "Νόμοις ἐπαίνων οὐδόλως, ἡ σὴ σεπτὴ ἄθλησις, ὑποπεσεῖται Ἀθλητά· ἰλιγγιῶ γὰρ καὶ δέδοικα, καὶ ἀπορῶ καὶ ἐξίσταμαι, ψαῦσαί σου κἂν γοῦν ποσῶς, Ἀθλοφόρε τοῖς προτερήμασι."

meMA.Ode1C2T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode1C2T.melody = he.h.m4_gr_GR_cog.heHE.ToOdigisantiPalai.name
meMA.Ode1C2T.incipit = "Σωτῆρα πάντων τεκοῦσα, τὴν τῆς…"
meMA.Ode1C2T.text = "Σωτῆρα πάντων τεκοῦσα, τὴν τῆς ζωῆς ἔκπτωσιν, ἐπηνωρθώσω Ἀγαθή· τὴν γὰρ ζωὴν ἀπεκύησας, πᾶσιν ἡμῖν πρυτανεύουσαν, ἄφεσιν ἁμαρτιῶν ταῖς πρεσβείαις σου."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C11.greekmelody = he.h.m1_gr_GR_cog.heHE.OMonosEidos.greekname
meMA.Ode3C11.melody = he.h.m1_gr_GR_cog.heHE.OMonosEidos.name
meMA.Ode3C11.incipit = "Τὰ πάθη ἀσκήσεως πυρί, τεφρώσας…"
meMA.Ode3C11.text = "Τὰ πάθη ἀσκήσεως πυρί, τεφρώσας ἱερώτατε, Ἀκεψιμᾶ πρὸς πείρας ἀθλήσεως, κριὸς καθάπερ ἐπισημότατος, ὑπʼ ἀνόμων τέθυσαι, ταῖς ῥοαῖς τοῦ αἵματος, ἁγιάσας πιστῶν τὰ πληρώματα."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C12.melody = he.h.m1_gr_GR_cog.heHE.OMonosEidos.name
meMA.Ode3C12.incipit = "Ἀδίκως στρεβλούμενος Σοφέ, καὶ ῥάβδοις…"
meMA.Ode3C12.text = "Ἀδίκως στρεβλούμενος Σοφέ, καὶ ῥάβδοις συντριβόμενος, καὶ ἀπηνῶς βασάνοις ξεόμενος, οὐκ ἐξηρνήσω τὸ θεῖον ὄνομα, οὐ πυρὶ ἐπέθυσας, Ἰωσὴφ πανάριστε, πυρακτούμενος ζήλῳ τῆς πίστεως."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C13.melody = he.h.m1_gr_GR_cog.heHE.OMonosEidos.name
meMA.Ode3C13.incipit = "Τὸν νῶτον καὶ τὰ στέρνα…"
meMA.Ode3C13.text = "Τὸν νῶτον καὶ τὰ στέρνα ἀφειδῶς, τυπτόμενος ὑπέφερες, Ἀειθαλᾶ ἑτέρου ὡς πάσχοντος· νοῒ γὰρ Μάρτυς, τελείως ἔνδοξε, πρὸς Θεὸν ἠτένιζες, σῴζειν τὸν δυνάμενον, τοὺς αὐτῷ ὁλοψύχως πιστεύοντας."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode3C1T.melody = he.h.m1_gr_GR_cog.heHE.OMonosEidos.name
meMA.Ode3C1T.incipit = "Ἐκ σοῦ ἀνατέταλκεν ἡμῖν, ὁ…"
meMA.Ode3C1T.text = "Ἐκ σοῦ ἀνατέταλκεν ἡμῖν, ὁ Ἥλιος ὁ ἄδυτος, φωτιστικαῖς πανάμωμε λάμψεσι, φωτίζων κόσμον σκότει κρατούμενον, καὶ προσαπολλύμενον, πλάνῃ τοῦ ἀλάστορος, Παναγία Παρθένε Θεόνυμφε."

meMA.Ode3C21.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C21.greekmelody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.greekname
meMA.Ode3C21.melody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.name
meMA.Ode3C21.incipit = "Ἐπιπαφλάζον πῦρ τὸ τῆς ἀπάτης…"
meMA.Ode3C21.text = "Ἐπιπαφλάζον πῦρ τὸ τῆς ἀπάτης, οὐ φέρων βλέπειν Ἅγιε, ὡς ὁ πυρίπνους καὶ ζηλωτής, ἀνομοῦντας διελέγχων· Οὐκ ἔστιν ἄλλος ἔλεγες, Θεὸς ὡς ὁ Κύριος."

meMA.Ode3C22.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C22.melody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.name
meMA.Ode3C22.incipit = "Πῦρ τὸ τοῦ Λόγου ὅπερ…"
meMA.Ode3C22.text = "Πῦρ τὸ τοῦ Λόγου ὅπερ ἦλθε Μάκαρ, βαλεῖν εἰς κόσμον ἅπαντα, σοῦ καθαψάμενος τῆς ψυχῆς, στέγειν ὅλως οὐκ εἴα, ἀλλὰ θερμῶς ἀνέκραζες· Χριστός μοι στερέωμα."

meMA.Ode3C23.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C23.melody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.name
meMA.Ode3C23.incipit = "Τὰ τῶν βασάνων εἴδη σου…"
meMA.Ode3C23.text = "Τὰ τῶν βασάνων εἴδη σου δεικνύων, ὥσπερ φοβεῖν ὁ τύραννος, τὴν ἀκατάπληκτον σου ψυχήν, ὑπετόπασε θεόφρων· σὺ δὲ στεῤῥῶς ἀνέκραζες, Χριστός μοι στερέωμα."

meMA.Ode3C2T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3C2T.melody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.name
meMA.Ode3C2T.incipit = "Ὄρος σε μέγα βλέπων ὁ…"
meMA.Ode3C2T.text = "Ὄρος σε μέγα βλέπων ὁ Προφήτης, ὑπερκειμένην ἔχον, τὴν κορυφὴν ἁπάντων τῶν βουνῶν, τῶν ἀγγελικῶν ταγμάτων, ὑπὲρ αἰτίαν ἔλεγε· Παρθένος γεννήσεται."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode3H.greekmelody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.greekname
meMA.Ode3H.melody = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.melody
meMA.Ode3H.incipit = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.incipit
meMA.Ode3H.text = he.h.m4_gr_GR_cog.heHE.OStereonVrontin.text

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Kontakion1.greekmelody = he.a.m2_gr_GR_cog.heAU.TaAnoZiton.greekname
meMA.Kontakion1.melody = he.a.m2_gr_GR_cog.heAU.TaAnoZiton.name
meMA.Kontakion1.incipit = "Τὰ θεῖα σοφέ, σεπτῶς ἐμυσταγώγησας…"
meMA.Kontakion1.text = "Τὰ θεῖα σοφέ, σεπτῶς ἐμυσταγώγησας, θυσία δεκτὴ ἐγένου Παμμακάριστε· τοῦ Χριστοῦ γὰρ ἔπιες, τὸ ποτήριον ἐνδόξως Ἅγιε, Ἀκεψιμᾶ σὺν τοῖς συνάθλοις σου, πρεσβεύων ἀπαύστως ὑπὲρ πάντων ἡμῶν."

meMA.Oikos1.text = "Τὴν χερσωθεῖσάν μου καρδίαν πολλοῖς πταίσμασιν, Ἰησοῦ παντοδύναμε, ὄμβροις τῆς σῆς ἀγαθότητος, δεῖξον καρποφόρον ἀρεταῖς, καὶ παράσχου φωτισμὸν γνώσεως τῇ διανοίᾳ μου, ἵνα ὑμνήσω γηθόμενος, τόν, Ἱεράρχην καὶ Ἀθλοφόρον, Ἀκεψιμᾶν τὸν μέγαν σὺν Ἀειθαλᾷ τῷ γενναίῳ, καὶ Ἰωσὴφ τῷ πανολβίῳ· ἐν σοὶ γὰρ θαῤῥοῦντες, ποικίλων βασάνων ἀνδρείως κατετόλμησαν· διὸ καὶ παρέχουσι νοσοῦσι τὴν ἴασιν, ὡς χάριν δεξάμενοι, πρεσβεύοντες ἀπαύστως ὑπὲρ πάντων ἡμῶν."

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3Kathisma1.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Ode3Kathisma1.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3Kathisma1.incipit = "Ἰωσὴφ ὁ γενναῖος ἀγωνιστής, Ἀκεψιμᾶς…"
meMA.Ode3Kathisma1.text = "Ἰωσὴφ ὁ γενναῖος ἀγωνιστής, Ἀκεψιμᾶς ὁ τῆς πλάνης ὀλοθρευτής, Ἀειθαλᾶς ὁ Ἔνδοξος, ἀθλητὴς καὶ ἀήττητος, οἱ φαιδροὶ ἀστέρες, τῆς πίστεως ᾄσμασιν, ἐπαξίως ὄντως ὑμνείσθωσαν σήμερον· οὗτοι γὰρ τὴν δόξαν, τῶν Περσῶν ἀμαυροῦντες, ἡλίῳ οὐκ ἔθυσαν, οὐ τὸ πῦρ ἐσεβάσθησαν. Οἷς ἐν πίστει βοήσωμεν· Πρεσβεύσατε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ, τὴν ἁγίαν μνήμην ὑμῶν."

meMA.Ode3Kathisma2.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3Kathisma2.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
meMA.Ode3Kathisma2.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3Kathisma2.incipit = "Τοῦ Χριστοῦ τῷ σημείῳ καθοπλισθείς…"
meMA.Ode3Kathisma2.text = "Τοῦ Χριστοῦ τῷ σημείῳ καθοπλισθείς, ἐν αὐτῷ τῶν τυράννων πᾶσαν ἰσχύν, ἀνδρείως κατέβαλες, ὡς τῆς πίστεως πρόμαχος, τὴν ἀθεΐαν πᾶσαν, εἰδώλων διήλεγξας, καὶ τοὺς πιστοὺς θεόφρον, τῇ πίστει ἐστήριξας· ὅθεν ἐπαξίως, τοὺς τῆς νίκης στεφάνους, ἀθλήσας ἀπέλαβες ἐκ χειρὸς τοῦ Κυρίου σου, Ἀθλοφόρε Γεώργιε· πρέσβευε Χριστῷ τῷ Θεῷ, τῶν πταισμάτων ἄφεσιν δωρήσασθαι, τοῖς ἑορτάζουσι πόθῳ, τὴν ἁγίαν μνήμην σου."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3KathismaT.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3KathismaT.incipit = me.m06.d29_gr_GR_cog.meMA.Kathisma2T.incipit
meMA.Ode3KathismaT.text = me.m06.d29_gr_GR_cog.meMA.Kathisma2T.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3KathismaSt.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
meMA.Ode3KathismaSt.incipit = oc.m8.d4_gr_GR_cog.ocMA.Kathisma13.incipit
meMA.Ode3KathismaSt.text = oc.m8.d4_gr_GR_cog.ocMA.Kathisma13.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C11.greekmelody = he.h.m1_gr_GR_cog.heHE.OrosSeTiChariti.greekname
meMA.Ode4C11.melody = he.h.m1_gr_GR_cog.heHE.OrosSeTiChariti.name
meMA.Ode4C11.incipit = "Ῥήμασι Σοφὲ Ἀκεψιμᾶ, θείας γνώσεως…"
meMA.Ode4C11.text = "Ῥήμασι Σοφὲ Ἀκεψιμᾶ, θείας γνώσεως, τοὺς ἀγνωσίας σκοτασμῷ, κεκρατημένους δυσμενεῖς, στεῤῥῶς κατεπάλαισας, τὰς ὑπʼ αὐτῶν μὴ πτήξας στρέβλας Μακάριε, προσαγομένας τῷ θείῳ σου σώματι."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C12.melody = he.h.m1_gr_GR_cog.heHE.OrosSeTiChariti.name
meMA.Ode4C12.incipit = "Πυρί σε πυρὸς οἱ λατρευταὶ…"
meMA.Ode4C12.text = "Πυρί σε πυρὸς οἱ λατρευταὶ κατηνάγκαζον, σέβας προσάξαι δολερῶς· ἀλλὰ τὸν νοῦν τῇ τοῦ Θεοῦ, ἀγάπῃ πυρούμενος, πυρσολατρεῖν ἀπεῖπας ὅλως δεχόμενος, ἀναψυχήν Ἰωσὴφ δυναμοῦσάν σε."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C13.melody = he.h.m1_gr_GR_cog.heHE.OrosSeTiChariti.name
meMA.Ode4C13.incipit = "Ναμάτων τῶν θείων πεπλησμένος τοῦ…"
meMA.Ode4C13.text = "Ναμάτων τῶν θείων πεπλησμένος τοῦ Πνεύματος, Ἀειθαλᾶ τὰ θολερά, τῆς ἀπιστίας καὶ πικρὰ ἐξέφυγες ὕδατα, καὶ ταῖς ῥοαῖς τῶν ἐκχυθέντων αἱμάτων σου, τοὺς ἀοράτους ἐχθροὺς κατεπόντισας."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode4C1T.melody = he.h.m1_gr_GR_cog.heHE.OrosSeTiChariti.name
meMA.Ode4C1T.incipit = "Ἁγίων Μαρτύρων ἱερὸν ἐγκαλλώπισμα, ὤφθης…"
meMA.Ode4C1T.text = "Ἁγίων Μαρτύρων ἱερὸν ἐγκαλλώπισμα, ὤφθης Παρθένε ἀληθῶς, καὶ τῶν πιστῶν καταφυγή, τεῖχός τε καὶ στήριγμα, καὶ παντελὴς ἀπολύτρωσις, μεγαλοφώνως· διό σε δοξάζομεν."

meMA.Ode4C21.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C21.greekmelody = he.h.m4_gr_GR_cog.heHE.EisakikoaKyrie.greekname
meMA.Ode4C21.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C21.incipit = "Νέμοις πᾶσι τοῖς ὑμνηταῖς, τὴν…"
meMA.Ode4C21.text = "Νέμοις πᾶσι τοῖς ὑμνηταῖς, τὴν εὐκλεῆ τε καὶ σεβασμίαν, ἀρωγήν σου καὶ ἀντίληψιν, παμμάκαρ Γεώργιε, ὡς παῤῥησίαν ἔχων πρὸς Κύριον."

meMA.Ode4C22.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C22.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C22.incipit = "Ἔχων ἄμαχον τὴν ἰσχύν, δεδωρημένην…"
meMA.Ode4C22.text = "Ἔχων ἄμαχον τὴν ἰσχύν, δεδωρημένην σοι ἐξ Ἁγίου, τῶν Ἁγίων ἀκροθίνιον, τὴν βαρβάρων ἔφοδον, σαῖς προσευχαῖς ταχέως κατάλυσον."

meMA.Ode4C23.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C23.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C23.incipit = "Νὺξ με πάντοθεν πειρασμῶν, ἐπιπολάζει…"
meMA.Ode4C23.text = "Νὺξ με πάντοθεν πειρασμῶν, ἐπιπολάζει καὶ ἀνενδότως, συνωθεῖ με πρὸς τὴν χάρυβδιν, τῶν παθῶν Γεώργιε, ἀλλὰ προφθάσας διάσωσον."

meMA.Ode4C2T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C2T.melody = he.h.m4_gr_GR_cog.heHE.EisakikoaKyrie.name
meMA.Ode4C2T.incipit = "Μόνη ἔσχες ἐν τῇ γαστρί…"
meMA.Ode4C2T.text = "Μόνη ἔσχες ἐν τῇ γαστρί, τὸν συνοχέα παντὸς τοῦ κόσμου· μόνη τοῦτον ἀπεκύησας, Θεοτόκε Πάναγνε, τὸν ἀκαταληψίᾳ νοούμενον."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C11.greekmelody = he.h.m1_gr_GR_cog.heHE.OFotisasTiEllampsei.greekname
meMA.Ode5C11.melody = he.h.m1_gr_GR_cog.heHE.OFotisasTiEllampsei.name
meMA.Ode5C11.incipit = "Μακάριοι ἀπεφάνθητε, Λόγον μακάριον, κηρύξαντες…"
meMA.Ode5C11.text = "Μακάριοι ἀπεφάνθητε, Λόγον μακάριον, κηρύξαντες ἐν σταδίῳ, ἀνδρείως ἀοίδιμοι, τὸν ὑμᾶς συνάψαντα, τῶν μακαρίων ταῖς χορείαις, πανευκλεῶς ἀριστεύσαντας."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C12.melody = he.h.m1_gr_GR_cog.heHE.OFotisasTiEllampsei.name
meMA.Ode5C12.incipit = "Ἀπόρθητοι ἀνεδείχθητε, πύργοι τῆς πίστεως…"
meMA.Ode5C12.text = "Ἀπόρθητοι ἀνεδείχθητε, πύργοι τῆς πίστεως, ἐλεπόλεις τοῦ ἐχθροῦ, παντελῶς ἀφανίσαντες, Ἰωσὴφ θεσπέσιε, Ἀκεψιμᾶ ἱερομύστα, Ἀειθαλᾶ ἱερώτατε."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C13.melody = he.h.m1_gr_GR_cog.heHE.OFotisasTiEllampsei.name
meMA.Ode5C13.incipit = "Ῥηγνύμενα ταῖς πληγαῖς, τῶν Μαρτύρων…"
meMA.Ode5C13.text = "Ῥηγνύμενα ταῖς πληγαῖς, τῶν Μαρτύρων τὰ σώματα, διέῤῥηξαν ἀθεΐας, ἀνίσχυρον δύναμιν, καὶ ἐδήλουν ἄριστα, τὴν ἀῤῥαγῆ ψυχῆς ἀγάπην, πρὸς τὸν Δεσπότην, καὶ Κύριον."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode5C1T.melody = he.h.m1_gr_GR_cog.heHE.OFotisasTiEllampsei.name
meMA.Ode5C1T.incipit = "Τηρήσας σε ὡς πρὸ τόκου…"
meMA.Ode5C1T.text = "Τηρήσας σε ὡς πρὸ τόκου, παρθένον ἀκήρατον, Πανάμωμε ὁ οἰκήσας, ἀσπόρως ἐν μήτρᾳ σου, διπλοῦς προελήλυθε, Θεὸς καὶ ἄνθρωπος θεώσας, τὸ προσληφθὲν ἀγαθότητι."

meMA.Ode5C21.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C21.greekmelody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.greekname
meMA.Ode5C21.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
meMA.Ode5C21.incipit = "Ἀτίθασον παράταξιν, δαιμόνων τροπωσάμενος, καὶ…"
meMA.Ode5C21.text = "Ἀτίθασον παράταξιν, δαιμόνων τροπωσάμενος, καὶ Σταυροῦ τῷ ὅπλῳ χρησάμενος, ὡς θείῳ ἀκοντίῳ, τούτῳ ἐξεκέντησας, καὶ εἰς γῆν κατέῤῥαξας, φαλαγγάρχας ζοφερούς."

meMA.Ode5C22.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C22.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
meMA.Ode5C22.incipit = "Ῥώμῃ τοῦ Παντοκράτορος, ῥωννύμενος Γεώργιε…"
meMA.Ode5C22.text = "Ῥώμῃ τοῦ Παντοκράτορος, ῥωννύμενος Γεώργιε, καὶ τῇ προνοία ποδηγούμενος, τῇ πάντα κυβερνώσῃ, τὸ σκάφος διέσωσας, τῆς ψυχῆς ἀκύμαντον, πρὸς λιμένα τῆς ζωῆς."

meMA.Ode5C23.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C23.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
meMA.Ode5C23.incipit = "Τί με θωπείαις ἔλεγες, τῷ…"
meMA.Ode5C23.text = "Τί με θωπείαις ἔλεγες, τῷ κακεργάτῃ Ἅγιε, τῆς τοῦ Χριστοῦ μου ἀγαπήσεως, ἐλπίζεις μεταστῆσαι; λίθον ἕψειν ἔοικας, γράφειν τε εἰς θάλασσαν, καὶ τοξεύειν οὐρανόν."

meMA.Ode5C2T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode5C2T.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
meMA.Ode5C2T.incipit = "Ὑψαύχενας κατάβαλε, αἱρετικοὺς Πανάμωμε, τοὺς…"
meMA.Ode5C2T.text = "Ὑψαύχενας κατάβαλε, αἱρετικοὺς Πανάμωμε, τοὺς ἀφειδῶς κατεπεμβαίνοντας, λαῷ τῷ ὀρθοδόξῳ· ἔχεις γὰρ τὸ δύνασθαι, τῇ θελήσει σύνδρομον, οἷα μήτηρ τοῦ Θεοῦ."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C11.greekmelody = he.h.m1_gr_GR_cog.heHE.EkyklosenImas.greekname
meMA.Ode6C11.melody = he.h.m1_gr_GR_cog.heHE.EkyklosenImas.name
meMA.Ode6C11.incipit = "Ὑψούμενα σφοδρῶς βασάνων, κύματα, ὑμῶν…"
meMA.Ode6C11.text = "Ὑψούμενα σφοδρῶς βασάνων, κύματα, ὑμῶν οὐ κατεκάλυψε, τὴν ἀνδρείαν καὶ τὸ εὔτονον Σοφοί· θείᾳ κυβερνήσει γὰρ ἐφθάσατε, τὸν γαληνὸν τῆς σωτηρίας ὅρμον γηθόμενοι."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C12.melody = he.h.m1_gr_GR_cog.heHE.EkyklosenImas.name
meMA.Ode6C12.incipit = "Ῥανίσιν ἱερῶν αἱμάτων Ἅγιοι, φοινίξαντες…"
meMA.Ode6C12.text = "Ῥανίσιν ἱερῶν αἱμάτων Ἅγιοι, φοινίξαντες Μακάριοι, περιβόλαιον τὸ θεῖον ἑαυτῶν, τοῦτο τε ὁσίως ἐνδυσάμενοι, τῷ Βασιλεῖ τῷ ἀθανάτῳ συμβασιλεύετε."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C13.melody = he.h.m1_gr_GR_cog.heHE.EkyklosenImas.name
meMA.Ode6C13.incipit = "Ὡραῖοι καλλοναῖς ἄθλων γεγόνατε, νυμφῶνος…"
meMA.Ode6C13.text = "Ὡραῖοι καλλοναῖς ἄθλων γεγόνατε, νυμφῶνος ἔνδον Ἅγιοι, ἐχωρήσατε θεούμενοι φαιδρῶς, θέσει καὶ υἱοὶ ἀποδεικνύμενοι, πανευκλεῶς Πατρὸς τῶν φώτων ἀξιοθαύμαστοι."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode6C1T.melody = he.h.m1_gr_GR_cog.heHE.EkyklosenImas.name
meMA.Ode6C1T.incipit = "Νενέκρωται ἐχθρὸς τῷ ζωηφόρῳ σου…"
meMA.Ode6C1T.text = "Νενέκρωται ἐχθρὸς τῷ ζωηφόρῳ σου, Παρθένε τόκῳ ἄχραντε, καὶ ἐζώωται Ἀδὰμ παρακοῇ, πάλαι νεκρωθεὶς καρποῦ γευσάμενος· ὅθεν ὑμνεῖ καὶ μακαρίζει σε Παναμώμητε."

meMA.Ode6C21.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C21.greekmelody = he.h.m4_gr_GR_cog.heHE.ZaliMeLogismon.greekname
meMA.Ode6C21.melody = he.h.m4_gr_GR_cog.heHE.ZaliMeLogismon.name
meMA.Ode6C21.incipit = "Σῶμά σου παραδοὺς ταῖς τιμωρίαις…"
meMA.Ode6C21.text = "Σῶμά σου παραδοὺς ταῖς τιμωρίαις, τὴν ψυχὴν ἐτήρησας, ἀπήμαντον θεομάκαρ· τὴν ἄνωθεν γὰρ ἔσχες ἀρωγήν, φρουρὰν προμηθεστάτην, ἐν τοῖς πολέμοις Γεώργιε."

meMA.Ode6C22.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C22.melody = he.h.m4_gr_GR_cog.heHE.ZaliMeLogismon.name
meMA.Ode6C22.incipit = "Ἵλεων τὸν Δεσπότην, ταῖς εὐχαῖς…"
meMA.Ode6C22.text = "Ἵλεων τὸν Δεσπότην, ταῖς εὐχαῖς σου, ἀπεργάζου πάντοτε, τὴν μνήμην σου τοῖς ἐκ πόθου ἐκτελοῦσι, καὶ ζάλης ὁρατῶν, ἐχθρῶν καὶ ἀοράτων, ἀπήμονας διαφύλαττε."

meMA.Ode6C23.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C23.melody = he.h.m4_gr_GR_cog.heHE.ZaliMeLogismon.name
meMA.Ode6C23.incipit = "Νόες σου κατεπλάγησαν ὁρῶντες, τὴν…"
meMA.Ode6C23.text = "Νόες σου κατεπλάγησαν ὁρῶντες, τὴν ἀνδρείαν ἄνωθεν, πῶς ἀγχεμάχοις ὅπλοις κατεπάλαισας, ἄσαρκον ἐχθρόν, τὸν πάλαι τοὺς γενάρχας, ἐν Παραδείσῳ πτερνίσαντα."

meMA.Ode6C2T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6C2T.melody = he.h.m4_gr_GR_cog.heHE.ZaliMeLogismon.name
meMA.Ode6C2T.incipit = "Ὕφανας ἱστουργίᾳ τῇ ἀῤῥήτῳ ἁλουργίδα…"
meMA.Ode6C2T.text = "Ὕφανας ἱστουργίᾳ τῇ ἀῤῥήτῳ ἁλουργίδα Πάναγνε, Πατρὸς καὶ Πνεύματος θείου, εὐδοκίᾳ τῷ πάντων Βασιλεῖ, ἀτρέπτως καὶ ἀφύρτως, σάρκα τὴν σὴν ἀμφιάσασα."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode6H.greekmelody = he.h.m4_gr_GR_cog.heHE.ZaliMeLogismon.greekname
meMA.Ode6H.melody = he.h.m4_gr_GR_cog.heHE.ZaliMeLogismon.melody
meMA.Ode6H.incipit = he.h.m4_gr_GR_cog.heHE.ZaliMeLogismon.incipit
meMA.Ode6H.text = he.h.m4_gr_GR_cog.heHE.ZaliMeLogismon.text

meMA.Kontakion2.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Kontakion2.greekmelody = he.a.m8_gr_GR_cog.heAU.TiYpermacho.greekname
meMA.Kontakion2.melody = he.a.m8_gr_GR_cog.heAU.TiYpermacho.name
meMA.Kontakion2.incipit = "Τῇ ὑπερμάχῳ καὶ ταχείᾳ ἀντιλήψει…"
meMA.Kontakion2.text = "Τῇ ὑπερμάχῳ καὶ ταχείᾳ ἀντιλήψει σου, προσπεφευγότες οἱ πιστοὶ καθικετεύομεν, λυτρωθῆναι παρὰ τοῦ Χριστοῦ Ἀθλοφόρε, τῶν σκανδάλων τοῦ ἐχθροῦ τοὺς ἀνυμνοῦντάς σε, καὶ παντοίων ἐκ κινδύνων καὶ κακώσεων, ἵνα κράζωμεν· Χαίροις Μάρτυς Γεώργιε."

meMA.Oikos2.text = "Μέγας ἐν προστασίαις ἐπὶ γῆς ἀνεδείχθης, τοῦ Κυρίου θεράπον καὶ φίλε· τὸν πιστὸν γὰρ λαὸν περισκέπων, σῴζεις ἀεὶ Ἔνδοξε· διὸ πίστει καὶ πόθῳ βοῶμέν σοι πολύαθλε."
meMA.Oikos22.text = "Χαῖρε, διʼ οὗ φρυκτωρεῖται ὁ κόσμος, χαῖρε, διʼ οὗ ὁ στρατὸς καταλάμπει."
meMA.Oikos23.text = "Χαῖρε, τῶν πιστῶν αἰχμαλώτων ἡ λύτρωσις, χαῖρε, δεσμωτῶν ἡ ὀξεῖα ἀντίληψις."
meMA.Oikos24.text = "Χαῖρε, ὕψος τῶν ἐκ πίστεως προστρεχόντων σοι θερμῶς, χαῖρε, πλοῦτος τῶν ποθούντων σε, καὶ ἐν θλίψει χαρμονή."
meMA.Oikos25.text = "Χαῖρε, ὅτι ὑπάρχεις βασιλέων τὸ τεῖχος, χαῖρε, ὅτι παρέχεις ἐν πολέμοις τὸ νῖκος."
meMA.Oikos26.text = "Χαῖρε, ἀστὴρ φωτίζων τοὺς πλέοντας, χαῖρε, λυτὴρ παντοίας κακώσεως."
meMA.Oikos27.text = "Χαῖρε, εἰς ὃν πᾶς πιστὸς καταφεύγει, χαῖρε, διʼ οὗ εὐφημεῖται ὁ πλάστης."
meMA.Oikos28.text = "Χαίροις, Μάρτυς Γεώργιε."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C11.greekmelody = he.h.m1_gr_GR_cog.heHE.SeNoitin.greekname
meMA.Ode7C11.melody = he.h.m1_gr_GR_cog.heHE.SeNoitin.name
meMA.Ode7C11.incipit = "Ἐκ περσικῆς, χώρας ἀναλάψαντες, ὥς…"
meMA.Ode7C11.text = "Ἐκ περσικῆς, χώρας ἀναλάψαντες, ὥς περ ἀστέρες φωταυγεῖς, Ἰωσὴφ καὶ Ἀειθαλᾶς, ἄθλων ταῖς λαμπρότησι, κόσμον κατεφώτισαν, ἐν εὐσεβείᾳ κραυγάζοντες· ὁ αἰνετός τῶν Πατέρων, Θεὸς καὶ ὑπερένδοξος."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C12.melody = he.h.m1_gr_GR_cog.heHE.SeNoitin.name
meMA.Ode7C12.incipit = "Πόνοις πολλοῖς, ζωὴν ἐκληρώσασθε, ἄπονον…"
meMA.Ode7C12.text = "Πόνοις πολλοῖς, ζωὴν ἐκληρώσασθε, ἄπονον Μάρτυρες Χριστοῦ, πάντα πόνον καὶ πειρασμόν· ὅθεν ταῖς εὐχαῖς ὑμῶν, παντοτε κουφίζετε, τῶν ἐκβοώντων πανένδοξοι· Ὁ αἰνετὸς τῶν Πατέρων, Θεὸς καὶ ὑπερένδοξος."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C13.melody = he.h.m1_gr_GR_cog.heHE.SeNoitin.name
meMA.Ode7C13.incipit = "Ἀκεψιμᾶν, νῦν τὸν ἱερώτατον, καί…"
meMA.Ode7C13.text = "Ἀκεψιμᾶν, νῦν τὸν ἱερώτατον, καί, Ἰωσὴφ τὸν θαυμαστόν, καὶ τὸν μέγαν Ἀειθαλᾶν, τοὺς Ἱερομάρτυρας, λόγοις μακαρίσωμεν, ἱερωτάτοις κραυγάζοντες· ὁ αἰνετός τῶν Πατέρων, Θεὸς καὶ ὑπερένδοξος."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode7C1T.melody = he.h.m1_gr_GR_cog.heHE.SeNoitin.name
meMA.Ode7C1T.incipit = "Ἱεραρχῶν, θεῖον ἐγκαλλώπισμα, καὶ Ἀθλοφόρων…"
meMA.Ode7C1T.text = "Ἱεραρχῶν, θεῖον ἐγκαλλώπισμα, καὶ Ἀθλοφόρων εὐκλεῶν, παναμώμητε ἀληθῶς, στέφανος γεγένησαι, πάντων τε κραταίωμα, τῶν μελῳδούντων ἑκάστοτε· ὁ αἰνετὸς τῶν Πατέρων, Θεὸς καὶ ὑπερένδοξος."

meMA.Ode7C21.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C21.greekmelody = he.h.m4_gr_GR_cog.heHE.ODiasosasEnPyri.greekname
meMA.Ode7C21.melody = he.h.m4_gr_GR_cog.heHE.ODiasosasEnPyri.name
meMA.Ode7C21.incipit = "Μόνα ποθῶν τὰ νοητά, μόνοις…"
meMA.Ode7C21.text = "Μόνα ποθῶν τὰ νοητά, μόνοις τε γαννύμενος Μάκαρ, τοῖς ἐν ἐλπίσιν ἀγαθοῖς, τὰ παρόντα ὡς ὄναρ λελόγισαι, ἐκβοῶν, ὑπερύμνητε· ὁ Θεὸς ὁ τῶν Πατέρων εὐλογητός εἶ."

meMA.Ode7C22.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C22.melody = he.h.m4_gr_GR_cog.heHE.ODiasosasEnPyri.name
meMA.Ode7C22.incipit = "Νοῦν ἡγεμόνα τῶν παθῶν, Ἔνδοξε…"
meMA.Ode7C22.text = "Νοῦν ἡγεμόνα τῶν παθῶν, Ἔνδοξε ἐποίεις ὡς νόμος, Θεοῦ ὁ κάλλιστός ἐστιν, ἰσχυρὸς ἐπὶ πάσης τῆς κτίσεως, ἐκνικᾶν τὸν βελτίονα, τῶν χειρόνων τὰς κινήσεις χάριτι θείᾳ."

meMA.Ode7C23.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C23.melody = he.h.m4_gr_GR_cog.heHE.ODiasosasEnPyri.name
meMA.Ode7C23.incipit = "Ὢ τοῦ θερμοῦ σου, πρὸς…"
meMA.Ode7C23.text = "Ὢ τοῦ θερμοῦ σου, πρὸς Θεὸν ἔρωτος Παμμάκαρ! πῶς ὄλβον, ὡς χοῦν λελόγισαι βοῶν· Τοῦ Δεσπότου τῶν ὅλων ἀντάξιον, τῆς ἀγάπης οὐ κέκρικα, κόσμον ὅλον ἐξισοῦσθαι, κἂν χρυσὸς πέλῃ."

meMA.Ode7C2T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode7C2T.melody = he.h.m4_gr_GR_cog.heHE.ODiasosasEnPyri.name
meMA.Ode7C2T.incipit = "Παρθένε Μήτηρ τοῦ Θεοῦ, θραῦσον…"
meMA.Ode7C2T.text = "Παρθένε Μήτηρ τοῦ Θεοῦ, θραῦσον τῶν βαρβάρων τὰ θράση, καὶ τὰς βουλὰς τῶν ἀσεβῶν, τῷ πιστῷ Βασιλεῖ καθυπόταξον, καὶ τὸ κέρας αὐχήμασι, τῆς ἀνδρείας μεγάλυνον τῶν Ὀρθοδόξων."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C11.greekmelody = he.h.m1_gr_GR_cog.heHE.EnKaminoPaides.greekname
meMA.Ode8C11.melody = he.h.m1_gr_GR_cog.heHE.EnKaminoPaides.name
meMA.Ode8C11.incipit = "Νομισθέντες ἔναντι ἐχθρῶν, Σοφοὶ ἑβδελυγμένοι…"
meMA.Ode8C11.text = "Νομισθέντες ἔναντι ἐχθρῶν, Σοφοὶ ἑβδελυγμένοι, μετήγεσθε ἀπὸ τόπων, ἐπὶ τόπους πρὸς πολλῶν, πεῖραν μαστιγώσεων, ἐκβοῶντες· Πάντα τὰ ἔργα Κυρίου, τὸν κύριον ὑμνεῖτε, καὶ ὑπερυψοῦτε εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C12.melody = he.h.m1_gr_GR_cog.heHE.EnKaminoPaides.name
meMA.Ode8C12.incipit = "Ἐν γυμνώσει σώματος ὑμεῖς, πληγαῖς…"
meMA.Ode8C12.text = "Ἐν γυμνώσει σώματος ὑμεῖς, πληγαῖς προσομιλοῦντες, ἐπλήξατε τὸν ἀσώματον, πανεύφημοι ἐχθρόν, λόγχῃ καρτερότητος, μελῳδοῦντες· Πάντα τὰ ἔργα Κυρίου, τὸν Κύριον ὑμνεῖτε, καὶ ὑπερυψοῦτε εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C13.melody = he.h.m1_gr_GR_cog.heHE.EnKaminoPaides.name
meMA.Ode8C13.incipit = "Συντριβέντες λίθοις ὥς ποτε, ὁ…"
meMA.Ode8C13.text = "Συντριβέντες λίθοις ὥς ποτε, ὁ πρῶτος τῶν Μαρτύρων, τὴν πέτραν οὐκ ἐξηρνήσασθε, τὴν ὄντως ἀῤῥαγῆ, Χριστὸν μεγαλώνυμοι, μελῳδοῦντες· Πάντα τὰ ἔργα Κυρίου, τὸν Κύριον ὑμνεῖτε, καὶ ὑπερυψοῦτε εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C1Tr.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1Tr.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C1Tr.melody = he.h.m1_gr_GR_cog.heHE.EnKaminoPaides.name
meMA.Ode8C1Tr.incipit = "Ὡς Μονάδα φύσει μὲν ἁπλήν…"
meMA.Ode8C1Tr.text = "Ὡς Μονάδα φύσει μὲν ἁπλήν, Τριάδα δὲ προσώποις, δοξάσωμεν τὸν Πατέρα, τὸν προάναρχον Υἱόν, καὶ Πνεῦμα τὸ Ἅγιον, μελῳδοῦντες· Πάντα τὰ ἔργα Κυρίου, τὸν Κύριον ὑμνεῖτε, καὶ ὑπερυψοῦτε εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode8C1T.melody = he.h.m1_gr_GR_cog.heHE.EnKaminoPaides.name
meMA.Ode8C1T.incipit = "Ἰακὼβ σε κλίμακά ποτε, ἑώρακε…"
meMA.Ode8C1T.text = "Ἰακὼβ σε κλίμακά ποτε, ἑώρακε Παρθένε, διʼ ἦς μὲν ὁ Θεὸς Λόγος, κατῆλθεν ἐπὶ γῆς, ἡμᾶς δὲ ἀνήγαγε πρὸς τὸ ὕψος· τοῦτον ἀπαύστως ὑμνοῦμεν Θεοτόκε, καὶ ὑπερυψοῦμεν εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C21.greekmelody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.greekname
meMA.Ode8C21.melody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.name
meMA.Ode8C21.incipit = "Ῥάβδῳ λόγων σου ἱερῶν, ἀνέτρεψας…"
meMA.Ode8C21.text = "Ῥάβδῳ λόγων σου ἱερῶν, ἀνέτρεψας δαιμόνων τὴν πληθύν, καὶ ἠλευθέρωσας πιστῶν, τὰς ἀγέλας τῆς τούτων λύμης, Χριστῷ μελῳδούντων· Εὐλογεῖτε τὰ ἔργα τὸν Κύριον, καὶ ὑπερυψοῦτε αὐτὸν εἰς τοὺς αἰῶνας."

meMA.Ode8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C22.melody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.name
meMA.Ode8C22.incipit = "Ὄμμα τείναντʼ εἰς οὐρανόν, ἀνέτειλέ…"
meMA.Ode8C22.text = "Ὄμμα τείναντʼ εἰς οὐρανόν, ἀνέτειλέ σοι πρώϊμον τὸ φῶς, ὥς περ ὑπέσχετο Θεός· ἔτι γάρ σου προσευχομένου, παρέστη βοῶν σοι· Ἐπιτάῤῥοθος ἥκω σοι· πτόησιν πᾶσαν ἀποῤῥίψας, ἀνδρίζου εἰς αἰῶνας."

meMA.Ode8C23.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C23.melody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.name
meMA.Ode8C23.incipit = "Φοβεράν σου τὴν προσβολήν, ἀνέδειξε…"
meMA.Ode8C23.text = "Φοβεράν σου τὴν προσβολήν, ἀνέδειξε Χριστὸς τοῖς πονηροῖς, καὶ ἀλαζόσι λοχαγοῖς· τὰς γὰρ τούτων μηχανουργίας, ἱστὸν ὡς ἀράχνης, ἐξηφάνισας κράζων Γεώργιε· Ὑπερευλογῶ σε, Χριστὲ εἰς τους αἰῶνας."

meMA.Ode8C2T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8C2T.melody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.name
meMA.Ode8C2T.incipit = "Ῥύμην ἄστατον καὶ φθοράν, ὁ…"
meMA.Ode8C2T.text = "Ῥύμην ἄστατον καὶ φθοράν, ὁ τόκος σου κατέλυσεν ἁγνή, τὴν τοῦ θανάτου καὶ ζωήν, τοῖς ἀνθρώποις πᾶσι παρέσχε, τοῖς τοῦτον ὑμνοῦσιν, ὡς Θεὸν τῶν ἁπάντων καὶ Κύριον, καὶ ὑπερυψοῦσιν, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode8H.greekmelody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.greekname
meMA.Ode8H.melody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.melody
meMA.Ode8H.incipit = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.incipit
meMA.Ode8H.text = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C11.greekmelody = he.h.m1_gr_GR_cog.heHE.TyponTisAgnis.greekname
meMA.Ode9C11.melody = he.h.m1_gr_GR_cog.heHE.TyponTisAgnis.name
meMA.Ode9C11.incipit = "Ὥσπερ ἄνοδοι καὶ κλίμακες, πρὸς…"
meMA.Ode9C11.text = "Ὥσπερ ἄνοδοι καὶ κλίμακες, πρὸς οὐρανὸν ἀνάγουσαι, ὑμᾶς ὤφθησαν, μάκαρ Ἰωσήφ, Ἀειθαλᾶ τε πανένδοξοι, αἱ τῶν λίθων νιφάδες πανεύφημοι, διʼ ὧν θανατωθέντες, ἀθανασίας ἠξιώθητε."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C12.melody = he.h.m1_gr_GR_cog.heHE.TyponTisAgnis.name
meMA.Ode9C12.incipit = "Στῶμεν εὐσεβῶς γεραίροντες, Ἀκεψιμᾶν τὸν…"
meMA.Ode9C12.text = "Στῶμεν εὐσεβῶς γεραίροντες, Ἀκεψιμᾶν τὸν θεῖον ἱερομάρτυρα, τὸν ἱερουργόν τε, Ἰωσὴφ τὸν πανάριστον, καὶ Χριστοῦ μυστηρίων διάκονον, Ἀειθαλᾶν τὸν μέγαν, τοὺς εὐκλεεῖς Θεοῦ θεράποντας."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C13.melody = he.h.m1_gr_GR_cog.heHE.TyponTisAgnis.name
meMA.Ode9C13.incipit = "Ἤδη πρὸς Θεὸν σκηνώσαντες, καὶ…"
meMA.Ode9C13.text = "Ἤδη πρὸς Θεὸν σκηνώσαντες, καὶ φωτισμοῦ ἀῤῥήτου καταξιούμενοι, καὶ ἀγγελικαῖς χοροστασίαις ἑνούμενοι, καὶ συνόντες Μαρτύρων στρατεύμασι, σὺν τούτοις Ἀθλοφόροι, ὑπὲρ ἡμῶν ἀεὶ πρεσβεύσατε."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
meMA.Ode9C1T.melody = he.h.m1_gr_GR_cog.heHE.TyponTisAgnis.name
meMA.Ode9C1T.incipit = "Φράσαι τὸ φρικτὸν μυστήριον, τοῦ…"
meMA.Ode9C1T.text = "Φράσαι τὸ φρικτὸν μυστήριον, τοῦ τοκετοῦ σου γλῶσσα ὅλως οὐ δύναται· τὸν γὰρ οὐρανοῦ, καὶ πάσης κτίσεως Κύριον, ἐσωμάτωσας σάρκα πτωχεύσαντα, ἁγνὴ Παρθενομῆτορ· ὅθεν συμφώνως σὲ δοξάζομεν."

meMA.Ode9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C21.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C21.greekmelody = he.h.m4_gr_GR_cog.heHE.OTokosSouAfthoros.greekname
meMA.Ode9C21.melody = he.h.m4_gr_GR_cog.heHE.OTokosSouAfthoros.name
meMA.Ode9C21.incipit = "Ὄρει μαρτυρίου προσεπέβης, καὶ στέφος…"
meMA.Ode9C21.text = "Ὄρει μαρτυρίου προσεπέβης, καὶ στέφος ἐδέξω Ἀθλοφόρε, ἐκ χειρὸς τοῦ Κυρίου· τοῦτο γὰρ ἐστι τὸ γέρας τῶν Μαρτύρων· ὅθεν σε πάντες, ἐπαξίως μεγαλύνομεν."

meMA.Ode9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C22.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C22.melody = he.h.m4_gr_GR_cog.heHE.OTokosSouAfthoros.name
meMA.Ode9C22.incipit = "Νέμεις λύσιν τῶν ἀμπλακημάτων, καὶ…"
meMA.Ode9C22.text = "Νέμεις λύσιν τῶν ἀμπλακημάτων, καὶ νόσους διώκεις Ἀθλοφόρε, τὰς τοῦ σώματος πόῤῥω, καὶ ἄρτιον ὅλον με ἀποδεικνύεις· διό σου πόθῳ, τὴν ἐμφέρειαν προσπτύσσομαι."

meMA.Ode9C23.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C23.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C23.melody = he.h.m4_gr_GR_cog.heHE.OTokosSouAfthoros.name
meMA.Ode9C23.incipit = "Ὡς πόλον πολεύων Ἀθλοφόρε, καὶ…"
meMA.Ode9C23.text = "Ὡς πόλον πολεύων Ἀθλοφόρε, καὶ θρόνῳ τοῦ πάντων Βασιλέως, παριστάμενος αἴγλην, τὴν σκεδάζουσαν νέφος ἁμαρτημάτων, πέμψον τῷ πόθῳ, τὴν ᾠδήν σοι ἐξυφάναντι."

meMA.Ode9C2T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C2T.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9C2T.melody = he.h.m4_gr_GR_cog.heHE.OTokosSouAfthoros.name
meMA.Ode9C2T.incipit = "Σύμμορφος Υἱὸς ἐξ ἀγεννήτου, Πατρὸς…"
meMA.Ode9C2T.text = "Σύμμορφος Υἱὸς ἐξ ἀγεννήτου, Πατρὸς γεννηθεὶς πρὸ τῶν αἰώνων, ἐπʼ ἐσχάτων δὲ αὖθις, διὰ Πνεύματος Ἁγίου, ἐνδημήσας τῇ Παρθένῳ, σάρκα πτωχεύσας, τὸ ἀνθρώπινον ἐθέωσας."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode9H.greekmelody = he.h.m4_gr_GR_cog.heHE.OTokosSouAfthoros.greekname
meMA.Ode9H.melody = he.h.m4_gr_GR_cog.heHE.OTokosSouAfthoros.melody
meMA.Ode9H.incipit = he.h.m4_gr_GR_cog.heHE.OTokosSouAfthoros.incipit
meMA.Ode9H.text = he.h.m4_gr_GR_cog.heHE.OTokosSouAfthoros.text

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Exaposteilarion1.greekmelody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.greekname
meMA.Exaposteilarion1.melody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.name
meMA.Exaposteilarion1.incipit = "Ἀκεψιμᾶς ὁ ἔνδοξος, Ἰωσὴφ ὁ…"
meMA.Exaposteilarion1.text = "Ἀκεψιμᾶς ὁ ἔνδοξος, Ἰωσὴφ ὁ γενναῖος, Ἀειθαλᾶς ὁ πάνσοφος, τοῦ Χριστοῦ τῇ ἰσχύϊ, ἐνήθλησαν καὶ τὴν πλάνην, τῶν Περσῶν καθελόντες, ὑπὲρ ἡμῶν πρεσβεύουσι, τῇ Ἁγία Τριάδι, οὓς εὐσεβῶς, ὡς ἱερομάρτυρας εὐφημοῦντες, φαιδρῶς πανηγυρίζομεν, τὴν λαμπρὰν τούτων μνήμην."

meMA.Exaposteilarion2.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Exaposteilarion2.greekmelody = he.a.m3_gr_GR_cog.heAU.EnPnevmatiToIero.greekname
meMA.Exaposteilarion2.melody = he.a.m3_gr_GR_cog.heAU.EnPnevmatiToIero.name
meMA.Exaposteilarion2.incipit = "Τοῖς ῥείθροις τῶν αἱμάτων σου…"
meMA.Exaposteilarion2.text = "Τοῖς ῥείθροις τῶν αἱμάτων σου, τῆς ἀπάτης τὴν φλόγα, ἀπέσβεσας Μακάριε, καὶ τυράννων τὰ θράση, εἰς τέλος ἐξηφάνισας, καὶ Χριστὸν ἐδόξασας, Γεώργιε Ἀθλοφόρε· ὅθεν στέφος ἐδέξω, ἀφθαρσίας καὶ ζωῆς, ἐκ δεξιᾶς τοῦ Ὑψίστου."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.ExapTheotokion.melody = he.a.m3_gr_GR_cog.heAU.EnPnevmatiToIero.name
meMA.ExapTheotokion.incipit = "Οὐκ ἔστιν ὅλως ἐν ἐμοί…"
meMA.ExapTheotokion.text = "Οὐκ ἔστιν ὅλως ἐν ἐμοί, σωτηρία Παρθένε, ὅτι κακῶς εἰσπέπτωκα, βάθος ἁμαρτημάτων, καὶ προσδοκῶ τὴν ἀπειλήν, τῆς φρικτῆς κολάσεως, καὶ τῶν ἐρίφων τῆς μοίρας, οἴκτειρόν με πρὸ δίκης, ὡς ὑπάρχουσα θερμή, ἀντίληψις Θεοτόκε."

meMA.Lauds1.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Lauds1.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
meMA.Lauds1.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meMA.Lauds1.incipit = "Τοῦ Χριστοῦ τὸ γεώργιον, τὸν…"
meMA.Lauds1.text = "Τοῦ Χριστοῦ τὸ γεώργιον, τὸν γενναῖον ἐν Μάρτυσι, τὸν σοφὸν Γεώργιον εὐφημήσωμεν, τῆς ἀληθείας τὸν κήρυκα, κλῆμα τὸ ἀείζωον, τῆς ἀμπέλου τῆς ζωῆς, τὸν καρπόν ἐξανθήσαντα, καὶ πηγάσαντα, εὐσεβείας τὸ γλεῦκος καὶ τοὺς πίστει, ἐκτελοῦντας ἐτησίως, τούτου τὴν μνήμην εὐφραίνοντα."

meMA.Lauds2.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Lauds2.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
meMA.Lauds2.incipit = me.m04.d23_gr_GR_cog.meVE.Stichera05.incipit
meMA.Lauds2.text = me.m04.d23_gr_GR_cog.meVE.Stichera05.text

