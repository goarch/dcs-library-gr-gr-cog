meDA.date = "Τῌ Γʹ ΝΟΕΜΒΡΙΟΥ"
meDA.commemoration.full = "Μνήμη τῶν Ἁγίων Μαρτύρων, Ἀκεψιμᾶ, Ἰωσήφ, καὶ Ἀειθαλᾶ, καὶ τῶν Ἐγκαινίων τοῦ Ναοῦ τοῦ Ἁγίου Μεγαλομάρτυρος Γεωργίου, τοῦ ἐν Λύδδῃ, ἤτοι τῆς Καταθέσεως τοῦ Τιμίου Σώματος αὐτοῦ." // full title of day
meDA.commemoration.first = "Μνήμη τοῦ Ἁγίου Μεγαλομάρτυρος Γεωργίου"
meDA.commemoration.first_short = "Μνήμη τοῦ Ἁγίου Μεγαλομάρτυρος Γεωργίου"
meDA.commemoration.first_title = titles_gr_GR_cog.ti.Martyrs
meDA.commemoration.first_name = ""
meDA.commemoration.second_short = "Μνήμη τῶν Ἁγ. Μαρτύρων, Ἀκεψιμᾶ, Ἰωσήφ, καὶ Ἀειθαλᾶ"
meDA.commemoration.second_title = "Τοῦ Ἁγ. Γεωργίου."
meDA.commemoration.second_name = ""
meDA.insert1 = "καὶ τῶν ἁγίων Μαρτύρων, Ἀκεψιμᾶ, Ἰωσήφ, καὶ Ἀειθαλᾶ, καὶ τοῦ ἁγίου ἐνδόξου Μεγαλομάρτυρος Γεωργίου τοῦ Τροπαιοφόρου," // for use in petitions and dismissal
meDA.insert2 = "ὧν καὶ τὴν μνήμην ἐπιτελοῦμεν·" // for use in petitions and dismissal
meDA.note = ""
meDA.pdfcoverdate = "τῆς 3ης Νοεμβρίου,"
meDA.pdfdatebefore = "τῆς 3ης Νοεμβρίου"
meDA.pdfheaderdate = "τῆς 3ης Νοεμβρίου"
meDA.fordate = "διὰ τὴν 3ην Νοεμβρίου"
