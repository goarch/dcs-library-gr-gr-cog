meDA.pdfheaderdate = "τῆς 17ης Νοεμβρίου"
meDA.fordate = "διὰ τὴν 17ην Νοεμβρίου"
meLE.commemoration1 = "Μνήμη τοῦ ἐν Ἁγίοις Πατρὸς ἡμῶν Γρηγορίου, Ἐπισκόπου Νεοκαισαρείας, τοῦ Θαυματουργοῦ."
meLE.commemoration2 = ""
