meVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera01.greekmelody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.greekname
meVE.Stichera01.melody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.name
meVE.Stichera01.incipit = "Τί σε νῦν καλέσω Γρηγόριε…"
meVE.Stichera01.text = "Τί σε νῦν καλέσω Γρηγόριε; πρακτικόν, ὅτι τὰ πάθη, καθυπέταξας τῷ νῷ· θεωρόν, ὅτι ἐδρέψω, τῆς σοφίας τὸν καρπόν· ἐνθέου, ὀπτασίας ἀξιούμενον, καὶ δόγματα, οὐράνια μυούμενον, ἱερουργὸν ἱερώτατον, θαυματουργὸν ὑπερθαύμαστον, ἱκέτευε, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν."

meVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera02.melody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.name
meVE.Stichera02.incipit = "Τί προσαγορεύσω σε Ὅσιε; ὁδηγὸν…"
meVE.Stichera02.text = "Τί προσαγορεύσω σε Ὅσιε; ὁδηγὸν τῶν πλανωμένων, καὶ νοσούντων ἰατρόν, χορηγὸν τῶν πρὸς τὴν χρείαν, τοῖς αἰτοῦσι δαψιλῆ, διώκτην, τῶν δαιμόνων ἰσχυρότατον, ἀλείπτην, τοῦ Μαρτύρων ἀγωνίσματος, προφητικῶς διαλάμποντα, χαρίσμασιν ἀξιάγαστε, ἱκέτευε, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν."

meVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Stichera03.melody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.name
meVE.Stichera03.incipit = "Τί σε νῦν προσείπω Γρηγόριε…"
meVE.Stichera03.text = "Τί σε νῦν προσείπω Γρηγόριε; καθαιρέτην τῆς ἀθέου, δυσσεβείας κρατερόν, ὁριστὴν τῆς εὐσεβείας, καὶ διδάσκαλον ἐθνῶν, εἰρήνης, βραβευτὴν ἀκαταμάχητον, πολέμων, καταλύτην ἀκαθαίρετον, ἐν ὄρεσι διαιτώμενον, καὶ βλέποντα τὰ ἐν πόλεσιν, ἱκέτευε, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν."

meVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Εἰς βάθος θεωρίας ὑπελθὼν πανσόφως…"
meVE.SticGlory.text = "Εἰς βάθος θεωρίας ὑπελθὼν πανσόφως, Ἱεράρχα Χριστοῦ, τὴν θείαν ἐμυήθης τῆς Τριάδος φανέρωσιν, καὶ πνεύματι προσβλέπων ἀκλινῶς, Χριστὸν τὸν Θεὸν ἡμῶν, τῶν θαυμάτων ἄβυσσον πηγάζεις ἡμῖν, τὴν ὑγρὰν ὑδάτων φύσιν, εἰς λιθώδη μεταποιήσας, καὶ νεωκόρον πλάνης ἀπαλλάξας ζοφεράς, τοὺς διώκτας ἔπεισας πιστοῦσθαι τὴν ἀλήθειαν, καὶ στῦλος εὐσεβείας ἀρετῶν ὀφθεὶς αὐτοῖς, τῶν θαυμάτων ὑποφήτης ἀνηγορεύθης. Διὸ δυσωποῦμέν σε, μὴ παύσῃ ὑπὲρ ἡμῶν τὸν Σωτῆρα δυσωπεῖν, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν."

meVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticTheotokion.greekmelody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.greekname
meVE.SticTheotokion.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meVE.SticTheotokion.incipit = me.m01.d16_gr_GR_cog.meVE.AposTheotokion.incipit
meVE.SticTheotokion.text = me.m01.d16_gr_GR_cog.meVE.AposTheotokion.text

meVE.SticStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.SticStavrotheotokion.greekmelody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.greekname
meVE.SticStavrotheotokion.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
meVE.SticStavrotheotokion.incipit = "Ξύλῳ σε κρεμάμενον, μέσον ληστῶν…"
meVE.SticStavrotheotokion.text = "Ξύλῳ σε κρεμάμενον, μέσον ληστῶν καθορῶσα, ἡ χωρὶς ὠδίνων σε, καὶ φθορᾶς κυήσασα Μητροπάρθενος, χαλεπῷ βέβληται, τὴν ψυχὴν Κύριε, βέλει λύπης καὶ σπαράττεται, πικρὰ στενάζουσα, σπλάγχνα καὶ καρδίαν τὴν ἄχραντον, καὶ ξέουσα τοῖς ὄνυξιν, ἀφειδῶς τὰς ὄψεις καὶ πύρινα, δάκρυα κενοῦσα, μετʼ οἰμωγῆς σοι κέκραγε Σωτήρ· Οἴμοι γλυκύτατον σπλάγχνον μου! πῶς ἀδίκως πάσχεις νῦν;"

meVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Γρηγόρησις Θεοῦ, ἐδόθη σοι σοφὲ…"
meVE.AposGlory.text = "Γρηγόρησις Θεοῦ, ἐδόθη σοι σοφὲ κατὰ τὸν Δανιήλ· ὥσπερ γὰρ ἐκείνῳ τὸ ἐνύπνιον, οὕτω τὸ τῆς πίστεως μυστήριον ἀπεκαλύφθη σοι· διὸ σωθῆναι πρέσβευε, τὰς ψυχάς ἡμῶν Ὅσιε Πάτερ."

meVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.AposTheotokion.melody = ""
meVE.AposTheotokion.incipit = "Ἀρχαγγελικὸν λόγον ὑπεδέξω, καὶ Χερουβικὸς…"
meVE.AposTheotokion.text = "Ἀρχαγγελικὸν λόγον ὑπεδέξω, καὶ Χερουβικὸς θρόνος ἀνεδείχθης, καὶ ἐν ἀγκάλαις ἐβάστασας Θεοτόκε, τὴν ἐλπίδα τῶν ψυχῶν ἡμῶν."

meVE.AposStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode6
meVE.AposStavrotheotokion.greekmelody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.greekname
meVE.AposStavrotheotokion.melody = he.a.m6_gr_GR_cog.heAU.TriimerosAnestis.name
meVE.AposStavrotheotokion.incipit = oc.m6.d4_gr_GR_cog.ocVE.AposTheotokion.incipit
meVE.AposStavrotheotokion.text = oc.m6.d4_gr_GR_cog.ocVE.AposTheotokion.text

meVE.Apolytikion1.mode = miscellanea_gr_GR_cog.misc.Mode8
meVE.Apolytikion1.melody = ""
meVE.Apolytikion1.incipit = "Ἐν προσευχαῖς γρηγορῶν, ταῖς τῶν…"
meVE.Apolytikion1.text = "Ἐν προσευχαῖς γρηγορῶν, ταῖς τῶν θαυμάτων ἐργασίαις ἐγκαρτερῶν, ἐπωνυμίαν ἐκτήσω τὰ κατορθώματα· ἀλλὰ πρέσβευε Χριστῷ τῷ Θεῷ, Πάτερ Γρηγόριε, φωτίσαι τὰς ψυχὰς ἡμῶν, μὴ ποτε ὑπνώσωμεν, ἐν ἁμαρτίαις εἰς θάνατον."

meMA.C1.acrostic.title = "Κανὼν τοῦ Ἁγίου,"
meMA.C1.acrostic.notice1 = "οὗ ἡ Ἀκροστιχίς·"
meMA.C1.acrostic.text = "Τῷ τερατουργῷ Γρηγορίῳ τὸν ἔπαινον ὑφαίνω."
meMA.C1.poet = poets_gr_GR_cog.po.Theofanous
meMA.C1.title = titles_gr_GR_cog.ti.CanonSaintM
meMA.C1.verse = prayers_gr_GR_cog.pr.verse_SaintM.text

meMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C11.greekmelody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.greekname
meMA.Ode1C11.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C11.incipit = "Τῶν σῶν θαυμάτων ἐν ἐμοὶ…"
meMA.Ode1C11.text = "Τῶν σῶν θαυμάτων ἐν ἐμοὶ Γρηγόριε, θείαν ἐνέργειαν, περιφανῶς Πάτερ, καὶ τανῦν ἀνάδειξον, ἐκ τοῦ βυθοῦ ῥυόμενος, τῶν πταισμάτων με μάκαρ, καὶ σῇ φωτίζων λαμπρότητι, ὅπως ἐπαξίως ὑμνήσω σε."

meMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C12.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C12.incipit = "Ὡς ἐντρεχὴς καὶ νουνεχὴς καὶ…"
meMA.Ode1C12.text = "Ὡς ἐντρεχὴς καὶ νουνεχὴς καὶ φρόνιμος, τὸ τῆς ψυχῆς εὐγενές, τῶν τῆς σαρκὸς μάκαρ, ἡδονῶν προέκρινας, τὰ τῆς σοφίας δόγματα, φιλοπόνως συλλέγων, διʼ ὧν ἐκείνη Γρηγόριε, τρέφεται Θεῷ πλησιάζουσα."

meMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C13.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C13.incipit = "Τὴν σωφροσύνην ἀδελφὴν κτησάμενον, ὡς…"
meMA.Ode1C13.text = "Τὴν σωφροσύνην ἀδελφὴν κτησάμενον, ὡς συνεργὸν τῶν καλῶν, σὲ καθορῶν ὄφις, ὁ δεινὸς Γρηγόριε, σοὶ τοὺς βασκάνους ἤγειρεν, οὓς κατῄσχυνας Πάτερ, μακροθυμίᾳ τὸ γύναιον, πάθει συσχεθὲν ἰασάμενος."

meMA.Ode1C14.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C14.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C14.incipit = "Ἐπὶ τῆς ξένης διατρίβων Ὅσιε…"
meMA.Ode1C14.text = "Ἐπὶ τῆς ξένης διατρίβων Ὅσιε, πᾶσιν αἰδέσιμος, διʼ ἀρετὴν ὤφθης, εὐσεβὴς φιλόθεος, θαυματουργίας χάρισμα, πρὸς Θεοῦ δεδεγμένος, διʼ ἦς γνωρίζῃ ὡς ἥλιος, λάμψας ἐν τῷ κόσμῳ Γρηγόριε."

meMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
meMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode1C1T.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
meMA.Ode1C1T.incipit = "Ῥίζης Ἁγνὴ βασιλικῆς ἐβλάστησας, καὶ…"
meMA.Ode1C1T.text = "Ῥίζης Ἁγνὴ βασιλικῆς ἐβλάστησας, καὶ Βασιλέα Χριστόν, τὸν τοῦ Θεοῦ Λόγον, ὑπὲρ νοῦν καὶ ἔννοιαν, σεσαρκωμένον τέτοκας, ἐξ ἁγνῶν σου αἱμάτων, διττὸν τὴν φύσιν ὑπάρχοντα, καὶ μοναδικὸν τὴν ὑπόστασιν."

meMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C11.greekmelody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.greekname
meMA.Ode3C11.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C11.incipit = "Ἀνακαθάρας σου τὸν νοῦν, τῆς…"
meMA.Ode3C11.text = "Ἀνακαθάρας σου τὸν νοῦν, τῆς τῶν παθῶν τρικυμίας, καὶ πανσόφου θεωρίας ἐμπλήσας, ἀνεδείχθης εὐπρεπές, σοφίας ἐνδιαίτημα, καὶ προφητείας χάριν, κατεπλουτίσθης Γρηγόριε."

meMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C12.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C12.incipit = "Τῇ θεοπνεύστῳ συγγραφῇ, προσομιλήσας παμμάκαρ…"
meMA.Ode3C12.text = "Τῇ θεοπνεύστῳ συγγραφῇ, προσομιλήσας παμμάκαρ, καὶ ποικίλης πολιτείας ἰδέαν, ἐκλεξάμενος σοφῶς. Ἐν ἀρετῆς εἰκόνισμα, ἐν σεαυτῷ θεόφρον, ἀπηκριβώσω Γρηγόριε."

meMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C13.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C13.incipit = "Ὁ θεοφάντωρ μυηθείς, τῇ θείᾳ…"
meMA.Ode3C13.text = "Ὁ θεοφάντωρ μυηθείς, τῇ θείᾳ μυσταγωγίᾳ, τὸ μυστήριον τῆς θεολογίας, κατεφώτισεν ἡμᾶς, Τριάδα ὁμοούσιον, ὁμοφυῆ τε σέβειν, ἄκτιστον καὶ συναΐδιον."

meMA.Ode3C14.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C14.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C14.incipit = "Ὑπὸ Θεοῦ ὁδηγηθείς, ὡς πόθῳ…"
meMA.Ode3C14.text = "Ὑπὸ Θεοῦ ὁδηγηθείς, ὡς πόθῳ τοῦτον ζητήσας, τὴν ἁγνὴν καὶ Θεοτόκον Μαρίαν, καὶ τὸν γόνον τῆς Βροντῆς, μυσταγωγοῦς ἐκέκτησο, τὸ τῆς Τριάδος φέγγος, σὲ θεοῤῥῆμον διδάσκοντας."

meMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3C1T.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
meMA.Ode3C1T.incipit = "Ῥάβδον βλαστήσασαν Χριστόν, τὸ ἄνθος…"
meMA.Ode3C1T.text = "Ῥάβδον βλαστήσασαν Χριστόν, τὸ ἄνθος τῆς ἀφθαρσίας, καὶ χρυσοῦν θυμιατήριον πάντες, σὲ γινώσκομεν Ἁγνή, θείας οὐσίας φέρουσαν, ἐν ταῖς ἀγκάλαις Κόρη, ἄνθρακα θεομακάριστε."

meMA.Ode3H.ode = miscellanea_gr_GR_cog.misc.Ode3
meMA.Ode3H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode3H.greekmelody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.greekname
meMA.Ode3H.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.melody
meMA.Ode3H.incipit = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.incipit
meMA.Ode3H.text = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.text

meMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3Kathisma1.greekmelody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.greekname
meMA.Ode3Kathisma1.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meMA.Ode3Kathisma1.incipit = "Νέος γέγονας Μωσῆς τοῖς ἔργοις…"
meMA.Ode3Kathisma1.text = "Νέος γέγονας Μωσῆς τοῖς ἔργοις, πλάκας πίστεως ἐπὶ τοῦ ὄρους, τῆς μυστικῆς θεοφανείας δεξάμενος, νομοθετήσας λαοῖς τὴν εὐσέβειαν, τοῦ τῆς Τριάδος μυστηρίου Γρηγόριε· ὅθεν ἅπαντες, τιμῶμεν πιστοὶ τὴν μνήμην σου, αἰτοῦντες διὰ σοῦ τὸ μέγα ἔλεος."

meMA.Ode3KathismaT.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3KathismaT.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meMA.Ode3KathismaT.incipit = oc.m3.d2_gr_GR_cog.ocMA.Kathisma23.incipit
meMA.Ode3KathismaT.text = oc.m3.d2_gr_GR_cog.ocMA.Kathisma23.text

meMA.Ode3KathismaSt.mode = miscellanea_gr_GR_cog.misc.Mode3
meMA.Ode3KathismaSt.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
meMA.Ode3KathismaSt.incipit = me.m01.d29_gr_GR_cog.meMA.Ode3KathismaSt.incipit
meMA.Ode3KathismaSt.text = me.m01.d29_gr_GR_cog.meMA.Ode3KathismaSt.text

meMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C11.greekmelody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.greekname
meMA.Ode4C11.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C11.incipit = "Γῆν τὴν καλήν, Πάτερ θεόφρον…"
meMA.Ode4C11.text = "Γῆν τὴν καλήν, Πάτερ θεόφρον ἐζήλωσας, καὶ τοῦ λόγου, σπόρον εἰσδεξάμενος, εἰς ἑκατὸν εὐαγγελικῶς, πολλαπλασιάζεις, εἰσέτι καὶ νῦν Γρηγόριε, προσάγων διδαχαῖς σου, τοὺς πιστῶς μελῳδοῦντας, τῇ δυνάμει σου δόξα Φιλάνθρωπε."

meMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.Ode4C12.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C12.incipit = "Ὡς ἀστραπή, Πάτερ ἐκλάμψας ὁ…"
meMA.Ode4C12.text = "Ὡς ἀστραπή, Πάτερ ἐκλάμψας ὁ βίος σου, τῶν δαιμόνων, πλάνην ἐφυγάδευσε· τῷ γὰρ φωτί, τῆς σῆς ἀρετῆς, τὸ ἐκείνων σκότος, προσομιλῆσαι οὐκ ἴσχυσε· διὸ ὁ νεωκόρος, ψυχοφθόρου ἀπάτης, κυλισθεὶς ὥσπερ λίθος φωτίζεται."

meMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C13.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C13.incipit = "Γνόφον φωτός, τοῦ θειοτάτου θεάσασθαι…"
meMA.Ode4C13.text = "Γνόφον φωτός, τοῦ θειοτάτου θεάσασθαι, ἠξιώθης, νόμον τε θεόγραφον, ὡς Μωϋσῆς, Πάτερ εἰληφώς, τῆς θεολογίας, τὸ ἀκριβὲς ἐκπεπαίδευσαι, ἐντεῦθεν νομοθέτης, τῇ Χριστοῦ Ἐκκλησία, ἀνεδείχθης θεόφρον Γρηγοριε."

meMA.Ode4C14.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C14.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C14.incipit = "Ῥητορικήν, ἐρεσχελίαν ἐξέκλινας, καὶ τῷ…"
meMA.Ode4C14.text = "Ῥητορικήν, ἐρεσχελίαν ἐξέκλινας, καὶ τῷ λόγῳ, Πάτερ τῷ τῆς χάριτος, καταυγασθείς, ἀποστολικήν, ὄντως ἐξουσίαν, κατὰ δαιμόνων ἐπλούτησας· τὴν σὴν γὰρ δραπετεύει, ἀπαστράπτουσαν αἴγλην, ὁ τοῦ σκότους προστάτης Γρηγόριε."

meMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
meMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode4C1T.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
meMA.Ode4C1T.incipit = "Ἡ κιβωτός, πόῤῥωθεν σὲ προετύπωσε…"
meMA.Ode4C1T.text = "Ἡ κιβωτός, πόῤῥωθεν σὲ προετύπωσε, δεξαμένη, νόμον τὸν θεόγραφον, τὴν ἐν γαστρί, τὸν ζωαρχικόν, Λόγον συλλαβοῦσαν, ἀνερμηνεύτως Πανάμωμε, τὸν τρέφοντα πλουσίως, τὰς ψυχὰς τῶν βοώντων, τῇ δυνάμει σου δόξα Φιλάνθρωπε."

meMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C11.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
meMA.Ode5C11.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C11.incipit = "Γεωργίᾳ σῶν λόγων, τὰς κεχερσωμένας…"
meMA.Ode5C11.text = "Γεωργίᾳ σῶν λόγων, τὰς κεχερσωμένας καρδίας ὡμάλισας, καὶ τὸν θεῖον σπόρον, ἐν αὐταῖς Ἱεράρχα κατέβαλες, καὶ καρπὸν πολύχουν, τῷ Λυτρωτῇ τὴν σωτηρίαν, τῶν πιστῶν θεοῤῥῆμον προσήγαγες."

meMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C12.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C12.incipit = "Ὁ Θεοῦ παραστάτης, ζήλῳ πυρακτούμενος…"
meMA.Ode5C12.text = "Ὁ Θεοῦ παραστάτης, ζήλῳ πυρακτούμενος χρίει σε Φαίδιμος, Ἱερέα Πάτερ, τῷ Θεῷ τῷ τὰ σύμπαντα βλέποντι, εὐσεβῶς θαῤῥήσας, καὶ τῇ σεπτῇ σου πολιτείᾳ, πεποιθώς θεοῤῥῆμον Γρηγόριε."

meMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C13.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C13.incipit = "Ῥοαῖς τῶν σῶν δογμάτων, τὰς…"
meMA.Ode5C13.text = "Ῥοαῖς τῶν σῶν δογμάτων, τὰς εἰδωλικὰς πυρπολήσεις κατέσβεσας, καὶ ταῖς διδαχαῖς σου, τοὺς πιστοὺς ἐβεβαίωσας Πάνσοφε, ἀναβὰς εἰς ὕψος, ὡς Σαμουὴλ ταῖς θεωρίαις, καὶ ὡς δένδρον φανεὶς τοῖς διώκουσι."

meMA.Ode5C14.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C14.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C14.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C14.incipit = "Ἱεράρχα θεόφρον, ταῖς σαῖς ἱκεσίαις…"
meMA.Ode5C14.text = "Ἱεράρχα θεόφρον, ταῖς σαῖς ἱκεσίαις δεινῶν με λυτρούμενος, τῶν ἐμῶν πταισμάτων, τὸ χειρόγραφον Πάτερ διάῤῥηξον, ἱερεὺς ὑπάρχων, καὶ ἐκ Θεοῦ τὴν ἐξουσίαν, εἰληφὼς ἀφιέναι τὰ πταίσματα."

meMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode5C1T.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
meMA.Ode5C1T.incipit = "Ὡραιώθης Παρθένε, τοῖς τῆς παρθενίας…"
meMA.Ode5C1T.text = "Ὡραιώθης Παρθένε, τοῖς τῆς παρθενίας σου ἀχράντοις κάλλεσι, καὶ τῆς πρώτης Εὔας, περιέστειλας αἶσχος τὸ δύσμορφον, τὸν Χριστὸν τεκοῦσα, περιβολὴν ἀθανασίας, χαριζόμενον τοῖς σὲ γεραίρουσιν."

meMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C11.greekmelody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.greekname
meMA.Ode6C11.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C11.incipit = "Τὴν λίμνην θαυματουργῶν, ἀδελφοκτόνον ἐξήρανας…"
meMA.Ode6C11.text = "Τὴν λίμνην θαυματουργῶν, ἀδελφοκτόνον ἐξήρανας, καὶ ποταμοῦ τὰς ὁρμάς, ἀνέστειλας Πάνσοφε, τὴν ῥάβδον πηξάμενος, τὴν καὶ παραχρῆμα, δενδρωθεῖσαν θείῳ νεύματι."

meMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C12.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C12.incipit = "Ὁ ζῆλος ὁ τοῦ Θεοῦ…"
meMA.Ode6C12.text = "Ὁ ζῆλος ὁ τοῦ Θεοῦ, κατέφαγέ σε Γρηγόριε· μὴ καρτερῶν γὰρ ὁρᾶν, Θεὸν ὑβριζόμενον, λαὸν ματαιόφρονα, ταῖς σαῖς ἱκεσίαις, θεοῤῥῆμον ἐξωλόθρευσας."

meMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C13.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C13.incipit = "Νενέκρωται βουληθείς, ἐξουθενεῖν σε ὁ…"
meMA.Ode6C13.text = "Νενέκρωται βουληθείς, ἐξουθενεῖν σε ὁ δείλαιος, Ἑβραῖος ὁ δυσσεβής, Θεοῦ σε δοξάζοντος, θεόφρον Γρηγόριε, τῶν αὐτοῦ δογμάτων, πληρωτὴν ἀναδεικνύμενον."

meMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6C1T.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
meMA.Ode6C1T.incipit = "Ἐπῆλθε τὸ παντουργόν, ἐπὶ σὲ…"
meMA.Ode6C1T.text = "Ἐπῆλθε τὸ παντουργόν, ἐπὶ σὲ Πνεῦμα Πανάμωμε, καὶ Λόγος ὁ τοῦ Θεοῦ, ἐν σοὶ κατεσκήνωσε, καὶ σάρξ ἐχρημάτισεν, ἀνεκδιηγήτως, διαμείνας ἀναλλοίωτος."

meMA.Ode6H.ode = miscellanea_gr_GR_cog.misc.Ode6
meMA.Ode6H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode6H.greekmelody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.greekname
meMA.Ode6H.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.melody
meMA.Ode6H.incipit = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.incipit
meMA.Ode6H.text = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.text

meMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Kontakion1.greekmelody = he.a.m2_gr_GR_cog.heAU.TaAnoZiton.greekname
meMA.Kontakion1.melody = he.a.m2_gr_GR_cog.heAU.TaAnoZiton.name
meMA.Kontakion1.incipit = "Θαυμάτων πολλῶν, δεξάμενος ἐνέργειαν, σημείοις…"
meMA.Kontakion1.text = "Θαυμάτων πολλῶν, δεξάμενος ἐνέργειαν, σημείοις φρικτοῖς, τοὺς δαίμονας ἐπτόησας, καὶ τὰς νόσους ἤλασας τῶν ἀνθρώπων, πάνσοφε Γρηγόριε· διὸ καλῇ Θαυματουργός, τὴν κλῆσιν ἐξ ἔργων κομισάμενος."

meMA.Oikos1.text = "Πόθεν ἀπάρξομαι τοὺς ἐπαίνους ἐξυφαίνειν ὁ τάλας, καθορῶν τὰ πολλὰ καὶ ὑπερθαύμαστα πράγματα; Ἐὰν ἀπὸ τοῦ βίου τοῦ Ὁσίου ἐγχειρήσω, τὸ σύνολον οὐκ ἰσχύω· πάντα γὰρ νοῦν ὑπερβαίνει ὁ ἔνθεος βίος αὐτοῦ. Ἐὰν ἀπὸ τῶν θαυμάτων, καὶ ἐν τούτῳ λοιπὸν αἰσχυνθήσομαι, ὑπὲρ τὴν ψάμμον γὰρ ὑπάρχουσι· διὰ τοῦτο ἀκούει θαυματουργός, τὴν κλῆσιν ἐξ ἔργων κομισάμενος."

meMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C11.greekmelody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.greekname
meMA.Ode7C11.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C11.incipit = "Πατέρων τὸ καύχημα, καὶ Διδασκάλων…"
meMA.Ode7C11.text = "Πατέρων τὸ καύχημα, καὶ Διδασκάλων τὸ σεμνολόγημα, φωστὴρ τῆς Ἐκκλησίας, τῆς εὐσεβείας στῦλος ἀκράδαντος, σὺ καθωράθης, κραυγάζων Γρηγόριε· Εὐλογητὸς ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C12.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C12.incipit = "Ἀστράψας τοῖς θαύμασι, τὴν οἰκουμένην…"
meMA.Ode7C12.text = "Ἀστράψας τοῖς θαύμασι, τὴν οἰκουμένην ἐφωταγώγησας· διὰ τοῦτο Θεόφρον, συναθροισθέντες σὲ μακαρίζομεν, οἱ τῶν σῶν λόγων, τρυφῶντες καὶ ψάλλοντες· Εὐλογητός ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C13.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C13.incipit = "Ἰάματα Πάνσοφε, τοῖς ἀσθενοῦσι πᾶσιν…"
meMA.Ode7C13.text = "Ἰάματα Πάνσοφε, τοῖς ἀσθενοῦσι πᾶσιν ἐπήγασας· ἐξεχύθη γὰρ χάρις, δαψιλεστάτη σοῦ ἐν τοῖς χείλεσι, θαυματουργίας, διʼ ἧς ἀνακράζομεν· Εὐλογητὸς ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode7C1T.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
meMA.Ode7C1T.incipit = "Νῦν πάντα πεπλήρωται, φωτὸς τοῦ…"
meMA.Ode7C1T.text = "Νῦν πάντα πεπλήρωται, φωτὸς τοῦ θείου, διὰ σοῦ Πάναγνε· σὺ γὰρ πύλη ἐφάνης, διʼ ἧς τῷ κόσμῳ Θεὸς ὡμίλησε, καταφωτίζων τοὺς πίστει κραυγάζοντας· Εὐλογητός ὁ Θεός, ὁ τῶν Πατέρων ἡμῶν."

meMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C11.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
meMA.Ode8C11.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C11.incipit = "Οἱ διὰ σοῦ πλουτήσαντες, τῆς…"
meMA.Ode8C11.text = "Οἱ διὰ σοῦ πλουτήσαντες, τῆς Τριάδος τὴν ἔλλαμψιν, τῆς ὁμοουσίου, καὶ σεπτῆς Γρηγόριε, τὴν σὴν νῦν πανήγυριν, ἐπιτελοῦντες χάριτι, θαυματουργικῇ, καταλαμφθῆναι αἰτοῦμεν, βοῶντες· Τὸν Δεσπότην, ἱερεῖς εὐλογεῖτε, λαὸς ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C12.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C12.incipit = "Νεοφανὲς ὡς ἔσοπτρον, δεδεγμένος πανόλβιε…"
meMA.Ode8C12.text = "Νεοφανὲς ὡς ἔσοπτρον, δεδεγμένος πανόλβιε, τὰς μαρμαρυγάς, τῆς ἀρχικῆς Θεότητος, τὸν κόσμον ἐφώτισας, ἀντανακλάσεις πέμπων φωτός, τοῖς μελῳδικῶς, ὀρθοδοξίᾳ βοῶσιν· Οἱ Παῖδες εὐλογεῖτε, ἱερεῖς ἀνυμνεῖτε, λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

meMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C13.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C13.incipit = "Ὑπὸ Θεοῦ σκεπόμενος, εὐσεβείας ὑπόθεσις…"
meMA.Ode8C13.text = "Ὑπὸ Θεοῦ σκεπόμενος, εὐσεβείας ὑπόθεσις, τοῖς θεοσεβέσιν, ἐφρουρήθης πάνσοφε, εἰς ὄρος ἱστάμενος, ὡς νομοθέτης ἄλλος Μωσῆς, τὸν Δημιουργόν, καὶ Λυτρωτήν ἐκδιδάσκων, Γρηγόριε κραυγάζεις· ἱερεῖς εὐλογεῖτε, λαὸς ὑπερυψοῦτε, εἰς πάντας τοὺς αἰῶνας."

meMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8C1T.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
meMA.Ode8C1T.incipit = "Φωτὸς ἀδύτου γέγονας, ἐνδιαίτημα Πάναγνε…"
meMA.Ode8C1T.text = "Φωτὸς ἀδύτου γέγονας, ἐνδιαίτημα Πάναγνε, ταῖς τῆς παρθενίας, καλλοναῖς ἀστράπτουσα, καὶ πάντας κατηύγασας, τοὺς Θεοτόκον σε ἀληθῆ, καθομολογοῦντας, ἐκ ψυχῆς καὶ βοῶντας· Οἱ Παῖδες εὐλογεῖτε, ἱερεῖς ἀνυμνεῖτε, λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

meMA.Ode8H.ode = miscellanea_gr_GR_cog.misc.Ode8
meMA.Ode8H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode8H.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
meMA.Ode8H.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.melody
meMA.Ode8H.incipit = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.incipit
meMA.Ode8H.text = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.text

meMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C11.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9C11.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C11.incipit = "Ἀρίστης πολιτείας λάμψας φωτί, νῦν…"
meMA.Ode9C11.text = "Ἀρίστης πολιτείας λάμψας φωτί, νῦν φωτὶ τῷ μεγάλῳ παρέστηκας, θεουργικαῖς, θαυματοποιΐαις ὡς νικητής, κατεστεμμένος Ὅσιε, Πάτερ, Ἱεράρχα θαυματουργέ, Γρηγόριε θεόφρον, φωστὴρ τῆς Ἐκκλησίας, τῶν Ὀρθοδόξων ἐγκαλλώπισμα."

meMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C12.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C12.incipit = "Ἰθύνεσθαι δυσώπει σαῖς προσευχαῖς, τὸ…"
meMA.Ode9C12.text = "Ἰθύνεσθαι δυσώπει σαῖς προσευχαῖς, τὸ βασίλειον νῦν ἱεράτευμα, τὸ ἐκλεκτόν, καὶ ἡγιασμένον θαυματουργέ, καὶ τοὺς πιστῶς τὴν μνήμην σου, νῦν ἐπιτελοῦντας ἐπιτυχεῖν, τῆς ἄνω βασιλείας, Γρηγόριε θεόφρον, ἀξιωθῆναι καθικέτευε."

meMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C13.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C13.incipit = "Νικήσας τῶν δαιμόνων τὰς προσβολάς…"
meMA.Ode9C13.text = "Νικήσας τῶν δαιμόνων τὰς προσβολάς, καὶ σαρκὸς ὑποτάξας τὸ φρόνημα, καὶ ἱερεύς, ἄκακος καὶ ὅσιος γεγονώς, δικαιοσύνης ἔνδυμα, περιβεβλημένος θαυματουργέ, παρίστασαι τῷ θρόνῳ, τοῦ πάντων Βασιλέως, νῦν παῤῥησίᾳ παμμακάριστε."

meMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9C1T.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
meMA.Ode9C1T.incipit = "Ὡράθης ὦ Παρθένε Μήτηρ Θεοῦ…"
meMA.Ode9C1T.text = "Ὡράθης ὦ Παρθένε Μήτηρ Θεοῦ, ὑπὲρ φύσιν τεκοῦσα ἐν σώματι, τὸν ἀγαθόν, Λόγον ἐκ καρδίας τῆς ἑαυτοῦ, ὃν ὁ Πατὴρ ἠρεύξατο, πάντων πρὸ αἰώνων ὡς ἀγαθός· ὃν νῦν καὶ τῶν σωμάτων, ἐπέκεινα νοοῦμεν, εἰ καὶ τὸ σῶμα περιβέβληται."

meMA.Ode9H.ode = miscellanea_gr_GR_cog.misc.Ode9
meMA.Ode9H.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.Ode9H.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
meMA.Ode9H.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.melody
meMA.Ode9H.incipit = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.incipit
meMA.Ode9H.text = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.text

meMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.Exaposteilarion1.greekmelody = he.a.m2_gr_GR_cog.heAU.TonMathitonOrontonSe.greekname
meMA.Exaposteilarion1.melody = he.a.m2_gr_GR_cog.heAU.TonMathitonOrontonSe.name
meMA.Exaposteilarion1.incipit = "Τὸν ἐν ποικίλοις θαύμασιν, Ἱεράρχην…"
meMA.Exaposteilarion1.text = "Τὸν ἐν ποικίλοις θαύμασιν, Ἱεράρχην, ἀναφανέντα δόκιμον ἐν τῷ κόσμῳ, θείαις εὐφημήσωμεν μελῳδίαις, Γρηγόριον φιλέορτοι, ὅπως ταῖς τούτου πρεσβείαις, λάβωμεν λύσιν πταισμάτων."

meMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
meMA.ExapTheotokion.melody = he.a.m2_gr_GR_cog.heAU.TonMathitonOrontonSe.name
meMA.ExapTheotokion.incipit = "Ὁ τῆς ζωῆς τῆς θείας…"
meMA.ExapTheotokion.text = "Ὁ τῆς ζωῆς τῆς θείας καὶ μακαρίας, φθονήσας μοι τῆς πάλαι ἐν Παραδείσῳ, ἐχθρὸς ὁ δολιώτατος καὶ πανοῦργος, καὶ τῆς Ἐδὲμ ἐξόριστον, ποιήσας με θανατοῦται, τῇ σῇ γεννήσει Παρθένε."

meMA.Lauds1.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Lauds1.greekmelody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.greekname
meMA.Lauds1.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meMA.Lauds1.incipit = "Χαίροις θεολογίαις σαφῶς, ἱερωτάταις ἱερῶς…"
meMA.Lauds1.text = "Χαίροις θεολογίαις σαφῶς, ἱερωτάταις ἱερῶς σεμνυνόμενος, ὁ στῦλος τῆς Ἐκκλησίας, ἡ τῶν δογμάτων κρηπίς, τὸ τοῦ Παρακλήτου θεῖον ὄργανον, ὁ νοῦς ὁ οὐράνιος, ἡ κιθάρα τοῦ Πνεύματος, ποιμὴν ὁ μέγας, καὶ Χριστοῦ Ἀρχιποίμενος, θρέμμα γνήσιον, καὶ ἀρνίον πραότατον· κρήνη ἀναβλυστάνουσα, δογμάτων τὰ νάματα, καὶ ἰαμάτων τὰ ῥεῖθρα, ἱερομύστα Γρηγόριε, Χριστὸν ἐκδυσώπει, ταῖς ψυχαῖς ἡμῶν δοθῆναι, τὸ μέγα ἔλεος."

meMA.Lauds2.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Lauds2.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meMA.Lauds2.incipit = "Χαίροις, Ἱεραρχῶν καλλονή, τῶν ἀρετῶν…"
meMA.Lauds2.text = "Χαίροις, Ἱεραρχῶν καλλονή, τῶν ἀρετῶν τὸ διαυγὲς καταγώγιον, ἡ στάθμη τῆς Ἐκκλησίας, ἱερωσύνης κανών· ποταμὸς ναμάτων θείων ἔμπλεως, ἐξ ὧν καταρδεύεται, ἡ ὑφήλιος ἅπασα, πρὸς εὐκαρπίαν, ψυχικὴν καὶ σωτήριον, καὶ αἱρέσεων, ἀποπλύνεται βόρβορος. Ἄνθρωπε ἐπουράνιε, ἐπίγειε Ἄγγελε, στόμα τὸν νόμον τὸν θεῖον, ἐμμελετῆσαν Γρηγόριε, Θεοῦ κληρονόμε, τοῦ παρέχοντος τῷ κόσμῳ, τὸ μέγα ἔλεος."

meMA.Lauds3.mode = miscellanea_gr_GR_cog.misc.Mode5
meMA.Lauds3.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
meMA.Lauds3.incipit = "Ὄμβροις σῶν ἱερῶν προσευχῶν, λίμνην…"
meMA.Lauds3.text = "Ὄμβροις σῶν ἱερῶν προσευχῶν, λίμνην ἐξήρανας ποτὲ μάχης πρόξενον· καὶ ῥεῖθρον τῇ δενδρωθείσῃ, ῥάβδῳ ἀτάκτως σοφέ, ἐπικλύζον εἵργεις θείᾳ χάριτι· βωμούς κατηδάφισας, τῶν δαιμονων Γρηγόριε, τῆς ἀπιστίας, τὸν χειμῶνα διέλυσας, θερμοτάταις σου, πρὸς Θεὸν παρακλήσεσι, θαύμασιν ἐβεβαίωσας, ψυχὰς καὶ προσήγαγες, τῷ εὐεργέτῃ τῶν ὅλων, παρʼ οὗ τὸν ἄξιον εἴληφας, μισθόν, ὃν δυσώπει, ταῖς ψυχαῖς ἡμῶν δοθῆναι, τὸ μέγα ἔλεος."

meMA.LaudsGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.LaudsGlory.melody = ""
meMA.LaudsGlory.incipit = "Τὸν περιβόητον ἐν θαύμασιν Ἱεράρχην…"
meMA.LaudsGlory.text = "Τὸν περιβόητον ἐν θαύμασιν Ἱεράρχην, καὶ τὰ ἄψυχα αἰδούμενα παραδόξως μετεβάλλετο· λίμνη γὰρ ἐχερσοῦτο, ἀδελφοὺς νουθετοῦσα, ῥάβδος δὲ ἐδενδροῦτο, ποταμόν χαλινοῦσα, λίθος λόγῳ μετετέθη, μεταφέρων τοὺς ἀπίστους πρὸς τὴν τοῦ Θεοῦ ἐπίγνωσιν, διʼ ἧς τὸ μέγα ἔλεος, παράσχου ὁ Θεὸς ταῖς ψυχαῖς ἡμῶν."

meMA.LaudsTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.LaudsTheotokion.melody = ""
meMA.LaudsTheotokion.incipit = oc.m8.d3_gr_GR_cog.ocVE.AposTheotokion.incipit
meMA.LaudsTheotokion.text = oc.m8.d3_gr_GR_cog.ocVE.AposTheotokion.text

meMA.LaudsStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
meMA.LaudsStavrotheotokion.melody = ""
meMA.LaudsStavrotheotokion.incipit = "Τὸν Ἐμμανουὴλ ἀμνὸν Θεοῦ καὶ…"
meMA.LaudsStavrotheotokion.text = "Τὸν Ἐμμανουὴλ ἀμνὸν Θεοῦ καὶ Λόγον, βλέπουσα σαρκὶ κρεμάμενον ἐν ξύλῳ, Ἀμνὰς ἡ μόνη ἀμίαντος καὶ Παρθένος, λύπῃ συνείχετο δακρύουσα."

meMA.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.AposGlory.melody = ""
meMA.AposGlory.incipit = "Ἱερωσύνης τὴν ψῆφον, θεόθεν δεξάμενος…"
meMA.AposGlory.text = "Ἱερωσύνης τὴν ψῆφον, θεόθεν δεξάμενος, καὶ τὸ θεῖον δέρας ἐξ ὕψους περιβαλόμενος, τοὺς πρὶν τῆς ἀπιστίας υἱούς, τέκνα φωτός, καὶ κληρονόμους ἀνέδειξας Θεοῦ, σοφίας χάριτος, ἐκχυθείσης ἐν χείλεσί σου, παραδόξων πραγμάτων αὐτουργέ, παμμάκαρ Γρηγόριε· διὸ καὶ νῦν ἐν τῇ μνήμῃ σου, αἴτησαι Χριστὸν τὸν Θεόν, ὑπὲρ τῶν ψυχῶν ἡμῶν."

meMA.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.AposTheotokion.melody = ""
meMA.AposTheotokion.incipit = oc.m4.d2_gr_GR_cog.ocMA.AposTheotokion.incipit
meMA.AposTheotokion.text = oc.m4.d2_gr_GR_cog.ocMA.AposTheotokion.text

meMA.AposStavrotheotokion.mode = miscellanea_gr_GR_cog.misc.Mode4
meMA.AposStavrotheotokion.greekmelody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.greekname
meMA.AposStavrotheotokion.melody = he.a.m4_gr_GR_cog.heAU.EdokasSimeiosin.name
meMA.AposStavrotheotokion.incipit = "Σταυρούμενον βλέπουσα, ἡ παναμώμητος Δέσποινα…"
meMA.AposStavrotheotokion.text = "Σταυρούμενον βλέπουσα, ἡ παναμώμητος Δέσποινα, τὸν Δεσπότην τῆς κτίσεως, θρηνοῦσα ἐκραύγαζεν· Οἴμοι θεῖον Τέκνον! πῶς φέρεις ὀδύνας, Θεὸς ὑπάρχων ἀπαθής; Ἀγγέλων τάξεις τρόμῳ ἐξέστησαν, ὁρῶσαι τὸ μυστήριον, τῆς σῆς ἀφάτου σταυρώσεως, Ἰησοῦ παντοδύναμε, ὁ Σωτὴρ τῶν ψυχῶν ἡμῶν."

meMA.MM.Lauds1123as5678.text = properties_gr_GR_cog.media.key

