meDA.date = "Τῌ ΙΖʹ ΝΟΕΜΒΡΙΟΥ"
meDA.commemoration.full = "Μνήμη τοῦ ἐν Ἁγίοις Πατρὸς ἡμῶν Γρηγορίου, Ἐπισκόπου Νεοκαισαρείας, τοῦ Θαυματουργοῦ" // full title of day
meDA.commemoration.first = "Μνήμη τοῦ Ἁγίου Γρηγορίου Νεοκαισαρείας"
meDA.commemoration.first_short = "Μνήμη τοῦ Ἁγίου Γρηγορίου Νεοκαισαρείας"
meDA.commemoration.first_title = titles_gr_GR_cog.ti.SaintM
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = ""
meDA.commemoration.second_name = ""
meDA.insert1 = "καὶ τοῦ ἐν ἁγίοις Πατρὸς ἡμῶν Γρηγορίου, Ἐπισκόπου Νεοκαισαρείας, τοῦ Θαυματουργοῦ," // for use in petitions and dismissal
meDA.insert2 = "οὗ καὶ τὴν μνήμην ἐπιτελοῦμεν·" // for use in petitions and dismissal
