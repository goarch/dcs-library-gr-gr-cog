hoD05.Apolytikion1.title = "Τοῦ ἁγίου ἐνδόξου Νεομάρτυρος Ἀργυρίου τοῦ Ἐπανομίτου."
hoD05.Apolytikion1.poet = ""
hoD05.Apolytikion1.mode = miscellanea_gr_GR_cog.misc.Mode3
hoD05.Apolytikion1.greekmelody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.greekname
hoD05.Apolytikion1.melody = he.a.m3_gr_GR_cog.heAU.TheiasPisteos.name
hoD05.Apolytikion1.incipit = "Χαίρει ἔχουσα, Ἐπανομή σε…"
hoD05.Apolytikion1.text = "Χαίρει ἔχουσα, Ἐπανομή σε, θεῖον βλάστημα, καὶ πολιοῦχον, Νεομάρτυς τοῦ Σωτῆρος Ἀργύριε, καὶ τὴν ἁγίαν σου ἄθλησιν μέλπουσα, τῇ σῇ πρεσβείᾳ προστρέχει κραυγάζουσα· Μάρτυς ἔνδοξε, Χριστὸν τὸν Θεὸν ἱκέτευε, δωρήσασθαι ἡμῖν τό μέγα ἔλεος."

