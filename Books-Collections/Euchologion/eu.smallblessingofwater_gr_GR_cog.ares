A_Resource_Whose_Name = eu.smallblessingofwater_gr_GR_cog

euSWB.Key0100.title = "Ἀκολουθία τοῦ Μικροῦ Ἁγιασμοῦ"

euSWB.R101 = "Τελουμένου Ἁγιασμοῦ εὐτρεπίζεται μικρὰ τράπεζα καὶ τίθεται ἐπʼ αὐτῆς τὸ ἱερὸν Εὐαγγέλιον, ξύλινος ἀργυρόδετος Σταυρός, θυμιατήριον (κατζίον), δοχεῖον μεθʼ ὕδατος καθαροῦ, δύο κηροπήγια, ἐν οἷς ἀνάπτονται κηρία καθαρά, μικρὰ δέσμη βασιλικοῦ ξηροῦ καὶ λευκὸν καθαρὸν μάκτρον. Συνηγμένων δὲ πάντων ἄρχεται ἡ Ἀκολουθία, τοῦ ἱερέως, ὡς καὶ ἐν πάσῃ ἱεροπραξίᾳ, φέροντος ἐπιτραχήλιον, τοῦ δὲ διακόνου στιχάριον σὺν ὀραρίῳ."
euSWB.R102 = "Τὸ Τροπάριον τοῦ Ναοῦ"

euSWB.R201 = "Εἶτα ψάλλομεν τὰ ἑπόμενα Τροπάρια τῆς Θεοτόκου κατʼ ἀλφάβητον μετὰ στίχου· «Ὑπεραγία Θεοτόκε, σῶσον ἡμάς»."

euSWB.Key0201.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0201.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.melody
euSWB.Key0201.incipit = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.incipit
euSWB.Key0201.text = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.text

euSWB.Key0202.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0202.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0202.incipit = "Ἀνυμνοῦμεν τὸν Υἱόν σου, Θεοτόκε…"
euSWB.Key0202.text = "Ἀνυμνοῦμεν τὸν Υἱόν σου, Θεοτόκε, καὶ βοῶμεν, πανάχραντε Δέσποινα, παντὸς κινδύνου ῥῦσαι τοὺς οἰκέτας σου."

euSWB.Key0203.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0203.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0203.incipit = "Βασιλέων, Προφητῶν καὶ Ἀποστόλων καὶ…"
euSWB.Key0203.text = "Βασιλέων, Προφητῶν καὶ Ἀποστόλων καὶ Μαρτύρων ὑπάρχεις τὸ καύχημα, καὶ προστασία τοῦ κόσμου, Πανάμωμε."

euSWB.Key0204.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0204.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0204.incipit = "Γλῶσσα πᾶσα εὐφημεῖ καὶ μακαρίζει…"
euSWB.Key0204.text = "Γλῶσσα πᾶσα εὐφημεῖ καὶ μακαρίζει, καὶ δοξάζει τὸν ἄχραντον τόκον σου, τῶν Ὀρθοδόξων Μαρία Θεόνυμφε."

euSWB.Key0205.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0205.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0205.incipit = "Δός, Χριστέ μου, καὶ ἐμοὶ…"
euSWB.Key0205.text = "Δός, Χριστέ μου, καὶ ἐμοὶ τῷ ἀναξίῳ ὀφλημάτων τὴν ἄφεσιν δέομαι, τῆς σὲ τεκούσης πρεσβείαις, ὡς εὔσπλαγχνος."

euSWB.Key0206.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0206.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0206.incipit = "Ἐπὶ σέ μου τὰς ἐλπίδας…"
euSWB.Key0206.text = "Ἐπὶ σέ μου τὰς ἐλπίδας ἀνέθεμην, Θεοτόκε· σῶσον ταῖς πρεσβείαις σου, καὶ δώρησαί μοι πταισμάτων τὴν ἄφεσιν."

euSWB.Key0207.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0207.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0207.incipit = "Ζώωσόν με, ἡ τεκοῦσα Ζωοδότην…"
euSWB.Key0207.text = "Ζώωσόν με, ἡ τεκοῦσα Ζωοδότην καὶ Σωτῆρα· σῶσον ταῖς πρεσβείαις σου, εὐλογημένη, ἐλπὶς τῶν ψυχῶν ἡμῶν."

euSWB.Key0208.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0208.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0208.incipit = "Ἡ τὸν Κτίστην τῶν ἁπάντων…"
euSWB.Key0208.text = "Ἡ τὸν Κτίστην τῶν ἁπάντων ἐν γαστρί σου συλλαβοῦσα, Παρθένε πανάμωμε, ταῖς σαῖς πρεσβείαις, σῶσον τὰς ψυχὰς ἡμῶν."

euSWB.Key0209.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0209.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0209.incipit = "Θεοτόκε, ἡ τεκοῦσα διὰ λόγου…"
euSWB.Key0209.text = "Θεοτόκε, ἡ τεκοῦσα διὰ λόγου, ὑπὲρ λόγον, τὸν Λόγον, Πανύμνητε, αὐτὸν δυσώπει, σῶσαι τὰς ψυχὰς ἡμῶν."

euSWB.Key0210.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0210.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0210.incipit = "Ἵλεών μοι τὸν Κριτήν τε…"
euSWB.Key0210.text = "Ἵλεών μοι τὸν Κριτήν τε καὶ Υἱόν σου, ἑπταικότι ὑπὲρ πάντα ἄνθρωπον, ταῖς σαῖς πρεσβείαις ἀπέργασαι, Δέσποινα."

euSWB.Key0211.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0211.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0211.incipit = "Κατὰ χρέος ἐκβοῶμέν σοι τό…"
euSWB.Key0211.text = "Κατὰ χρέος ἐκβοῶμέν σοι τό, Χαῖρε, Θεοτόκε, ἁγνὴ ἀειπάρθενε, ἐκδυσωποῦντες πρεσβείαις σου σῴζεσθαι."

euSWB.Key0212.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0212.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0212.incipit = "Λύτρωσαί με τοῦ πυρὸς τοῦ…"
euSWB.Key0212.text = "Λύτρωσαί με τοῦ πυρὸς τοῦ αἰωνίου, καὶ βασάνων τῶν ἀποκειμένων μοι, θεογεννῆτορ, ὅπως μακαρίζω σε."

euSWB.Key0213.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0213.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0213.incipit = "Μὴ παρίδῃς τὰς δεήσεις τῶν…"
euSWB.Key0213.text = "Μὴ παρίδῃς τὰς δεήσεις τῶν σῶν δούλων, δυσωποῦμεν, Πανύμνητε Δέσποινα, ἵνα ῥυσθῶμεν πάσης περιστάσεως."

euSWB.Key0214.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0214.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0214.incipit = "Νοσημάτων καὶ παντοίων ἀλγηδόνων, καὶ…"
euSWB.Key0214.text = "Νοσημάτων καὶ παντοίων ἀλγηδόνων, καὶ κινδύνων ἡμᾶς ἐλευθέρωσον, τῇ ἱερᾷ σου σκέπῃ καταφεύγοντας."

euSWB.Key0215.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0215.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0215.incipit = "Ξένον θαῦμα τὸ ἐν σοί…"
euSWB.Key0215.text = "Ξένον θαῦμα τὸ ἐν σοί, Θεοκυῆτορ· διʼ ἡμᾶς γὰρ καθʼ ἡμᾶς γεγέννηται ὁ πάντων Κτίστης ἐκ σοῦ καὶ Θεὸς ἡμῶν."

euSWB.Key0216.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0216.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0216.incipit = "Ὁ ναός σου, Θεοτόκε, ἀνεδείχθη…"
euSWB.Key0216.text = "Ὁ ναός σου, Θεοτόκε, ἀνεδείχθη ἰατρεῖον νοσημάτων ἄμισθον, καὶ θλιβομένων ψυχῶν παραμύθιον."

euSWB.Key0217.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0217.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0217.incipit = "Παναγία Θεοτόκε, ἡ τεκούσα τὸν…"
euSWB.Key0217.text = "Παναγία Θεοτόκε, ἡ τεκούσα τὸν Σωτῆρα, κινδύνων διάσωσον, καὶ πάσης ἄλλης ἀνάγκης τοὺς δούλους σου."

euSWB.Key0218.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0218.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0218.incipit = "Ῥῦσαι πάσης ἀπειλῆς ἐπερχομένης τοὺς…"
euSWB.Key0218.text = "Ῥῦσαι πάσης ἀπειλῆς ἐπερχομένης τοὺς σοὺς δούλους, Πανάχραντε Δέσποινα, καὶ πάσης βλάβης ψυχῆς τε καὶ σώματος."

euSWB.Key0219.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0219.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0219.incipit = "Σῶσον πάντας ταῖς πρεσβείαις σου…"
euSWB.Key0219.text = "Σῶσον πάντας ταῖς πρεσβείαις σου, Παρθένε, τοὺς εἰς σέ, Θεοτόκε, προστρέχοντας, καὶ ῥῦσαὶ πάσης ἀνάγκης καὶ θλίψεως."

euSWB.Key0220.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0220.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0220.incipit = "Τίς προστρέχων τῷ Ναῷ σου…"
euSWB.Key0220.text = "Τίς προστρέχων τῷ Ναῷ σου, Θεοτόκε, οὐ λαμβάνει ταχέως τὴν ἴασιν, ψυχῆς ὁμοῦ τε καὶ σώματος, Ἄχραντε;"

euSWB.Key0221.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0221.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0221.incipit = "Ὑπὸ πάντων δυσωπούμενος, Οἰκτίρμον, τῶν…"
euSWB.Key0221.text = "Ὑπὸ πάντων δυσωπούμενος, Οἰκτίρμον, τῶν Ἁγίων καὶ τῶν ἄνω Τάξεων, ἰλάσθητί μοι διὰ τῆς Τεκούσης σε."

euSWB.Key0222.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0222.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0222.incipit = "Φεῖσαι, Σῶτερ, τῶν ψυχῶν τῶν…"
euSWB.Key0222.text = "Φεῖσαι, Σῶτερ, τῶν ψυχῶν τῶν τεθνεώντων, ἐπʼ ἐλπίδι ζωῆς ἀδελφῶν ἡμῶν, καὶ ἄνες, ἄφες αὐτοῖς τὰ ἐγκλήματα."

euSWB.Key0223.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0223.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0223.incipit = "Χαῖρε κόσμου ἱλαστήριον, Παρθένε, χαῖρε…"
euSWB.Key0223.text = "Χαῖρε κόσμου ἱλαστήριον, Παρθένε, χαῖρε στάμνε καὶ λυχνία πάγχρυσε, τοῦ θείου μάννα καὶ φωτός, Θεόνυμφε."

euSWB.Key0224.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0224.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0224.incipit = "Ψάλλομέν σοι τῷ Θεῷ τῷ…"
euSWB.Key0224.text = "Ψάλλομέν σοι τῷ Θεῷ τῷ ἐν Τριάδι, ἐκβοῶντες φωνὴν τὴν τρισάγιον, ἐκδυσωποῦντες σωτηρίας τεύξασθαι."

euSWB.Key0225.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0225.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0225.incipit = "Ὦ Παρθένε, ἡ τεκοῦσα τὸν…"
euSWB.Key0225.text = "Ὦ Παρθένε, ἡ τεκοῦσα τὸν Σωτῆρα καὶ Δεσπότην τοῦ κόσμου καὶ Κύριον, αὐτὸν δυσώπει, σῶσαι τὰς ψυχὰς ἡμῶν."

euSWB.Key0226.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0226.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0226.incipit = "Χαῖρε ὄρος, χαῖρε βάτε, χαῖρε…"
euSWB.Key0226.text = "Χαῖρε ὄρος, χαῖρε βάτε, χαῖρε πύλη, χαῖρε κλῖμαξ, χαῖρε θεία τράπεζα, ἡ πάντων χαῖρε βοήθεια, Δέσποινα."

euSWB.Key0227.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0227.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0227.incipit = "Ταῖς πρεσβείαις, Ἐλεῆμον, τῆς Μητρός…"
euSWB.Key0227.text = "Ταῖς πρεσβείαις, Ἐλεῆμον, τῆς Μητρός σου τῆς Ἀχράντου, καὶ πάντων τῶν Ἁγίων σου, τὰ σὰ ἐλέη τῷ λαῷ σου δώρησαι."

euSWB.Key0228.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0228.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0228.incipit = "Τῇ δυνάμει τοῦ σταυροῦ σου…"
euSWB.Key0228.text = "Τῇ δυνάμει τοῦ σταυροῦ σου, Ζωοδότα, φώτισόν με τὸν δοῦλόν σου δέομαι, ἵνα ὑμνῶ σε διʼ αὐτοῦ σῳζόμενος."

euSWB.Key0229.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0229.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0229.incipit = "Τῇ πρεσβείᾳ τῶν ἐνδόξων Ἀρχαγγέλων…"
euSWB.Key0229.text = "Τῇ πρεσβείᾳ τῶν ἐνδόξων Ἀρχαγγέλων καὶ Ἀγγέλων, καὶ τῶν ἄνω Τάξεων, σοὺς δούλους, Σῶτερ, καλῶς διαφύλαξον."

euSWB.Key0230.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0230.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0230.incipit = "Τῇ πρεσβείᾳ τοῦ τιμίου καὶ…"
euSWB.Key0230.text = "Τῇ πρεσβείᾳ τοῦ τιμίου καὶ ἐνδόξου Βαπτιστοῦ σου Προφήτου Προδρόμου τε, Χριστέ μου Σῶτερ, τοὺς δούλους σου φύλαξον."

euSWB.Key0231.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0231.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0231.incipit = "Τῇ πρεσβείᾳ τῶν ἐνδόξων Ἀποστόλων…"
euSWB.Key0231.text = "Τῇ πρεσβείᾳ τῶν ἐνδόξων Ἀποστόλων, καὶ Μαρτύρων, καὶ πάντων τῶν Ἁγίων σου, τὰ σὰ ἐλέη τῷ λαῷ σου δώρησαι."

euSWB.Key0232.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0232.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0232.incipit = "Τῇ πρεσβείᾳ τῶν μεγάλων διδασκάλων…"
euSWB.Key0232.text = "Τῇ πρεσβείᾳ τῶν μεγάλων διδασκάλων, Βασιλείου σοφοῦ, Γρηγορίου τε καὶ Ἰωάννου, τοὺς δούλους σου φύλαττε."

euSWB.Key0233.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0233.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0233.incipit = "Τὴν ὀξεῖαν καὶ θερμήν σου…"
euSWB.Key0233.text = "Τὴν ὀξεῖαν καὶ θερμήν σου προστασίαν καὶ τὴν σκέπην, παμμάκαρ Νικόλαε, τοῖς ὑμνηταῖς σου πλουσίως κατάπεμψον."

euSWB.Key0234.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0234.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0234.incipit = "Τῇ πρεσβείᾳ τῶν ἐνδόξων ἀθλοφόρων…"
euSWB.Key0234.text = "Τῇ πρεσβείᾳ τῶν ἐνδόξων ἀθλοφόρων, Δημητρίου, Γεωργίου, Θεοδώρων τε, καὶ Ἀρτεμίου ἡμᾶς διαφύλαξον."

euSWB.Key0235.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0235.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0235.incipit = "Τῇ πρεσβείᾳ τῶν ἐνδόξων Ἀναργύρων…"
euSWB.Key0235.text = "Τῇ πρεσβείᾳ τῶν ἐνδόξων Ἀναργύρων, Θεοτόκε, τοὺς δούλους σου φύλαττε, ὡς προστασία τοῦ κόσμου καὶ στήριγμα."

euSWB.Key0236.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0236.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0236.incipit = "Ἀθλοφόρε τοῦ Χριστοῦ Παντελεῆμον, τοὺς…"
euSWB.Key0236.text = "Ἀθλοφόρε τοῦ Χριστοῦ Παντελεῆμον, τοὺς τῇ σκέπῃ τῇ σῇ καταφεύγοντας, ταῖς σαῖς πρεσβείαις νόσων ἐλευθέρωσον."

euSWB.Key0237.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0237.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0237.incipit = "Τῶν ἁγίων καὶ δικαίων προπατόρων…"
euSWB.Key0237.text = "Τῶν ἁγίων καὶ δικαίων προπατόρων, ταῖς πρεσβείαις, ἁπάντων δικαίων τε, καὶ τῶν ὁσίων, Χριστέ, ἡμᾶς φύλαττε."

euSWB.Key0238.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0238.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0238.incipit = "Τὸν Πατέρα καὶ Υἱόν δοξολογοῦμεν…"
euSWB.Key0238.text = "Τὸν Πατέρα καὶ Υἱόν δοξολογοῦμεν, καὶ τὸ Πνεῦμα τὸ Ἅγιον, λέγοντες· Τριὰς Ἁγία, σῶσον τὰς ψυχὰς ἡμῶν."

euSWB.Key0239.mode = miscellanea_gr_GR_cog.misc.Mode6
euSWB.Key0239.melody = he.h.m6_gr_GR_cog.heHE.IToChaireDiAngelou.name
euSWB.Key0239.incipit = "Ἡ ἀῤῥήτως ἐπʼ ἐσχάτων συλλαβοῦσα…"
euSWB.Key0239.text = "Ἡ ἀῤῥήτως ἐπʼ ἐσχάτων συλλαβοῦσα, καὶ τεκοῦσα τὸν Κτίστην τὸν ἴδιον, Παρθένε, σῷζε τοὺς σὲ μεγαλύνοντας."

euSWB.Key0240.incipit = oc.m6.d5_gr_GR_cog.ocMA.Kathisma13.incipit
euSWB.Key0240.text = oc.m6.d5_gr_GR_cog.ocMA.Kathisma13.text

euSWB.R301 = "Εἶτα τὰ παρόντα Τροπάρια"

euSWB.Key0301.mode = miscellanea_gr_GR_cog.misc.Mode8
euSWB.Key0301.incipit = "Νῦν ἐπέστη ὁ καιρός, ὁ…"
euSWB.Key0301.text = "Νῦν ἐπέστη ὁ καιρός, ὁ πάντας ἁγιάζων, καὶ ὁ δίκαιος ἡμᾶς ἀναμένει Κριτής· ἀλλʼ ἐπίστρεψον, ψυχή, πρὸς μετάνοιαν, ὡς ἡ Πόρνη κράζουσα σὺν δάκρυσι· Κύριε, ἐλέησόν με."

euSWB.Key0302.mode = miscellanea_gr_GR_cog.misc.Mode8
euSWB.Key0302.incipit = "Νάμασιν ἐπομβρήσας, Χριστέ, πηγὴν τῶν…"
euSWB.Key0302.text = "Νάμασιν ἐπομβρήσας, Χριστέ, πηγὴν τῶν ἰάσεων, ἐν τῷ πανσέπτῳ ναῷ τῆς Παρθένου σήμερον, τῷ τῆς σῆς εὐλογίας ῥαντισμῷ, φυγαδεύεις τὰς νόσους τῶν ἀσθενούντων, ἰατρὲ τῶν ψυχῶν καὶ τῶν σωμάτων ἡμῶν."

euSWB.Key0303.mode = miscellanea_gr_GR_cog.misc.Mode8
euSWB.Key0303.melody = he.h.m8_gr_GR_cog.heHE.OukEstinAgios.name
euSWB.Key0303.incipit = "Παρθένος ἔτεκες ἀπειρόγαμε, καὶ Παρθένος…"
euSWB.Key0303.text = "Παρθένος ἔτεκες ἀπειρόγαμε, καὶ Παρθένος ἔμεινας, Μήτηρ ἀνύμφευτε, Θεοτόκε, Μαρία· Χριστὸν τὸν Θεὸν ἡμῶν ἱκέτευε, σωθῆναι ἡμᾶς."

euSWB.Key0304.mode = miscellanea_gr_GR_cog.misc.Mode8
euSWB.Key0304.incipit = "Παναγία Θεοτόκε Παρθένε, τῶν χειρῶν…"
euSWB.Key0304.text = "Παναγία Θεοτόκε Παρθένε, τῶν χειρῶν ἡμῶν τὰ ἔργα κατεύθυνον, καὶ συγχώρησιν τῶν πταισμάτων ἡμῶν αἴτησαι, ἐν τῷ ψάλλειν ἡμᾶς τῶν Ἀγγέλων τὸν ὕμνον."

euSWB.R401 = "Ὁ Ἱερεὺς λέγει τὴν Εὐχὴν ταύτην·"
euSWB.Key0401a.text = "Κύριε ὁ Θεὸς ἡμῶν, ὁ μέγας τῇ βουλῇ καὶ θαυμαστὸς τοῖς ἔργοις, ὁ πάσης ὁρατῆς τε καὶ ἀοράτου κτίσεως δημιουργός· ὁ φυλάσσων τὴν διαθήκην σου καὶ τὸ ἔλεός σου τοῖς ἀγαπῶσί σε καὶ τηροῦσι τὰ σὰ προστάγματα· ὁ πάντων τῶν ἐν ἀνάγκαις ἐλεεινὰ προσδεχόμενος δάκρυα· διὰ γὰρ τοῦτο παραγέγονας ἐν δούλου μορφῇ, οὐ φάσμασιν ἡμᾶς ἐκδειματούμενος, ἀλλʼ ὑγίειαν τῷ σώματι ἀληθῆ ὀρέγων καὶ λέγων· ἴδε ὑγιὴς γέγονας, μηκέτι ἁμάρτανε. Ἀλλὰ καὶ ἐκ πηλοῦ ζῶντας ὀφθαλμοὺς εἰργάσω καὶ νίψασθαι κελεύσας, τὸ φῶς οἰκῆσαι παρεσκεύασας λόγῳ· ὁ τὰς τῶν ἐναντίων παθῶν σπιλάδας ταράττων, καὶ τὴν τοῦ βίου τούτου ἁλμυρὰν θάλασσαν καταστείλας, καὶ τὰ ἀχθηφόρα τῶν ἡδονῶν κατευνάσας κύματα· Αὐτὸς οὖν, φιλάνθρωπε Βασιλεῦ, ὁ δοὺς ἡμῖν χιονοφεγγόφωτον φορέσαι στολὴν ἐξ ὕδατός τε καὶ πνεύματος, καὶ διὰ τῆς τοῦ ὕδατος τούτου μεταλήψεώς τε καὶ ῥαντισμοῦ τὴν σὴν εὐλογίαν ἡμῖν κατάπεμψον, τὸν ῥύπον τῶν παθῶν ἀποσμήχουσαν."
euSWB.Key0401b.text = "Ναί, Δέσποτα, δεόμεθα· ἐπίσκεψαι ἡμῶν, Ἀγαθέ, τὴν ἀσθένειαν καὶ ἴασαι ἡμῶν τὰς νόσους ψυχῆς τε καὶ σώματος, τῷ ἐλέει σου·"
euSWB.Key0402.text = "(τοῦ ἁγίου τῆς ἡμέρας), οὗ καὶ τὴν μνήμην ἐπιτελοῦμεν· καὶ πάντων σου τῶν Ἁγίων."
euSWB.Key0403.text = "Καὶ φύλαττε, Κύριε, τοὺς δούλους σου τοὺς πιστοὺς βασιλεῖς ἡμῶν, χάρισαι αὐτοῖς ψυχῆς καὶ σώματος τὴν ὑγίειαν, καὶ τῇ δουλικῇ σου τοῦτο τῶν χριστιανῶν πολιτείᾳ ποίησον κατὰ πάντα ἐπιεικεῖς."
euSWB.Key0404.text = "Μνήσθητι, Κύριε, πάσης ἐπισκοπῆς ὀρθοδόξων, τῶν ὀρθοτομούντων τὸν λόγον τῆς σῆς ἀληθείας, καὶ παντὸς ἱερατικοῦ τάγματος καὶ τῆς σωτηρίας αὐτῶν. Μνήσθητι, Κύριε, τῶν μισούντων καὶ ἀγαπώντων ἡμᾶς, τῶν διακονούντων ἀδελφῶν ἡμῶν, τῶν περιεστώτων καὶ τῶν διʼ εὐλόγους αἰτίας ἀπολειφθέντων καὶ τῶν ἐντειλαμένων ἡμῖν τοῖς ἀναξίοις εὔχεσθαι ὑπὲρ αὐτῶν. Μνήσθητι, Κύριε, καὶ τῶν ἐν αἰχμαλωσίᾳ καὶ θλίψεσιν ἀδελφῶν ἡμῶν, καὶ ἐλέησον αὐτοὺς καὶ ἡμᾶς κατὰ τὸ μέγα σου ἔλεος, πάσης ἀνάγκης ῥυόμενος."
euSWB.Key0405.text = "Ὅτι σὺ εἶ ἡ πηγὴ τῶν ἰαμάτων, Χριστὲ ὁ Θεὸς ἡμῶν, καὶ σοὶ τὴν δόξαν ἀναπέμπομεν, σὺν τῷ ἀνάρχῳ σου Πατρί, καὶ τῷ παναγίῳ καὶ ἀγαθῷ καὶ ζωοποιῷ σου Πνεύματι, νῦν καὶ ἀεὶ καὶ εἰς τοὺς αἰῶνας τῶν αἰώνων."

euSWB.R501 = "Εὐχὴ ἑτέρα λεγομένη ἀντὶ τῆς συνήθους μεγάλης, χάριν συντομίας."
euSWB.Key0501.incipit = "Θεὲ μεγαλώνυμε, ὁ ποιῶν θαυμάσια…"
euSWB.Key0501.text = "Θεὲ μεγαλώνυμε, ὁ ποιῶν θαυμάσια ὧν οὐκ ἔστιν ἀριθμός, ἐλθὲ τανῦν καὶ πρὸς τοὺς ἐπικαλουμένους σε δούλους σου. Ἐξαπόστειλον τὸ Πνεῦμά σου τὸ ἅγιον καὶ ἁγίασον τὸ ὕδωρ τοῦτο (ἐκ γʹ). Καὶ δὸς τοῖς μεταλαμβάνουσι καὶ ῥαντιζομένοις ἐξ αὐτοῦ ἀπαλλαγὴν παντὸς κακοῦ, στερέωσιν καὶ καθαρισμὸν οἴκων καὶ ἀπέλασιν πάσης διαβολικῆς ἐνεργείας."
euSWB.Key0501a.text = "Θεὲ μεγαλώνυμε, ὁ ποιῶν θαυμάσια ὧν οὐκ ἔστιν ἀριθμός, ἐλθὲ τανῦν καὶ πρὸς τοὺς ἐπικαλουμένους σε δούλους σου."
euSWB.Key0501b.text = "Ἐξαπόστειλον τὸ Πνεῦμά σου τὸ ἅγιον καὶ ἁγίασον τὸ ὕδωρ τοῦτο."
euSWB.Key0501c.text = "Καὶ δὸς τοῖς μεταλαμβάνουσι καὶ ῥαντιζομένοις ἐξ αὐτοῦ ἀπαλλαγὴν παντὸς κακοῦ, στερέωσιν καὶ καθαρισμὸν οἴκων καὶ ἀπέλασιν πάσης διαβολικῆς ἐνεργείας."

euSWB.Key0502.title = "Εὐχὴ ἑτέρα."
euSWB.Key0502.incipit = "Κύριε ὁ Θεὸς ἡμῶν, ὁ τὸ πικρὸν ὕδωρ…"
euSWB.Key0502.text = "Κύριε ὁ Θεὸς ἡμῶν, ὁ τὸ πικρὸν ὕδωρ ἐπὶ Μωϋσέως τῷ λαῷ εἰς γλυκὺ μεταποιήσας, καὶ τὰ βλαβερὰ ὕδατα ἐπὶ Ἐλισσαίου ἅλατι θεραπεύσας, καὶ τὰ Ἰορδάνεια ῥεῖθρα ἁγιάσας τῇ ἀχράντῳ σου ἐπιφανείᾳ, αὐτὸς καὶ νῦν, Δέσποτα, ἁγίασον τὸ ὕδωρ τοῦτο τῇ ἐνεργείᾳ καὶ ἐπιφοιτήσει τοῦ ἁγίου σου Πνέυματος, καὶ ποίησον αὐτὸ γενέσθαι πᾶσι τοῖς ἀρυομένοις καὶ μεταλαμβάνουσιν ἐξ αὐτοῦ εὐλογίας πηγήν, ἰατρεῖον παθῶν, ἁγιασμὸν οἴκων, πάσης ἐπιβουλῆς ὁρατῆς τε καὶ ἀοράτου ἀλεξητήριον."

euSWB.Key0503.title = "Εὐχὴ Ἁγιασμοῦ."
euSWB.Key0503.inicpit = "Κτίστα τῶν ὑδάτων…"
euSWB.Key0503a.text = "Κτίστα τῶν ὑδάτων, δημιουργὲ τῶν ἁπάντων, Κύριε ὁ Θεὸς ὁ παντοκράτωρ, ὁ πάντα ποιῶν καὶ μετασκευάζων, μεταποίησον καὶ μετασκεύασον καὶ ἁγίασον τὸ ὕδωρ τοῦτο τῇ δυνάμει καὶ ἐνεργείᾳ καὶ ἐπιφοιτήσει τοῦ ἁγίου σου Πνεύματος,"
euSWB.Key0503b.text = "(τούτου λεγομένου εὐλογεῖ διὰ τῆς χειρὸς τὸ ὕδωρ σταυροειδῶς)"
euSWB.Key0503c.text = "καὶ ἐνίσχυσον αὐτὸ κατὰ πάσης ἀντικειμένης ἐνεργείας. Ποίησον αὐτὸ γενέσθαι πᾶσι τοῖς ἀρυομένοις καὶ μεταλαμβάνουσιν ἐξ αὐτοῦ εὐλογίας πηγήν, ἰατρείαν παθῶν, πάσης ἐπιβουλῆς ὁρατῆς καὶ ἀοράτου ἀλεξητήριον. Τὸν δὲ διὰ τοῦ ῥαντισμοῦ αὐτοῦ ἐγκαινιζόμενον οἶκον τοῦτον εὐλόγησον καὶ ἁγίασον, συντηρῶν αὐτὸν διὰ παντὸς ἀσάλευτον."
euSWB.Key0504.text = "Ὅτι σὺ εἶ ὁ φωτισμός, σωτὴρ καὶ φύλαξ τῶν ψυχῶν καὶ τῶν σωμάτων ἡμῶν καὶ σοὶ τὴν δόξαν ἀναπέμπομεν, τῷ Πατρὶ καὶ τῷ Υἱῷ καὶ τῷ ἁγίῳ Πνεύματι, νῦν καὶ ἀεὶ καὶ εἰς τοὺς αἰῶνας τῶν αἰώνων."

euSWB.R601 = "Ὁ Ἱερεύς, κλινόμενος, λέγει μυστικῶς τὴν Εὐχὴν ταύτην·"
euSWB.Key0601.text = eu.greatblessingofwater_gr_GR_cog.euGW.Prayer41.text

euSWB.R602 = "Εἶτα, λαβὼν τὸν τίμιον Σταυρόν, εὐλογεῖ τὰ ὕδατα ἐκ τρίτου, κατάγων καὶ ἀνάγων αὐτὸν ὄρθιον, καὶ ψάλλων·"

euSWB.R603 = "Εἶτα, ῥαντίζων σταυροειδῶς, ψάλλει τὸ παρὸν Τροπάριον."

euSWB.Key0602.mode = miscellanea_gr_GR_cog.misc.Mode2
euSWB.Key0602.incipit = "Τῶν σῶν δωρεῶν, ἀξίους ἡμᾶς…"
euSWB.Key0602.text = "Τῶν σῶν δωρεῶν, ἀξίους ἡμᾶς ποίησον, Θεοτόκε Παρθένε, παρορῶσα τὰ πλημμελήματα ἡμῶν, καὶ παρέχουσα ἰάματα, τοῖς ἐν πίστει λαμβάνουσι τὴν εὐλογίαν σου, Ἄχραντε."

euSWB.R604 = "Εἶτα ἀσπάζεται ὁ Ἱερεὺς τὸν τίμιον Σταυρὸν ὠσαύτως καὶ πᾶς ὁ λαός. Εἶθʼ οὕτω ῥαντίζει πάντα τὸν λαόν, τὸν ναὸν (ἢ τὸν οἶκον) διὰ τοῦ ἁγιάσματος."

euSWB.R605 = "Ο Ἱερεὺς [ἢ ὁ Χορὸς] ψάλλει τὸ παρὸν Τροπάριον, ὅπερ καὶ πολλάκις λέγεται, μέχρι τῆς ἀποῤῥαντίσεως δηλονότι."
