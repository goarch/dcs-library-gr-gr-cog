euFUN.Key2300.title = "ΕΠΙ ΤΟΥ ΤΑΦΟΥ"
euFUN.Key2301.text = "Ἀναγινώσκεται τὸ Νεκρώσιμον Τρισάγιον, ὡς ἐν τῷ οἶκῳ."

euFUN.Key3000.title = "ΑΚΟΛΟΥΘΙΑ ΝΕΚΡΩΣΙΜΟΣ ΕΙΣ ΝΗΠΙΑ ΚΑΤΑ ΤΗΝ ΔΙΑΚΑΙΝΗΣΙΜΟΝ ΕΒΔΟΜΑΔΑ"
euFUN.Key3001.text = "Αὕτη εἶναι ὁμοία…"
