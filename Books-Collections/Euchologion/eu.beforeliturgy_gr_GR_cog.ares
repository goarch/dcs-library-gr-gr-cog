euBL.R302.rubric = "Ἐνδυομένου τοῦ Ἀρχιερέως ἐκτὸς τοῦ Βήματος,…"
euBL.Key0301.text = "Ἄνωθεν οἱ Προφῆται σὲ προκατήγγειλαν· στάμνον, ράβδον, πλάκα, κιβωτόν, λυχνίαν, ὄρος ἀλατόμητον, χρυσοῦν θυμιατήριον καὶ σκηνήν, πύλην ἀδιόδευτον, παλάτιον καὶ κλίμακα, καὶ θρόνον τοῦ Βασιλέως." //vesting hymn
