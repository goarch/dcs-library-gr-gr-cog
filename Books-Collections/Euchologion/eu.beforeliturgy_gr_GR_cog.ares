euLBL.title = "Διάταξις τῆς Θείας καὶ Ἱερᾶς Λειτουργίας"

euBL.Key0100.title = "Καιρός"
euBL.R101.rubric = "Μέλλων ὁ Ἱερεὺς…"
euBL.R102.rubric = "Τοῦ δὲ καιροῦ…"
euBL.R103.rubric = "Εἶτα λέγει ο Δίακονος χαμηλῇ τῇ φωνῇ·"
euBL.R104.rubric = "Εἶτα λέγουσι…"
euBL.R105.rubric = "(Τούτου δὲ λεγομένου…)"
euBL.R106.rubric = "καὶ ποιοῦσι σταυροὺς…"
euBL.R107.rubric = "Εὐθὺς δὲ…"
euBL.R108.rubric = "Καὶ τὴ εἰκόνα."
euBL.R109.rubric = "Τὴν δὲ του Προδρόμου…"
euBL.R110.rubric = "Ἢ τὸ Κοντάκιον·"
euBL.R111.rubric = "Εῖτα,…"
euBL.R112.rubric = "Ἐὰν δὲ τύχῃ…"
euBL.R113.rubric = "Μετὰ δὲ τὸν ἀσαπασμὸν…"
euBL.R114.rubric = "Καὶ λέγει…"
euBL.R115.rubric = "Καὶ ὁ Ἱερεὺς…"
euBL.R116.rubric = "Ὁ Ἱερεὺς ποιεῖ…"
euBL.R117.rubric = "Ἰστέον, ὅτι…"
euBL.Key0100h.text = "Τὸν Δεσπότην καὶ Ἀρχιερέα ἡμῶν, Κύριε, φύλαττε. Εἰς πολλὰ ἔτη, Δέσποτα."
