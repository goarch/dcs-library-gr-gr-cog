octrMA.Ode7Martyricon.mode = miscellanea_gr_GR_cog.misc.Mode8
octrMA.Ode7Martyricon.melody = ""
octrMA.Ode7Martyricon.incipit = "Τῆς στενῆς καὶ τεθλιμμένης ὁδοῦ…"
octrMA.Ode7Martyricon.text = "Τῆς στενῆς καὶ τεθλιμμένης ὁδοῦ, ἀκλινεῖς ὁδοιπόροι γεγόνατε, ἅγιοι Μάρτυρες· τῶν γὰρ πειρασμῶν τὴν τρικυμίαν ὑπεμείνατε, καὶ τῶν ἀσωμάτων Λειτουργῶν τὴν πολιτείαν ἀνελάβετε, πέτρα ὑπομονῆς, καὶ θεμέλιοι εὐσεβείας ἀνεδείχθητε, πρεσβεύσατε Χριστῷ τῷ Θεῷ, ὑπὲρ τῶν ψυχῶν ἡμῶν."

