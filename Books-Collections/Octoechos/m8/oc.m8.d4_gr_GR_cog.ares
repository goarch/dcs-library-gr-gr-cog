A_Resource_Whose_Name = oc.m8.d4_gr_GR_cog

ocBK.ModeNaked = miscellanea_gr_GR_cog.misc.Mode8.naked

ocVE.Stichera1.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.Stichera1.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
ocVE.Stichera1.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
ocVE.Stichera1.incipit = "Λόγε Θεοῦ ὑπεράγαθε, ὁ δι’…"
ocVE.Stichera1.text = "Λόγε Θεοῦ ὑπεράγαθε, ὁ διʼ ἡμᾶς ἐν Σταυρῷ, κρεμασθεὶς ὡς κατάκριτος, τοῦ πυρὸς τοῦ μέλλοντος, καὶ φρικτῆς ἀποφάσεως, καὶ ποινῆς πάσης ἡμᾶς ἐξάρπασον, ἐκδυσωπούσης τῆς Θεομήτορος· σὲ γὰρ φιλάνθρωπε, καθʼ ἑκάστην ἅπαντες, ἐν λογισμοῖς, Χριστὲ παροργίζομεν, τὸν ὑπεράγαθον."

ocVE.Stichera2.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.Stichera2.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
ocVE.Stichera2.incipit = "Ἥλιος ἰδών σε ἔφριξεν, ἐπὶ…"
ocVE.Stichera2.text = "Ἥλιος ἰδών σε ἔφριξεν, ἐπὶ Σταυροῦ Ἰησοῦ, ἡπλωμένον θελήματι, καὶ ἡ γῆ ἐσείετο, καὶ αἱ πέτραι ἐῤῥήγνυντο, καὶ τὰ μνημεῖα φόβῳ ἠνοίγοντο, καὶ αἱ Δυνάμεις πᾶσαι ἐξίσταντο· σὲ ὡς ἑώρακεν, ἡ Παρθένος Δέσποτα, ἐν τῷ Σταυρῷ, Οἴμοι! ἀνεκραύγαζε, τί τὸ ὁρώμενον;"

ocVE.Stichera3.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.Stichera3.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
ocVE.Stichera3.incipit = "Ὢ τῆς ἀπείρου χρηστότητος, τοῦ…"
ocVE.Stichera3.text = "Ὢ τῆς ἀπείρου χρηστότητος, τοῦ σαρκωθέντος ἐκ σοῦ, Θεοτόκε πανύμνητε! Σταυρὸν γὰρ καὶ θάνατον, ἑκουσίως ὑπέμεινεν, ἵνα τὸν κόσμον, σώσῃ ὃν ἔπλασεν, ὃν ἐκδυσώπει, κᾀμὲ τὸν ἄθλιον, καὶ πολυώδυνον, ῥύσασθαι κολάσεως, ἔνθα τὸ φῶς, λάμπει τὸ ἀνέσπερον, κατασκηνῶσαί με."

ocVE.Stichera4.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.Stichera4.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
ocVE.Stichera4.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
ocVE.Stichera4.incipit = "Χαῖρε Παρθένε Θεόνυμφε…"
ocVE.Stichera4.text = "Χαῖρε Παρθένε Θεόνυμφε· χαῖρε πιστῶν ἡ ἐλπίς· χαῖρε κόσμου καθάρσιον· χαῖρε πάσης θλίψεως, ἡ τοὺς δούλους σου σῴζουσα· ἡ τοῦ θανάτου, χαῖρε κατάλυσις· ὁ ζωηφόρος χαῖρε Παράδεισος· χαῖρε ἀντίληψις, τῶν προσκαλουμένων σε· χαῖρε Θεοῦ, θεῖον ἐνδιαίτημα, καὶ ὄρος ἅγιον."

ocVE.Stichera5.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.Stichera5.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
ocVE.Stichera5.incipit = "Χαῖρε Θεοτόκε Πάναγνε, χαῖρε πηγὴ…"
ocVE.Stichera5.text = "Χαῖρε Θεοτόκε Πάναγνε, χαῖρε πηγὴ τῆς ζωῆς, χαῖρε κλῖμαξ οὐράνιε, χαῖρε πάσης Δέσποινα, καὶ Κυρία τῆς Κτίσεως. Εὐλογημένη, χαῖρε Πανάμωμε, δεδοξασμένη, χαῖρε ἀμόλυντε, χαῖρε πανύμνητε, χαῖρε θεῖον σκήνωμα, χαῖρε σεμνή, χαῖρε Μητροπάρθενε, Νύμφη ἀνύμφευτε."

ocVE.Stichera6.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.Stichera6.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
ocVE.Stichera6.incipit = "Χαῖρε Μητρόθεε Δέσποινα, χαῖρε ἡ…"
ocVE.Stichera6.text = "Χαῖρε Μητρόθεε Δέσποινα, χαῖρε ἡ μόνη ἐλπίς, τῶν βροτῶν καὶ ἀντίληψις, χαῖρε καταφύγιον, χαῖρε λυχνία φωτός, ἠγλαϊσμένον, χαῖρε παλάτιον, τὸ φωτοφόρον, χαῖρε λαμπάδιον, χαῖρε ἀμόλυντον, παρθενίας καύχημα, χαῖρε πηγή, βρύουσα, ἰάματα, τοῖς προσιοῦσί σοι."

ocVE.SticTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.SticTheotokion.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
ocVE.SticTheotokion.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
ocVE.SticTheotokion.incipit = "Ὢ τοῦ παραδόξου θαύματος! ὢ…"
ocVE.SticTheotokion.text = "Ὢ τοῦ παραδόξου θαύματος! ὢ μυστηρίου καινοῦ! ὢ φρικτῆς ἐγχειρήσεως! ἡ Παρθένος ἔλεγεν, ἐν Σταυρῷ σε ὡς ἔβλεψεν, ἐν μέσῳ δύο λῃστῶν κρεμάμενον, ὃν ἀνωδίνως, φρικτῶς ἐκύησεν, ἔκλαιε κράζουσα· Οἴμοι Τέκνον φίλτατον! πῶς σε δεινός, δῆμος καὶ ἀχάριστος, Σταυρῷ προσήλωσεν."

ocVE.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.Aposticha1.melody = ""
ocVE.Aposticha1.incipit = "Ὑψώθης ἐν Σταυρῷ Χριστὲ ὁ…"
ocVE.Aposticha1.text = "Ὑψώθης ἐν Σταυρῷ Χριστὲ ὁ Θεός, καὶ ἔσωσας τῶν ἀνθρώπων τὸ γένος, δοξάζομέν σου τὰ παθήματα."

ocVE.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.Aposticha2.melody = ""
ocVE.Aposticha2.incipit = "Ἐπάγης ἐν τῷ Σταυρῷ Χριστὲ…"
ocVE.Aposticha2.text = "Ἐπάγης ἐν τῷ Σταυρῷ Χριστὲ ὁ Θεός, καὶ ἤνοιξας παραδείσου τὰς πύλας, δοξάζομέν σε Λυτρωτὰ ἡμῶν."

ocVE.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.Aposticha3.greekmelody = he.a.m8_gr_GR_cog.heAU.OiMartyresSouKyrie.greekname
ocVE.Aposticha3.melody = he.a.m8_gr_GR_cog.heAU.OiMartyresSouKyrie.melody
ocVE.Aposticha3.incipit = he.a.m8_gr_GR_cog.heAU.OiMartyresSouKyrie.incipit
ocVE.Aposticha3.text = he.a.m8_gr_GR_cog.heAU.OiMartyresSouKyrie.text

ocVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.AposTheotokion.greekmelody = he.a.m8_gr_GR_cog.heAU.OiMartyresSouKyrie.greekname
ocVE.AposTheotokion.melody = he.a.m8_gr_GR_cog.heAU.OiMartyresSouKyrie.name
ocVE.AposTheotokion.incipit = "Σταυρῷ σε καθηλούμενον, ὡς ἐθεάσατο…"
ocVE.AposTheotokion.text = "Σταυρῷ σε καθηλούμενον, ὡς ἐθεάσατο ἡ σὲ τεκοῦσα, μόνε Μακρόθυμε, ὀδυρομένη δάκρυα ἔῤῥει κρουνηδόν, καὶ τὸ ὑπερβάλλον τῆς χρηστότητος, καὶ τὸ συμπαθὲς τὸ ὑπὲρ ἄνθρωπον, λίαν ἐκπληττομένη, ὕμνει τὸ μακρόθυμον πολυεύσπλαγχνε." //τὸ κράτος σου.

ocVE.ApolTheotokionVM.mode = miscellanea_gr_GR_cog.misc.Mode8
ocVE.ApolTheotokionVM.melody = ""
ocVE.ApolTheotokionVM.incipit = "Τὸν ἀμνὸν καὶ ποιμένα καὶ…"
ocVE.ApolTheotokionVM.text = "Τὸν ἀμνὸν καὶ ποιμένα καὶ Σωτῆρα τοῦ κόσμου, ἐν τῷ Σταυρῷ θεωροῦσα, ἡ τεκοῦσα ἔλεγε δακρύουσα· ὁ μὲν κόσμος ἀγάλλεται, δεχόμενος τὴν λύτρωσιν, τὰ δὲ σπλάγχνα μου φλέγονται, ὁρώσης σου τὴν σταύρωσιν, ἣν ὑπὲρ πάντων ὑπομένεις, ὁ Υἱὸς καὶ Θεός μου."

ocMA.Kathisma11.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Kathisma11.melody = ""
ocMA.Kathisma11.incipit = "Βλέπων ὁ λῃστὴς…"
ocMA.Kathisma11.text = "Βλέπων ὁ λῃστὴς τὸν ἀρχηγὸν τῆς ζωῆς, ἐπὶ Σταυροῦ κρεμάμενον ἔλεγεν· Εἰ μὴ Θεὸς ὑπῆρχε σαρκωθείς, ὁ σὺν ἡμῖν σταυρωθείς, οὐκ ἂν ὁ ἥλιος τὰς ἀκτῖνας ἐναπέκρυψεν, οὐδὲ ἡ γῆ σειομένη ἐκυμαίνετο. Ἀλλʼ ὁ πάντων ἀνεχόμενος, μνήσθητί μου Κύριε, ἐν τῇ Βασιλείᾳ σου."

ocMA.Kathisma12.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Kathisma12.melody = ""
ocMA.Kathisma12.incipit = "Ἐν μέσῳ δύο λῃστῶν…"
ocMA.Kathisma12.text = "Ἐν μέσῳ δύο λῃστῶν, ζυγὸς δικαιοσύνης εὑρέθη ὁ Σταυρός σου· τοῦ μὲν καταγομένου εἰς ᾅδην, τῷ βάρει τῆς βλασφημίας, τοῦ δὲ κουφιζομένου πταισμάτων, πρός γνῶσιν θεολογίας. Χριστὲ ὁ Θεός, δόξα σοι."

ocMA.Kathisma13.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Kathisma13.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
ocMA.Kathisma13.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
ocMA.Kathisma13.incipit = "Τὸν Ἀμνὸν καὶ Ποιμένα…"
ocMA.Kathisma13.text = "Τὸν Ἀμνὸν καὶ Ποιμένα, καὶ Λυτρωτήν, ἡ Ἀμνὰς θεωροῦσα, ἐν τῷ Σταυρῷ, ὠλόλυζε δακρύουσα, καὶ πικρῶς ἀνεκραύγαζεν· Ὁ μὲν κόσμος ἀγάλλεται, δεχόμενος τὴν λύτρωσιν, τὰ δὲ σπλάγχνα μου φλέγονται, ὁρώσης σου τὴν σταύρωσιν, ἥν περ ὑπομένεις, διὰ σπλάγχνα ἐλέους, Θεὲ ὑπεράγαθε, ἀνεξίκακε Κύριε· ᾗ πιστῶς ἐκβοήσωμεν· Σπλαγχνίσθητι Παρθένε ἐφʼ ἡμᾶς, καὶ πταισμάτων δώρησαι τὴν ἄφεσιν, τοῖς προσκυνοῦσιν ἐν πίστει, αὐτοῦ τὰ παθήματα."

ocMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Kathisma21.greekmelody = he.a.m8_gr_GR_cog.heAU.AnestisEkNekron.greekname
ocMA.Kathisma21.melody = he.a.m8_gr_GR_cog.heAU.AnestisEkNekron.name
ocMA.Kathisma21.incipit = "Ἐν μέσῳ τῆς Ἐδέμ…"
ocMA.Kathisma21.text = "Ἐν μέσῳ τῆς Ἐδέμ, ξύλον θάνατον ἤνθησεν, ἐν μέσῳ δὲ τῆς γῆς, ξύλον ζωὴν ἐβλάστησε· γευσάμενοι γὰρ τοῦ πρώτου, ἄφθαρτοι ὄντες, φθαρτοὶ γεγόναμεν· τυχόντες δὲ τοῦ δευτέρου, τῆς ἀφθαρσίας κατετρυφήσαμεν· ἐν τῷ Σταυρῷ γὰρ ἔσωσε Χριστός, τὸ γένος τῶν ἀνθρώπων."

ocMA.Kathisma22.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Kathisma22.greekmelody = he.a.m8_gr_GR_cog.heAU.ToProstachthen.greekname
ocMA.Kathisma22.melody = he.a.m8_gr_GR_cog.heAU.ToProstachthen.name
ocMA.Kathisma22.incipit = "Ἐν Παραδείσῳ μὲν τὸ πρίν…"
ocMA.Kathisma22.text = "Ἐν Παραδείσῳ μὲν τὸ πρὶν ξύλον ἐγύμνωσεν, ἐπὶ τῇ γεύσει ὁ ἐχθρὸς εἰσφέρει νέκρωσιν· τοῦ Σταυροῦ δὲ τὸ ξύλον τῆς ζωῆς τὸ ἔνδυμα, ἀνθρώποις φέρον ἐπάγη ἐπὶ τῆς γῆς, καὶ κόσμος ὅλος ἐπλήσθη πάσης χαρᾶς· ὃν ὁρῶντες ὑψούμενον, Θεῷ ἐν πίστει λαοί, συμφώνως ἐκβοήσωμεν· Πλήρης δόξης ὁ οἶκός σου."

ocMA.Kathisma23.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Kathisma23.greekmelody = he.a.m8_gr_GR_cog.heAU.ToProstachthen.greekname
ocMA.Kathisma23.melody = he.a.m8_gr_GR_cog.heAU.ToProstachthen.name
ocMA.Kathisma23.incipit = "Παρισταμένη τῷ Σταυρῷ…"
ocMA.Kathisma23.text = "Παρισταμένη τῷ Σταυρῷ, δακρυῤῥοοῦσα, ἐλεεινῶς ἡ Θεοτόκος ἀνεβόα· Ἀκατάληπτον ὄντως, Υἱὲ τὸ πάθος σου, οὐ φέρω τῶν σπλάγχνων μου χωρισμόν, οὐ στέγω ὁρῶσά σε, ἐν Σταυρῷ, μὴ παρίδῃς τὴν δούλην σου, ἀνάστα ἐκ τῶν νεκρῶν, δοξάζων με κραυγάζουσαν· Πολυέλεε δόξα σοι."

ocMA.Kathisma31.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Kathisma31.greekmelody = he.a.m8_gr_GR_cog.heAU.ToProstachthen.greekname
ocMA.Kathisma31.melody = he.a.m8_gr_GR_cog.heAU.ToProstachthen.name
ocMA.Kathisma31.incipit = "Ξύλον πικρίαν ἐν Ἐδέμ…"
ocMA.Kathisma31.text = "Ξύλον πικρίαν ἐν Ἐδέμ, τὸ πρὶν ἐξήνεγκε, ξύλον Σταυροῦ δὲ γλυκεράν, ζωὴν ἐξήνθησεν· ὁ Ἀδὰμ γὰρ φαγών, εἰς φθοράν, κατώλισθεν· ἡμεῖς δέ, κατατρυφῶντες σαρκός Χριστοῦ, ζωούμεθα, καὶ θεούμεθα μυστικῶς, Βασιλείαν λαμβάνοντες, ἀΐδιον τοῦ Θεοῦ· διὸ καὶ πίστει κράζομεν· Δόξα Λόγε τῷ πάθει σου."

ocMA.Kathisma32.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Kathisma32.greekmelody = he.a.m8_gr_GR_cog.heAU.ToProstachthen.greekname
ocMA.Kathisma32.melody = he.a.m8_gr_GR_cog.heAU.ToProstachthen.name
ocMA.Kathisma32.incipit = "Διʼ ἐγκρατείας τῶν παθῶν…"
ocMA.Kathisma32.text = "Διʼ ἐγκρατείας τῶν παθῶν, τὰς πυριφλέκτους, ἀπονεκρώσαντες ὁρμάς, καὶ τὰς κινήσεις, τοῦ Χριστοῦ οἱ Μάρτυρες, ἔλαβον τὴν χάριν, τὰς νόσους ἀποδιώκειν, τῶν ἀσθενῶν, καὶ ζῶντες καὶ μετὰ τέλος, θαυματουργεῖν, ὄντως θαῦμα παράδοξον! ὅτι ὀστέα γυμνά, ἐκβλύζουσιν ἰάματα. Δόξα τῷ μόνῳ Θεῷ ἡμῶν."

ocMA.Kathisma33.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Kathisma33.greekmelody = he.a.m8_gr_GR_cog.heAU.AnestisEkNekron.greekname
ocMA.Kathisma33.melody = he.a.m8_gr_GR_cog.heAU.AnestisEkNekron.name
ocMA.Kathisma33.incipit = "Ἡ ἄσπιλος ἀμνάς…"
ocMA.Kathisma33.text = "Ἡ ἄσπιλος ἀμνάς, τὸν ἀμνὸν καὶ ποιμένα, κρεμάμενον Σταυρῷ, κατιδοῦσα ἐβόα· Τέκνον μου τί τὸ ξένον, καὶ παρʼ ἐλπίδα, νῦν τοῦτο θέαμα; Πῶς ἡ ζωὴ τῶν πάντων, βροτοῖς ὁμοίως καταδεδίκασαι; Ἀλλὰ ἀνάστα Λόγε ἐκ νεκρῶν, τριήμερος ὡς εἴρηκας."

ocMA.C1.acrostic.title = "Κανὼν Σταυρώσιμος,"
ocMA.C1.acrostic.notice1 = "οὗ ἡ ἀκροστιχὶς ἄνευ τῶν Θεοτοκίων·"
ocMA.C1.acrostic.text = "Τῷ προσπαγέντι τῷ ξύλῳ Θεῷ, χάρις. Ἰωσήφ."

ocMA.C2.acrostic.title = "Κανὼν τῆς Θεοτόκου,"
ocMA.C2.acrostic.notice1 = "οὗ ἡ ἀκροστιχίς·"
ocMA.C2.acrostic.text = "Δέησίς ἐστιν ὀγδόη τῇ Παρθένῳ. Ἰωσήφ."

ocMA.CA.notice = ""

ocMA.OdeW1C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW1C1H.ode = miscellanea_gr_GR_cog.misc.Ode1
ocMA.OdeW1C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.greekname
ocMA.OdeW1C1H.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.melody
ocMA.OdeW1C1H.incipit = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.incipit
ocMA.OdeW1C1H.text = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.text

ocMA.OdeW1C11.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
ocMA.OdeW1C11.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
ocMA.OdeW1C11.incipit = "Τῇ ἐκ τοῦ ξύλου ἐνηδόνῳ…"
ocMA.OdeW1C11.text = "Τῇ ἐκ τοῦ ξύλου ἐνηδόνῳ βρώσει με, νεκρὸν γενόμενον, ἐπὶ Σταυροῦ Λόγε, νεκρωθεὶς ἐζώωσας, καὶ δόξῃ κατεκάλλυνας· προσκυνῶ σου τὸ κράτος, ὑμνολογῶ τὰ παθήματα, καὶ τὴν εὐσπλαγχνίαν τὴν ἄμετρον."

ocMA.OdeW1C12.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
ocMA.OdeW1C12.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
ocMA.OdeW1C12.incipit = "Ὡς ἐφηπλώθη ἐπὶ ξύλου ἄμπελος…"
ocMA.OdeW1C12.text = "Ὡς ἐφηπλώθη ἐπὶ ξύλου ἄμπελος, ἡ ἀγεώργητος, οἶνον ἡμῖν θείας, χάριτος ἀπέσταξε, καρδίας τὸν εὐφραίνοντα, καὶ τῆς πλάνης τὴν μέθην, ὁλοσχερῶς ἀναστέλλοντα, καὶ τὴν ἁμαρτίαν καθαίροντα."

ocMA.OdeW1C13.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
ocMA.OdeW1C13.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
ocMA.OdeW1C13.incipit = "Πεποικιλμένοι ἱεροῖς ἐν στίγμασι, Χριστοῦ…"
ocMA.OdeW1C13.text = "Πεποικιλμένοι ἱεροῖς ἐν στίγμασι, Χριστοῦ οἱ Μάρτυρες, καὶ ἀθλητῶν πόνοις, ἐγκαλλωπιζόμενοι, καλλοποιῷ παρίστασθε, μετὰ δόξης Δεσπότῃ, πανευκλεῶς εὐφραινόμενοι, καὶ θεοειδεῖς γνωριζόμενοι."

ocMA.OdeW1C14.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW1C14.ode = miscellanea_gr_GR_cog.misc.Ode1
ocMA.OdeW1C14.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
ocMA.OdeW1C14.incipit = "Ῥώμῃ τῇ θείᾳ προφανῶς ῥωννύμενοι…"
ocMA.OdeW1C14.text = "Ῥώμῃ τῇ θείᾳ προφανῶς ῥωννύμενοι, ἅγιοι Μάρτυρες, τοῦ δυνατοῦ πᾶσαν, ἰσχὺν τὴν ὀλέθριον, ἀνδρείως κατεβάλετε, καὶ στεφθέντες ὡραίως, νικητικοῖς διαδήμασι, χαίροντες Κυρίῳ παρίστασθε."

ocMA.OdeW1C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
ocMA.OdeW1C1T.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
ocMA.OdeW1C1T.incipit = "Παρισταμένη τῷ Σταυρῷ σου Κύριε…"
ocMA.OdeW1C1T.text = "Παρισταμένη τῷ Σταυρῷ σου Κύριε, ἡ Ἀπειρόγαμος, καὶ τὰς ἐν σοὶ τρώσεις, καθορῶσα Δέσποτα, τιτρωσκομένη ἔλεγεν· Οἴμοι! Τέκνον· ὠδῖνας, ἀποφυγοῦσα τῷ τόκῳ σου, νῦν ὀδυνηρῶς κατατρύχομαι."

ocMA.OdeW1C21.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW1C21.ode = miscellanea_gr_GR_cog.misc.Ode1
ocMA.OdeW1C21.greekmelody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.greekname
ocMA.OdeW1C21.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
ocMA.OdeW1C21.incipit = "Δεδοξασμένα περὶ σοῦ λελάληνται, δεδοξασμένη…"
ocMA.OdeW1C21.text = "Δεδοξασμένα περὶ σοῦ λελάληνται, δεδοξασμένη Ἁγνή, ἡ τῶν πιστῶν δόξα, μόνη χρηματίσασα· διὸ μελλούσης δόξης με, κοινωνὸν σαῖς πρεσβείαις, δοξάζοντά σε ἀνάδειξον, ἄχραντε πανάμωμε Δέσποινα."

ocMA.OdeW1C22.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW1C22.ode = miscellanea_gr_GR_cog.misc.Ode1
ocMA.OdeW1C22.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
ocMA.OdeW1C22.incipit = "Εὐλογημένος ὁ καρπὸς Πανάμωμε, ὁ…"
ocMA.OdeW1C22.text = "Εὐλογημένος ὁ καρπὸς Πανάμωμε, ὁ τῆς κοιλίας σου, διʼ οὗ βροτοὶ πάντες, τῆς ἀρᾶς ἐλύθημεν· εὐλογημένη Πάναγνε, ἀνερμήνευτον θαῦμα, ἀκατανόητον ὅραμα, πάντων τῶν βροτῶν τὸ διάσωσμα."

ocMA.OdeW1C23.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW1C23.ode = miscellanea_gr_GR_cog.misc.Ode1
ocMA.OdeW1C23.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
ocMA.OdeW1C23.incipit = "Ἡ τῶν Ἀγγέλων δυσωπεῖ σὲ…"
ocMA.OdeW1C23.text = "Ἡ τῶν Ἀγγέλων δυσωπεῖ σὲ Κύριε, πληθὺς ἑκάστοτε, τῶν Μαθητῶν δῆμος, Προφητῶν ὁ σύλλογος, Μαρτύρων καὶ Ὁσίων σου. Διὰ τῆς Θεοτόκου, ἁμαρτημάτων συγχώρησιν, δώρησαι ἡμῖν ὡς φιλάνθρωπος."

ocMA.OdeW1C24.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW1C24.ode = miscellanea_gr_GR_cog.misc.Ode1
ocMA.OdeW1C24.melody = he.h.m8_gr_GR_cog.heHE.ArmatilatinFarao.name
ocMA.OdeW1C24.incipit = "Σὲ τὴν ἐν σπλάγχνοις δεξαμένην…"
ocMA.OdeW1C24.text = "Σὲ τὴν ἐν σπλάγχνοις δεξαμένην Ἄχραντε, τὸ πῦρ τὸ ἄστεκτον, ἐκδυσωπῶ πίστει, τῆς γεέννης ῥῦσαί με, καὶ τῆς ἀποκειμένης μοι, διὰ πλῆθος πταισμάτων, κολάσεως ἐλευθέρωσον, σοῦ ταῖς εὐπροσδέκτοις δεήσεσι."

ocMA.OdeW3C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW3C1H.ode = miscellanea_gr_GR_cog.misc.Ode3
ocMA.OdeW3C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.greekname
ocMA.OdeW3C1H.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.melody
ocMA.OdeW3C1H.incipit = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.incipit
ocMA.OdeW3C1H.text = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.text

ocMA.OdeW3C11.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
ocMA.OdeW3C11.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
ocMA.OdeW3C11.incipit = "Ὁ στερεώσας οὐρανόν, καὶ γῆν…"
ocMA.OdeW3C11.text = "Ὁ στερεώσας οὐρανόν, καὶ γῆν ὁ θεμελιώσας, καὶ τὴν θάλασσαν τῷ λόγῳ πεδήσας, σὺ ἐδέθης διʼ ἐμέ, Σταυρῷ προσαναρτώμενος, ὅπως δεσμῶν με λύσῃς, τῆς ἁμαρτίας Φιλάνθρωπε."

ocMA.OdeW3C12.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
ocMA.OdeW3C12.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
ocMA.OdeW3C12.incipit = "Σταυροῦ τῷ ξύλῳ ὁ ἐχθρός…"
ocMA.OdeW3C12.text = "Σταυροῦ τῷ ξύλῳ ὁ ἐχθρός, προσκόψας ἐθανατώθη, σὺν τοῖς δαίμοσιν αὐτοῦ τοῖς κακούργοις· καὶ ὁ γεύσει πονηρᾷ, κατακριθεὶς ἠλέηται, καὶ ἑδρασμῷ ἡ κτίσις, τῆς εὐσεβείας ἐνίδρυται."

ocMA.OdeW3C13.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
ocMA.OdeW3C13.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
ocMA.OdeW3C13.incipit = "Πολυειδέσιν αἰκισμοῖς, καὶ ξίφεσι καὶ…"
ocMA.OdeW3C13.text = "Πολυειδέσιν αἰκισμοῖς, καὶ ξίφεσι καὶ θηρίοις, καὶ γυμνότητι σωμάτων οἱ θεῖοι, καὶ γενναῖοι Ἀθληταί, διδόμενοι ἀχείρωτοι, τῷ πονηρῷ διώκτῃ, ἔμειναν νεύσει τῇ κρείττονι."

ocMA.OdeW3C14.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW3C14.ode = miscellanea_gr_GR_cog.misc.Ode3
ocMA.OdeW3C14.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
ocMA.OdeW3C14.incipit = "Ἀποσκοποῦντες λογισμῷ, νηφούσῃ τε διανοίᾳ…"
ocMA.OdeW3C14.text = "Ἀποσκοποῦντες λογισμῷ, νηφούσῃ τε διανοίᾳ, πρὸς τὰ μένοντα ῥεόντων τελείως, κατεφρόνησαν, Χριστοῦ, οἱ Μάρτυρες οἱ ἔνδοξοι· ὅθεν τοὺς ἀνυποίστους, πόνους ὑπέφερον χαίροντες."

ocMA.OdeW3C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
ocMA.OdeW3C1T.melody = he.h.m8_gr_GR_cog.heHE.OStereosasKatArchas.name
ocMA.OdeW3C1T.incipit = "Ἡ πολυύμνητος Ἀμνάς, τὸν Ἄρνα…"
ocMA.OdeW3C1T.text = "Ἡ πολυύμνητος Ἀμνάς, τὸν Ἄρνα θεασαμένη, πρὸς ἑκούσιον ἑλκόμενον πάθος, καὶ σταυρούμενον σαρκί, ἠλάλαζε δακρύουσα, καὶ τὴν μακροθυμίαν, ὕμνει τὴν τούτου δοξάζουσα."

ocMA.OdeW3C21.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW3C21.ode = miscellanea_gr_GR_cog.misc.Ode3
ocMA.OdeW3C21.greekmelody = he.h.m8_gr_GR_cog.heHE.OuraniasApsidos.greekname
ocMA.OdeW3C21.melody = he.h.m8_gr_GR_cog.heHE.OuraniasApsidos.name
ocMA.OdeW3C21.incipit = "Ἱερᾶς πολιτείας, ἀποπεσὼν Ἄχραντε, παρασυνεβλήθην…"
ocMA.OdeW3C21.text = "Ἱερᾶς πολιτείας, ἀποπεσὼν Ἄχραντε, παρασυνεβλήθην τοῖς κτήνεσι, καὶ κατάκριτος, ὅλος γεγένημαι· ἡ τὸν Κριτὴν τετοκυῖα, πάσης κατακρίσεως, ῥῦσαι καὶ σῶσόν με."

ocMA.OdeW3C22.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW3C22.ode = miscellanea_gr_GR_cog.misc.Ode3
ocMA.OdeW3C22.melody = he.h.m8_gr_GR_cog.heHE.OuraniasApsidos.name
ocMA.OdeW3C22.incipit = "Στεναγμοὺς ἀσιγήτους, καὶ ἐκτενὲς δάκρυον…"
ocMA.OdeW3C22.text = "Στεναγμοὺς ἀσιγήτους, καὶ ἐκτενὲς δάκρυον, καὶ διηνεκῆ μοι παράσχου, Κόρη κατάνυξιν, ὅπως πενθήσω μου, τὰ συμφυέντα μοι πάθη, σαρκικῷ φρονήματι, Θεοχαρίτωτε."

ocMA.OdeW3C23.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW3C23.ode = miscellanea_gr_GR_cog.misc.Ode3
ocMA.OdeW3C23.melody = he.h.m8_gr_GR_cog.heHE.OuraniasApsidos.name
ocMA.OdeW3C23.incipit = "Ἐπουράνιαι τάξεις, λειτουργικὰ πνεύματα, δῆμος…"
ocMA.OdeW3C23.text = "Ἐπουράνιαι τάξεις, λειτουργικὰ πνεύματα, δῆμος Προφητῶν Ἀποστόλων σου, καὶ Μαρτύρων σου, σὺν τῇ Τεκούσῃ σε, ἐκδυσωποῦσιν Οἰκτίρμον· τῷ λαῷ σου δώρησαι, πταισμάτων ἄφεσιν."

ocMA.OdeW3C24.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW3C24.ode = miscellanea_gr_GR_cog.misc.Ode3
ocMA.OdeW3C24.melody = he.h.m8_gr_GR_cog.heHE.OuraniasApsidos.name
ocMA.OdeW3C24.incipit = "Συμπαθείας με θείας, ὡς συμπαθὴς…"
ocMA.OdeW3C24.text = "Συμπαθείας με θείας, ὡς συμπαθὴς Ἄχραντε, νῦν καταξιῶσαι δυσώπει, τὸν εὐσυμπάθητον· τρόπους ἀσπλάγχνους γάρ, ἀσυμπαθεῖς κεκτημένον, μετανοίας τρόποις με, νῦν ἀνακάλεσαι."

ocMA.OdeW4C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW4C1H.ode = miscellanea_gr_GR_cog.misc.Ode4
ocMA.OdeW4C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.greekname
ocMA.OdeW4C1H.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.melody
ocMA.OdeW4C1H.incipit = he.h.m8_gr_GR_cog.heHE.SyMouIschys.incipit
ocMA.OdeW4C1H.text = he.h.m8_gr_GR_cog.heHE.SyMouIschys.text

ocMA.OdeW4C11.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
ocMA.OdeW4C11.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
ocMA.OdeW4C11.incipit = "Γένος βροτῶν, τοῦ πτώματος ἀνακέκληται…"
ocMA.OdeW4C11.text = "Γένος βροτῶν, τοῦ πτώματος ἀνακέκληται, οὗ ὑπέστη, πάλαι ὁ πρωτόπλαστος· ὁ γὰρ τῶν ὅλων Δημιουργός, ἤρθη ἐπὶ ξύλου, δακτύλους ἐξαιματούμενος, καὶ ἥλοις ἑκουσίως, προσηλούμενος χεῖρας, καὶ πλευρὰν ὑπὸ λόγχης νυττόμενος."

ocMA.OdeW4C12.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
ocMA.OdeW4C12.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
ocMA.OdeW4C12.incipit = "Ἔστη Σταυρός, καὶ πλάνη πᾶσα…"
ocMA.OdeW4C12.text = "Ἔστη Σταυρός, καὶ πλάνη πᾶσα κατέπεσεν· ἐγυμνώθη, Σῶτερ ὁ ἀλλότριος, σοῦ γυμνωθέντος, καὶ ὁ Ἀδάμ, θείας ἀφθαρσίας, καταστολὴν ἐπενδύσατο· ἡ κτίσις ἐφωτίσθη, σκοτισθέντος ἡλίου, ἐπὶ ξύλου Χριστὲ σταυρουμένου σου."

ocMA.OdeW4C13.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
ocMA.OdeW4C13.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
ocMA.OdeW4C13.incipit = "Νεοσφαγῆ, καθάπερ θύματα Μάρτυρες, τῷ…"
ocMA.OdeW4C13.text = "Νεοσφαγῆ, καθάπερ θύματα Μάρτυρες, τῷ τυθέντι, Λόγῳ προσηνέχθητε, ταῖς τῶν αἱμάτων ἐπιῤῥοαῖς, πλάνης τὰς θαλάσσας, ξηράναντες θείᾳ χάριτι, καὶ χύσιν παθημάτων, ἐπομβρίαις θαυμάτων, ἀναστέλλοντες πάντοτε ἔνδοξοι."

ocMA.OdeW4C14.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW4C14.ode = miscellanea_gr_GR_cog.misc.Ode4
ocMA.OdeW4C14.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
ocMA.OdeW4C14.incipit = "Τῆξιν μελῶν, καὶ τῶν ὀδόντων…"
ocMA.OdeW4C14.text = "Τῆξιν μελῶν, καὶ τῶν ὀδόντων ἐκρίζωσιν, καὶ ὀνύχων, Μάρτυρες ὑπέστητε, χεῖρας κοπτόμενοι ἀφειδῶς, γλῶσσάν τε καὶ πόδας, καὶ ἁρμονίας τοῦ σώματος· διὸ ὑπερβαλλούσης, ἠξιώθητε δόξης, τῷ τῶν ὅλων Θεῷ παριστάμενοι."

ocMA.OdeW4C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
ocMA.OdeW4C1T.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
ocMA.OdeW4C1T.incipit = "Τὸν ἑαυτῆς, μόσχον ἡ ἄμεμπτος…"
ocMA.OdeW4C1T.text = "Τὸν ἑαυτῆς, μόσχον ἡ ἄμεμπτος δάμαλις, κατιδοῦσα, ξύλῳ ἀναρτώμενον, τέκνον ἐβόα ὀλολυγμῷ, πῶς σε παρανόμων, δῆμος οὐδόλως ᾠκτείρησεν, αὐτὸν ᾠκτειρηκότα, ἀλλὰ σκέψει δολίᾳ, θανατῶσαι ἀδίκως προείλετο;"

ocMA.OdeW4C21.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW4C21.ode = miscellanea_gr_GR_cog.misc.Ode4
ocMA.OdeW4C21.greekmelody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.greekname
ocMA.OdeW4C21.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
ocMA.OdeW4C21.incipit = "Τὸ πονηρόν, ἁμαρτιῶν μου χειρόγραφον…"
ocMA.OdeW4C21.text = "Τὸ πονηρόν, ἁμαρτιῶν μου χειρόγραφον, θείᾳ λόγχῃ, Πάναγνε διάῤῥηξον, τῇ κεντησάσῃ θείαν πλευράν, τοῦ ἐνανθρωπῆσαι, ἐκ σοῦ Παρθένε θελήσαντος, καὶ βίβλῳ με γραφῆναι, σῳζομένων δυσώπει, τὸν ἀφρόνως Θεοῦ μακρυνόμενον."

ocMA.OdeW4C22.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW4C22.ode = miscellanea_gr_GR_cog.misc.Ode4
ocMA.OdeW4C22.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
ocMA.OdeW4C22.incipit = "Ἵνα φωναῖς, χαριστηρίοις δοξάζω σε…"
ocMA.OdeW4C22.text = "Ἵνα φωναῖς, χαριστηρίοις δοξάζω σε, ἵνα θείῳ, πόθῳ μεγαλύνω σε, τὴν τῷ μεγίστῳ σου τοκετῷ, πάντας σμικρυνθέντας, Πανάμωμε μεγαλύνασαν, μεγάλως ἁμαρτῶντα, καὶ δεινῶς συμπτωθέντα, συγχωρήσεως Κόρη ἀξίωσον."

ocMA.OdeW4C23.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW4C23.ode = miscellanea_gr_GR_cog.misc.Ode4
ocMA.OdeW4C23.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
ocMA.OdeW4C23.incipit = "Νόμοι ἐν σοί, κεκαινοτόμηνται φύσεως…"
ocMA.OdeW4C23.text = "Νόμοι ἐν σοί, κεκαινοτόμηνται φύσεως· ὑπὲρ φύσιν, Λόγον γὰρ ἐκύησας· διό σε πίστει ἐκδυσωπῶ· Τὸν ὑπὲρ τὴν φύσιν, τὴν ἀνθρωπίνην Πανάμωμε, πολλὰ ἡμαρτηκότα, καὶ Θεοῦ μακρυνθέντα, ἐπιστρέψαντα σῶσον πρεσβείαις σου."

ocMA.OdeW4C24.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW4C24.ode = miscellanea_gr_GR_cog.misc.Ode4
ocMA.OdeW4C24.melody = he.h.m8_gr_GR_cog.heHE.SyMouIschys.name
ocMA.OdeW4C24.incipit = "Ὁ δυσμενής, τῆς ἁμαρτίας τοῖς…"
ocMA.OdeW4C24.text = "Ὁ δυσμενής, τῆς ἁμαρτίας τοῖς βέλεσι, τὴν ψυχήν μου, ὅλην ἐτραυμάτισε, καὶ κατεμόλυνεν ἡδοναῖς, τὴν ἐμὴν καρδίαν, καὶ τῆς ὁδοῦ ἀπεπλάνησε, Παρθένε τῆς εὐθείας· διὰ τοῦτο βοῶ σοι· Ἐπιστρέφοντα δέξαι καὶ σῶσόν με."

ocMA.OdeW5C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW5C1H.ode = miscellanea_gr_GR_cog.misc.Ode5
ocMA.OdeW5C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
ocMA.OdeW5C1H.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.melody
ocMA.OdeW5C1H.incipit = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.incipit
ocMA.OdeW5C1H.text = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.text

ocMA.OdeW5C11.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
ocMA.OdeW5C11.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
ocMA.OdeW5C11.incipit = "Ἵνα τῆς ἐνηδόνου, γεύσεως λυτρώσῃς…"
ocMA.OdeW5C11.text = "Ἵνα τῆς ἐνηδόνου, γεύσεως λυτρώσῃς με χολῆς Μακρόθυμε, ἀπεγεύσω θέλων, καὶ νεκρώσεως, ὅπως ἐκδύσῃς με, Ἰησοῦ τὸ πάθος, γυμνὸς παγῆναι κατεδέξω, ἐπὶ ξύλου· ὑμνῶ σου τὸ εὔσπλαγχνον."

ocMA.OdeW5C12.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
ocMA.OdeW5C12.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
ocMA.OdeW5C12.incipit = "Τὴν φθαρεῖσαν ψυχήν μου, Λόγε…"
ocMA.OdeW5C12.text = "Τὴν φθαρεῖσαν ψυχήν μου, Λόγε τοῖς παθήμασι καινοποιούμενος, τὴν ψυχὴν παρέθου, τῷ Πατρὶ ἐπὶ ξύλου κρεμάμενος· καὶ οὐ φέρει ταῦτα, ἄψυχος γῆ κατανοοῦσα, ἀλλὰ φόβῳ κλονεῖται ὑμνοῦσά σε."

ocMA.OdeW5C13.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
ocMA.OdeW5C13.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
ocMA.OdeW5C13.incipit = "Ὡραιώθητε θείοις, Μάρτυρες παθήμασι καλλωπιζόμενοι…"
ocMA.OdeW5C13.text = "Ὡραιώθητε θείοις, Μάρτυρες παθήμασι καλλωπιζόμενοι, καὶ ἰχνηλατοῦντες, τὸν τοῖς πάθεσι πᾶσιν ἀπάθειαν, δεδωκότα Λόγον, μονογενῆ Πατρὸς ἀνάρχου· διὰ τοῦτο αὐτῷ συνδοξάζεσθε."

ocMA.OdeW5C14.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW5C14.ode = miscellanea_gr_GR_cog.misc.Ode5
ocMA.OdeW5C14.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
ocMA.OdeW5C14.incipit = "Ξενωθέντες τῶν κάτω, τὰ μὴ…"
ocMA.OdeW5C14.text = "Ξενωθέντες τῶν κάτω, τὰ μὴ θεωρούμενα κατεκληρώσασθε, ἐν ἐπουρανίοις, αὐλιζόμενοι θείοις σκηνώμασι, καὶ μεθέξει θείᾳ, θεοποιούμενοι ἀΰλως, τοῦ Σωτῆρος ἀήττητοι Μάρτυρες."

ocMA.OdeW5C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
ocMA.OdeW5C1T.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
ocMA.OdeW5C1T.incipit = "Ξένον θέαμα βλέπω, ἔκραζες Πανύμνητε…"
ocMA.OdeW5C1T.text = "Ξένον θέαμα βλέπω, ἔκραζες Πανύμνητε· πῶς ὁ τῷ βλέμματι, πᾶσαν γῆν σαλεύων, ἐπὶ ξύλου ὑψούμενος ὕπνωσας, τοὺς ὑπνοῦντας μέλλων, ἐκ τοῦ αἰῶνος ἀφυπνίζειν; Προσκυνῶ σου Υἱὲ τὸ μακρόθυμον."

ocMA.OdeW5C21.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW5C21.ode = miscellanea_gr_GR_cog.misc.Ode5
ocMA.OdeW5C21.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
ocMA.OdeW5C21.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
ocMA.OdeW5C21.incipit = "Γενεαὶ γενεῶν σε, τὴν ἀειμακάριστον…"
ocMA.OdeW5C21.text = "Γενεαὶ γενεῶν σε, τὴν ἀειμακάριστον νῦν μακαρίζουσιν· οὐρανῶν δυνάμεις, ὡς τὰ κάτω τοῖς ἄνω συνάψασαν, εὐφημοῦσι μόνην, ἐν γυναιξίν· Εὐλογημένη, τοῦ πεσόντος Ἀδὰμ ἡ ἀνάκλησις."

ocMA.OdeW5C22.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW5C22.ode = miscellanea_gr_GR_cog.misc.Ode5
ocMA.OdeW5C22.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
ocMA.OdeW5C22.incipit = "Διαμένειν με σῶον, μὴ περιτρεπόμενον…"
ocMA.OdeW5C22.text = "Διαμένειν με σῶον, μὴ περιτρεπόμενον στάσεως κρείττονος, ἀλλʼ εὐθυποροῦντα, καὶ Θεῷ τὰ εὐάρεστα πράττοντα, ἐνδυνάμωσόν με, τὸν ἀγαθὸν τεκοῦσα Λόγον, τὸν ἡμᾶς ἀλογίας ῥυσάμενον."

ocMA.OdeW5C23.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW5C23.ode = miscellanea_gr_GR_cog.misc.Ode5
ocMA.OdeW5C23.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
ocMA.OdeW5C23.incipit = "Ὁ τὸ αἷμά σου Λόγε…"
ocMA.OdeW5C23.text = "Ὁ τὸ αἷμά σου Λόγε, διὰ ὑπερβάλλουσαν ἐλέους ἄβυσσον, ἐν Σταυρῷ κενώσας, τῶν παθῶν μου τὴν ἄβυσσον ξήρανον, καὶ ἐν κατανύξει, σοὶ τῷ Θεῷ εὐαρεστῆσαι, διὰ τῆς Θεοτόκου ἀξίωσον."

ocMA.OdeW6C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW6C1H.ode = miscellanea_gr_GR_cog.misc.Ode6
ocMA.OdeW6C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.AvyssosAmartion.greekname
ocMA.OdeW6C1H.melody = he.h.m8_gr_GR_cog.heHE.AvyssosAmartion.melody
ocMA.OdeW6C1H.incipit = he.h.m8_gr_GR_cog.heHE.AvyssosAmartion.incipit
ocMA.OdeW6C1H.text = he.h.m8_gr_GR_cog.heHE.AvyssosAmartion.text

ocMA.OdeW6C11.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
ocMA.OdeW6C11.melody = he.h.m8_gr_GR_cog.heHE.AvyssosAmartion.name
ocMA.OdeW6C11.incipit = "Ὕμνησαν τῶν οὐρανῶν, αἱ δυνάμεις…"
ocMA.OdeW6C11.text = "Ὕμνησαν τῶν οὐρανῶν, αἱ δυνάμεις καὶ ἐξέστησαν πᾶσαι, ἐπὶ σταυροῦ σε Λόγε, καθορῶσαι κρεμάμενον· καὶ Ἀδὰμ ὁ πληγωθείς, Σῶτερ ἰάτρευται τῇ πληγῇ σου, καὶ ἡ κατάρα ἐξωστράκισται."

ocMA.OdeW6C12.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
ocMA.OdeW6C12.melody = he.h.m8_gr_GR_cog.heHE.AvyssosAmartion.name
ocMA.OdeW6C12.incipit = "Λέλυται ἐκ τῶν δεσμῶν, τὸ…"
ocMA.OdeW6C12.text = "Λέλυται ἐκ τῶν δεσμῶν, τὸ ἀνθρώπινον Μακρόθυμε γένος, σοῦ ἐν σαρκὶ δεθέντος, καὶ δεσμεῖται ὁ τύραννος, ὑπὸ πάντων τῶν πιστῶν, καταπαιζόμενος ὡς στρουθίον. Δόξα Χριστὲ τῇ δυναστείᾳ σου."

ocMA.OdeW6C13.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
ocMA.OdeW6C13.melody = he.h.m8_gr_GR_cog.heHE.AvyssosAmartion.name
ocMA.OdeW6C13.incipit = "Ὤφθητε θεοειδεῖς, Ἀθλοφόροι ὥσπερ ἄνθρακες…"
ocMA.OdeW6C13.text = "Ὤφθητε θεοειδεῖς, Ἀθλοφόροι ὥσπερ ἄνθρακες πᾶσαν, τῆς δυσσεβείας ὕλην, κατακαίοντες χάριτι, ἐπʼ ἀνθράκων τε πυρός, ὁλοκαυτούμενοι καὶ τὴν θείαν, ἀναψυχήν ὑποδεχόμενοι."

ocMA.OdeW6C14.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW6C14.ode = miscellanea_gr_GR_cog.misc.Ode6
ocMA.OdeW6C14.melody = he.h.m8_gr_GR_cog.heHE.AvyssosAmartion.name
ocMA.OdeW6C14.incipit = "Θρέμματα ἀληθινοῦ, δεδειγμένοι Ἀθλοφόροι Ποιμένος…"
ocMA.OdeW6C14.text = "Θρέμματα ἀληθινοῦ, δεδειγμένοι Ἀθλοφόροι Ποιμένος, μέσον ἀγρίων λύκων, ἀβλαβεῖς διεμείνατε· καὶ τελέσαντες καλῶς, δρόμον τὸν ἔνθεον ἐν τῇ μάνδρᾳ, τῇ οὐρανίῳ ἐσκηνώσατε."

ocMA.OdeW6C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
ocMA.OdeW6C1T.melody = he.h.m8_gr_GR_cog.heHE.AvyssosAmartion.name
ocMA.OdeW6C1T.incipit = "Κύριόν σε τῆς ζωῆς, καὶ…"
ocMA.OdeW6C1T.text = "Κύριόν σε τῆς ζωῆς, καὶ ὡραῖον ἀπεκύησα κάλλει, ὑπὲρ υἱοὺς ἀνθρώπων, ἡ Παρθένος ἐκραύγαζε· καὶ πῶς θνήσκεις νῦν Υἱέ, κάλλος οὐκ ἔχων ἐν τῷ σταυροῦσθαι, ὁ καλλωπίζων πάντα νεύματι;"

ocMA.OdeW6C21.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW6C21.ode = miscellanea_gr_GR_cog.misc.Ode6
ocMA.OdeW6C21.greekmelody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.greekname
ocMA.OdeW6C21.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
ocMA.OdeW6C21.incipit = "Ἠλέηται διὰ σοῦ, ἡ φύσις…"
ocMA.OdeW6C21.text = "Ἠλέηται διὰ σοῦ, ἡ φύσις τῆς ἀνθρωπότητος· τὸν ἐλεήμονα γάρ, ἐκύησας Κύριον, ἐλεῆμον Πάναγνε· ὅθεν δυσωπῶ σε, τὴν ἐμὴν ψυχὴν ἐλέησον."

ocMA.OdeW6C22.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW6C22.ode = miscellanea_gr_GR_cog.misc.Ode6
ocMA.OdeW6C22.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
ocMA.OdeW6C22.incipit = "Τῶν Ἀσωμάτων Χριστέ, τὰ τάγματα…"
ocMA.OdeW6C22.text = "Τῶν Ἀσωμάτων Χριστέ, τὰ τάγματα δυσωποῦσί σε, Μαρτύρων τε Προφητῶν, καὶ τῶν Ἀποστόλων σου, διὰ τῆς Τεκούσης σε, τὸν λαόν σου σῶζε, ἀπὸ πάσης περιστάσεως."

ocMA.OdeW6C23.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW6C23.ode = miscellanea_gr_GR_cog.misc.Ode6
ocMA.OdeW6C23.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
ocMA.OdeW6C23.incipit = "Ἡ ἀγεώργητος γῆ, τὸν γεωργὸν…"
ocMA.OdeW6C23.text = "Ἡ ἀγεώργητος γῆ, τὸν γεωργὸν ἡ κυήσασα, καὶ πάντων Δημιουργόν, τὴν ὑλομανήσασαν, ψυχήν μου τοῖς πάθεσι, δεῖξον καρποφόρον, διὰ θείας ἐπιγνώσεως."

ocMA.OdeW6C24.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW6C24.ode = miscellanea_gr_GR_cog.misc.Ode6
ocMA.OdeW6C24.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
ocMA.OdeW6C24.incipit = "Παρέβην τὰς ἐντολάς, τὰς πρὸς…"
ocMA.OdeW6C24.text = "Παρέβην τὰς ἐντολάς, τὰς πρὸς Θεὸν ὁδηγούσας με, καὶ θέλων τοῖς πονηροῖς, δεδούλωμαι πάθεσι· διὸ ἱκετεύω σε· Τῆς αὐτῶν με ῥῦσαι, δεσποτείας Ἀειπάρθενε."

ocMA.OdeW7C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW7C1H.ode = miscellanea_gr_GR_cog.misc.Ode7
ocMA.OdeW7C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.greekname
ocMA.OdeW7C1H.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.melody
ocMA.OdeW7C1H.incipit = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.incipit
ocMA.OdeW7C1H.text = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.text

ocMA.OdeW7C11.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
ocMA.OdeW7C11.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
ocMA.OdeW7C11.incipit = "Ἐπλήγης τὰς χεῖράς σου, ἐν…"
ocMA.OdeW7C11.text = "Ἐπλήγης τὰς χεῖράς σου, ἐν αἷς εἰργάσω Χριστὲ τὰ θαύματα, καὶ τραυμάτων ἠνέσχου, τὰ τραύματά μου πάντα ἰώμενος· ὑμνῶ σε Λόγε κραυγάζων Μακρόθυμε. Εὐλογητός ὁ Θεός, ὁ τῶν πατέρων ἡμῶν."

ocMA.OdeW7C12.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
ocMA.OdeW7C12.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
ocMA.OdeW7C12.incipit = "Ὠρύχθης τὰς χεῖράς σου, καὶ…"
ocMA.OdeW7C12.text = "Ὠρύχθης τὰς χεῖράς σου, καὶ πόδας ἥλοις Χριστὲ σταυρούμενος, καὶ πλευρὰν ἐλογχεύθης, κρουνοὺς πηγάζων πᾶσιν ἀφέσεως, τοῖς μελῳδοῦσιν ἀπαύστως καὶ λέγουσιν· Εὐλογητὸς ὁ Θεός, ὁ τῶν πατέρων ἡμῶν."

ocMA.OdeW7C13.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
ocMA.OdeW7C13.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
ocMA.OdeW7C13.incipit = "Χορείαν στησώμεθα, ὑμνολογοῦντες Θεοῦ τοὺς…"
ocMA.OdeW7C13.text = "Χορείαν στησώμεθα, ὑμνολογοῦντες Θεοῦ τοὺς Μάρτυρας, τοῖς χοροῖς τῶν Ἀγγέλων, ἀριθμουμένους καὶ τὰ ἐπίγεια, φωταγωγοῦντας καὶ πάντοτε μέλποντας. Εὐλογητός ὁ Θεός, ὁ τῶν πατέρων ἡμῶν."

ocMA.OdeW7C14.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW7C14.ode = miscellanea_gr_GR_cog.misc.Ode7
ocMA.OdeW7C14.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
ocMA.OdeW7C14.incipit = "Ἁγίων λαμπρότησιν, ἁγιασθέντες κατεσκηνώσατε, ἐπιπέμποντες…"
ocMA.OdeW7C14.text = "Ἁγίων λαμπρότησιν, ἁγιασθέντες κατεσκηνώσατε, ἐπιπέμποντες πᾶσιν, ἁγιασμόν τε καὶ ἀπολύτρωσιν, τοῖς εὐφημοῦσιν ὑμᾶς καὶ κραυγάζουσιν· Εὐλογητὸς ὁ Θεός, ὁ τῶν πατέρων ἡμῶν."

ocMA.OdeW7C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
ocMA.OdeW7C1T.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
ocMA.OdeW7C1T.incipit = "Ὁ ἄδυτος ἥλιος, πῶς ἔδυς…"
ocMA.OdeW7C1T.text = "Ὁ ἄδυτος ἥλιος, πῶς ἔδυς ξύλῳ Λόγε τεινόμενος, ἡ Παρθένος ἐβόα, καὶ βλέπων ἔστη τοῦ δρόμου ἥλιος, φαίνειν μὴ σθένων σοῦ πάσχοντος Δέσποτα; Ὑμνολογῶ προσκυνῶ, τὸ θεῖον κράτος σου."

ocMA.OdeW7C21.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW7C21.ode = miscellanea_gr_GR_cog.misc.Ode7
ocMA.OdeW7C21.greekmelody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.greekname
ocMA.OdeW7C21.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
ocMA.OdeW7C21.incipit = "Ἀῤῥήτῳ κυήσει σου, φρικτῶν ἀῤῥήτων…"
ocMA.OdeW7C21.text = "Ἀῤῥήτῳ κυήσει σου, φρικτῶν ἀῤῥήτων ἡμᾶς ἠξίωσας, Θεοτόκε πραγμάτων· διὸ φρικτῆς με ῥῦσαι κολάσεως, καὶ τῆς ἀῤῥήτου χαρᾶς καταξίωσον, ἵνα ὑμνῶ σε ἀεί, τὴν πολυΰμνητον."

ocMA.OdeW7C22.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW7C22.ode = miscellanea_gr_GR_cog.misc.Ode7
ocMA.OdeW7C22.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
ocMA.OdeW7C22.incipit = "Ῥαθύμως τὸν βίον μου, ἐκδαπανήσας…"
ocMA.OdeW7C22.text = "Ῥαθύμως τὸν βίον μου, ἐκδαπανήσας ἄκαρπος ἔμεινα, καὶ πτοοῦμαι τὴν δίκην, καὶ τῆς γεέννης τὸ πῦρ τὸ ἄσβεστον· ἡ πῦρ τεκοῦσα Παρθένε τὸ ἄστεκτον, ῥῦσαί με τοῦ πυρός, τῇ μεσιτείᾳ σου."

ocMA.OdeW7C23.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW7C23.ode = miscellanea_gr_GR_cog.misc.Ode7
ocMA.OdeW7C23.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
ocMA.OdeW7C23.incipit = "Θαυμάτων ἐπέκεινα, τὸ μέγα θαῦμα…"
ocMA.OdeW7C23.text = "Θαυμάτων ἐπέκεινα, τὸ μέγα θαῦμα τῆς σῆς κυήσεως· διὰ τοῦτο βοῶ σοι· Ἁγνὴ Παρθένε θεογεννήτρια, τὰ σὰ ἐλέη ἐπʼ ἐμοὶ θαυμάστωσον, καὶ τῆς μελλούσης ὀργῆς, ῥῦσαι καὶ σῶσόν με."

ocMA.OdeW7C24.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW7C24.ode = miscellanea_gr_GR_cog.misc.Ode7
ocMA.OdeW7C24.melody = he.h.m8_gr_GR_cog.heHE.TheouSynkatavasin.name
ocMA.OdeW7C24.incipit = "Ἐμὲ τὸν βιώσαντα, ἐν ἀμελείᾳ…"
ocMA.OdeW7C24.text = "Ἐμὲ τὸν βιώσαντα, ἐν ἀμελείᾳ, καὶ παραβλέψαντα, τοὺς ἁγίους σου νόμους, καὶ τὰ σεπτά σου Σῶτερ ἐντάλματα, οἴκτειρον σῶσον διὰ τῆς Τεκούσης σε, ὡς εὐεργέτης Θεός, καὶ πολυέλεος."

ocMA.OdeW8C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW8C1H.ode = miscellanea_gr_GR_cog.misc.Ode8
ocMA.OdeW8C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
ocMA.OdeW8C1H.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.melody
ocMA.OdeW8C1H.incipit = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.incipit
ocMA.OdeW8C1H.text = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.text

ocMA.OdeW8C11.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
ocMA.OdeW8C11.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
ocMA.OdeW8C11.incipit = "Ῥίζης Χριστὲ ἐβλάστησας, Ἱεσσαὶ σωματούμενος…"
ocMA.OdeW8C11.text = "Ῥίζης Χριστὲ ἐβλάστησας, Ἱεσσαὶ σωματούμενος, καὶ ῥιζοτομεῖς, τὴν ἐκφυεῖσαν ἄκανθαν, Ἀδὰμ παραβάσεως, στέφος φορῶν ἀκάνθινον· ξύλῳ δὲ παγείς, τὴν ἐκ τοῦ ξύλου ἰάσω, βλαστήσασαν κατάραν, καὶ τοὺς μέλποντας σῴζεις· Λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

ocMA.OdeW8C12.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
ocMA.OdeW8C12.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
ocMA.OdeW8C12.incipit = "Ἵνα Θεὸν τὸν ἄνθρωπον, ἀπεργάσῃ…"
ocMA.OdeW8C12.text = "Ἵνα Θεὸν τὸν ἄνθρωπον, ἀπεργάσῃ Φιλάνθρωπε, γέγονας βροτός, καὶ τῷ Σταυρῷ ὡμίλησας, πλευρὰν ἐκκεντούμενος, καὶ ὄξος ποτιζόμενος· ὅθεν οἱ σωθέντες, σοῦ τοῖς πάθεσι Λόγε, βοῶμεν εὐχαρίστως· Ἱερεῖς εὐλογεῖτε, λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

ocMA.OdeW8C13.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
ocMA.OdeW8C13.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
ocMA.OdeW8C13.incipit = "Συμποδισθέντες Μάρτυρες, καὶ ὡς ἄρνες…"
ocMA.OdeW8C13.text = "Συμποδισθέντες Μάρτυρες, καὶ ὡς ἄρνες θυόμενοι, καὶ ἐπὶ πυρός, ἀνηλεῶς ὀπτώμενοι, θηρσὶν ἐκδιδόμενοι, τὰς κεφαλὰς τεμνόμενοι, χαίρετε χαρᾷ, ἀνεκλαλήτῳ βοῶντες· Οἱ παῖδες εὐλογεῖτε, ἱερεῖς ἀνυμνεῖτε, λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

ocMA.OdeW8C14.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW8C14.ode = miscellanea_gr_GR_cog.misc.Ode8
ocMA.OdeW8C14.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
ocMA.OdeW8C14.incipit = "Στεφανηφόροι Μάρτυρες, τῶν Ἀγγέλων συνόμιλοι…"
ocMA.OdeW8C14.text = "Στεφανηφόροι Μάρτυρες, τῶν Ἀγγέλων συνόμιλοι, οἱ τοὺς ὠμοτάτους, δυσμενεῖς πατήσαντες, πρεσβείαν ποιήσατε, ὑπὲρ ἡμῶν πρὸς Κύριον, ὅπως ἐν ἀγάπῃ, καὶ πολλῇ ὁμονοίᾳ, ζησώμεθα βοῶντες· Ἱερεῖς εὐλογεῖτε, λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

ocMA.OdeW8C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
ocMA.OdeW8C1T.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
ocMA.OdeW8C1T.incipit = "Ὀδυνηρῶς στενάζουσα, μητρικῶς ὀλολύζουσα, καὶ…"
ocMA.OdeW8C1T.text = "Ὀδυνηρῶς στενάζουσα, μητρικῶς ὀλολύζουσα, καὶ τὴν ἐκ τῶν σπλάγχνων, συνοχὴν μὴ φέρουσα, Σταυρῷ ἐνητένιζες, τῷ ἐκ τῆς σῆς τεχθέντι γαστρός· Τέκνον ἐκβοῶσα, τί τὸ ὅραμα τοῦτο; πῶς πάσχεις ὁ τῇ θείᾳ, ἀπαθὴς φύσει! θέλων, τὸ γένος τῶν ἀνθρώπων, φθορᾶς ἐλευθερῶσαι."

ocMA.OdeW8C21.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
ocMA.OdeW8C21.greekmelody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.greekname
ocMA.OdeW8C21.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
ocMA.OdeW8C21.incipit = "Νενεκρωμένην ζώωσον, συμπτωθεῖσαν ἀνάστησον, τετραυματισμένην…"
ocMA.OdeW8C21.text = "Νενεκρωμένην ζώωσον, συμπτωθεῖσαν ἀνάστησον, τετραυματισμένην, τὴν ψυχήν μου ἴασαι, τὸν νοῦν μου εἰρήνευσον, τῶν πειρασμῶν τὰ κύματα, πράϋνον Παρθένε, καὶ βοῶντά με σῶσον. Οἱ παῖδες εὐλογεῖτε, ἱερεῖς ἀνυμνεῖτε, λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

ocMA.OdeW8C22.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
ocMA.OdeW8C22.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
ocMA.OdeW8C22.incipit = "Ὡς ὁ λῃστὴς κραυγάζω σοι…"
ocMA.OdeW8C22.text = "Ὡς ὁ λῃστὴς κραυγάζω σοι· Μνήσθητί μου Φιλάνθρωπε· κλαίω ὡς ἡ πόρνη, καὶ βοῶ σοι· Ἥμαρτον, ὡς πάλαι ὁ ἄσωτος, μετανοοῦντα δέξαι με, τὸν ἀπεγνωσμένον, διὰ τῆς Θεοτόκου, προθύμως ἵνα μέλπω· Ἱερεῖς εὐλογεῖτε, λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

ocMA.OdeW8C23.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW8C23.ode = miscellanea_gr_GR_cog.misc.Ode8
ocMA.OdeW8C23.melody = he.h.m8_gr_GR_cog.heHE.EptaplasiosKaminon.name
ocMA.OdeW8C23.incipit = "Ἱκετικῶς βοῶμέν σοι, Θεοτόκε Πανύμνητε…"
ocMA.OdeW8C23.text = "Ἱκετικῶς βοῶμέν σοι, Θεοτόκε Πανύμνητε, μετὰ τῶν ἀπείρων, νοερῶν δυνάμεων, Μαρτύρων Ὁσίων τε, καὶ Ἀποστόλων καὶ Προφητῶν· Ποίησον πρεσβείαν, ὑπὲρ πάντων τῶν πίστει, ἐνθέως μελῳδούντων· Ἱερεῖς εὐλογεῖτε, λαὸς ὑπερυψοῦτε, Χριστὸν εἰς τοὺς αἰῶνας."

ocMA.OdeW9C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW9C1H.ode = miscellanea_gr_GR_cog.misc.Ode9
ocMA.OdeW9C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.greekname
ocMA.OdeW9C1H.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.melody
ocMA.OdeW9C1H.incipit = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.incipit
ocMA.OdeW9C1H.text = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.text

ocMA.OdeW9C11.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
ocMA.OdeW9C11.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
ocMA.OdeW9C11.incipit = "Ἰατρεύσας μου Δέσποτα τὰς πληγάς…"
ocMA.OdeW9C11.text = "Ἰατρεύσας μου Δέσποτα τὰς πληγάς, πληγωθεὶς καὶ αἱμάξας, τὰς χεῖράς σου, καὶ πρὸς ὁδούς, βαίνειν σωτηρίους ὡς ἀγαθός, κατεύθυνάς με Κύριε, πόδας ὀρυχθείς ἐπὶ τοῦ Σταυροῦ, οὓς πάλαι οἱ γενάρχαι, ἀκούσαντες βαδίζειν, ἐν Παραδείσῳ κατεκρύπτοντο."

ocMA.OdeW9C12.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
ocMA.OdeW9C12.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
ocMA.OdeW9C12.incipit = "Ὠρθώθη ὀρθωθέντος σου ἐν Σταυρῷ…"
ocMA.OdeW9C12.text = "Ὠρθώθη ὀρθωθέντος σου ἐν Σταυρῷ, ὁ πεσὼν πτῶμα μέγα πρωτόπλαστος, ἡ δὲ ἰσχύς, ἅπασα ἐπτώθη τοῦ δυσμενοῦς, πᾶσα δὲ γῆ ἡγίασται, αἵματι καὶ ὕδατι ἐκ τῆς σῆς, πλευρᾶς προχεομένῳ· διό σε Πανοικτίρμον, ἀκαταπαύστως μεγαλύνομεν."

ocMA.OdeW9C13.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
ocMA.OdeW9C13.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
ocMA.OdeW9C13.incipit = "Στρεβλούμενοι τὰς στρέβλας τοῦ πονηροῦ…"
ocMA.OdeW9C13.text = "Στρεβλούμενοι τὰς στρέβλας τοῦ πονηροῦ, διελύσατε ἅγιοι Μάρτυρες, καὶ τοῖς δεσμοῖς, οἷς περ ὑπεμείνατε καρτερῶς, τοῦτον συνεποδίσατε, καὶ καθυπετάξατε τοῖς ποσίν, αἰσχύνης πεπλησμένον, καὶ γέλως τοῖς ὁρῶσι, χάριτι θείᾳ χρηματίσαντα."

ocMA.OdeW9C14.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
ocMA.OdeW9C14.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
ocMA.OdeW9C14.incipit = "Ἡ γῆ καθηγιάσθη τοῖς ἱεροῖς…"
ocMA.OdeW9C14.text = "Ἡ γῆ καθηγιάσθη τοῖς ἱεροῖς, τῶν Μαρτύρων λειψάνοις καὶ αἵμασι· καὶ γὰρ πηγήν, βρύουσαν ἰάσεις παντοδαπάς, ταῦτα ἐνθέως κέκτηται, πάθη τῶν σωμάτων καὶ τῶν ψυχῶν, ἀπαύστως ἰωμένην, καὶ λώβην τῶν δαιμόνων, ἐκκρουομένην θείᾳ χάριτι."

ocMA.OdeW9C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
ocMA.OdeW9C1T.melody = he.h.m8_gr_GR_cog.heHE.ExestiEpiTouto.name
ocMA.OdeW9C1T.incipit = "Φυγοῦσα τὰς ὠδῖνας τὰς μητρικάς…"
ocMA.OdeW9C1T.text = "Φυγοῦσα τὰς ὠδῖνας τὰς μητρικάς, τῷ καιρῷ τῆς λοχείας Μακρόθυμε, σὲ ἐν τῷ νῦν, πάθει ἑκουσίως προσομιλεῖν, καὶ ἄλγος καθυφίστασθαι, ἤλγησα τὰ σπλάγχνα καὶ τὴν ψυχήν, ὀδύνης ἐπληρώθην, ἡ Πάναγνος ἐβόα· ἣν ἐπαξίως μεγαλύνομεν."

ocMA.OdeW9C21.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
ocMA.OdeW9C21.greekmelody = he.h.m8_gr_GR_cog.heHE.EfrixePasaAkoi.greekname
ocMA.OdeW9C21.melody = he.h.m8_gr_GR_cog.heHE.EfrixePasaAkoi.name
ocMA.OdeW9C21.incipit = "Ὦ θεία κλίνη Σολομών, ἣν…"
ocMA.OdeW9C21.text = "Ὦ θεία κλίνη Σολομών, ἣν κυκλοῦσι δυνατοὶ νῦν ἑξήκοντα, ῥήσει τῆς θείας Γραφῆς, ἐν ᾗ ὁ Λόγος ἐπανεπαύσατο, ταῖς μυριάσι με ἀεί, δαιμόνων κλονούμενον, ἄτρωτον φύλαξον, τῇ δυνάμει σου ἁγνὴ Ἀειπάρθενε."

ocMA.OdeW9C22.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
ocMA.OdeW9C22.melody = he.h.m8_gr_GR_cog.heHE.EfrixePasaAkoi.name
ocMA.OdeW9C22.incipit = "Στάζουσα θεῖον γλυκασμόν, τῶν ἁπάντων…"
ocMA.OdeW9C22.text = "Στάζουσα θεῖον γλυκασμόν, τῶν ἁπάντων γλυκασμὸν ἡ κυήσασα, ἰῷ τοῦ ὄφεως, τὴν φαρμαχθεῖσαν ψυχήν μου γλύκανον, ἀλλοτριοῦσά με πικρᾶς, ἁμαρτίας πάντοτε, τῇ μεσιτείᾳ σου, προστασία τῶν πιστῶν ἀκαταίσχυντε."

ocMA.OdeW9C23.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW9C23.ode = miscellanea_gr_GR_cog.misc.Ode9
ocMA.OdeW9C23.melody = he.h.m8_gr_GR_cog.heHE.EfrixePasaAkoi.name
ocMA.OdeW9C23.incipit = "Ἥλιε δόξης Ἰησοῦ, τὴν ἀθλίαν…"
ocMA.OdeW9C23.text = "Ἥλιε δόξης Ἰησοῦ, τὴν ἀθλίαν μου ψυχὴν φωταγώγησον, ταῖς παρακλήσεσι, τῆς σὲ τεκούσης Ἁγνῆς θεόπαιδος, τῶν Ἀσωμάτων λειτουργῶν, σεπτῶν Ἀποστόλων σου, Ἱεραρχῶν Προφητῶν, καὶ Μαρτύρων εὐκλεῶν καὶ Ὁσίων σου."

ocMA.OdeW9C24.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.OdeW9C24.ode = miscellanea_gr_GR_cog.misc.Ode9
ocMA.OdeW9C24.melody = he.h.m8_gr_GR_cog.heHE.EfrixePasaAkoi.name
ocMA.OdeW9C24.incipit = "Φρίττω σου μόνε Βασιλεῦ, τὴν…"
ocMA.OdeW9C24.text = "Φρίττω σου μόνε Βασιλεῦ, τὴν δευτέραν παρουσίαν καὶ δέδοικα, ὅλος κατάκριτος, ἠπορημένος ὑπάρχων Κύριε· διὸ πρὸ τέλους σοι βοῶ, διὰ τῆς Τεκούσης σε· Φεῖσαι καὶ σῶσόν με, ἐλεῆμον Ἀγαθὲ καὶ Φιλάνθρωπε."

ocMA.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Aposticha1.melody = ""
ocMA.Aposticha1.incipit = "Τοῦ Μωϋσέως ἡ ῥάβδος, τὸν…"
ocMA.Aposticha1.text = "Τοῦ Μωϋσέως ἡ ῥάβδος, τὸν τίμιον Σταυρόν σου, προετύπου Σωτὴρ ἡμῶν· ἐν αὐτῷ γὰρ σῴζεις, ὡς ἐκ βυθοῦ θαλάσσης, τὸν λαόν σου Φιλάνθρωπε."

ocMA.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Aposticha2.greekmelody = he.a.m8_gr_GR_cog.heAU.OEnEdemParadeisos.greekname
ocMA.Aposticha2.melody = he.a.m8_gr_GR_cog.heAU.OEnEdemParadeisos.melody
ocMA.Aposticha2.incipit = he.a.m8_gr_GR_cog.heAU.OEnEdemParadeisos.incipit
ocMA.Aposticha2.text = he.a.m8_gr_GR_cog.heAU.OEnEdemParadeisos.text

ocMA.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.Aposticha3.greekmelody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.greekname
ocMA.Aposticha3.melody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.name
ocMA.Aposticha3.incipit = "Μάρτυρες Χριστοῦ οἱ ἀήττητοι, οἱ…"
ocMA.Aposticha3.text = "Μάρτυρες Χριστοῦ οἱ ἀήττητοι, οἱ νικήσαντες τὴν πλάνην, τῇ δυνάμει τοῦ Σταυροῦ, ἀπολαύετε τὴν χάριν, αἰωνίως τῆς ζωῆς. Τυράννων, ἀπειλὰς οὐκ ἐπτοήθητε, βασάνοις, αἰκιζόμενοι εὐφραίνεσθε, καὶ νῦν τὰ αἵματα ὑμῶν, γέγονεν ἰάματα ταῖς ψυχαῖς ἡμῶν, πρεσβεύσατε, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν."

ocMA.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.AposTheotokion.greekmelody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.greekname
ocMA.AposTheotokion.melody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.name
ocMA.AposTheotokion.incipit = "Ξύλῳ προσπηγνύμενον…"
ocMA.AposTheotokion.text = "Ξύλῳ προσπηγνύμενον Κύριε, ὡς ἑώρακεν ἀσπόρως ἡ τεκοῦσά σε Ἀμνάς, κατεξαίνετο τὰς ὄψεις, καὶ ἐβόα ἐν κλαυθμῷ· Υἱέ μου, πῶς σφαγὴν φέρεις τὴν ἄδικον; πῶς θνῄσκεις, ὁ ἀθάνατος ὡς ἄνθρωπος; Λόγον μοι δὸς φῶς γλυκύτατον, βλέψον Μητέρα θρηνοῦσάν σε, καὶ δόξασον, ταύτην Λόγε τῇ ἐγέρσει σου."

ocMA.ApolTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
ocMA.ApolTheotokion.melody = ""
ocMA.ApolTheotokion.incipit = oc.m7.d5_gr_GR_cog.ocMA.Kathisma13.incipit
ocMA.ApolTheotokion.text = oc.m7.d5_gr_GR_cog.ocMA.Kathisma13.text

ocLI.Beatitudes1.mode = miscellanea_gr_GR_cog.misc.Mode8
ocLI.Beatitudes1.melody = ""
ocLI.Beatitudes1.incipit = oc.m8.d1_gr_GR_cog.ocLI.Beatitudes1.incipit
ocLI.Beatitudes1.text = oc.m8.d1_gr_GR_cog.ocLI.Beatitudes1.text

ocLI.Beatitudes2.mode = miscellanea_gr_GR_cog.misc.Mode8
ocLI.Beatitudes2.melody = ""
ocLI.Beatitudes2.incipit = "Ῥάβδῳ Μωϋσῆς, Σταυρὸν ἐξεικονίζει, τέμνει…"
ocLI.Beatitudes2.text = "Ῥάβδῳ Μωϋσῆς, Σταυρὸν ἐξεικονίζει, τέμνει τὸν βυθόν, λαὸν Ἰσραηλίτην, διαβιβάζων, ἡμεῖς δὲ τοῦτον τυποῦντες, τοὺς νοητοὺς ἐχθροὺς τροπούμεθα."

ocLI.Beatitudes3.mode = miscellanea_gr_GR_cog.misc.Mode8
ocLI.Beatitudes3.melody = ""
ocLI.Beatitudes3.incipit = "Πάλαι Ἰακώβ, ἐπευλογῶν τοὺς Παῖδας…"
ocLI.Beatitudes3.text = "Πάλαι Ἰακώβ, ἐπευλογῶν τοὺς Παῖδας, χεῖρας ἐναλλάξ, ἐφήπλου σημαινούσας, τὸν σὸν Σταυρόν, διʼ οὗ πάντες ἐκ τῆς κατάρας, Χριστὲ Σωτὴρ ἠλευθερώθημεν."

ocLI.Beatitudes4.mode = miscellanea_gr_GR_cog.misc.Mode8
ocLI.Beatitudes4.melody = ""
ocLI.Beatitudes4.incipit = "Πάθη τοῦ Χριστοῦ, ζηλοῦντες Ἀθλοφόροι…"
ocLI.Beatitudes4.text = "Πάθη τοῦ Χριστοῦ, ζηλοῦντες Ἀθλοφόροι, βάσανα πικρά, ἠνέγκατε γενναίως, καὶ ἀφθαρσίας στεφάνοις καταστεφθέντες, τοὺς οὐρανοὺς περιπολεύετε."

ocLI.BeatitudesTr.mode = miscellanea_gr_GR_cog.misc.Mode8
ocLI.BeatitudesTr.melody = ""
ocLI.BeatitudesTr.incipit = "Δόξα τῷ Πατρί, τῷ μόνῳ…"
ocLI.BeatitudesTr.text = "Δόξα τῷ Πατρί, τῷ μόνῳ ἀθανάτῳ, δόξα τῷ Υἱῷ, τῷ ζῶντι εἰς αἰῶνας, δόξα τῷ Πνεύματι ἅμα, τῷ παναγίῳ, τῷ πᾶσαν κτίσιν ἁγιάζοντι."

ocLI.BeatitudesT.mode = miscellanea_gr_GR_cog.misc.Mode8
ocLI.BeatitudesT.melody = ""
ocLI.BeatitudesT.incipit = "Ἐκ παρθενικῆς, ἀνέτειλε γαστρός σου…"
ocLI.BeatitudesT.text = "Ἐκ παρθενικῆς, ἀνέτειλε γαστρός σου, ὁ Δημιουργός, ἡλίου καὶ σελήνης, ὃν καθορῶσα σταυρούμενον Θεοτόκε, πᾶσα ἡ κτίσις ἐκυμαίνετο."

ocLI.MM.Beatitudes1234TrTas78910GB.text = properties_gr_GR_cog.media.key

