octrMA.Kathisma12.mode = miscellanea_gr_GR_cog.misc.Mode5
octrMA.Kathisma12.greekmelody = oc.m5.d5_gr_GR_cog.ocMA.Kathisma12.greekmelody
octrMA.Kathisma12.melody = oc.m5.d5_gr_GR_cog.ocMA.Kathisma12.melody
octrMA.Kathisma12.incipit = oc.m5.d5_gr_GR_cog.ocMA.Kathisma12.incipit
octrMA.Kathisma12.text = oc.m5.d5_gr_GR_cog.ocMA.Kathisma12.text

octrMA.Kathisma1T.mode = miscellanea_gr_GR_cog.misc.Mode5
octrMA.Kathisma1T.greekmelody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.greekname
octrMA.Kathisma1T.melody = he.a.m5_gr_GR_cog.heAU.TonSynanarchonLogon.name
octrMA.Kathisma1T.incipit = "Ἀπειρόγαμε Νύμφη…"
octrMA.Kathisma1T.text = "Ἀπειρόγαμε Νύμφη καὶ ἀειπάρθενε, σὺν Ἀγγέλοις ἀπαύστως ἀνευφημοῦμέν σε, ὅτι ἐποίησεν ἡμῖν μεγαλεῖα διὰ σοῦ, ὁ Υἱός σου καὶ Θεός, ὁ πρὸ αἰώνων ἐκ Πατρός, ἐν μήτρᾳ σου χωρηθῆναι, εὐδοκήσας, καὶ ἐκ τῆς πλάνης, ἐλευθερῶσαι τὸ γένος ἡμῶν."

octrMA.Ode7Martyricon.mode = miscellanea_gr_GR_cog.misc.Mode5
octrMA.Ode7Martyricon.greekmelody = oc.m5.d3_gr_GR_cog.ocMA.Kathisma32.greekmelody
octrMA.Ode7Martyricon.melody = oc.m5.d3_gr_GR_cog.ocMA.Kathisma32.melody
octrMA.Ode7Martyricon.incipit = oc.m5.d3_gr_GR_cog.ocMA.Kathisma32.incipit
octrMA.Ode7Martyricon.text = oc.m5.d3_gr_GR_cog.ocMA.Kathisma32.text

