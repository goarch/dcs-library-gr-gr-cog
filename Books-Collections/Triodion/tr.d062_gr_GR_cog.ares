trCO.header = "(Μέγα)"

trVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode4
trVE.Stichera01.greekmelody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.greekname
trVE.Stichera01.melody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.name
trVE.Stichera01.incipit = "Τῶν Ἀποστόλων δυὰς ἱερωτάτη, ἕνα…"
trVE.Stichera01.text = "Τῶν Ἀποστόλων δυὰς ἱερωτάτη, ἕνα τῆς Τριάδος σε, ἐπισταμένη Χριστέ, νῦν παρὰ σοῦ ἀποστέλλεται, ἀγάγαι πῶλον, ὑποζυγίου υἱὸν ὡς γέγραπται, ἐφ΄ ᾧ ταπεινούμενος, καθίσεις εὔσπλαγχνε, τὴν ἐν ὑψίστοις θελήματι, καθέδραν πᾶσι, τοῖς σὲ ποθοῦσιν ἑτοιμαζόμενος, καὶ τοὺς ἀλόγοις ὑποκύψαντας, φρενοβλαβῶς Λόγε πάθεσι λογισμούς ἀπεργάσω. Ὡσαννά σοι ἀνακράζοντας."

trVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode4
trVE.Stichera02.greekmelody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.greekname
trVE.Stichera02.melody = he.a.m4_gr_GR_cog.heAU.OExYpsistouKlitheis.name
trVE.Stichera02.incipit = "Καθυποδέχου Σιὼν τὸν Βασιλέα, ἰδού…"
trVE.Stichera02.text = "Καθυποδέχου Σιὼν τὸν Βασιλέα, ἰδού σοι πρᾳότατος, ἤδη ἐφίσταται, ἐξαναστῆσαι τὸν Λάζαρον, καὶ καταλῦσαι, τὸ τοῦ θανάτου πικρὸν βασίλειον. Πληθὺς θεοσύλλεκτε, τῶν ἱερῶν Μοναστῶν, μετὰ Μιγάδων ἀθροίσθητε, καθυπαντῆσαι, μετὰ Βαΐων Χριστῷ κραυγάζοντες· Εὐλογημένος ὁ ἐρχόμενος, σῶσαι γένος βροτῶν διὰ πάθους Σταυροῦ, καὶ ἀπάθειαν πᾶσι, παρασχεῖν διʹ ἀγαθότητα."

trVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.Stichera03.greekmelody = he.a.m8_gr_GR_cog.heAU.OEnEdemParadeisos.greekname
trVE.Stichera03.melody = he.a.m8_gr_GR_cog.heAU.OEnEdemParadeisos.name
trVE.Stichera03.incipit = "Ὁ Σεραφὶμ τοῖς ἄνω φοβερός…"
trVE.Stichera03.text = "Ὁ Σεραφὶμ τοῖς ἄνω φοβερός, Χριστὲ ἐποχούμενος, ὡς Θεός τε καὶ τῶν ὅλων ποιητής, αὐτὸς ἐν πώλῳ ἐπὶ γῆς, καθεσθῆναι ἐπείγεσαι, ὡς ὑπάρχων καθʹ ἡμᾶς ἀνθρωπικῶς, ἡ Βηθανία ἀγάλλεται, ὡς δεχομένη σε Σωτήρ, Ἱεροσόλυμα χαίρει δέ, ὡς προσδοκῶντά σε λαβεῖν, θάνατος τέθνηκε, προαισθόμενος τὸν Λάζαρον, φοιτᾶν ἐκ τῶν νεκρῶν, καὶ ἡμεῖς τοῖς Βαΐοις, προϋπαντὴν τελοῦντες ἐν χαρᾷ, ἀνυμνοῦμεν τὸ κράτος, τῆς ἀγαθότητός σου Κύριε."

trVE.AposIdiomelon1.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.AposIdiomelon1.melody = miscellanea_gr_GR_cog.misc.Idiomelon
trVE.AposIdiomelon1.incipit = "Τοῦ Πλουσίου τῆς ἀσυμπαθοῦς ὁμοιώσεως…"
trVE.AposIdiomelon1.text = "Τοῦ Πλουσίου τῆς ἀσυμπαθοῦς ὁμοιώσεως, καὶ ἀμεταδότσυ γνώμης, ῥῦσαί με Χριστὲ ὁ Θεός, ὁ διὰ Σταυροῦ σου, καθαρισμὸν τῶν ἁμαρτιῶν ἡμῶν ποιησάμενος, Λαζάρου δὲ τοῦ πτωχοῦ, τῆς εὐχαρίστου ὑπομονῆς, ζηλωτὴν ἀνάδειξον, καὶ τῶν κόλπων τοῦ Πατριάρχου Ἀβραάμ, μὴ ἀποξενώσῃς με, διὰ τὸ μέγα σου ἔλεος."

trVE.AposMartyric.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.AposMartyric.melody = ""
trVE.AposMartyric.incipit = "Μάρτυρες Κυρίου, πάντα τόπον ἁγιάζετε…"
trVE.AposMartyric.text = "Μάρτυρες Κυρίου, πάντα τόπον ἁγιάζετε, καὶ πᾶσαν νόσον θεραπεύετε, καὶ νῦν πρεσβεύσατε, ῥυσθῆναι τῶν παγίδων τοῦ ἐχθροῦ, τὰς ψυχὰς ἡμῶν δεόμεθα."

trVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.AposTheotokion.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
trVE.AposTheotokion.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
trVE.AposTheotokion.incipit = me.m11.d05_gr_GR_cog.meVE.SticStavrotheotokion.incipit
trVE.AposTheotokion.text = me.m11.d05_gr_GR_cog.meVE.SticStavrotheotokion.text

trMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Kathisma21.greekmelody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.greekname
trMA.Kathisma21.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
trMA.Kathisma21.incipit = "Δυὰς ἀποστέλλεται, τῶν Μαθητῶν ἀγαγεῖν…"
trMA.Kathisma21.text = "Δυὰς ἀποστέλλεται, τῶν Μαθητῶν ἀγαγεῖν, τὸν πῶλον ὡς γέγραπται, ἐν ᾧ Χριστὸς ἐπιβάς, ὡραῖος ἐλεύσεται, αἴνεσιν ἐκ νηπίων, καταρτίσασθαι θείαν. Τοῦτον οὖν ὑπαντῆσαι, ἐπειχθῶμεν σπουδαίως, Βαΐα ἐναρέτων, αὐτῷ φέροντες πράξεων."

trMA.Kathisma22.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Kathisma22.greekmelody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.greekname
trMA.Kathisma22.melody = he.a.m4_gr_GR_cog.heAU.TachyProkatalave.name
trMA.Kathisma22.incipit = oc.m4.d6_gr_GR_cog.ocMA.Kathisma23.incipit
trMA.Kathisma22.text = oc.m4.d6_gr_GR_cog.ocMA.Kathisma23.text

trMA.Kathisma31.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Kathisma31.greekmelody = he.a.m8_gr_GR_cog.heAU.AnestisEkNekron.greekname
trMA.Kathisma31.melody = he.a.m8_gr_GR_cog.heAU.AnestisEkNekron.name
trMA.Kathisma31.incipit = "Δυὰς τῶν Μαθητῶν, ἀποστέλλεται σήμερον…"
trMA.Kathisma31.text = "Δυὰς τῶν Μαθητῶν, ἀποστέλλεται σήμερον, τὸν πῶλον ἀγαγεῖν, τῷ Δεσπότῃ τῶν ἁπάντων, ἔρχεται ἐπιβῆναι, ὁ ὀχούμενος Σεραφὶμ πλήθεσιν, ἄρχεται δειματοῦσθαι, ὁ κοσμοκράτωρ παμφάγος θάνατος, διὰ Λαζάρου πρῶτον σκυλευθείς, τὸ γένος τῶν ἀνθρώπων."

trMA.Kathisma32.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Kathisma32.greekmelody = he.a.m8_gr_GR_cog.heAU.AnestisEkNekron.greekname
trMA.Kathisma32.melody = he.a.m8_gr_GR_cog.heAU.AnestisEkNekron.name
trMA.Kathisma32.incipit = "Τῷ πάθει τοῦ Υἱοῦ, ἡ…"
trMA.Kathisma32.text = "Τῷ πάθει τοῦ Υἱοῦ, ἡ Ἁγνὴ ἐφεστῶσα, θρηνοῦσα γοερῶς, κατηλάλαζε μέλος. Πῶς σε τὸν ἀσιγήτως, Ἀγγέλων ὕμνοις δοξολογούμενον, παῖδες Ἑβραίων φεῦ μοι! Πιλάτου κρίσει Υἱὲ παρέστησαν! Ὑμνολογῶ σου Λόγε τὴν πολλήν, καὶ ἄῤῥητον εὐσπλαγχνίαν."

trMA.C1.poet = poets_gr_GR_cog.po.Iosif

trMA.C2.poet = poets_gr_GR_cog.po.Theodorou

trMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode5C11.greekmelody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.greekname
trMA.Ode5C11.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
trMA.Ode5C11.incipit = "Ἐπὶ Σταυροῦ σὺ Κύριε, ὑπνώσας…"
trMA.Ode5C11.text = "Ἐπὶ Σταυροῦ σὺ Κύριε, ὑπνώσας μεταβέβληκας, εἰς ὕπνον Δέσποτα τὸν θάνατον· Λάζαρος γὰρ ἐβόας, ὁ φίλος κεκοίμηται, ἀλλὰ ἀπελεύσομαι, ἐξυπνῆσαι νῦν αὐτόν."

trMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode5C12.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
trMA.Ode5C12.incipit = "Τῶν Προφητῶν κηρύγματα, πληρῶν προφητευόμενα…"
trMA.Ode5C12.text = "Τῶν Προφητῶν κηρύγματα, πληρῶν προφητευόμενα, προφητοκτόνον πρὸς τὴν πόλιν Χριστέ, οἰκτίρμον παρεγένου, κτανθῆναι θελήματι, τὸν ἀποκτανθέντα με, διασῴζων τῆς φθορᾶς."

trMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode5C13.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
trMA.Ode5C13.incipit = "Οἱ σῶμα τὸ δυσήνιον, τῷ…"
trMA.Ode5C13.text = "Οἱ σῶμα τὸ δυσήνιον, τῷ λόγῳ ὑποτάξαντες, διʹ ἐγκρατείας καὶ δεήσεως, μονασταὶ καὶ μιγάδες, Χριστῷ ὑπαντήσατε, πώλῳ ἐπιβαίνοντι, ἐρχομένῳ τε παθεῖν."

trMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode5C1T.melody = he.h.m4_gr_GR_cog.heHE.AnateilonMoiKyrie.name
trMA.Ode5C1T.incipit = "Ῥανίσι τοῦ ἐλέους σου, κατάρδευσον…"
trMA.Ode5C1T.text = "Ῥανίσι τοῦ ἐλέους σου, κατάρδευσον Πανάχραντε, τὴν ἐκτακεῖσάν μου καρδίαν, φλογμῷ τῆς ἁμαρτίας, καὶ τὸν ἐσβεσμένον μου, τῆς καρδίας ἄναψον, λύχνον πύλη τοῦ φωτός."

trMA.Ode5C21.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode5C21.greekmelody = he.h.m8_gr_GR_cog.heHE.TonZofonTisPsychisMou.greekname
trMA.Ode5C21.melody = he.h.m8_gr_GR_cog.heHE.TonZofonTisPsychisMou.name
trMA.Ode5C21.incipit = "Δυάδα Μαθητῶν σου, ἐν τῷ…"
trMA.Ode5C21.text = "Δυάδα Μαθητῶν σου, ἐν τῷ μέλλειν σε φθάνειν εἰς Βηθανίαν Χριστέ, στέλλεις ἀγάγαι σοι πῶλον, ἐφʼ ὃν οὐδεὶς ἀνθρώπων ἐκάθισε· πλὴν γάρ σου, οὐδεὶς τὰ ἄλογα ἔθνη, Σωτὴρ καθυπέταξε."

trMA.Ode5C22.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode5C22.melody = he.h.m8_gr_GR_cog.heHE.TonZofonTisPsychisMou.name
trMA.Ode5C22.incipit = "Συνῆλθεν Ἰουδαίων, ἐξ Ἱεροσολύμων εἰς…"
trMA.Ode5C22.text = "Συνῆλθεν Ἰουδαίων, ἐξ Ἱεροσολύμων εἰς Βηθανίαν πληθύς, καὶ ταῖς συγγόνοις Λαζάρου, σήμερον μὲν συμπάσχει, ἐπὰν δὲ αὔριον γνῷ, τοῦτον ἐκ τάφου πηδῶντα, κινεῖται πρὸς φόνον Χριστοῦ."

trMA.Ode5C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode5C2Tr.melody = he.h.m8_gr_GR_cog.heHE.TonZofonTisPsychisMou.name
trMA.Ode5C2Tr.incipit = "Τριὰς ἡ παναγία, ὁ Πατήρ…"
trMA.Ode5C2Tr.text = "Τριὰς ἡ παναγία, ὁ Πατήρ, ὁ Υἱός, καὶ Πνεῦμα τὸ παντουργόν, ἡ μακαρία Θεότης, ἡ ἄναρχος οὐσία, τὸ τριλαμπέστατον φῶς, τὸ πανδερκέστατον κράτος, τοὺς δούλους σου φύλαττε."

trMA.Ode5C2T.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode5C2T.melody = he.h.m8_gr_GR_cog.heHE.TonZofonTisPsychisMou.name
trMA.Ode5C2T.incipit = "Σταυρῷ σε κατιδοῦσα, ἐμπεπαρμένον τοῖς…"
trMA.Ode5C2T.text = "Σταυρῷ σε κατιδοῦσα, ἐμπεπαρμένον τοῖς ἥλοις, Χριστὲ ἡ Μήτηρ σου, καὶ ἐκ πλευρᾶς ζωηρᾶς σου, ῥυὲν Αἷμα καὶ ὕδωρ, κατετιτρώσκετο, τῇ μητρικῇ συμπαθείᾳ· Υἱόν γάρ σε ἔγνω αὐτῆς."

trMA.Ode5C2A1.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C2A1.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode5C2A1.melody = he.h.m8_gr_GR_cog.heHE.TonZofonTisPsychisMou.name
trMA.Ode5C2A1.incipit = "Ἰδοὺ παρεσκευάσθη, ὁ Χριστὸς ἐπιστῆναι…"
trMA.Ode5C2A1.text = "Ἰδοὺ παρεσκευάσθη, ὁ Χριστὸς ἐπιστῆναι, πρὸς τὴν Ἱερουσαλήμ, οἱ ἐν τοῖς ὄρεσι πάντες, καὶ ἐν ταῖς ἐρημίαις, συνέλθετε μονασταί, αὐτῷ χαρὰ ὑπαντῆσαι, σύν πάσῃ τῇ ὑπʼ οὐρανῷ."

trMA.Ode5C2H.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C2H.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode5C2H.greekmelody = he.h.m8_gr_GR_cog.heHE.TonZofonTisPsychisMou.greekname
trMA.Ode5C2H.melody = he.h.m8_gr_GR_cog.heHE.TonZofonTisPsychisMou.melody
trMA.Ode5C2H.incipit = he.h.m8_gr_GR_cog.heHE.TonZofonTisPsychisMou.incipit
trMA.Ode5C2H.text = he.h.m8_gr_GR_cog.heHE.TonZofonTisPsychisMou.text

trMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode8C11.greekmelody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.greekname
trMA.Ode8C11.melody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.name
trMA.Ode8C11.incipit = "Τὴν ἀνάστασιν καὶ ζωήν, ἔχουσαι…"
trMA.Ode8C11.text = "Τὴν ἀνάστασιν καὶ ζωήν, ἔχουσαι Γυναῖκες προσφιλῆ, τί ἀποδύρεσθε πικρῶς; παραγίνεται καὶ ζωώσει, τὸν γνήσιον φίλον, τῇ αὐτοῦ ἀναστάσει τὴν ἔγερσιν, πάντων προμηνύων, ὁ πάντων εὐεργέτης."

trMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode8C12.melody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.name
trMA.Ode8C12.incipit = "Καταγώγια μοναστῶν, ἀθροίσθητε ὡς ἄρνες…"
trMA.Ode8C12.text = "Καταγώγια μοναστῶν, ἀθροίσθητε ὡς ἄρνες λογικοί, τῷ ἀρχιποίμενι Χριστῷ, ὑπαντῆσαι νῦν κλαδηφόροι, προέρχεται θέλων, ὡς ἀρνίον σφαγῆναι ὁ Κύριος, ὅπως τὴν τοῦ λύκου, ἐξάρῃ τυραννίδα."

trMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode8C13.melody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.name
trMA.Ode8C13.incipit = "Ἐρχομένου πρὸς Βηθσφαγῆ, κρότου σου…"
trMA.Ode8C13.text = "Ἐρχομένου πρὸς Βηθσφαγῆ, κρότου σου ποδῶν ὁ δυσμενής, ᾔσθετο ᾍδης, καὶ ποδῶν τοῦ Λαζάρου ἥπτετο λέγων· Εἰ μέλλει φωνεῖν σε ἡ ζωή, μὴ μελήσῃς, ἀλλʹ ἔξελθε· ἔγνων τὴν ἐμὴν γάρ, κατάλυσιν ἐν τάχει."

trMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode8C1T.melody = he.h.m4_gr_GR_cog.heHE.GiKaiPantaTaEnAfti.name
trMA.Ode8C1T.incipit = "Ἱεραί σε τῶν Προφητῶν, κηρύττουσι…"
trMA.Ode8C1T.text = "Ἱεραί σε τῶν Προφητῶν, κηρύττουσι φωναὶ συμβολικῶς, πύλην καὶ ὄρος καὶ σκηνὴν τὴν ἁγίαν, φωτὸς νεφέλην, ἐξ ἧς τοῖς ἐν σκότει, καὶ σκιᾷ καθημένοις ἀνέτειλεν, Ἥλιος Παρθένε, ὁ μόνος φωτοδότης."

trMA.Ode8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C21.greekmelody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.greekname
trMA.Ode8C21.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.name
trMA.Ode8C21.incipit = "Ἡ δυὰς τῶν Μαθητῶν, ἀποσταλεῖσα…"
trMA.Ode8C21.text = "Ἡ δυὰς τῶν Μαθητῶν, ἀποσταλεῖσα φέρει ὑποζύγιον, τῷ ἐπὶ ταῖς νεφέλαις ἐπιβαίνοντι, ὃν τὰ πάντα ὑμνοῦσι, καὶ ὑπερυψοῦσιν, εἰς πάντας τοὺς αἰῶνας."

trMA.Ode8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C22.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.name
trMA.Ode8C22.incipit = "Ἐπὶ θύραις ὁ Χριστός, λοιπὸν…"
trMA.Ode8C22.text = "Ἐπὶ θύραις ὁ Χριστός, λοιπὸν ἡ Βηθανία μὴ σκυθρώπαζε· εἰς γὰρ χαρὰν τὸ πένθος μεταβάλλει σου, τὸ σὸν θρέμμα ἐγείρων, Λάζαρον ἐκ τάφου, αὐτὸν ὑμνολογοῦντα."

trMA.Ode8C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C2Tr.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.name
trMA.Ode8C2Tr.incipit = "Εἷς Θεὸς οὖν ἡ Τριάς…"
trMA.Ode8C2Tr.text = "Εἷς Θεὸς οὖν ἡ Τριάς, οὐ τοῦ Πατρὸς ἐκστάντος εἰς υἱότητα, οὐδὲ Υἱοῦ τραπέντος εἰς ἐκπόρευσιν, ἀλλʹ ἰδίᾳ καὶ ἄμφω, φῶς Θεὸν τὰ τρία, δοξάζω εἰς αἰῶνας."

trMA.Ode8C2T.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C2T.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.name
trMA.Ode8C2T.incipit = "Μόνη ἄφθορος κύεις, μόνη θηλάζεις…"
trMA.Ode8C2T.text = "Μόνη ἄφθορος κύεις, μόνη θηλάζεις βρέφος μὴ λοχεύουσα, μόνη τὸν κτίστην τίκτεις, καὶ Δεσπότην σου, εἰ καὶ Μήτηρ καὶ δούλη, Σὲ Παρθενομῆτορ, ὑμνοῦμεν εἰς αἰῶνας."

trMA.Ode8C2A1.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2A1.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C2A1.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.name
trMA.Ode8C2A1.incipit = "Τοῖς φυτοῖς τῶν ἀρετῶν, καὶ…"
trMA.Ode8C2A1.text = "Τοῖς φυτοῖς τῶν ἀρετῶν, καὶ αἰσθητῶς τοῖς κλάδοις, ὡς διπλοῦν Χριστόν, ἑτοιμασθῶμεν πάντες ὑποδέξασθαι, ὀχούμενον ἐν πώλῳ, ὃν ὑπερυψοῦμεν, εἰς πάντας τοὺς αἰῶνας."

trMA.Ode8C2H.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2H.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C2H.greekmelody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.greekname
trMA.Ode8C2H.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.melody
trMA.Ode8C2H.incipit = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.incipit
trMA.Ode8C2H.text = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.text

trMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode9C11.greekmelody = he.h.m4_gr_GR_cog.heHE.OtiEpoiiseMoiMegaleia.greekname
trMA.Ode9C11.melody = he.h.m4_gr_GR_cog.heHE.OtiEpoiiseMoiMegaleia.name
trMA.Ode9C11.incipit = "Ἰδοὺ προανεφώνεις, ἀναβαίνομεν Ἰησοῦ, πρὸς…"
trMA.Ode9C11.text = "Ἰδοὺ προανεφώνεις, ἀναβαίνομεν Ἰησοῦ, πρὸς Πόλιν, τὴν ἁγίαν, καὶ χερσὶν μιαιφόνων ἀληθῶς, παραδοθήσομαι σταυρῷ, ἀποκτανθῆναι σαρκί."

trMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode9C12.melody = he.h.m4_gr_GR_cog.heHE.OtiEpoiiseMoiMegaleia.name
trMA.Ode9C12.incipit = "Θανάτου θέλων Λόγε, ἐξαρπάσαι φίλον…"
trMA.Ode9C12.text = "Θανάτου θέλων Λόγε, ἐξαρπάσαι φίλον τὸν σόν, σαρκὶ θανατωθῆναι διʹ ἡμᾶς, κατεπείγῃ τοὺς βροτούς, ἀθανατίζων τοὺς πιστούς, μόνε ἀθάνατε."

trMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode9C13.melody = he.h.m4_gr_GR_cog.heHE.OtiEpoiiseMoiMegaleia.name
trMA.Ode9C13.incipit = "Βαΐα σωφροσύνης, ἐπεισοίσωμεν τῷ Χριστῷ…"
trMA.Ode9C13.text = "Βαΐα σωφροσύνης, ἐπεισοίσωμεν τῷ Χριστῷ, ἐν πώλῳ μετριάζοντι σαρκί, καὶ προσείπωμεν αὐτῷ· Ἐπὶ τὸ πάθος ὁ ἐλθών, εὐλογητὸς εἶ Σωτήρ."

trMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode9C1T.melody = he.h.m4_gr_GR_cog.heHE.OtiEpoiiseMoiMegaleia.name
trMA.Ode9C1T.incipit = "Φρικτή σου ἡ λοχεία, Θεοτόκε…"
trMA.Ode9C1T.text = "Φρικτή σου ἡ λοχεία, Θεοτόκε Μήτηρ Χριστοῦ· διό σε μακαρίζομεν πιστῶς, καὶ δοξάζομεν σεπτῶς, αἱ γενεαὶ τῶν γενεῶν, εἰς τοὺς αἰῶνας, Ἀμήν."

trMA.Ode9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C21.greekmelody = he.h.m8_gr_GR_cog.heHE.TonProdilothenta.greekname
trMA.Ode9C21.melody = he.h.m8_gr_GR_cog.heHE.TonProdilothenta.name
trMA.Ode9C21.incipit = "Ἄρτι ἀποστέλλων, τοὺς Μαθητὰς Χριστὸς…"
trMA.Ode9C21.text = "Ἄρτι ἀποστέλλων, τοὺς Μαθητὰς Χριστὸς ἔφη· Λύσαντές μοι πῶλον, ἀγάγετε ἐπιβῆναι, ἵνα λύσω τῆς ἀλογίας τὰ ἔθνη, καὶ καθυποτάξω, ὡς Υἱὸς τῷ Πατρί."

trMA.Ode9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C22.melody = he.h.m8_gr_GR_cog.heHE.TonProdilothenta.name
trMA.Ode9C22.incipit = "Ἔρχεται ὁ Κύριος, ἄνοιξόν σου…"
trMA.Ode9C22.text = "Ἔρχεται ὁ Κύριος, ἄνοιξόν σου τὰς πύλας, Βηθανία πρόσδεξαι, ἐν πίστει τὸν Δεσπότην· καὶ γὰρ ἥκει ἐξαναστῆσαι ἐκ τάφου, Λάζαρον ὡς μόνος παντοδύναμος."

trMA.Ode9C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C2Tr.melody = he.h.m8_gr_GR_cog.heHE.TonProdilothenta.name
trMA.Ode9C2Tr.incipit = "Τὸ τρισσοφαὲς Κύριε, τῆς σῆς…"
trMA.Ode9C2Tr.text = "Τὸ τρισσοφαὲς Κύριε, τῆς σῆς μοναρχίας, ἐκφαντορικαῖς λάμψεσιν, εἰς νοῦν ἡμῶν ἀστράπτον, ἀπὸ πλάνης πολυσχιδοῦς ἐπιστρέφει, πρὸς ἑνωτικὴν ἡμᾶς ἐνθέωσιν."

trMA.Ode9C2T.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C2T.melody = he.h.m8_gr_GR_cog.heHE.TonProdilothenta.name
trMA.Ode9C2T.incipit = "Χαίροις τὸ παλάτιον, τοῦ πάντων…"
trMA.Ode9C2T.text = "Χαίροις τὸ παλάτιον, τοῦ πάντων Βασιλέως, διʹ ἧς τὰ βασίλεια οὐρανῶν ἠνεῴχθη, τοῖς ἐπὶ γῆς Θεοτόκε Παρθένε, καὶ ἡ μετὰ Ἀγγέλων συγκατοίκησις."

trMA.Ode9C2A1.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2A1.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C2A1.melody = he.h.m8_gr_GR_cog.heHE.TonProdilothenta.name
trMA.Ode9C2A1.incipit = "Οἱ ἐν ταῖς ἐρήμοις, καὶ…"
trMA.Ode9C2A1.text = "Οἱ ἐν ταῖς ἐρήμοις, καὶ ὄρεσι καὶ σπηλαίοις, ἥκατε ἀθροίσθητε, σὺν ἡμῖν βαϊοφόροι, ὑπαντῆσαι τῷ Βασιλεῖ καὶ Δεσπότῃ· ἔρχεται γὰρ σῶσαι τὰς ψυχὰς ἡμῶν."

trMA.Ode9C2H.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2H.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C2H.greekmelody = he.h.m8_gr_GR_cog.heHE.TonProdilothenta.greekname
trMA.Ode9C2H.melody = he.h.m8_gr_GR_cog.heHE.TonProdilothenta.melody
trMA.Ode9C2H.incipit = he.h.m8_gr_GR_cog.heHE.TonProdilothenta.incipit
trMA.Ode9C2H.text = he.h.m8_gr_GR_cog.heHE.TonProdilothenta.text

trMA.AposIdiomelon1.poet = poets_gr_GR_cog.po.LeontosTouVasileos
trMA.AposIdiomelon1.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.AposIdiomelon1.melody = miscellanea_gr_GR_cog.misc.Idiomelon
trMA.AposIdiomelon1.incipit = "Περιφρονήσασα ψυχή μου τῶν θείων…"
trMA.AposIdiomelon1.text = "Περιφρονήσασα ψυχή μου τῶν θείων χρησμῶν, εὐάλωτος γέγονας, ταῖς μηχαναῖς τοῦ ἐχθροῦ· οἰκείᾳ ῥοπῇ, παραδοθεῖσα τῇ φθορᾷ, καὶ καρωθεῖσα ὑπὸ ἁμαρτίας πολλῆς, τὸ θεότευκτον ἄμφιον ἐῤῥύπωσας, καὶ ἀνευτρέπιστον τοῦ βασιλικοῦ γάμου πεποίηκας, ἀλλʹ ἵνα μὴ σὺν τῇ ἁμαρτίᾳ ἑλκυσθῇς, καὶ ὑποκεκρυμμένη τῶν παθῶν τῷ ἐνδύματι, ἀνακλιθεῖσα, τὰς εὐθύνας τῆς εἰσόδου εἰσπραχθῇς, καὶ τοῦ νυμφῶνος ἐκβληθῇς, τῷ Σωτῆρι κράξον. Τὸ φοβερὸν ὄμμα, ὁ λαβὼν ὅπερ εἰμί, καὶ ὃς ἧς μὴ ἐάσας, καὶ πρὸ σταυροῦ, χλαμύδα ἐμπαιγμοῦ διʹ ἐμὲ φορέσας, τὸν σάκκον μου διάῤῥηξον, καὶ εὐφροσύνην ἀμφίασον, καὶ ἐκ σκότους ἐξωτέρου, καὶ κλαυθμοῦ αἰωνίου ῥῦσαί με, καὶ ἐλέησόν με."

trMA.AposMartyric.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.AposMartyric.melody = ""
trMA.AposMartyric.incipit = "Τοὺς Ἀθλοφόρους τοῦ Χριστοῦ δεῦτε…"
trMA.AposMartyric.text = "Τοὺς Ἀθλοφόρους τοῦ Χριστοῦ δεῦτε λαοὶ ἅπαντες τιμήσωμεν, ὕμνοις καὶ ᾠδαῖς πνευματικαῖς, τοὺς φωστῆρας τοῦ Κόσμου, καὶ κήρυκας τῆς Πίστεως, τὴν πηγὴν τὴν ἀένναον, ἐξ ἧς ἀναβλύζει, τοῖς πιστοῖς τὰ ἰάματα, αὐτῶν ταῖς ἱκεσίαις Χριστὲ ὁ Θεὸς ἡμῶν, τὴν εἰρήνην δώρησαι τῷ Κόσμῳ σου, καὶ ταῖς ψυχαῖς ἡμῶν τὸ μέγα ἔλεος."

trMA.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.AposGlory.melody = miscellanea_gr_GR_cog.misc.Idiomelon
trMA.AposGlory.incipit = "Τὴν ψυχωφελῆ, πληρώσαντες Τεσσαρακοστήν, καὶ…"
trMA.AposGlory.text = "Τὴν ψυχωφελῆ, πληρώσαντες Τεσσαρακοστήν, καὶ τὴν ἁγίαν Ἑβδομάδα τοῦ Πάθους σου, αἰτοῦμεν κατιδεῖν Φιλάνθρωπε, τοῦ δοξάσαι ἐν αὐτῇ τὰ μεγαλεῖά σου, καὶ τὴν ἄφατον διʹ ἡμᾶς οἰκονομίαν σου, ὁμοφρόνως μελῳδοῦντες, Κύριε δόξα σοι."

trTE.Troparion.mode = miscellanea_gr_GR_cog.misc.Mode3
trTE.Troparion.melody = ""
trTE.Troparion.incipit = "Ἀνυπόστατος Κύριε ἡ ὀργή, τῆς…"
trTE.Troparion.text = "Ἀνυπόστατος Κύριε ἡ ὀργή, τῆς ἐπὶ ἁμαρτωλοὺς ἀπειλῆς σου· καὶ οὐκ ἐσμὲν ἄξιοι ατενίσαι, καὶ αἰτῆσαι παρὰ σοῦ ἔλεος, μὴ τῷ θυμῷ σου, μηδὲ τῇ ὀργῇ σου ἀπολέσῃς ἡμᾶς, οὓς ἐκ γῆς τῇ χειρί σου ἔπλασας."
trTE.Troparion2.incipit = "οὓς ἐκ γῆς τῇ χειρί…"
trTE.Troparion2.text = "οὓς ἐκ γῆς τῇ χειρί σου ἔπλασας."
