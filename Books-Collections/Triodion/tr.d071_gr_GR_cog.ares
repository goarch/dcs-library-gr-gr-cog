trVE.Stichera05.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.Stichera05.melody = miscellanea_gr_GR_cog.misc.Idiomelon
trVE.Stichera05.incipit = "Σήμερον ὁ Ἅδης στένων βοᾷ…"
trVE.Stichera05.text = "Σήμερον ὁ Ἅδης στένων βοᾷ· Συνέφερέ μοι, εἰ τὸν ἐκ Μαρίας γεννηθέντα, μὴ ὑπεδεξάμην· ἐλθὼν γὰρ ἐπʼ ἐμέ, τὸ κράτος μου ἔλυσε, πύλας χαλκᾶς συνέτριψε, ψυχάς ἃς κατεῖχον τὸ πρίν, Θεὸς ὢν ἀνέστησε. Δόξα Κύριε τῷ Σταυρῷ σου, καὶ τῇ Ἀναστάσει σου."

trVE.Stichera06.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.Stichera06.melody = miscellanea_gr_GR_cog.misc.Idiomelon
trVE.Stichera06.incipit = "Σήμερον ὁ Ἅδης στένων βοᾷ…"
trVE.Stichera06.text = "Σήμερον ὁ Ἅδης στένων βοᾷ· Κατελύθη μου ἡ ἐξουσία, ἐδεξάμην θνητόν, ὥσπερ ἕνα τῶν θανέντων, τοῦτον δὲ κατέχειν ὅλως οὐκ ἰσχύω, ἀλλʼ ἀπολῶ μετὰ τούτου, ὧν ἐβασίλευον· ἐγὼ εἶχον τοὺς νεκροὺς ἀπʼ αἰῶνας, ἀλλὰ οὗτος ἰδοὺ πάντας ἐγείρει. Δόξα Κύριε τῷ Σταυρῷ σου, καὶ τῇ Ἀναστάσει σου."

trVE.Stichera07.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.Stichera07.melody = miscellanea_gr_GR_cog.misc.Idiomelon
trVE.Stichera07.incipit = "Σήμερον ὁ Ἅδης στένων βοᾷ…"
trVE.Stichera07.text = "Σήμερον ὁ Ἅδης στένων βοᾷ· Κατεπόθη μου τὸ κράτος, ὁ Ποιμὴν ἐσταυρώθη, καὶ τὸν Ἀδὰμ ἀνέστησεν· ὧν περ ἐβασίλευον ἐστέρημαι, καὶ οὓς κατέπιον ἰσχύσας, πάντας ἐξήμεσα, ἐκένωσε τοὺς τάφους ὁ σταυρωθείς, οὐκ ἰσχύει τοῦ θανάτου τὸ κράτος. Δόξα Κύριε τῷ Σταυρῷ σου, καὶ τῇ Ἀναστάσει σου."

