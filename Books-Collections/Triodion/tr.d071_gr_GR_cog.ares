trLI.CherubicHymn.title = "Ἀντὶ τοῦ συνήθους Χερουβικοῦ."
trLI.CherubicHymn.mode = miscellanea_gr_GR_cog.misc.Mode5
trLI.CherubicHymnPart1.incipit = "Σιγησάτω πᾶσα σὰρξ…"
trLI.CherubicHymnPart1.text = "Σιγησάτω πᾶσα σὰρξ βροτεία καὶ στήτω μετὰ φόβου καὶ τρόμου καὶ μηδὲν γήϊνον ἐν ἑαυτῇ λογιζέσθω· ὁ γὰρ Βασιλεὺς τῶν βασιλευόντων καὶ Κύριος τῶν κυριευόντων προσέρχεται σφαγιασθῆναι καὶ δοθῆναι εἰς βρῶσιν τοῖς πιστοῖς· προηγοῦνται δὲ τούτου οἱ χοροὶ τῶν Ἀγγέλων μετὰ πάσης ἀρχῆς καὶ ἐξουσίας."
trLI.CherubicHymnPart2.incipit = "Τὰ πολυόμματα…"
trLI.CherubicHymnPart2.text = "Τὰ πολυόμματα Χερουβεὶμ καὶ τὰ ἑξαπτέρυγα Σεραφεὶμ τὰς ὄψεις καλύπτοντα καὶ βοῶντα τὸν ὕμνον· Ἀλληλούϊα."

