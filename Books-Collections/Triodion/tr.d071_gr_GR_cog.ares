trLI.AfterCommunion.mode = miscellanea_gr_GR_cog.misc.Mode2
trLI.AfterCommunion.incipit = "Μνήσθητι εὔσπλαγχνε καὶ ἡμῶν…"
trLI.AfterCommunion.text = "Μνήσθητι εὔσπλαγχνε καὶ ἡμῶν, καθὼς ἐμνημόνευσας τοῦ Λῃστοῦ, ἐν τῇ βασιλείᾳ τῶν οὐρανῶν."

