trCO.header = "(Μέγα)"

trVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.Stichera01.greekmelody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.greekname
trVE.Stichera01.melody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.name
trVE.Stichera01.incipit = "Μέσον διϊππεύοντες σήμερον, ἡμερῶν τῆς…"
trVE.Stichera01.text = "Μέσον διϊππεύοντες σήμερον, ἡμερῶν τῆς ἐγκρατείας, τῇ δυνάμει τοῦ Σταυροῦ, τὸν ἐν τούτῳ ὑψωθέντα, μέσον γῆς ὡς κραταιόν, Σωτῆρα, καὶ Θεὸν δοξολογήσωμεν, βοῶντες, θεωροὺς ἡμᾶς ἀνάδειξον, τῶν Παθημάτων σου Δέσποτα, καὶ τῆς σεπτῆς Ἀναστάσεως, δωρούμενος, ἱλασμὸν ἡμῖν, καὶ μέγα ἔλεος."

trVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.Stichera02.greekmelody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.greekname
trVE.Stichera02.melody = he.a.m8_gr_GR_cog.heAU.TiYmasKalesomen.name
trVE.Stichera02.incipit = "Πάθη ταπεινώσωμεν σώματος, τῶν βρωμάτων…"
trVE.Stichera02.text = "Πάθη ταπεινώσωμεν σώματος, τῶν βρωμάτων ἀποχῇ, καὶ ἡδονῶν ἀποστροφῇ, καὶ τὸ ξύλον τοῦ Σταυροῦ περιπτυξώμεθα πιστῶς. Ὁρᾶται, ἐμφανῶς γὰρ προσκυνούμενος, καὶ πάντας, ἁγιάζει θείᾳ χάριτι, καὶ τῷ Κυρίῳ βοήσωμεν· Εὐχαριστοῦμέν σοι Εὔσπλαγχνε, τῷ σῴζοντι, διὰ τούτου τὰς ψυχὰς ἡμῶν."

trVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.Stichera03.melody = "Τὴν Θεοτόκον."
trVE.Stichera03.incipit = "Νῦν τὸν Σταυρὸν προσκυνοῦντες, πάντες…"
trVE.Stichera03.text = "Νῦν τὸν Σταυρὸν προσκυνοῦντες, πάντες κραυγάζομεν· Χαῖρε ξύλον τῆς ζωῆς, χαῖρε σκῆπτρον ἅγιον τοῦ Χριστοῦ, χαῖρε βροτῶν δόξα ἐπουράνιε, χαῖρε Ἀνάκτων τὸ καύχημα, χαῖρε τὸ κράτος τῆς πίστεως, χαῖρε ὅπλον ἀήττητον, χαῖρε τῶν ἐχθρῶν φυγαδευτήριον, χαῖρε φέγγος λαμπρόν, σωτήριον τοῦ Κόσμου, χαῖρε Μαρτύρων τὸ μέγα κλέος, χαῖρε σθένος Δικαίων, χαῖρε Ἀγγέλων λαμπρότης, χαῖρε πάνσεπτε."

trVE.AposIdiomelon1.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.AposIdiomelon1.melody = miscellanea_gr_GR_cog.misc.Idiomelon
trVE.AposIdiomelon1.incipit = "Μεγαλοῤῥήμων Φαρισαῖος, ἑβδελύχθη καυχησάμενος, καὶ…"
trVE.AposIdiomelon1.text = "Μεγαλοῤῥήμων Φαρισαῖος, ἑβδελύχθη καυχησάμενος, καὶ Τελώνης ταπεινόφρων, διὰ σιγῆς ἐδικαιώθη προσευξάμενος· διὸ τῶν ἑκατέρων μαθοῦσα ψυχή μου τὸ διάφορον, τὴν ταπεινοφροσύνην ἑλοῦ καὶ κατάσπαζε· Χριστὸς γὰρ ταπεινοῖς ἐπηγγείλατο, διδόναι χάριν ὡς φιλάνθρωπος."

trVE.AposMartyric.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.AposMartyric.melody = ""
trVE.AposMartyric.incipit = "Μάρτυρες Κυρίου, ἱκετεύσατε τὸν Θεὸν…"
trVE.AposMartyric.text = "Μάρτυρες Κυρίου, ἱκετεύσατε τὸν Θεὸν ἡμῶν, καὶ αἰτήσασθε ταῖς ψυχαῖς ἡμῶν, πλῆθος οἰκτιρμῶν, καὶ τὸν ἱλασμόν, τῶν πολλῶν παραπτωμάτων δεόμεθα."

trVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
trVE.AposTheotokion.melody = ""
trVE.AposTheotokion.incipit = oc.m8.d3_gr_GR_cog.ocMA.AposTheotokion.incipit
trVE.AposTheotokion.text = oc.m8.d3_gr_GR_cog.ocMA.AposTheotokion.text

trMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Kathisma21.melody = "Τὸ ἀσάλευτον στήριγμα."
trMA.Kathisma21.incipit = "Ἐγκρατείᾳ λαμπρύναντες, τὰς ψυχὰς ἡμῶν…"
trMA.Kathisma21.text = "Ἐγκρατείᾳ λαμπρύναντες, τὰς ψυχὰς ἡμῶν, τὸν Σταυρὸν προσκυνήσωμεν, τὸν σωτήριον, ἐν ᾧ Χριστὸς προσηλώθη, καὶ βοήσωμεν αὐτῷ· Χαῖρε νηστευόντων ἡ τρυφή, καὶ βεβαία βοήθεια. Χαῖρε ἀναιρέτα τῶν παθῶν, τῶν δαιμόνων ἀντίπαλε, χαῖρε Ξύλον μακάριον."

trMA.Kathisma22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Kathisma22.melody = "Αὐτόμελον."
trMA.Kathisma22.incipit = "Τὸ ἀσάλευτον στήριγμα, τὸ τῆς…"
trMA.Kathisma22.text = "Τὸ ἀσάλευτον στήριγμα, τὸ τῆς Πίστεως, καὶ σεβάσμιον δώρημα, τῶν ψυχῶν ἡμῶν, τὴν Θεοτόκον ἐν ὕμνοις μεγαλύνωμεν πιστοί. Χαῖρε ἡ τὴν πέτραν τῆς ζωῆς, ἐν γαστρί σου χωρήσασα, χαῖρε τῶν περάτων ἡ ἐλπίς, θλιβομένων ἀντίληψις, χαῖρε Νύμφη ἀνύμφευτε."

trMA.Kathisma31.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Kathisma31.greekmelody = he.a.m8_gr_GR_cog.heAU.OsAparchas.greekname
trMA.Kathisma31.melody = he.a.m8_gr_GR_cog.heAU.OsAparchas.name
trMA.Kathisma31.incipit = "Ὥσπερ ζωὴν τῆς Κτίσεως, τὸν…"
trMA.Kathisma31.text = "Ὥσπερ ζωὴν τῆς Κτίσεως, τὸν σὸν Σταυρὸν προκείμενον, ἡ Οἰκουμένη ἀσπάζεται Κύριε, καὶ προσκυνοῦσα κράζει σοι· τῇ αὐτοῦ ἐνεργείᾳ, ἐν εἰρήνῃ βαθείᾳ, τοὺς ἀνυμνοῦντάς σε, τοὺς εὐλογοῦντάς σε, διὰ τῆς ἐγκρατείας συντήρησον Πολυέλεε."

trMA.Kathisma32.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Kathisma32.greekmelody = he.a.m8_gr_GR_cog.heAU.OsAparchas.greekname
trMA.Kathisma32.melody = he.a.m8_gr_GR_cog.heAU.OsAparchas.name
trMA.Kathisma32.incipit = oc.m8.d2_gr_GR_cog.ocVE.ApolTheotokionVM.incipit
trMA.Kathisma32.text = oc.m8.d2_gr_GR_cog.ocVE.ApolTheotokionVM.text

trMA.C1.poet = poets_gr_GR_cog.po.Iosif

trMA.C2.poet = poets_gr_GR_cog.po.Theodorou

trMA.Ode2C1H.ode = miscellanea_gr_GR_cog.misc.Ode2
trMA.Ode2C1H.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode2C1H.greekmelody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOPalaiTonIsrail.greekname
trMA.Ode2C1H.melody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOPalaiTonIsrail.melody
trMA.Ode2C1H.incipit = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOPalaiTonIsrail.incipit
trMA.Ode2C1H.text = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOPalaiTonIsrail.text

trMA.Ode2C11.ode = miscellanea_gr_GR_cog.misc.Ode2
trMA.Ode2C11.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode2C11.greekmelody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOPalaiTonIsrail.greekname
trMA.Ode2C11.melody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOPalaiTonIsrail.name
trMA.Ode2C11.incipit = "Μέσον τῆς Κτίσεως, ὃν καθυπέμεινας…"
trMA.Ode2C11.text = "Μέσον τῆς Κτίσεως, ὃν καθυπέμεινας Σταυρόν, Μεσσία Λόγε Θεοῦ, τῷ τῆς Νηστείας σήμερον μεσασμῷ, πιστῶς προσκυνοῦμεν, αἰτούμενοι κατιδεῖν, καὶ τὴν Ἀνάστασιν τὴν σήν."

trMA.Ode2C12.ode = miscellanea_gr_GR_cog.misc.Ode2
trMA.Ode2C12.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode2C12.melody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOPalaiTonIsrail.name
trMA.Ode2C12.incipit = "Ῥάβδῳ δυνάμεως, προτυπωθείσῃ τῷ Μωσῇ…"
trMA.Ode2C12.text = "Ῥάβδῳ δυνάμεως, προτυπωθείσῃ τῷ Μωσῇ, τὴν θάλασσαν τῶν παθῶν, διατεμόντες φθάσωμεν πρὸς γῆν, τῆς ἐπαγγελίας, καὶ μάννα τοῦ νοητοῦ, ἐμφορηθῶμεν δαψιλῶς."

trMA.Ode2C13.ode = miscellanea_gr_GR_cog.misc.Ode2
trMA.Ode2C13.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode2C13.melody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOPalaiTonIsrail.name
trMA.Ode2C13.incipit = "Τίς μὴ θρηνήσει σε; τίς…"
trMA.Ode2C13.text = "Τίς μὴ θρηνήσει σε; τίς μὴ πενθήσει σε ψυχή, ποθοῦσαν τὰ πονηρά, οὐκ ἐκζητοῦσαν πόθῳ τὰ ἀγαθά, δικαίου Κριτοῦ δέ, καταφρονοῦσαν ἀεί, μακροθυμοῦντος ἐπὶ σοί;"

trMA.Ode2C1T.ode = miscellanea_gr_GR_cog.misc.Ode2
trMA.Ode2C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode2C1T.melody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOPalaiTonIsrail.name
trMA.Ode2C1T.incipit = "Σάρκα γενόμενον, ἀναλλοιώτως τὸν Χριστόν…"
trMA.Ode2C1T.text = "Σάρκα γενόμενον, ἀναλλοιώτως τὸν Χριστόν, Παρθένε κυοφορεῖς, ὃν ἐκτενῶς ἱκέτευε, σαρκικῶν παθῶν ἀπαλλάξαι, τοὺς προσκυνοῦντας Σταυρόν, ὃν καθυπέμεινε σαρκί."

trMA.Ode2C21.ode = miscellanea_gr_GR_cog.misc.Ode2
trMA.Ode2C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode2C21.greekmelody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOProTonAionon.greekname
trMA.Ode2C21.melody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOProTonAionon.name
trMA.Ode2C21.incipit = "Ἴδετε ἴδετε, ὅτι ἐγώ εἰμι…"
trMA.Ode2C21.text = "Ἴδετε ἴδετε, ὅτι ἐγώ εἰμι ὁ Θεὸς ἡμῶν, ὁ τῇ Οἰκουμένῃ, τὸν Σταυρόν μου παρασχών, ὅπλον σωτηρίας, εἰς τὸ νῦν προσκυνεῖσθαι αὐτόν, ὅπως οἱ ἀσπαζόμενοι, καταργῶσι τοῦ ἐχθροῦ μηχανήματα."

trMA.Ode2C22.ode = miscellanea_gr_GR_cog.misc.Ode2
trMA.Ode2C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode2C22.melody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOProTonAionon.name
trMA.Ode2C22.incipit = "Μέγας εἶ Κύριε, καὶ πολυέλεος…"
trMA.Ode2C22.text = "Μέγας εἶ Κύριε, καὶ πολυέλεος, ὅτι δέδωκας τὸν ζωοποιόν σου, προσκυνεῖσθαι νῦν Σταυρόν, ἔνθα σου αἱ χεῖρες, καὶ οἱ πόδες ἡλώθησαν· ἐν ᾧ τὸ αἷμα ἐῤῥύη, τῆς ἀχράντου σου Πλευρᾶς, ζωὴν πηγάζον ἡμῖν."

trMA.Ode2C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode2
trMA.Ode2C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode2C2Tr.melody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOProTonAionon.name
trMA.Ode2C2Tr.incipit = "Ὑπερτελεστάτη Μονάς, ὑπέρθεε, τρισυπόστατε, ἀγέννητε…"
trMA.Ode2C2Tr.text = "Ὑπερτελεστάτη Μονάς, ὑπέρθεε, τρισυπόστατε, ἀγέννητε Πάτερ, καὶ Υἱὲ μονογενές, Πνεῦμα ἐκ Πατρὸς ἐκπορευθέν, διʼ Υἱοῦ δὲ φανέν, οὐσία μία καὶ φύσις, κυριότης, βασιλεία, σῶσον πάντας ἡμᾶς."

trMA.Ode2C2T.ode = miscellanea_gr_GR_cog.misc.Ode2
trMA.Ode2C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode2C2T.melody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOProTonAionon.name
trMA.Ode2C2T.incipit = "Ἄῤῥητον τὸ θαῦμα, τῆς σῆς…"
trMA.Ode2C2T.text = "Ἄῤῥητον τὸ θαῦμα, τῆς σῆς κυήσεως Μητροπάρθενε· πῶς γὰρ καὶ λοχεύεις, καὶ ἁγνεύεις ἐν ταὐτῷ; πῶς παιδοτοκεῖς, καὶ ἀγνοεῖς πεῖραν ὅλως ἀνδρός; Ὡς εἶδεν ὁ ὑπὲρ φύσιν, ἐξ ἐμοῦ καινοπρεπῶς, Λόγος Θεοῦ γεννηθείς."

trMA.Ode2C2A1.ode = miscellanea_gr_GR_cog.misc.Ode2
trMA.Ode2C2A1.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode2C2A1.melody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOProTonAionon.name
trMA.Ode2C2A1.incipit = "Σὲ Μωσῆς ὁ μέγας, προδιετύπωσε…"
trMA.Ode2C2A1.text = "Σὲ Μωσῆς ὁ μέγας, προδιετύπωσε, τὸν Σταυρὸν ἡμῖν, χεῖρας ἐκπετάσας, καὶ πορθήσας Ἀμαλήκ, σὲ ἐκτυποῦντες ἐν σκιαῖς καὶ ἀέρι, ἡμεῖς ἐκτρέπομεν καὶ νικῶμεν, τὸν ἀρχέκακον ἐχθρόν, ὑμνολογοῦντες Χριστόν."

trMA.Ode2C2H.ode = miscellanea_gr_GR_cog.misc.Ode2
trMA.Ode2C2H.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode2C2H.greekmelody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOProTonAionon.greekname
trMA.Ode2C2H.melody = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOProTonAionon.melody
trMA.Ode2C2H.incipit = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOProTonAionon.incipit
trMA.Ode2C2H.text = he.h.m8_gr_GR_cog.heHE.IdeteIdeteOProTonAionon.text

trMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C11.greekmelody = he.h.m8_gr_GR_cog.heHE.OStegazonEnYdasi.greekname
trMA.Ode8C11.melody = he.h.m8_gr_GR_cog.heHE.OStegazonEnYdasi.name
trMA.Ode8C11.incipit = "Ὁ συσσείσας θεμέλια, πάσης τῆς…"
trMA.Ode8C11.text = "Ὁ συσσείσας θεμέλια, πάσης τῆς γῆς ὡς Θεός, ὑψωθεὶς ἐν ξύλῳ, ἄσειστον πᾶσιν ἐδωρήσω, πιστοῖς ἔρεισμα Κύριε, τὸ σωτήριον ὅπλον τοῦ Σταυροῦ σου, ὅν περ προσκυνοῦντες, σὲ ὑπερυψοῦμεν, εἰς πάντας τοὺς αἰῶνας."

trMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C12.melody = he.h.m8_gr_GR_cog.heHE.OStegazonEnYdasi.name
trMA.Ode8C12.incipit = "Ἀπαστράπτον θεώμενοι, ὑπὲρ ἡλίου αὐγάς…"
trMA.Ode8C12.text = "Ἀπαστράπτον θεώμενοι, ὑπὲρ ἡλίου αὐγάς, τοῦ Σταυροῦ τὸ ξύλον, δεῦτε νηστείᾳ ἀστραπτόμενοι, νῦν ἀσπασώμεθα, ἀρυόμενοι χάριν φωτοφόρον, σκότος ἐκμειοῦσαν, τῶν ὑπερυψούντων, Χριστὸν εἰς τοὺς αἰῶνας."

trMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C13.melody = he.h.m8_gr_GR_cog.heHE.OStegazonEnYdasi.name
trMA.Ode8C13.incipit = "Ὕδωρ ζῶν τὸ ἁλλόμενον, εἰς…"
trMA.Ode8C13.text = "Ὕδωρ ζῶν τὸ ἁλλόμενον, εἰς αἰωνίαν ζωήν, σὺ ὑπάρχων Λόγε, αἷμα καὶ ὕδωρ, ἐκ πλευρᾶς ἐν Σταυρῷ, ἔβλυσας Δέσποτα, ἁμαρτίας χειμάῤῥους ἀναστέλλων. Ὅθεν δυσωπῶ σε· Ξήρανον παθῶν μου, τὰς πονηρὰς ἐκβλύσεις."

trMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C1T.melody = he.h.m8_gr_GR_cog.heHE.OStegazonEnYdasi.name
trMA.Ode8C1T.incipit = "Νοητὸν ὡς ἁγίασμα, τὸν ἐν…"
trMA.Ode8C1T.text = "Νοητὸν ὡς ἁγίασμα, τὸν ἐν ἁγίοις Θεόν, ἀναπεπαυμένον, τίκτεις ἁγία, Θεομῆτορ ἁγνή, πάντα τὰ πέρατα, ἁγιάζοντα θείᾳ προσκυνήσει, σήμερον Παρθένε Ξύλου παναγίου, ἐν ᾧ σαρκὶ ἐπάγη."

trMA.Ode8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C21.greekmelody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.greekname
trMA.Ode8C21.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.name
trMA.Ode8C21.incipit = "Δεῦτε ἴδωμεν λαοί, τὸ Ζωηφόρον…"
trMA.Ode8C21.text = "Δεῦτε ἴδωμεν λαοί, τὸ Ζωηφόρον Ξύλον, νῦν προκείμενον, ἐν ᾧ Χριστὸς ἐπάγη ὁ Θεὸς ἡμῶν, καὶ σὺ φόβῳ ὑμνοῦντες, τοῦτον προσκυνοῦμεν εἰς πάντας τοὺς αἰῶνας."

trMA.Ode8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C22.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.name
trMA.Ode8C22.incipit = "Τὸν τρισύνθετον Σταυρόν, ὡς τῆς…"
trMA.Ode8C22.text = "Τὸν τρισύνθετον Σταυρόν, ὡς τῆς Τριάδος τύπον ἀνυμνήσωμεν, καὶ προσκυνοῦντες φόβῳ ἀνακράξωμεν· Εὐλογοῦντες ὑμνοῦντες, καὶ ὑπερυψοῦντες Χριστὸν εἰς τοὺς αἰῶνας."

trMA.Ode8C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C2Tr.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.name
trMA.Ode8C2Tr.incipit = "Εἷς Θεὸς οὖν ἡ Τριάς…"
trMA.Ode8C2Tr.text = "Εἷς Θεὸς οὖν ἡ Τριάς, οὐ τοῦ Πατρὸς ἐκστάντος εἰς υἱότητα, οὐδὲ Υἱοῦ τραπέντος εἰς ἐκπόρευσιν, ἀλλʼ ἰδίᾳ καὶ ἄμφω, ὡς Θεὸν τὰ τρία δοξάζω εἰς αἰῶνας."

trMA.Ode8C2T.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C2T.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.name
trMA.Ode8C2T.incipit = "Μόνη ἀφθόρως κύεις, μόνη θηλάζεις…"
trMA.Ode8C2T.text = "Μόνη ἀφθόρως κύεις, μόνη θηλάζεις βρέφος μὴ λοχεύουσα, μόνη τὸν Κτίστην τίκτεις καὶ Δεσπότην σου, εἰ καὶ δούλη καὶ μήτηρ, σὲ Παρθενομῆτορ, ὑμνοῦμεν εἰς αἰῶνας."

trMA.Ode8C2A1.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2A1.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C2A1.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.name
trMA.Ode8C2A1.incipit = "Τὸν τυφλὸν ἐκ γενετῆς, ὁ…"
trMA.Ode8C2A1.text = "Τὸν τυφλὸν ἐκ γενετῆς, ὁ ὀμματώσας λόγῳ, πηρωθέν μου σύ, τὸ τῆς καρδίας ὄμμα, πάλιν ἄνοιξον, ἵνα βλέψω τὸ φῶς, τῶν σῶν προσταγμάτων, Χριστὲ εἰς τοὺς αἰῶνας."

trMA.Ode8C2H.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2H.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C2H.greekmelody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.greekname
trMA.Ode8C2H.melody = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.melody
trMA.Ode8C2H.incipit = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.incipit
trMA.Ode8C2H.text = he.h.m8_gr_GR_cog.heHE.AngeloiKaiOuranoi.text

trMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C11.greekmelody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.greekname
trMA.Ode9C11.melody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.name
trMA.Ode9C11.incipit = "Εὐλογητὸς Κύριος, ὁ Θεὸς τοῦ…"
trMA.Ode9C11.text = "Εὐλογητὸς Κύριος, ὁ Θεὸς τοῦ Ἰσραήλ, ὁ Σταυρῷ σου λύσας τὴν ἀρχαίαν ἀράν, καὶ τοῦτον ἡμῖν δωρησάμενος, κραταίωμα καὶ καταφυγήν, καὶ ἀσφαλη κρηπῖδα· διʼ οὗ τοὺς ἐχθροὺς ἡμῶν, νῦν κερατιοῦμεν."

trMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C12.melody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.name
trMA.Ode9C12.incipit = "Ὅτι σειραῖς συσφίγγομαι, ἀμετρήτων μου…"
trMA.Ode9C12.text = "Ὅτι σειραῖς συσφίγγομαι, ἀμετρήτων μου κακῶν, καὶ τὰς τρίβους σου τὰς σωτηρίους Χριστέ, ἑκὼν ἐπιγνῶναι οὐ βούλομαι, τῷ σῷ με ἐπίστρεψον Σταυρῷ, τὴν πώρωσίν μου λύων, διʼ ἄφατον ἔλεος, τῆς σῆς εὐσπλαγχνίας."

trMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C13.melody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.name
trMA.Ode9C13.incipit = "Τὴν Φαρισαίου ἔπαρσιν, μιμησάμενος κακῶς…"
trMA.Ode9C13.text = "Τὴν Φαρισαίου ἔπαρσιν, μιμησάμενος κακῶς, κατηνέχθην, πτῶμα χαλεπὸν καὶ δεινόν, καὶ κεῖμαι ἐχθρῶν καταπάτημα, ἀλλʼ οἴκτειρον σῶσόν με Χριστέ, σεαυτὸν διʼ οἶκτον, ταπεινώσας ὕψιστε, Βασιλεῦ τῆς δόξης."

trMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C1T.melody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.name
trMA.Ode9C1T.incipit = "Αἱ γενεαί σε ἅπασαι, μακαρίζουσιν…"
trMA.Ode9C1T.text = "Αἱ γενεαί σε ἅπασαι, μακαρίζουσιν Ἁγνή· Ἰησοῦς γὰρ μόνος, ὁ τεχθεὶς ἐκ τῆς σῆς νηδύος, αὐτὸς ὡς ἐπίσταται, ἐποίησε Κόρη μετὰ σοῦ, Παρθένε μεγαλεῖα, ὃν δυσώπει σῴζεσθαι, ποίμνην καὶ λαόν σου."

trMA.Ode9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C21.greekmelody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.greekname
trMA.Ode9C21.melody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.name
trMA.Ode9C21.incipit = "Εὐλογητὸς Κύριος, ὁ Θεὸς τοῦ…"
trMA.Ode9C21.text = "Εὐλογητὸς Κύριος, ὁ Θεὸς τοῦ Ἰσραήλ, ὁ Σταυρῷ σου λύσας, τὴν ἀρχαίαν ἀράν, καὶ τοῦτον τιθεὶς ἡμῖν εἰς προσκύνησιν, αὐτὸν ἀσπαζόμενοι πιστῶς, αὐτὸν καὶ ἀνυμνοῦντες, σοῦ τὸ μέγα ἔλεος, ὑμνοῦμεν ἀπαύστως."

trMA.Ode9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C22.melody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.name
trMA.Ode9C22.incipit = "Τῆς Ἐκκλησίας καύχημα, σὺ εἶ…"
trMA.Ode9C22.text = "Τῆς Ἐκκλησίας καύχημα, σὺ εἶ τίμιε Σταυρέ, βασιλείας ὅπλον, καὶ τοῦ Κόσμου παντός, εἰρήνης βραβεῖον θεότευκτον. Σταυρὲ Ὀρθοδόξων ἡ χαρά, τῆς Οἰκουμένης φύλαξ, φύλαξον ἁγίασον, τοὺς σὲ προσκυνοῦντας."

trMA.Ode9C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C2Tr.melody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.name
trMA.Ode9C2Tr.incipit = "Τριὰς ἁγία δόξα σοι, ἡ…"
trMA.Ode9C2Tr.text = "Τριὰς ἁγία δόξα σοι, ἡ Ὁμότιμος Μονάς, θεία φύσις, μία βασιλεία φρικτή. Ὁ Πατήρ, ὁ Υἱὸς σὺν τῷ Πνεύματι, τὸ φῶς τὸ ἀπρόσιτον παντί, ἡ ἄναρχος Θεότης, σῶσον τοὺς λατρεύοντας, σοὶ τῷ πάντων Κτίστῃ."

trMA.Ode9C2T.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C2T.melody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.name
trMA.Ode9C2T.incipit = "Ἐν τῷ Σταυρῷ ὡς ἵστατο…"
trMA.Ode9C2T.text = "Ἐν τῷ Σταυρῷ ὡς ἵστατο, ἡ Ἀμνάς σου Ἰησοῦ, τὸν Ποιμένα, καὶ Δεσπότην αὐτῆς, ὁρῶσα πικρῶς ἐπωδύρετο, καὶ σπλάγχνα κινοῦσα ἐπὶ σοί, Χριστὲ ἀνεκαλεῖτο. τί τὸ ξένον θέαμα; ἡ ζωὴ πῶς θνῄσκεις;"

trMA.Ode9C2A1.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2A1.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C2A1.melody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.name
trMA.Ode9C2A1.incipit = "Τὸν Μανασσῆν ὡς ἔσωσας, μεταγνόντα…"
trMA.Ode9C2A1.text = "Τὸν Μανασσῆν ὡς ἔσωσας, μεταγνόντα ὁ Θεός, σῶσον κᾀμέ, δάκρυσι μετανοοῦντα πικρῶς, καὶ μὴ ἀποστρέψῃς τὸν δοῦλόν σου· ἐξέκλινα γάρ μου τὴν ψυχήν, ὡς πάλαι Ἰσραὴλ ἐκεῖνος, πάσας τὰς ἡμέρας μου, ζῶν ἐν ἀσωτίᾳ."

trMA.Ode9C2H.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2H.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C2H.greekmelody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.greekname
trMA.Ode9C2H.melody = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.melody
trMA.Ode9C2H.incipit = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.incipit
trMA.Ode9C2H.text = he.h.m8_gr_GR_cog.heHE.EvlogitosOKyrios.text

trMA.AposIdiomelon1.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.AposIdiomelon1.melody = miscellanea_gr_GR_cog.misc.Idiomelon
trMA.AposIdiomelon1.incipit = "Τοῦ μεγαλαύχου Φαρισαίου, τὴν ἐξ…"
trMA.AposIdiomelon1.text = "Τοῦ μεγαλαύχου Φαρισαίου, τὴν ἐξ οἰήσεως ἐννοοῦσα ψυχή μου κατάκρισιν, καὶ τοῦ ταπεινόφρονος Τελώνου, τὴν διʼ ἐξαγορεύσεως πταισμάτων, ἐπιγνοῦσα δικαίωσιν, τοῦ μὲν ἀποθέσθαι κατεπείγου, τὴν ἐπ ἀρετῆς προπέτειαν, τοῦ δὲ προλαβέσθαι, τὴν ἐφʼ οἷς ἐπλημμέλησας ἐξομολόγησιν, διεγείρου τὴν ἀταπείνωτον σεαυτῇ καρπουμένη, διὰ μετριοπαθείας ὕψωσιν, παρὰ Χριστοῦ τοῦ ἔχοντος τὸ μέγα ἔλεος."

trMA.AposMartyric.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.AposMartyric.melody = ""
trMA.AposMartyric.incipit = "Μεγάλως ἠγωνίσασθε Μάρτυρες, τὰς βασάνους…"
trMA.AposMartyric.text = "Μεγάλως ἠγωνίσασθε Μάρτυρες, τὰς βασάνους τῶν ἀνόμων, ὑπομείναντες γενναίως, τὸν Χριστὸν ὁμολογοῦντες, ἐναντίον βασιλέων, καὶ πάλιν μεταστάντες ἐκ τοῦ βίου, δυνάμεις ἐνεργεῖτε ἐν τῷ Κόσμῳ, καὶ ἀσθενεῖς θεραπεύετε, ἐκ τῶν παθῶν αὐτῶν Ἅγιοι, πρεσβεύσατε, τοῦ σωθῆναι τὰς ψυχὰς ἡμῶν."

trMA.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.AposTheotokion.melody = ""
trMA.AposTheotokion.incipit = oc.m8.d3_gr_GR_cog.ocVE.AposTheotokion.incipit
trMA.AposTheotokion.text = oc.m8.d3_gr_GR_cog.ocVE.AposTheotokion.text

