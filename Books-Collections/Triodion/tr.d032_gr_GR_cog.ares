trVE.Stichera01.poet = poets_gr_GR_cog.po.Iosif
trVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode1
trVE.Stichera01.greekmelody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.greekname
trVE.Stichera01.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
trVE.Stichera01.incipit = "Σταυρῷ ἐξεπέτασας Χριστέ, τὰς ἀχράντους…"
trVE.Stichera01.text = "Σταυρῷ ἐξεπέτασας Χριστέ, τὰς ἀχράντους χεῖράς σου, ἐπισυνάγων τὰ πέρατα· διὸ κραυγάζω σοι· Τὸν ἐσκορπισμένον, νοῦν μου ἐπισύναξον, αἰχμάλωτον ἑλκόμενον πάθεσι, καὶ παθημάτων με, κοινωνὸν τῶν σῶν ἀνάδειξον, ἐγκρατείᾳ ὅλον καθαιρόμενον."

trVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode1
trVE.Stichera02.greekmelody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.greekname
trVE.Stichera02.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
trVE.Stichera02.incipit = "Τοὺς Παῖδας στομώσασα ποτέ, ἡ…"
trVE.Stichera02.text = "Τοὺς Παῖδας στομώσασα ποτέ, ἡ νηστεία ἔδειξε, δυνατωτέρους ὡς γέγραπται, πυρὸς φλογίζοντος. Ταπεινὴ ψυχή μου, νήστευσον ἀνάπτουσα, ἐν σοὶ τὴν τοῦ Δεσπότου ἀγάπησιν, διʼ ἧς τὴν μέλλουσαν, ἐκφυγεῖν δυνήσῃ γέενναν, καὶ τὰ πάθη φλέξαι τὰ ὀλέθρια."

trVE.Stichera03.poet = poets_gr_GR_cog.po.Theodorou
trVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode3
trVE.Stichera03.melody = "Γενναῖοι Μάρτυρες."
trVE.Stichera03.incipit = "Καιρὸς εὐφρόσυνος τῆς Νηστείας, διὰ…"
trVE.Stichera03.text = "Καιρὸς εὐφρόσυνος τῆς Νηστείας, διὰ ἁγνείας φωτοειδοῦς, καὶ ἀγάπης εἰλικρινοῦς, προσευχῆς φωταυγοῦς, καὶ πάσης ἄλλης ἀρετῆς, ἐμφορηθέντες πλουσίως, φαιδρῶς ἐκβοήσωμεν· Σταυρὲ τοῦ Χριστοῦ πανάγιε, ὁ βλαστήσας τὴν τρυφὴν τῆς ζωῆς, πάντας καθαρᾷ σε προσκυνῆσαι καρδίᾳ, ἀξίωσον ἡμᾶς, ἱλασμὸν ἡμῖν διδούς, καὶ τὸ μέγα ἔλεος."

trVE.AposIdiomelon1.mode = miscellanea_gr_GR_cog.misc.Mode3
trVE.AposIdiomelon1.melody = miscellanea_gr_GR_cog.misc.Idiomelon
trVE.AposIdiomelon1.incipit = "Ὁ σαρκὶ σταυρωθεὶς Κύριε, καὶ…"
trVE.AposIdiomelon1.text = "Ὁ σαρκὶ σταυρωθεὶς Κύριε, καὶ σαυτῷ συσταυρώσας, τὸν παλαιὸν ἡμῶν ἄνθρωπον, τῇ δὲ λόγχῃ νυγεὶς τὴν πλευράν, καὶ τὸν ἀνθρωπόλεθρον συνεκκεντήσας ὄφιν, καθήλωσον τῷ φόβῳ σου τὰς σάρκας μου, καὶ τῷ πόθῳ σου τρῶσόν μου τὴν ψυχήν, ἵνα τὸ σὸν κατοπτριζόμενος πάθος, ἐγκρατῶς διανύσω τὴν τῆς νηστείας προθεσμίαν, μὴ μόνον γαστρός, ἀλλὰ καὶ τῶν ἄλλων εἰσόδων τῆς ἁμαρτίας κρατῶν, συντριβὴν δὲ καρδίας, καὶ πνεύματος ταπείνωσιν θύσω σοι, περὶ τῶν προγεγονότων μοι πταισμάτων ἀφʼ ὧν με ῥῦσαι φιλάνθρωπε."

trVE.AposMartyric.mode = miscellanea_gr_GR_cog.misc.Mode3
trVE.AposMartyric.melody = ""
trVE.AposMartyric.incipit = oc.m3.d4_gr_GR_cog.ocVE.Aposticha3.incipit
trVE.AposMartyric.text = oc.m3.d4_gr_GR_cog.ocVE.Aposticha3.text

trVE.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode3
trVE.AposTheotokion.greekmelody = he.a.m3_gr_GR_cog.heAU.MegaliTouStavrouSou.greekname
trVE.AposTheotokion.melody = he.a.m3_gr_GR_cog.heAU.MegaliTouStavrouSou.name
trVE.AposTheotokion.incipit = oc.m3.d6_gr_GR_cog.ocVE.SticTheotokion.incipit
trVE.AposTheotokion.text = oc.m3.d6_gr_GR_cog.ocVE.SticTheotokion.text

trMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Kathisma21.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
trMA.Kathisma21.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
trMA.Kathisma21.incipit = "Χριστὲ ἐπὶ Σταυροῦ, ἁπλωθεὶς ἐνεκρώθης…"
trMA.Kathisma21.text = "Χριστὲ ἐπὶ Σταυροῦ, ἁπλωθεὶς ἐνεκρώθης, νεκρώσας τὸν ἐχθρόν, καὶ ἀρχέκακον ὄφιν, ζωώσας δὲ τοὺς δήγματι, τῷ ἐκείνου τεθνήξαντας· ὅθεν δέομαι, τὴν νεκρωθεῖσαν ψυχήν μου, Σῶτερ ζώωσον, ἐν προσευχῇ καὶ νηστείᾳ, πρὸς σὲ ἀτενίζουσαν."

trMA.Kathisma22.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Kathisma22.greekmelody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.greekname
trMA.Kathisma22.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
trMA.Kathisma22.incipit = "Ὡς εἶδεν ἐν Σταυρῷ, ἡ…"
trMA.Kathisma22.text = "Ὡς εἶδεν ἐν Σταυρῷ, ἡ, Ἀμνάς σε τὸν Ἄρνα, κρεμάμενον Χριστέ, τῶν κακούργων ἐν μέσῳ ἐβόα δακρύουσα, καὶ πικρῶς ὀλολύζουσα, τέκνον φίλτατον, τί τὸ ὁρώμενον θαῦμα; Μῆτερ ἄχραντε, ζωὴ παγκόσμιος τοῦτο, ἀντέφης γνωσθήσεται."

trMA.Kathisma31.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Kathisma31.greekmelody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.greekname
trMA.Kathisma31.melody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.name
trMA.Kathisma31.incipit = "ᾈσμάτων σάλπιγγι, κατασαλπίσωμεν, ἡμέραν εὔσημον…"
trMA.Kathisma31.text = "ᾈσμάτων σάλπιγγι, κατασαλπίσωμεν, ἡμέραν εὔσημον, διεξερχόμενοι, τῆς ἐγκρατείας τὸν καιρόν, καὶ κράξωμεν ἐκβοῶντες· Αὕτη τὴν ζωὴν ἡμῶν ἐν τῷ Κόσμῳ ἐξήνθησεν, ἐναπομαράνασα, ἀκρασίας τὸν θάνατον, δυνάμει τοῦ Σταυροῦ σου Χριστὲ Λόγε, ἐν ταύτῃ τοὺς δούλους σου φύλαττε."

trMA.Kathisma32.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Kathisma32.greekmelody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.greekname
trMA.Kathisma32.melody = he.a.m3_gr_GR_cog.heAU.TinOraiotita.name
trMA.Kathisma32.incipit = me.m06.d16_gr_GR_cog.meMA.Ode3KathismaSt.incipit
trMA.Kathisma32.text = me.m06.d16_gr_GR_cog.meMA.Ode3KathismaSt.text

trMA.C1.poet = poets_gr_GR_cog.po.Iosif

trMA.C2.poet = poets_gr_GR_cog.po.Theodorou

trMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode3C11.greekmelody = he.h.m1_gr_GR_cog.heHE.StereothitoIKardiaMou.greekname
trMA.Ode3C11.melody = he.h.m1_gr_GR_cog.heHE.StereothitoIKardiaMou.name
trMA.Ode3C11.incipit = "Σταυρῷ παλάμας ἐξεπέτασας, τῆς ταθείσης…"
trMA.Ode3C11.text = "Σταυρῷ παλάμας ἐξεπέτασας, τῆς ταθείσης πάλαι χειρὸς τοῦ Ἀδάμ, πρὸς τὸ τῆς γνώσεως φυτόν, ἀναιρῶν τὸ ἁμάρτημα, διὰ σπλάγχνα οἰκτιρμῶν, Λόγε Θεοῦ ὑπεράγαθε."

trMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode3C12.melody = he.h.m1_gr_GR_cog.heHE.StereothitoIKardiaMou.name
trMA.Ode3C12.incipit = "Στερέωσόν μου τὴν διάνοιαν, κλονουμένην…"
trMA.Ode3C12.text = "Στερέωσόν μου τὴν διάνοιαν, κλονουμένην φθόνῳ τοῦ ὄφεως, τὰς τῶν παθῶν ἐπαγωγάς, τῷ σῷ πάθει ἀνάστειλον, ὁ παθῶν καὶ τὴν ἀπάθειαν, πιστοῖς χαρισάμενος."

trMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode3C13.melody = he.h.m1_gr_GR_cog.heHE.StereothitoIKardiaMou.name
trMA.Ode3C13.incipit = "Ἡ τῆς Νηστείας χάρις ἔλαμψεν…"
trMA.Ode3C13.text = "Ἡ τῆς Νηστείας χάρις ἔλαμψεν, ἀκρασίας σκότος διώκουσα. Ἰδοὺ εὐπρόσδεκτος καιρός, καὶ ἡμέρα σωτήριος, μετανοίας ἐνδειξώμεθα, καρποὺς καὶ ζησώμεθα."

trMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode3C1T.melody = he.h.m1_gr_GR_cog.heHE.StereothitoIKardiaMou.name
trMA.Ode3C1T.incipit = "Καταπιπτόντων ἐπανόρθωσις, ἡδονῶν κρημνῷ συμπτωθέντα…"
trMA.Ode3C1T.text = "Καταπιπτόντων ἐπανόρθωσις, ἡδονῶν κρημνῷ συμπτωθέντα με, καὶ ἁμαρτίαις χαλεπαῖς, ἐμπεσόντα εἰς βάραθρα, ἐξανάστησον Ἁγνή, καὶ πρὸς ζωὴν καθοδήγησον."

trMA.Ode3C21.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C21.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode3C21.greekmelody = he.h.m3_gr_GR_cog.heHE.StereosonKyrie.greekname
trMA.Ode3C21.melody = he.h.m3_gr_GR_cog.heHE.StereosonKyrie.name
trMA.Ode3C21.incipit = "Στερέωσον Κύριε, τὰς καρδίας ἡμῶν…"
trMA.Ode3C21.text = "Στερέωσον Κύριε, τὰς καρδίας ἡμῶν, τῷ σῷ Σταυρῷ, μὴ ἐκκλίνειν ἀπὸ σοῦ, ἐπὶ λόγους πονηρούς, ἢ εἰς πράξεις βδελυράς."

trMA.Ode3C22.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C22.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode3C22.melody = he.h.m3_gr_GR_cog.heHE.StereosonKyrie.name
trMA.Ode3C22.incipit = "Τοῦ πάθους σου Δέσποτα, ὁ…"
trMA.Ode3C22.text = "Τοῦ πάθους σου Δέσποτα, ὁ οὐρανὸς καὶ ἡ γῆ, αἰσθόμενοι ἠλλοιοῦντο ἐμφανῶς, Βασιλέα τοῦ παντός, σὲ δεικνύντες ἀληθῶς."

trMA.Ode3C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode3C2Tr.melody = he.h.m3_gr_GR_cog.heHE.StereosonKyrie.name
trMA.Ode3C2Tr.incipit = "Ἰσότιμε ἄναρχε, παναγία Τριάς, ζωοποιέ…"
trMA.Ode3C2Tr.text = "Ἰσότιμε ἄναρχε, παναγία Τριάς, ζωοποιέ, καὶ ἀρχίφωτε Μονάς, ὁ Πατὴρ καὶ ὁ Υἱός, καὶ τὸ Πνεῦμά με σῶσον."

trMA.Ode3C2T.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C2T.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode3C2T.melody = he.h.m3_gr_GR_cog.heHE.StereosonKyrie.name
trMA.Ode3C2T.incipit = "Μητρόθεε ἄνανδρε, τίκτεις μόνη Θεόν…"
trMA.Ode3C2T.text = "Μητρόθεε ἄνανδρε, τίκτεις μόνη Θεόν, μὴ φθαρεῖσα παρθενίας τὸ ἁγνόν, ἀλλὰ μείνασα σεμνή, ὥσπερ ἦς πρὸ τοῦ τόκου."

trMA.Ode3C2A1.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C2A1.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode3C2A1.melody = he.h.m3_gr_GR_cog.heHE.StereosonKyrie.name
trMA.Ode3C2A1.incipit = "Τὴν κόκκινον χλαῖνάν σου, ἥλους…"
trMA.Ode3C2A1.text = "Τὴν κόκκινον χλαῖνάν σου, ἥλους καὶ τὸν Σταυρόν, τὸν σπόγγον τε, καὶ τὴν λόγχην Ἰησοῦ, προσκυνῶ καὶ ἀνυμνῶ, τὰ ζωώσαντα τὸ πᾶν."

trMA.Ode3C2H.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C2H.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode3C2H.greekmelody = he.h.m3_gr_GR_cog.heHE.StereosonKyrie.greekname
trMA.Ode3C2H.melody = he.h.m3_gr_GR_cog.heHE.StereosonKyrie.melody
trMA.Ode3C2H.incipit = he.h.m3_gr_GR_cog.heHE.StereosonKyrie.incipit
trMA.Ode3C2H.text = he.h.m3_gr_GR_cog.heHE.StereosonKyrie.text

trMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode8C11.greekmelody = he.h.m1_gr_GR_cog.heHE.TonTousYmnologousEnKamino.greekname
trMA.Ode8C11.melody = he.h.m1_gr_GR_cog.heHE.TonTousYmnologousEnKamino.name
trMA.Ode8C11.incipit = "Ὁ μετὰ ἀνομων λογισθῆναι…"
trMA.Ode8C11.text = "Ὁ μετὰ ἀνομων λογισθῆναι, διὰ πλήθους ἐλέους καταδεξάμενος, τὰς ἐμὰς ἁμαρτίας, ἐξάλειψον ἐν πίστει, ὅπως σὲ δοξάζω, εἰς πάντας τοὺς αἰῶνας."

trMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode8C12.melody = he.h.m1_gr_GR_cog.heHE.TonTousYmnologousEnKamino.name
trMA.Ode8C12.incipit = "Τῶν ἁμαρτιῶν μου τὸ χειρόγραφον…"
trMA.Ode8C12.text = "Τῶν ἁμαρτιῶν μου τὸ χειρόγραφον, τῇ σῇ διάῤῥηξον λόγχῃ, καὶ τῆς καρδίας μου τὰς ὀδύνας, θεράπευσον Κύριε, πληγείσης βέλει τῆς κακίας, τῶν πονηρῶν δαιμόνων."

trMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode8C13.melody = he.h.m1_gr_GR_cog.heHE.TonTousYmnologousEnKamino.name
trMA.Ode8C13.incipit = "Μεμελανωμένην τὴν καρδίαν μου, τῆς…"
trMA.Ode8C13.text = "Μεμελανωμένην τὴν καρδίαν μου, τῆς ἁμαρτίας τῷ λύθρῳ, τῷ σῷ ἀπόπλυνον ἐκ πλευρᾶς ἀποστάζοντι, Αἵματι Χριστέ μου, ἵνα σε δοξάζω, εἰς πάντας τοὺς αἰῶνας."

trMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode8C1T.melody = he.h.m1_gr_GR_cog.heHE.TonTousYmnologousEnKamino.name
trMA.Ode8C1T.incipit = "Ἡ ἀγεωργήτως βλαστήσασα, τὸν ἐπουράνιον…"
trMA.Ode8C1T.text = "Ἡ ἀγεωργήτως βλαστήσασα, τὸν ἐπουράνιον Στάχυν, τὸν διατρέφοντα θεϊκῇ δυναστείᾳ τὰ σύμπαντα, Παρθένε, ἔμπλησον πεινῶσαν, τὴν ταπεινὴν ψυχήν μου."

trMA.Ode8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C21.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode8C21.greekmelody = he.h.m3_gr_GR_cog.heHE.TonEnFlogi.greekname
trMA.Ode8C21.melody = he.h.m3_gr_GR_cog.heHE.TonEnFlogi.name
trMA.Ode8C21.incipit = "Χαίροις Σταυρέ, διʼ οὗ ἀνεγνωρίσθη…"
trMA.Ode8C21.text = "Χαίροις Σταυρέ, διʼ οὗ ἀνεγνωρίσθη, μιᾷ ῥοπῇ Λῃστὴς θεολόγος κραυγάζων· Μνήσθητί μου Κύριε ἐν τῇ σῇ Βασιλείᾳ, οὗπερ τῆς μερίδος, κοινωνοὺς ἡμᾶς δεῖξον."

trMA.Ode8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C22.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode8C22.melody = he.h.m3_gr_GR_cog.heHE.TonEnFlogi.name
trMA.Ode8C22.incipit = "Σὺ λογχευθείς, τῇ φλογίνῃ ῥομφαίᾳ…"
trMA.Ode8C22.text = "Σὺ λογχευθείς, τῇ φλογίνῃ ῥομφαίᾳ, ἀνθυποστρέφεις Χριστέ, καὶ βροτοῖς ἐξανοίγεις, πάλιν τὸν Παράδεισον, ἐν ᾧ καὶ εἰσιόντες, σοῦ τῆς ἀθανάτου, ζωῆς ἀεὶ τρυφῶμεν."

trMA.Ode8C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode8C2Tr.melody = he.h.m3_gr_GR_cog.heHE.TonEnFlogi.name
trMA.Ode8C2Tr.incipit = "Σὺν τῷ Πατρί, τὸν Υἱὸν…"
trMA.Ode8C2Tr.text = "Σὺν τῷ Πατρί, τὸν Υἱὸν προσκυνοῦμεν, καὶ Πνεῦμα ἅγιον, ἐν μιᾷ τῇ οὐσίᾳ, ἀσιγήτως κράζοντες, τοῖς πηλίνοις στόμασι· Δόξα ἐν ὑψίστοις, Θεῷ τῷ ἐν Τριάδι."

trMA.Ode8C2T.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2T.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode8C2T.melody = he.h.m3_gr_GR_cog.heHE.TonEnFlogi.name
trMA.Ode8C2T.incipit = "Παιδοτοκεῖς παρθενεύουσα μόνη Θεοχαρίτωτε, τὸ…"
trMA.Ode8C2T.text = "Παιδοτοκεῖς παρθενεύουσα μόνη Θεοχαρίτωτε, τὸ Μυστήριον μέγα, φρικτὸν τὸ τεράστιον! Θεὸν γὰρ ἐγέννησας, σεσωματωμένον τὸν Σωτῆρα τοῦ Κόσμου."

trMA.Ode8C2A1.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2A1.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode8C2A1.melody = he.h.m3_gr_GR_cog.heHE.TonEnFlogi.name
trMA.Ode8C2A1.incipit = "Σταυρὲ Χριστοῦ, ἡ ἐλπὶς τῶν…"
trMA.Ode8C2A1.text = "Σταυρὲ Χριστοῦ, ἡ ἐλπὶς τῶν περάτων, διαπεράσαι ἡμᾶς ἐν τῇ σῇ κυβερνήσει, γαληνῶς τὸ πέλαγος, τῆς καλλίστης Νηστείας ἀξίωσον σώσας, ἐκ τρικυμίας πταισμάτων."

trMA.Ode8C2H.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2H.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode8C2H.greekmelody = he.h.m3_gr_GR_cog.heHE.TonEnFlogi.greekname
trMA.Ode8C2H.melody = he.h.m3_gr_GR_cog.heHE.TonEnFlogi.melody
trMA.Ode8C2H.incipit = he.h.m3_gr_GR_cog.heHE.TonEnFlogi.incipit
trMA.Ode8C2H.text = he.h.m3_gr_GR_cog.heHE.TonEnFlogi.text

trMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode9C11.greekmelody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.greekname
trMA.Ode9C11.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
trMA.Ode9C11.incipit = "Νενηστευκὼς Ἐλισσαῖος ἀνέστησε, νενεκρωμένον τὸν…"
trMA.Ode9C11.text = "Νενηστευκὼς Ἐλισσαῖος ἀνέστησε, νενεκρωμένον τὸν παῖδα, ὡς γέγραπται, καὶ ἡμεῖς νηστεύοντες, σαρκικὰ φρονήματα ἀπονεκρῶσαι πιστοὶ κατεπειχθῶμεν, ἵνα ζωῆς τῆς ἐκεῖ ἐπιτύχωμεν."

trMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode9C12.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
trMA.Ode9C12.incipit = "Οἴμοι ψυχή! φοβερὸν τὸ κριτήριον…"
trMA.Ode9C12.text = "Οἴμοι ψυχή! φοβερὸν τὸ κριτήριον, καὶ τοῦ Κριτοῦ ἡ φρικώδης ἀπόφασις, σπεῦσον μετανόησον, Χριστῷ διαλλάγηθι, τῷ διὰ σὲ ἐν Σταυρῷ ἀναρτηθέντι, καὶ ῥυσαμένῳ πιστοὺς κατακρίσεως."

trMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode9C13.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
trMA.Ode9C13.incipit = "Τῆς μετανοίας μοι πύλας διάνοιξον…"
trMA.Ode9C13.text = "Τῆς μετανοίας μοι πύλας διάνοιξον, τὰς τῶν παθῶν μου εἰσόδους ἀπόκλεισον, ὁ Λῃστῇ τὴν εἴσοδον δείξας εὐεπίβατον, τοῦ Παραδείσου Χριστέ, τῇ σῇ Σταυρώσει, ἵνα δοξάζω τὴν σὴν ἀγαθότητα."

trMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.Ode9C1T.melody = he.h.m1_gr_GR_cog.heHE.TinZoodochonPigin.name
trMA.Ode9C1T.incipit = "Ὅτι εἰς βάθη κακίας ἀπέῤῥιμμαι…"
trMA.Ode9C1T.text = "Ὅτι εἰς βάθη κακίας ἀπέῤῥιμμαι, καὶ λογισμοῖς ἐναντίοις χειμάζομαι, δαίμοσι πειθόμενος, ἡδοναῖς δουλούμενος, βοήθησόν μοι ἁγνὴ Παρθενομῆτορ, πρὸς σωτηρίας ὁδὸν ὁδηγοῦσά με."

trMA.Ode9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C21.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode9C21.greekmelody = he.h.m3_gr_GR_cog.heHE.EnSinaioToOrei.greekname
trMA.Ode9C21.melody = he.h.m3_gr_GR_cog.heHE.EnSinaioToOrei.name
trMA.Ode9C21.incipit = "Παρεδόθης ἑκὼν καὶ ὑπήγαγες, ἑαυτὸν…"
trMA.Ode9C21.text = "Παρεδόθης ἑκὼν καὶ ὑπήγαγες, ἑαυτὸν τοῖς φονευταῖς, κριτηρίῳ παρέστης τυπτόμενος, ἐξ ὧν ἔπλασας χειρῶν, ἐσταυρώθης ἐπαίχθης, ἑλογχεύθης Κύριε, ἔπαθες σώματι πάντα ἐνεγκὼν συμπαθῶς, ἵνα σώσῃς ἡμᾶς."

trMA.Ode9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C22.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode9C22.melody = he.h.m3_gr_GR_cog.heHE.EnSinaioToOrei.name
trMA.Ode9C22.incipit = "Τῶν Ἀγγέλων οἱ δῆμοι ἐτρόμαξαν…"
trMA.Ode9C22.text = "Τῶν Ἀγγέλων οἱ δῆμοι ἐτρόμαξαν, βλέποντές σε ἐν Σταυρῷ, οἱ φωστῆρες τὸ φέγγος ἀπέλιπον, καὶ ἐσείετο ἡ γῆ, ἐδονεῖτο τὰ πάντα τῇ ὕβρει σου Κύριε, θείοις σου Πάθεσιν, εἰργάσω ἡμῖν, ὁ Θεὸς τὸ σωτήριον."

trMA.Ode9C2Tr.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2Tr.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode9C2Tr.melody = he.h.m3_gr_GR_cog.heHE.EnSinaioToOrei.name
trMA.Ode9C2Tr.incipit = "Τῇ οὐσίᾳ Μονάς ἐστιν ἄτμητος…"
trMA.Ode9C2Tr.text = "Τῇ οὐσίᾳ Μονάς ἐστιν ἄτμητος, ἡ ὑπέρθεος Τριάς, ἑνουμένη τῇ φύσει μερίζεται, τοῖς προσώποις ἰδικῶς· μὴ τμωμένη γὰρ τμᾶται, ἓν οὖσα τρισσεύεται, αὕτη Πατήρ ἐστιν, ὁ Υἱὸς καὶ Πνεῦμα τὸ ζῶν, ἡ φρουροῦσα τὸ πᾶν."

trMA.Ode9C2T.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2T.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode9C2T.melody = he.h.m3_gr_GR_cog.heHE.EnSinaioToOrei.name
trMA.Ode9C2T.incipit = "Παιδοτόκον παρθένον τίς ἤκουσε, καὶ…"
trMA.Ode9C2T.text = "Παιδοτόκον παρθένον τίς ἤκουσε, καὶ μητέρα πλὴν ἀνδρός; Μαριὰμ ἐκτελεῖς τὸ τεράστιον, ἀλλὰ φράζε μου τὸ Πῶς; Μὴ ἐρεύνα τὰ βάθη, τῆς παιδοτοκίας μου, τοῦτο παναληθές, ὑπὲρ δὲ ἀνθρώπινον νοῦν ἡ κατάληψις."

trMA.Ode9C2A1.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2A1.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode9C2A1.melody = he.h.m3_gr_GR_cog.heHE.EnSinaioToOrei.name
trMA.Ode9C2A1.incipit = "Τῷ σῷ μώλωπι πάντες ἰάθημεν…"
trMA.Ode9C2A1.text = "Τῷ σῷ μώλωπι πάντες ἰάθημεν, ἐκ παθῶν ἁμαρτιῶν· ἐν Σταυρῷ γὰρ ἀρθεὶς ἐτραυμάτισας, τὸν ἀρχέκακον ἐχθρόν. Ἀλλὰ ἀκατακρίτως ἡμᾶς καταξίωσον, καὶ τὴν Ἀνάστασιν φθάσαι διανύσαντας, τὸν τῆς Νηστείας καιρόν."

trMA.Ode9C2H.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2H.mode = miscellanea_gr_GR_cog.misc.Mode3
trMA.Ode9C2H.greekmelody = he.h.m3_gr_GR_cog.heHE.EnSinaioToOrei.greekname
trMA.Ode9C2H.melody = he.h.m3_gr_GR_cog.heHE.EnSinaioToOrei.melody
trMA.Ode9C2H.incipit = he.h.m3_gr_GR_cog.heHE.EnSinaioToOrei.incipit
trMA.Ode9C2H.text = he.h.m3_gr_GR_cog.heHE.EnSinaioToOrei.text

trMA.AposIdiomelon1.mode = miscellanea_gr_GR_cog.misc.Mode7
trMA.AposIdiomelon1.melody = miscellanea_gr_GR_cog.misc.Idiomelon
trMA.AposIdiomelon1.incipit = "Ὁ διὰ σταυροῦ σου Κύριε…"
trMA.AposIdiomelon1.text = "Ὁ διὰ σταυροῦ σου Κύριε, λύσας θάνατον, ἐπεισαχθέντα τῷ Κόσμῳ, διὰ ξύλου βρῶσιν, ἣν ἀπηγόρευσας ἐν Παραδείσῳ, αὐτός, διὰ τῆς ἐνεστώσης Νηστείας ἡμᾶς, ῥῦσαι πάσης ἡδονῆς ψυχοφθόρου, καὶ ἀξίωσον ἐργάζεσθαι τὴν μένουσαν βρῶσιν, εἰς ζωὴν αἰώνιον, ἵνα τύχωμεν τῶν στεφάνων τῆς ἀφθάρτου τρυφῆς, ὧν ἡτοίμασας, τοῖς ἀληθέσι νηστευταῖς δεόμεθα."

trMA.AposMartyric.mode = miscellanea_gr_GR_cog.misc.Mode7
trMA.AposMartyric.greekmelody = he.a.m7_gr_GR_cog.heAU.OukEtiKolyometha.greekname
trMA.AposMartyric.melody = he.a.m7_gr_GR_cog.heAU.OukEtiKolyometha.name
