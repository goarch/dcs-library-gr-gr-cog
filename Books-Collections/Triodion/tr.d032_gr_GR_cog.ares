trMA.AposMartyric.text = oc.m7.d4_gr_GR_cog.ocMA.Aposticha3.text

trMA.AposTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode7
trMA.AposTheotokion.greekmelody = he.a.m7_gr_GR_cog.heAU.OukEtiKolyometha.greekname
trMA.AposTheotokion.melody = he.a.m7_gr_GR_cog.heAU.OukEtiKolyometha.name
trMA.AposTheotokion.incipit = oc.m7.d4_gr_GR_cog.ocVE.SticTheotokion.incipit
trMA.AposTheotokion.text = oc.m7.d4_gr_GR_cog.ocVE.SticTheotokion.text

trTE.Troparion.mode = miscellanea_gr_GR_cog.misc.Mode6
trTE.Troparion.melody = ""
trTE.Troparion.incipit = "Ὕψιστε ὁ ἐν οὐρανοῖς κατοικῶν…"
trTE.Troparion.text = "Ὕψιστε ὁ ἐν οὐρανοῖς κατοικῶν, ὁ κτίσας πᾶσαν πνοήν, σῶσον ἡμᾶς ὁ Θεός· ἐπὶ σοὶ γὰρ ἠλπίσαμεν Σωτὴρ ἡμῶν."
trTE.Troparion2.incipit = "ἐπὶ σοὶ γὰρ ἠλπίσαμεν Σωτὴρ…"
trTE.Troparion2.text = "ἐπὶ σοὶ γὰρ ἠλπίσαμεν Σωτὴρ ἡμῶν."
