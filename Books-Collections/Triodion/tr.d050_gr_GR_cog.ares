trMA.C1.title = titles_gr_GR_cog.ti.CanonTriodion
trMA.C1.verse = prayers_gr_GR_cog.pr.verse_God.text

trMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
trMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode1C11.greekmelody = he.h.m5_gr_GR_cog.heHE.ToSotiriTheo.greekname
trMA.Ode1C11.melody = he.h.m5_gr_GR_cog.heHE.ToSotiriTheo.name
trMA.Ode1C11.incipit = "Ὡμοιώθην Χριστέ, τῷ ἐν χερσὶ…"
trMA.Ode1C11.text = "Ὡμοιώθην Χριστέ, τῷ ἐν χερσὶ τῶν λῃστῶν περιπεσόντι, καὶ τυπτήμασιν ἡμιθανεῖ ὑπὸ τούτων, καταλειφθέντι Σωτήρ, κἀγὼ οὕτω πέπληγμαι, ταῖς ἁμαρτίαις μου."

trMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
trMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode1C12.melody = he.h.m5_gr_GR_cog.heHE.ToSotiriTheo.name
trMA.Ode1C12.incipit = "Μὴ παρίδῃς ἐμέ, τὸν ἀσθενοῦντα…"
trMA.Ode1C12.text = "Μὴ παρίδῃς ἐμέ, τὸν ἀσθενοῦντα δεινῶς, ἐβόα Σῶτερ ὀδυρόμενος, εἰς τοὺς λῃστὰς ὁ τὸν πλοῦτον ἀποσυλήσας σου, κᾀγὼ οὕτω δέομαι· οἴκτειρον σῶσόν με."

trMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
trMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode1C13.melody = he.h.m5_gr_GR_cog.heHE.ToSotiriTheo.name
trMA.Ode1C13.incipit = "Ἰατρεύσας ἐμέ, τὸν μαστιχθέντα τὸν…"
trMA.Ode1C13.text = "Ἰατρεύσας ἐμέ, τὸν μαστιχθέντα τὸν νοῦν, ταῖς ἁμαρτίαις ἐν ταῖς μάστιξιν, ὑπὸ λῃστῶν τῶν ἀδίκων καὶ πονηρῶν λογισμῶν, Χριστὲ Σωτὴρ σῶσόν με, ὡς πολυέλεος."

trMA.Ode1C1T.ode = miscellanea_gr_GR_cog.misc.Ode1
trMA.Ode1C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode1C1T.melody = he.h.m5_gr_GR_cog.heHE.ToSotiriTheo.name
trMA.Ode1C1T.incipit = "Ἄχραντε Μήτηρ Χριστοῦ, τὸν σαρκωθέντα…"
trMA.Ode1C1T.text = "Ἄχραντε Μήτηρ Χριστοῦ, τὸν σαρκωθέντα ἐκ σοῦ καὶ ἐκ τῶν κόλπων τοῦ Γεννήτορος, μὴ ἐκφοιτήσαντα Θεόν, ἀπαύστως πρέσβευε, ἐκ πάσης περιστάσεως σῶσαι οὓς ἔπλασεν."

trMA.C2.title = titles_gr_GR_cog.ti.CanonDevoutM
trMA.C2.verse = prayers_gr_GR_cog.pr.verse_SaintM.text
trMA.C2.notice1 = "Ἡ ἀκολουθία τοῦ Ἁγίου Ἰωάννου τῆς Κλίμακος ψάλλεται (ἢ ἀναγινώσκεται) ἐδὼ ἐφέτος, ἐπειδὴ συνέπεσε μὲ τὴν ἀπόδοσιν τῆς ἑορτῆς τοῦ Εὐαγγελισμοῦ."

trMA.Ode1C21.ode = miscellanea_gr_GR_cog.misc.Ode1
trMA.Ode1C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode1C21.greekmelody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.greekname
trMA.Ode1C21.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
trMA.Ode1C21.incipit = "Ἐν φωτὶ ἀΰλῳ καὶ νοητῷ…"
trMA.Ode1C21.text = "Ἐν φωτὶ ἀΰλῳ καὶ νοητῷ, ἐκ τῆς κατηφείας, τῶν ἐνύλων ἀναδραμών, Ἰωάννη Ὅσιε λιταῖς σου, ταῖς πρὸς τὸν Κύριόν με φώτισον."

trMA.Ode1C22.ode = miscellanea_gr_GR_cog.misc.Ode1
trMA.Ode1C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode1C22.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
trMA.Ode1C22.incipit = "Ὡς τῆς ἐγκρατείας τὸν γλυκασμόν…"
trMA.Ode1C22.text = "Ὡς τῆς ἐγκρατείας τὸν γλυκασμόν, θηλάσας ἀπώσω, τὴν πικρίαν τῶν ἡδονῶν· ὅθεν ὑπὲρ μέλι καὶ κηρίον, ἡδύνεις Πάτερ τὰς αἰσθήσεις ἡμῶν."

trMA.Ode1C23.ode = miscellanea_gr_GR_cog.misc.Ode1
trMA.Ode1C23.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode1C23.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
trMA.Ode1C23.incipit = "Ἐπιβὰς τῷ ὕψει τῶν ἀρετῶν…"
trMA.Ode1C23.text = "Ἐπιβὰς τῷ ὕψει τῶν ἀρετῶν, καὶ τὰς χαμαιζήλους, διαπτύσας τῶν ἡδονῶν, γλυκασμὸς ἐδείχθης σωτηρίας, Ὅσιε Πάτερ τῷ ποιμνίῳ σου."

trMA.Ode1C2T.ode = miscellanea_gr_GR_cog.misc.Ode1
trMA.Ode1C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode1C2T.melody = he.h.m8_gr_GR_cog.heHE.YgranDiodefsas.name
trMA.Ode1C2T.incipit = "Σοφίαν καὶ Λόγον ἡ τοῦ…"
trMA.Ode1C2T.text = "Σοφίαν καὶ Λόγον ἡ τοῦ Πατρός, ἀφράστως τεκοῦσα, τῆς ψυχῆς μου τὸ χαλεπόν, θεράπευσον τραῦμα καὶ καρδίας, τὴν ἀλγηδόνα καταπράϋνον."

trMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode3C11.greekmelody = he.h.m5_gr_GR_cog.heHE.StereosonImasOTheos.greekname
trMA.Ode3C11.melody = he.h.m5_gr_GR_cog.heHE.StereosonImasOTheos.name
trMA.Ode3C11.incipit = "Ὁδῷ ἐν τῇ τοῦ βίου…"
trMA.Ode3C11.text = "Ὁδῷ ἐν τῇ τοῦ βίου Χριστὲ δεινῶς ὁδεύων τετραυμάτισμαι, ὑπὸ λῃστῶν ἐν τοῖς πάθεσιν, ἀλλʹ ἀνάστησόν με δέομαι."

trMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode3C12.melody = he.h.m5_gr_GR_cog.heHE.StereosonImasOTheos.name
trMA.Ode3C12.incipit = "Ἐσύλησαν τὸν νοῦν μου λῃσταί…"
trMA.Ode3C12.text = "Ἐσύλησαν τὸν νοῦν μου λῃσταί, καὶ ἔλιπόν με ἐν τοῖς μώλωψιν, ἡμιθανῆ τῶν πταισμάτων μου ἀλλὰ ἴασαί με Κύριε."

trMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode3C13.melody = he.h.m5_gr_GR_cog.heHE.StereosonImasOTheos.name
trMA.Ode3C13.incipit = "Ἐγύμνωσάν με Σῶτερ Χριστέ, τῶν…"
trMA.Ode3C13.text = "Ἐγύμνωσάν με Σῶτερ Χριστέ, τῶν ἐντολῶν σου τὰ παθήματα, καὶ ἡδοναῖς μεμαστίγωμαι, ἀλλʹ ἐπίχεέ μοι ἔλεος."

trMA.Ode3C1T.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode3C1T.melody = he.h.m5_gr_GR_cog.heHE.StereosonImasOTheos.name
trMA.Ode3C1T.incipit = "Ἱκέτευε ἀπαύστως Ἁγνή, τον προελθόντα…"
trMA.Ode3C1T.text = "Ἱκέτευε ἀπαύστως Ἁγνή, τον προελθόντα ἐκ λαγόνων σου ῥυσθῆναι πλάνης διαβόλου τοὺς ὑμνοῦντάς σε Θεόνυμφε."

trMA.Ode3C21.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode3C21.greekmelody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.greekname
trMA.Ode3C21.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
trMA.Ode3C21.incipit = "Ἔφλεξας τῷ ἄνθρακι, τῷ τῆς…"
trMA.Ode3C21.text = "Ἔφλεξας τῷ ἄνθρακι, τῷ τῆς ἀσκήσεως Ὅσιε, τὴν τῶν παθῶν, ἄκανθαν καὶ θάλπεις, Μοναστῶν τὰ συστήματα."

trMA.Ode3C22.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode3C22.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
trMA.Ode3C22.incipit = "Μύρον ἁγιάσματος ἐκ τῶν ἀσκητικῶν…"
trMA.Ode3C22.text = "Μύρον ἁγιάσματος ἐκ τῶν ἀσκητικῶν Ὅσιε ἀρωμάτων, ὅλος συνετέθης, εἰς ὀσμὴν εὐωδίας Θεοῦ."

trMA.Ode3C23.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C23.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode3C23.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
trMA.Ode3C23.incipit = "Νόμοις τοῖς ἀσκήσεως ἐμμελετῶν τὰ…"
trMA.Ode3C23.text = "Νόμοις τοῖς ἀσκήσεως ἐμμελετῶν τὰ πάθη ἐβύθισας, ὥσπερ ἄλλους, πρὶν Φαραωνίτας, τῇ ῥοῇ τῶν δακρύων σου."

trMA.Ode3C2T.ode = miscellanea_gr_GR_cog.misc.Ode3
trMA.Ode3C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode3C2T.melody = he.h.m8_gr_GR_cog.heHE.SyEiToStereoma.name
trMA.Ode3C2T.incipit = "Στῆσόν μου τὸν ἄστατον, τῶν…"
trMA.Ode3C2T.text = "Στῆσόν μου τὸν ἄστατον, τῶν λογισμῶν ἁγνὴ τάραχον Μῆτερ Θεοῦ, τὴν πρὸς τὸν Υἱόν σου, κατευθύνουσα κίνησιν."

trMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode3Kathisma1.melody = "Τὸ ξένον τῆς Παρθένου."
trMA.Ode3Kathisma1.incipit = "Τὸν ἄχραντον Σταυρόν, σου Σωτὴρ…"
trMA.Ode3Kathisma1.text = "Τὸν ἄχραντον Σταυρόν, σου Σωτὴρ ἡμῶν ὡς ὅπλον σωτηρίας κατέχοντες, ἐν αὐτῷ σοι βοῶμεν· Σῶσον ἡμᾶς, ὁ παθὼν ἑκουσίως ὑπὲρ ἡμῶν, ὁ πάντων Θεὸς ὡς πολυέλεος."

trMA.Ode3Kathisma2.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode3Kathisma2.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
trMA.Ode3Kathisma2.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
trMA.Ode3Kathisma2.incipit = "Ταῖς ἀρεταῖς πρὸς οὐρανὸν ἀναλάμψας…"
trMA.Ode3Kathisma2.text = "Ταῖς ἀρεταῖς πρὸς οὐρανὸν ἀναλάμψας, καταπηξάμενος σαφῶς ἐπανῆλθες, πρὸς θεωρίας ἄπλετον βυθὸν εὐσεβῶς, πάσας στηλιτεύσας μέν, τῶν Δαιμόνων ἐνέδρας, σκέπεις ἐκ τῆς λώβης δέ, τοὺς ἀνθρώπους τῆς τούτων, ὦ Ἰωάννη, κλῖμαξ ἀρετῶν· καὶ νῦν πρεσβεύεις σωθῆναι τοὺς δούλους σου."

trMA.Ode3Kathisma3.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Ode3Kathisma3.greekmelody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.greekname
trMA.Ode3Kathisma3.melody = he.a.m4_gr_GR_cog.heAU.OYpsotheisEnToStavro.name
trMA.Ode3Kathisma3.incipit = me.m07.d31_gr_GR_cog.meMA.Ode3KathismaT.incipit
trMA.Ode3Kathisma3.text = me.m07.d31_gr_GR_cog.meMA.Ode3KathismaT.text

trMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
trMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode4C11.greekmelody = he.h.m5_gr_GR_cog.heHE.AkikoaKyrieTinEkTouTafou.greekname
trMA.Ode4C11.melody = he.h.m5_gr_GR_cog.heHE.AkikoaKyrieTinEkTouTafou.name
trMA.Ode4C11.incipit = "Λῃσταί μου ἐσύλησαν, τὴν ἐργασίαν…"
trMA.Ode4C11.text = "Λῃσταί μου ἐσύλησαν, τὴν ἐργασίαν τὴν ἔνθεον, καὶ κατέλιπόν με, ταῖς πληγαῖς τιμωρούμενον."

trMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
trMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode4C12.melody = he.h.m5_gr_GR_cog.heHE.AkikoaKyrieTinEkTouTafou.name
trMA.Ode4C12.incipit = "Ἐξέδυσάν Σῶτέρ με, τῶν ἐντολῶν…"
trMA.Ode4C12.text = "Ἐξέδυσάν Σῶτέρ με, τῶν ἐντολῶν σου, οἱ ἄστατοι λογισμοί μου· ὅθεν μεμαστίγωμαι πταίσμασι."

trMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
trMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode4C13.melody = he.h.m5_gr_GR_cog.heHE.AkikoaKyrieTinEkTouTafou.name
trMA.Ode4C13.incipit = "Λευΐτης τοῖς μώλωψι τραυματισθέντα ὡς…"
trMA.Ode4C13.text = "Λευΐτης τοῖς μώλωψι τραυματισθέντα ὡς εἶδέ με παρῆλθε Σωτήρ μου, ἀλλὰ σύ με διάσωσον."

trMA.Ode4C1T.ode = miscellanea_gr_GR_cog.misc.Ode4
trMA.Ode4C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode4C1T.melody = he.h.m5_gr_GR_cog.heHE.AkikoaKyrieTinEkTouTafou.name
trMA.Ode4C1T.incipit = "Κυρίως δοξάζομεν σὲ Θεοτόκε ἀνύμφευτε…"
trMA.Ode4C1T.text = "Κυρίως δοξάζομεν σὲ Θεοτόκε ἀνύμφευτε, καὶ τῷ σῷ λιμένι, οἱ πιστοὶ καταφεύγομεν."

trMA.Ode4C21.ode = miscellanea_gr_GR_cog.misc.Ode4
trMA.Ode4C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode4C21.greekmelody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.greekname
trMA.Ode4C21.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
trMA.Ode4C21.incipit = "Ὡς λειμὼν εὐωδέστατος, καὶ τῶν…"
trMA.Ode4C21.text = "Ὡς λειμὼν εὐωδέστατος, καὶ τῶν ἀρετῶν Παράδεισος ἔμψυχος, τὴν ἐγκράτειαν ἐξήνθησας, δι΄ ἧς πάντας ἔθρεψας τοὺς τιμῶντάς σε."

trMA.Ode4C22.ode = miscellanea_gr_GR_cog.misc.Ode4
trMA.Ode4C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode4C22.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
trMA.Ode4C22.incipit = "Νομοθέτην ἀσκήσεως, καὶ τῶν μοναστῶν…"
trMA.Ode4C22.text = "Νομοθέτην ἀσκήσεως, καὶ τῶν μοναστῶν κανόνα πραότατον, ὡς Μωσῆν σε καὶ Δαυῒδ ἀληθῶς, κεκτημένοι Πάτερ μακαρίζομεν."

trMA.Ode4C23.ode = miscellanea_gr_GR_cog.misc.Ode4
trMA.Ode4C23.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode4C23.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
trMA.Ode4C23.incipit = "Φυτευθεὶς ἐν τοῖς ὕδασι, τοῖς…"
trMA.Ode4C23.text = "Φυτευθεὶς ἐν τοῖς ὕδασι, τοῖς τῆς ἐγκρατείας, ὤφθης μακάριε, κλῆμα Πάτερ εὐθαλέστατον εὐσεβείας βότρυας προβαλλόμενον."

trMA.Ode4C2T.ode = miscellanea_gr_GR_cog.misc.Ode4
trMA.Ode4C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode4C2T.melody = he.h.m8_gr_GR_cog.heHE.EisakikoaKyrie.name
trMA.Ode4C2T.incipit = "Ὑπὸ χρόνον γενόμενον, τὸν ἐκ…"
trMA.Ode4C2T.text = "Ὑπὸ χρόνον γενόμενον, τὸν ἐκ τοῦ Πατρὸς ἀχρόνως ἐκλάψαντα Θεομῆτορ ἡμῖν τέτοκας, ὃν δυσώπει σῶσαι τοὺς ὑμνοῦντάς σε."

trMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode5C11.greekmelody = he.h.m5_gr_GR_cog.heHE.EkNyktosOrthrizontes.greekname
trMA.Ode5C11.melody = he.h.m5_gr_GR_cog.heHE.EkNyktosOrthrizontes.name
trMA.Ode5C11.incipit = "Ἰησοῦ ἐπίσκεψαι, τοὺς μώλωπας ψυχῆς…"
trMA.Ode5C11.text = "Ἰησοῦ ἐπίσκεψαι, τοὺς μώλωπας ψυχῆς τῆς ἐμῆς, καθάπερ πάλαι, τὸν ἐν χερσὶ πεσόντα λῃστῶν, καὶ ἰάτρευσόν μου, Χριστέ, τὸ ἄλγος δέομαι."

trMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode5C12.melody = he.h.m5_gr_GR_cog.heHE.EkNyktosOrthrizontes.name
trMA.Ode5C12.incipit = "Ἀλγεινῶς ταῖς μάστιξιν, ἠσθένησε ψυχή…"
trMA.Ode5C12.text = "Ἀλγεινῶς ταῖς μάστιξιν, ἠσθένησε ψυχή μου Χριστὲ ταῖς τῶν πταισμάτων, καὶ ἔνθεν γυμνὸς περίκειμαι, ἀρετῶν ἐνθέων, καθικετεύω, Σῶσόν με."

trMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode5C13.melody = he.h.m5_gr_GR_cog.heHE.EkNyktosOrthrizontes.name
trMA.Ode5C13.incipit = "Ἱερεὺς ὡς εἶδέ με, καὶ…"
trMA.Ode5C13.text = "Ἱερεὺς ὡς εἶδέ με, καὶ Λευΐτης οὐκ ἴσχυσε σαφῶς· παρῆλθον γάρ με, ἀλλʹ αὐτὸς ὡς εὔσπλαγχνος, νῦν τὴν σωτηρίαν, παρέσχες καὶ διέσωσας."

trMA.Ode5C1T.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode5C1T.melody = he.h.m5_gr_GR_cog.heHE.EkNyktosOrthrizontes.name
trMA.Ode5C1T.incipit = "Μὴ παρίδῃς Δέσποτα, τὸν δείλαιον…"
trMA.Ode5C1T.text = "Μὴ παρίδῃς Δέσποτα, τὸν δείλαιον ἐμὲ δυσωπῶ τὸν μαστιχθέντα τὸν νοῦν ἀλγεινῶς ὑπὸ λῃστῶν, ἀλλʹ οἰκτείρησον πρεσβείαις Σωτὴρ τῆς κυησάσης σε."

trMA.Ode5C21.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode5C21.greekmelody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.greekname
trMA.Ode5C21.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
trMA.Ode5C21.incipit = "Σβέσας πάντα τὰ πάθη δρόσῳ…"
trMA.Ode5C21.text = "Σβέσας πάντα τὰ πάθη δρόσῳ τῶν ἀγώνων σου, Πάτερ μακάριε, δαψιλῶς ἀνῆψας, τῷ πυρὶ τῆς ἀγάπης καὶ πίστεως, ἐγκρατείας λύχνον, καὶ φωτισμὸς τῆς ἀπαθείας, καὶ ἡμέρας υἱὸς ἐχρημάτισας."

trMA.Ode5C22.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode5C22.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
trMA.Ode5C22.incipit = "Τὸν τῆς πίστεως βότρυν, θείᾳ…"
trMA.Ode5C22.text = "Τὸν τῆς πίστεως βότρυν, θείᾳ γεωργίᾳ σου, Πάτερ ἐξέθρεψας, καὶ ληνοῖς ἀπέθου, καὶ ἐξέθλιψας πόνοις ἀσκήσεως, καὶ κρατῆρα πλήσας, πνευματικόν τῆς ἐγκρατείας, κατευφραίνεις καρδίας τῆς ποίμνης σου."

trMA.Ode5C23.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C23.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode5C23.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
trMA.Ode5C23.incipit = "Ὑπομείνας γενναίως, προσβολὰς καὶ στίγματα…"
trMA.Ode5C23.text = "Ὑπομείνας γενναίως, προσβολὰς καὶ στίγματα, τῶν ἐναντίων ἐχθρῶν, ἀνεδείχθης στῦλος, καρτερίας στηρίζων τὴν ποίμνην σου, βακτηρίᾳ θείᾳ, ἐπὶ νομὰς τῆς ἐγκρατείας, καὶ ἐφ΄ ὕδωρ ἐκτρέφων Μακάριε."

trMA.Ode5C2T.ode = miscellanea_gr_GR_cog.misc.Ode5
trMA.Ode5C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode5C2T.melody = he.h.m8_gr_GR_cog.heHE.InaTiMeAposo.name
trMA.Ode5C2T.incipit = "Ῥήσεσι σῶν χειλέων, Πάναγνε ἑπόμενοι…"
trMA.Ode5C2T.text = "Ῥήσεσι σῶν χειλέων, Πάναγνε ἑπόμενοι, σὲ μακαρίζομεν· μετὰ σοῦ γὰρ ὄντως, μεγαλεῖα ποιήσας ὁ Κύριος, ἐμεγάλυνέ σε, καὶ ἀληθῆ Θεοῦ Μητέρα, γεννηθεὶς ἐκ γαστρός σου ἀνέδειξεν."

trMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
trMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode6C11.greekmelody = he.h.m5_gr_GR_cog.heHE.EkykloseMeAvyssos.greekname
trMA.Ode6C11.melody = he.h.m5_gr_GR_cog.heHE.EkykloseMeAvyssos.name
trMA.Ode6C11.incipit = "Τοῖς πάθεσιν ἠνάλωσα, τὸν βίον…"
trMA.Ode6C11.text = "Τοῖς πάθεσιν ἠνάλωσα, τὸν βίον τὸν ἔνθεον Δέσποτα, καὶ ὅλως τοῖς πταίσμασι, δεινῶς μαστιζόμενος, κατέφυγόν σοι, οἰκτείρησόν με δέομαι."

trMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
trMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode6C12.melody = he.h.m5_gr_GR_cog.heHE.EkykloseMeAvyssos.name
trMA.Ode6C12.incipit = "Ἀφήρπασαν τὸν πλοῦτόν μου, καὶ…"
trMA.Ode6C12.text = "Ἀφήρπασαν τὸν πλοῦτόν μου, καὶ ὥσπερ νεκρόν με κατέλιπον, λῃσταὶ τοῖς παθήμασι, τὸν νοῦν μου μαστίξαντες, ἀλλʹ οἰκτειρήσας, διάσωσόν με Κύριε."

trMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
trMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode6C13.melody = he.h.m5_gr_GR_cog.heHE.EkykloseMeAvyssos.name
trMA.Ode6C13.incipit = "Ὡς εἶδεν ὁ Λευΐτης μου…"
trMA.Ode6C13.text = "Ὡς εἶδεν ὁ Λευΐτης μου, μαστίγων τὸ ἄλγος, τοὺς μώλωπας μὴ φέρων παρῆλθέ με, αὐτὸς δὲ Φιλάνθρωπε, κατέχεάς μοι, το πλούσιόν σου ἔλεος."

trMA.Ode6C1T.ode = miscellanea_gr_GR_cog.misc.Ode6
trMA.Ode6C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode6C1T.melody = he.h.m5_gr_GR_cog.heHE.EkykloseMeAvyssos.name
trMA.Ode6C1T.incipit = "Βάτον σε ἀκατάφλεκτον, καὶ ὄρος…"
trMA.Ode6C1T.text = "Βάτον σε ἀκατάφλεκτον, καὶ ὄρος καὶ κλίμακα ἔμψυχον, καὶ πύλην οὐράνιον, ἀξίως δοξάζομεν, Μαρία ἔνδοξε, Ὀρθοδόξων καύχημα."

trMA.Ode6C21.ode = miscellanea_gr_GR_cog.misc.Ode6
trMA.Ode6C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode6C21.greekmelody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.greekname
trMA.Ode6C21.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
trMA.Ode6C21.incipit = "Ἐδέξω ἐν τῇ ψυχῇ, τὸν…"
trMA.Ode6C21.text = "Ἐδέξω ἐν τῇ ψυχῇ, τὸν θεῖον πλοῦτον τοῦ Πνεύματος, τὴν ἄμεμπτον προσευχήν, ἁγνείαν σεμνότητα, ἀγρυπνίαν σύντονον, ἐγκρατείας πόνους, δι ὧν οἶκος ἐγνωρίσθης Θεοῦ."

trMA.Ode6C22.ode = miscellanea_gr_GR_cog.misc.Ode6
trMA.Ode6C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode6C22.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
trMA.Ode6C22.incipit = "Ὕλης τῆς κάτω Σοφὲ παρέδραμες…"
trMA.Ode6C22.text = "Ὕλης τῆς κάτω Σοφὲ παρέδραμες τὴν εὐτέλειαν, ἀΰλῳ δὲ προσευχῇ τὸν νοῦν ἀνεπτέρωσας, καὶ τῆς ἄνω λήξεως, ὤφθης κληρονόμος, διὰ βίου τελειότητα."

trMA.Ode6C23.ode = miscellanea_gr_GR_cog.misc.Ode6
trMA.Ode6C23.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode6C23.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
trMA.Ode6C23.incipit = "Ἱδρῶσιν ἀσκητικοῖς, τοὺς ἄνθρακας τῶν…"
trMA.Ode6C23.text = "Ἱδρῶσιν ἀσκητικοῖς, τοὺς ἄνθρακας τῶν βελῶν τοῦ ἐχθροῦ, κατέσβεσας ἀληθῶς, καὶ τὸ πῦρ τῆς πίστεως, ἐκλάμψας κατέφλεξας, τὰ τῆς ἀπιστίας, τῶν αἱρέσεων φρυάγματα."

trMA.Ode6C2T.ode = miscellanea_gr_GR_cog.misc.Ode6
trMA.Ode6C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode6C2T.melody = he.h.m8_gr_GR_cog.heHE.IlasthitiMoiSotir.name
trMA.Ode6C2T.incipit = "Ἐξέλαμψεν ἐκ Σιών, ἡ τοῦ…"
trMA.Ode6C2T.text = "Ἐξέλαμψεν ἐκ Σιών, ἡ τοῦ Ὑψίστου εὐπρέπεια, τὸ πρόβλημα τῆς σαρκός, καθ΄ ἕνωσιν ἄῤῥητον, ἐκ σοῦ Ἀπειρόγαμε, περιβεβλημένη, καὶ τὸν Κόσμον κατεφώτισε."

trMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode4
trMA.Kontakion1.melody = he.a.m4_gr_GR_cog.heAU.EpefanisSimeron.name
trMA.Kontakion1.incipit = "Ἐν τῷ ὕψει Κύριος, τῆς…"
trMA.Kontakion1.text = "Ἐν τῷ ὕψει Κύριος, τῆς ἐγκρατείας, ἀληθῆ σε ἔθετο, ὥσπερ ἀστέρα ἀπλανῆ, φωταγωγοῦντα τὰ πέρατα, καθηγητὰ Ἰωάννη Πατὴρ ἡμῶν."

trMA.Oikos1.text = "Οἶκον Θεοῦ ὡς ἀληθῶς, σαυτὸν εἰργάσω Πάτερ, ταῖς θείαις ἀρεταῖς σου, σαφῶς κατακοσμήσας, ὥσπερ χρυσίον τηλαυγές, πίστιν ἐλπίδα καὶ ἀγάπην ἀληθῆ, θείους θεσμοὺς ἐκθέμενος, ἐγκρατείᾳ ἀσκήσας ὡς ἄσαρκος, φρόνησιν, ἀνδρείαν, σωφροσύνην κτησάμενος ταπείνωσιν, διʹ ἧς ἀνυψώθης· διὸ καὶ ἐφωτίσθης εὐχαῖς ἀεννάοις, καὶ τοῦ οὐρανοῦ κατέλαβες τὰς σκηνώσεις, καθηγητὰ Ἰωάννη Πατὴρ ἡμῶν."

trSY.commemoration.text = "Τῇ αὐτῇ ἡμέρᾳ, Κυριακῇ τετάρτῃ τῶν Νηστειῶν, μνήμην ποιοῦμεν τοῦ Ὁσίου Πατρὸς ἡμῶν Ἰωάννου, τοῦ Συγγραφέως τῆς Κλίμακος."
trSY.commemoration.onotherday.text = "Τῇ αὐτῇ ἡμέρᾳ, μνήμην ποιοῦμεν τοῦ Ὁσίου Πατρὸς ἡμῶν Ἰωάννου, τοῦ Συγγραφέως τῆς Κλίμακος."
trSY.commemoration.couplet1.title = titles_gr_GR_cog.ti.Verses
trSY.commemoration.couplet1.verse1 = "Ὁ σάρκα καὶ ζῶν νεκρὸς ὢν Ἰωάννης,"
trSY.commemoration.couplet1.verse2 = "Αἰωνίως ζῇ, καὶ νεκρὸς φανεὶς ἄπνους."
trSY.commemoration.couplet2.verse1 = "Σύγγραμμα λιπὼν Κλίμακα τῇ ἀνόδῳ,"
trSY.commemoration.couplet2.verse2 = "Δείκνυσιν αὐτοῦ πορείαν τῆς ἀνόδου."
trSY.commemoration.narration.p01 = "[paragraph 01]"
trSY.commemoration.narration.p02 = "[paragraph 02]"
trSY.commemoration.narration.p03 = "[paragraph 03]"
trSY.commemoration.narration.p04 = "[paragraph 04]"
trSY.commemoration.narration.p05 = "[paragraph 05]"
trSY.commemoration.narration.p06 = "[paragraph 06]"
trSY.commemoration.narration.p07 = "[paragraph 07]"
trSY.lastline = "Ταῖς αὐτοῦ πρεσβείαις, ὁ Θεός, ἐλέησον, καὶ σῶσον ἡμᾶς. Ἀμήν."

trMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
trMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode7C11.greekmelody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.greekname
trMA.Ode7C11.melody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.name
trMA.Ode7C11.incipit = "Λῃσταὶ περιέπεσαν ἐπʼ ἐμὲ τὸν…"
trMA.Ode7C11.text = "Λῃσταὶ περιέπεσαν ἐπʼ ἐμὲ τὸν δείλαιον, καὶ μάστιξιν ἔλιπον νεκρὸν ὥσπερ ἄπνουν με· διό σε ἱκετεύω, ὁ Θεὸς ἐπίσκεψαί με."

trMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
trMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode7C12.melody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.name
trMA.Ode7C12.incipit = "Τὸν νοῦν μου ἐσύλησαν λογισμοὶ…"
trMA.Ode7C12.text = "Τὸν νοῦν μου ἐσύλησαν λογισμοὶ οἱ ἄστατοι καὶ πλήξαντες πάθεσι, νεκρόν με ἔλιπον, τῷ πλήθει τῶν πταισμάτων, ἀλλὰ Σῶτερ ἴασαί με."

trMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
trMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode7C13.melody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.name
trMA.Ode7C13.incipit = "Ὡς εἶδε Λευΐτης με, ταῖς…"
trMA.Ode7C13.text = "Ὡς εἶδε Λευΐτης με, ταῖς πληγαῖς ὀδυνώμενον, μὴ φέρων τοὺς μώλωπας, διὰ τὸ ἀνίατον παρῆλθέ με Σωτήρ μου, ἀλλʹ αὐτὸς ἰάτρευσόν με."

trMA.Ode7C1T.ode = miscellanea_gr_GR_cog.misc.Ode7
trMA.Ode7C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode7C1T.melody = he.h.m5_gr_GR_cog.heHE.OYperypsoumenos.name
trMA.Ode7C1T.incipit = "Σὺ ὁ ἐκ Παρθένου με…"
trMA.Ode7C1T.text = "Σὺ ὁ ἐκ Παρθένου με σαρκωθεὶς διέσωσας, τοῖς μώλωψι χέας μου, τὸ πλούσιον ἔλεος Χριστὲ τῶν οἰκτιρμῶν σου, διὰ τοῦτό σε δοξάζω."

trMA.Ode7C21.ode = miscellanea_gr_GR_cog.misc.Ode7
trMA.Ode7C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode7C21.greekmelody = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.greekname
trMA.Ode7C21.melody = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.name
trMA.Ode7C21.incipit = "Ἐν τῇ χλόῃ τῆς ἄνω…"
trMA.Ode7C21.text = "Ἐν τῇ χλόῃ τῆς ἄνω, βασιλείας, τὴν ποίμνην Πάτερ ἐξέθρεψας καὶ ῥάβδῳ τῶν δογμάτων, τοὺς θῆρας ἀπελάσας, τῶν αἱρέσεων ἔψαλλες· ὁ τῶν Πατέρων ἡμῶν, Θεὸς εὐλογητός εἶ."

trMA.Ode7C22.ode = miscellanea_gr_GR_cog.misc.Ode7
trMA.Ode7C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode7C22.melody = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.name
trMA.Ode7C22.incipit = "Ἐν τῇ ἄνω εἰσῆλθες, νυμφικῇ…"
trMA.Ode7C22.text = "Ἐν τῇ ἄνω εἰσῆλθες, νυμφικῇ εὐωχίᾳ, τοῦ Βασιλέως Χριστοῦ, στολὴν ἐνδεδυμένος ἀξίαν τοῦ καλοῦντος, ἐν ᾧ καὶ ἀνεκλίθης βοῶν· ὁ τῶν Πατέρων ἡμῶν Θεὸς εὐλογητός εἶ."

trMA.Ode7C23.ode = miscellanea_gr_GR_cog.misc.Ode7
trMA.Ode7C23.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode7C23.melody = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.name
trMA.Ode7C23.incipit = "Μὴ βραχεὶς ἁμαρτίαις, ποταμὸς ἀνεδείχθης…"
trMA.Ode7C23.text = "Μὴ βραχεὶς ἁμαρτίαις, ποταμὸς ἀνεδείχθης, τῆς ἐγκρατείας Πάτερ λογισμοὺς κατακλύζων, καὶ ῥύπον ἐκκαθαίρων, τῶν βοώντων ἐκ πίστεως· ὁ τῶν Πατέρων ἡμῶν, Θεὸς εὐλογητὸς εἶ."

trMA.Ode7C2T.ode = miscellanea_gr_GR_cog.misc.Ode7
trMA.Ode7C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode7C2T.melody = he.h.m8_gr_GR_cog.heHE.OiEkTisIoudaias.name
trMA.Ode7C2T.incipit = "Ἐκ γαστρός σου προῆλθε, σαρκωθεὶς…"
trMA.Ode7C2T.text = "Ἐκ γαστρός σου προῆλθε, σαρκωθεὶς ἐκ Παρθένου τῶν ὅλων Κύριος· διό σε Θεοτόκον, φρονοῦντες ὀρθοδόξως, τῷ Υἱῷ σου κραυγάζομεν· ὁ τῶν Πατέρων ἡμῶν, Θεὸς εὐλογητός εἶ."

trMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode8C11.greekmelody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.greekname
trMA.Ode8C11.melody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.name
trMA.Ode8C11.incipit = "Ὑπὸ τῶν λῃστῶν τῶν λογισμῶν…"
trMA.Ode8C11.text = "Ὑπὸ τῶν λῃστῶν τῶν λογισμῶν μου Σῶτερ διέφθειρα βίον μου πταισμάτων μάστιξιν· ὅθεν τῆς θείας γεγύμνωμαι εἰκόνος σοῦ τοῦ φιλανθρώπου Θεοῦ ἀλλʹ οἴκτειρόν με."

trMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode8C12.melody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.name
trMA.Ode8C12.incipit = "Ἦλθες ἐπὶ γῆς, ἐκ τῶν…"
trMA.Ode8C12.text = "Ἦλθες ἐπὶ γῆς, ἐκ τῶν ὑψίστων Σῶτερ, οἰκτείρας τὸν μάστιξι, τραυματισθέντα με, ὅλον πταισμάτων τοῖς μώλωψιν οἰκτίρμον, καὶ ἐξέχεάς μοι, Χριστὲ τὸ ἔλεός σου."

trMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode8C13.melody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.name
trMA.Ode8C13.incipit = "Σῶμα καὶ ψυχήν, σὺ ὁ…"
trMA.Ode8C13.text = "Σῶμα καὶ ψυχήν, σὺ ὁ Δεσπότης Σῶτερ, ἀντίλυτρον δέδωκας ἐμοῦ καὶ ἔσωσας, ὅλου πταισμάτων, ἑσμῷ τραυματισθέντος, ἐν ταῖς ἀνιάτοις, πληγαῖς ὡς ἐλεήμων."

trMA.Ode8C1T.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode8C1T.melody = he.h.m5_gr_GR_cog.heHE.SoiToPantourgo.name
trMA.Ode8C1T.incipit = "Σὲ τὴν ὑπὲρ νοῦν, θεανδρικῷ…"
trMA.Ode8C1T.text = "Σὲ τὴν ὑπὲρ νοῦν, θεανδρικῷ τῷ λόγῳ, τεκοῦσαν τὸν Κύριον, καὶ παρθενεύουσαν, πάντα τὰ ἔργα, Παρθένε εὐλογοῦμεν, καὶ ὑπερυψοῦμεν, εἰς πάντας τοὺς αἰῶνας."

trMA.Ode8C21.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C21.greekmelody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.greekname
trMA.Ode8C21.melody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.name
trMA.Ode8C21.incipit = "Στήλην σε ἔμπνουν ὡς ἀληθῶς…"
trMA.Ode8C21.text = "Στήλην σε ἔμπνουν ὡς ἀληθῶς καὶ εἰκόνα ἐγκρατείας Πάτερ κεκτημένοι πάντες σου τὴν μνήμην τιμῶμεν Ἰωάννη."

trMA.Ode8C22.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C22.melody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.name
trMA.Ode8C22.incipit = "Θίασος χαίρει τῶν Μοναστῶν, καὶ…"
trMA.Ode8C22.text = "Θίασος χαίρει τῶν Μοναστῶν, καὶ χορεύει, τῶν Ὁσίων δῆμος καὶ Δικαίων· στέφος γὰρ ἀξίως, σὺν τούτοις ἐκομίσω."

trMA.Ode8C23.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C23.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C23.melody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.name
trMA.Ode8C23.incipit = "Ὡραϊσμένος ταῖς ἀρεταῖς εἰς νυμφῶνα…"
trMA.Ode8C23.text = "Ὡραϊσμένος ταῖς ἀρεταῖς εἰς νυμφῶνα τῆς ἀῤῥήτου δόξης συνεισῆλθες, ὕμνον ἀναμέλπων, Χριστῷ εἰς τοὺς αἰῶνας."

trMA.Ode8C2T.ode = miscellanea_gr_GR_cog.misc.Ode8
trMA.Ode8C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode8C2T.melody = he.h.m8_gr_GR_cog.heHE.TonVasileaTonOuranon.name
trMA.Ode8C2T.incipit = "Τοὺς βοηθείας τῆς παρὰ σοῦ…"
trMA.Ode8C2T.text = "Τοὺς βοηθείας τῆς παρὰ σοῦ δεομένους μὴ παρίδῃς Παρθένε ὑμνοῦντας καὶ ὑπερυψοῦντάς σε Κόρη εἰς αἰῶνας."

trMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode9C11.greekmelody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.greekname
trMA.Ode9C11.melody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.name
trMA.Ode9C11.incipit = "Ἐντολάς σου Δέσποτα μὴ φυλάξας…"
trMA.Ode9C11.text = "Ἐντολάς σου Δέσποτα μὴ φυλάξας, γνώμῃ ἐμαυτοῦ, τοῖς πάθεσιν ὑπελθών, τοῖς τῶν ἡδονῶν, γεγύμνωμαι χάριτος, καὶ ταῖς πληγαῖς ἔῤῥιμμαι γυμνός· ὅθεν αἰτοῦμαί σε, τὸν Σωτῆρα διασῶσαί με."

trMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode9C12.melody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.name
trMA.Ode9C12.incipit = "Οὐ Λευΐτης ἴσχυσεν, ἀποσμῆξαι, μώλωπας…"
trMA.Ode9C12.text = "Οὐ Λευΐτης ἴσχυσεν, ἀποσμῆξαι, μώλωπας ἐμούς, ἀλλʹ ἦλθες ὁ ἀγαθός, πρός με συμπαθῶς καὶ ἔχεας ἔλεος σῶν οἰκτιρμῶν, Σῶτερ ἐπ΄ ἐμὲ ὥσπερ πανάριστος, ἰατρός με ἰασάμενος."

trMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode9C13.melody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.name
trMA.Ode9C13.incipit = "Ὡς ὑπάρχων εὔσπλαγχνος, κατοικτείρας ἔσωσας…"
trMA.Ode9C13.text = "Ὡς ὑπάρχων εὔσπλαγχνος, κατοικτείρας ἔσωσας Χριστὲ τὸν μάστιξιν ἀλγεινῶς, ὑπὸ τῶν λῃστῶν, Σωτὴρ μαστιχθέντα με καὶ τὴν ψυχὴν σῶμά τε σαυτοῦ ὥσπερ δηνάρια δύο δέδωκας ἀντίλυτρον."

trMA.Ode9C1T.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C1T.mode = miscellanea_gr_GR_cog.misc.Mode5
trMA.Ode9C1T.melody = he.h.m5_gr_GR_cog.heHE.IsaiaChoreve.name
trMA.Ode9C1T.incipit = "Ὑπὲρ νοῦν ὁ τόκος σου…"
trMA.Ode9C1T.text = "Ὑπὲρ νοῦν ὁ τόκος σου, Θεομῆτορ· ἄνευ γὰρ ἀνδρός, ἡ σύλληψις ἐν σοὶ καὶ παρθενικῶς, ἡ κύησις γέγονεν· καὶ γὰρ Θεός, ἐστιν ὁ τεχθείς· Ὃν μεγαλύνοντες, σὲ Παρθένε μακαρίζομεν."

trMA.Ode9C21.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C21.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C21.greekmelody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.greekname
trMA.Ode9C21.melody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.name
trMA.Ode9C21.incipit = "Ἰατὴρ νοσούντων ἐν πταίσμασι θεόθεν…"
trMA.Ode9C21.text = "Ἰατὴρ νοσούντων ἐν πταίσμασι θεόθεν Μακάριε, ἐλατὴρ δὲ ἐδείχθης καὶ διώκτης τῶν πονηρῶν πνευμάτων· διό σε μακαρίζομεν."

trMA.Ode9C22.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C22.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C22.melody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.name
trMA.Ode9C22.incipit = "Τὴν γῆν ὡς φθορᾶς οἰκητήριον…"
trMA.Ode9C22.text = "Τὴν γῆν ὡς φθορᾶς οἰκητήριον, κατέλιπες Πάτερ, καὶ εἰς γῆν κατεσκήνωσας, τῶν πραέων, καὶ σὺν αὐτοῖς ἀγάλλῃ, τῆς θείας ἀπολαύων τρυφῆς."

trMA.Ode9C23.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C23.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C23.melody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.name
trMA.Ode9C23.incipit = "Σήμερον ἡμέρα ἑόρτιος· πάντα συγκαλεῖ…"
trMA.Ode9C23.text = "Σήμερον ἡμέρα ἑόρτιος· πάντα συγκαλεῖ γὰρ τῶν μοναζόντων τὰ ποίμνια, εἰς χορείαν πνευματικήν, τράπεζαν, καὶ βρῶσιν ἀκηράτου ζωῆς."

trMA.Ode9C2T.ode = miscellanea_gr_GR_cog.misc.Ode9
trMA.Ode9C2T.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Ode9C2T.melody = he.h.m8_gr_GR_cog.heHE.TinAgninEndoxos.name
trMA.Ode9C2T.incipit = "Ὁ ἐν σοὶ σκηνωσας Πανάμωμε…"
trMA.Ode9C2T.text = "Ὁ ἐν σοὶ σκηνωσας Πανάμωμε, τὸν πρὶν τοὺς γενάρχας κακοτρόπως πτερνίσαντα, βροτοκτόνον καταβαλών, ἐτέχθη, καὶ πάντας ἡμᾶς ἔσωσε."

trMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode2
trMA.Exaposteilarion1.greekmelody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.greekname
trMA.Exaposteilarion1.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
trMA.Exaposteilarion1.incipit = "Τοῦ κόσμου τὴν εὐπάθειαν, ὡς…"
trMA.Exaposteilarion1.text = "Τοῦ κόσμου τὴν εὐπάθειαν, ὡς μοχθηρὰν ἐξέκλινας, καὶ ἀτροφίᾳ τὴν σάρκα, μαράνας ἀνεκαίνισας, ψυχῆς τὸν τόνον Ὅσιε, καὶ δόξαν κατεπλούτησας, οὐράνιον ἀοίδιμε· διὸ μὴ παύσῃ πρεσβεύων ὑπὲρ ἡμῶν Ἰωάννη."

trMA.ExapTheotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
trMA.ExapTheotokion.greekmelody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.greekname
trMA.ExapTheotokion.melody = he.a.m2_gr_GR_cog.heAU.GynaikesAkoutisthite.name
trMA.ExapTheotokion.incipit = "Κυρίως Θεοτόκον σε, ὁμολογοῦμεν Δέσποινα…"
trMA.ExapTheotokion.text = "Κυρίως Θεοτόκον σε, ὁμολογοῦμεν Δέσποινα, οἱ διὰ σοῦ σεσωσμένοι· καὶ γὰρ Θεὸν ἐκύησας, ἀποῤῥήτως τὸν λύσαντα, διὰ Σταυροῦ τὸν θάνατον, πρὸς ἑαυτὸν δʹ ἑλκύσαντα, Ὁσίων δήμους, μεθʹ ὧν σε, ἀνευφημοῦμεν Παρθένε."

trMA.Lauds1.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Lauds1.greekmelody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.greekname
trMA.Lauds1.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
trMA.Lauds1.incipit = tr.d050_gr_GR_cog.trVE.Stichera01.incipit
trMA.Lauds1.text = tr.d050_gr_GR_cog.trVE.Stichera01.text

trMA.Lauds2.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Lauds2.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
trMA.Lauds2.incipit = tr.d050_gr_GR_cog.trVE.Stichera02.incipit
trMA.Lauds2.text = tr.d050_gr_GR_cog.trVE.Stichera02.text

trMA.Lauds3.mode = miscellanea_gr_GR_cog.misc.Mode8
trMA.Lauds3.melody = he.a.m8_gr_GR_cog.heAU.OTouParadoxou.name
trMA.Lauds3.incipit = tr.d050_gr_GR_cog.trVE.Stichera03.incipit
trMA.Lauds3.text = tr.d050_gr_GR_cog.trVE.Stichera03.text

trMA.LaudsGlory.mode = miscellanea_gr_GR_cog.misc.Mode1
trMA.LaudsGlory.melody = miscellanea_gr_GR_cog.misc.Idiomelon
trMA.LaudsGlory.incipit = "Δεῦτε ἐργασώμεθα ἐν τῷ μυστικῷ…"
trMA.LaudsGlory.text = "Δεῦτε ἐργασώμεθα ἐν τῷ μυστικῷ ἀμπελῶνι καρποὺς μετανοίας, ἐν τούτῳ ποιούμενοι οὐκ ἐν βρώμασι καὶ πόμασι κοπιῶντες, ἀλλʹ ἐν προσευχαῖς καὶ νηστείαις τὰς ἀρετὰς κατορθοῦντες, τούτοις ἀρεσκόμενος, ὁ Κύριος τοῦ ἔργου δηνάριον παρέχει δι οὗ ψυχὰς λυτροῦται, χρέους ἁμαρτίας, ὁ μόνος πολυέλεος."

trLI.Kontakion1.mode = tr.d050_gr_GR_cog.trMA.Kontakion1.mode
trLI.Kontakion1.melody = tr.d050_gr_GR_cog.trMA.Kontakion1.melody
trLI.Kontakion1.incipit = tr.d050_gr_GR_cog.trMA.Kontakion1.incipit
trLI.Kontakion1.text = tr.d050_gr_GR_cog.trMA.Kontakion1.text

trLI.Megalynarion.text = "Τὴν οὐρανοδρόμον ἣν Ἰακώβ, κλίμακα προεῖδεν, ἐτεχνήσω πνευματικῶς, πάτερ Ἰωάννη, συνθήκῃ τῶν σῶν λόγων· διʼἧς πρὸς ἀφθαρσίας βαίνομεν μέθεξιν."
