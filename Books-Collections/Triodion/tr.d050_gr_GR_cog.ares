trDA.commemoration.full = "ΚΥΡΙΑΚΗ Δʹ ΤΩΝ ΝΗΣΤΕΙΩΝ ΤΟΥ ΟΣΙΟΥ ΠΑΤΡΟΣ ΗΜΩΝ ΙΩΑΝΝΟΥ ΤΟΥ ΣΥΓΓΡΑΦΕΩΣ ΤΗΣ «ΚΛΙΜΑΚΟΣ»" //full title of day
trDA.commemoration.short = "Κυριακὴ Δʹ τῶν Νηστειῶν τοῦ Ὁσίου Ἰωάννου τῆς Κλίμακος"
trDA.title = titles_gr_GR_cog.ti.SaintM
trDA.insert1 = "τοῦ Ὁσίου Πατρὸς ἡμῶν Ἰωάννου, τοῦ Συγγραφέως τῆς Κλίμακος," //for use in petitions and dismissal
trDA.insert2 = "οὗ καὶ τὴν μνήμην ἐπιτελοῦμεν·" //for use in petitions and dismissal
trDA.note = ""
trHO.daytitle = ""
trHO.commemorations = ""
trHO.description1 = ""
trHO.description2 = ""
trHO.note1 = ""
trHO.note2 = ""
trCO.header = ""
trDA.dismissal = dismissals_gr_GR_cog.dis00.resurrection
trDA.dismissal.incipit = dismissals_gr_GR_cog.dis00.resurrection.incipit

