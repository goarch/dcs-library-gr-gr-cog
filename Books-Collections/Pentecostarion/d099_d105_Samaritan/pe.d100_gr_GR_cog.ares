peMA.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Aposticha1.greekmelody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.greekname
peMA.Aposticha1.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
peMA.Aposticha1.incipit = "Κλίνας τοὺς οὐρανούς, κατῆλθες ὁ…"
peMA.Aposticha1.text = "Κλίνας τοὺς οὐρανούς, κατῆλθες ὁ Σωτήρ μου, καὶ σάρκα ἐκ Παρθένου, δίχα τροπῆς ὑπέδυς, πηγάζων μοι τὴν ἄφεσιν."

peMA.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Aposticha2.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
peMA.Aposticha2.incipit = "Ὅλος ἐν τῷ Θεῷ, ὁ…"
peMA.Aposticha2.text = "Ὅλος ἐν τῷ Θεῷ, ὁ λόγος σὺ ὑπάρχων, ὀλλύμενόν με θέλων, ἐξᾶραι τῶν πταισμάτων, ἑνοῦσαί μοι Φιλάνθρωπε."

peMA.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Aposticha3.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
peMA.Aposticha3.incipit = "Σὺ εἶ Παμβασιλεῦ, σοφία ἡ…"
peMA.Aposticha3.text = "Σὺ εἶ Παμβασιλεῦ, σοφία ἡ μεγάλη, διʼ οὗ Πατὴρ τὸν κόσμον, ἐποίησε πανσόφως, σὺν τῷ ἁγίῳ Πνεύματι."

