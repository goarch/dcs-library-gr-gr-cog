peMA.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode4
peMA.Aposticha1.greekmelody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.greekname
peMA.Aposticha1.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
peMA.Aposticha1.incipit = "Τὴν πηγὴν ἐν τῷ φρέατι…"
peMA.Aposticha1.text = "Τὴν πηγὴν ἐν τῷ φρέατι, κατιδὼν τὴν ἀέναον, καθημένην γύναιον, φέρον καύσωνας, πλείστων παθῶν ἀκεσώδυνον, λαβεῖν ἐπεζήτησεν, ὕδωρ ζῶν τὸ ἐξ αὐτῆς, κρουνηδὸν ἐκχεόμενον· ὃ καὶ ἔλαβε, δωρεὰν ἐκ τοῦ Λόγου· καὶ οὐκέτι πρὸς τὸ φρέαρ ἐπισπεύδει, τὸ γεηρὸν καὶ ἐπίκηρον."

peMA.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode4
peMA.Aposticha2.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
peMA.Aposticha2.incipit = "Ἰουδαίων τὰ ἔθιμα, τοῦ γυναίου…"
peMA.Aposticha2.text = "Ἰουδαίων τὰ ἔθιμα, τοῦ γυναίου διώκοντος, καὶ τὸ σφῶν προβάλλοντος ἀκοινώνητον, τῇ μεταλήψει τοῦ ὕδατος, Χριστὸς μετωχέτευσεν, ὁ σοφὸς Δημιουργός, τοῖς ἡδέσι προσφθέγμασιν, ἐξαιτήσασθαι, τὸ ζωήῤῥυτον πόμα, θεῖον ὕδωρ, οὗ πιοῦσα πρὸς τὴν πόλιν, μετοχετεύει τὰ νάματα."

peMA.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode4
peMA.Aposticha3.melody = he.a.m4_gr_GR_cog.heAU.OsGennaionEnMartysi.name
peMA.Aposticha3.incipit = "Οὔτε ἄντλημα κέκτησαι, καὶ τὸ…"
peMA.Aposticha3.text = "Οὔτε ἄντλημα κέκτησαι, καὶ τὸ φρέαρ βαθύτατον· πόθεν οὖν καὶ δώσεις μοι ὕδωρ ἄφθαρτον; ἡ Σαμαρεῖτις ἐβόα σοι, Χριστέ σε ὡς ἄνθρωπον, οἰομένη οὐ Θεόν, καὶ τοὺς λόγους θαυμάζουσα· ἣν προσρήμασι, γλυκυτάτοις ἀρδεύσας σὲ Θεόν τε, καὶ Σωτῆρα τῶν ἁπάντων, ὁμολογεῖν παρεσκεύασας."

