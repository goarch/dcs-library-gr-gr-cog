peMA.Lauds4.mode = miscellanea_gr_GR_cog.misc.Mode6
peMA.Lauds4.melody = "Αὐτόμελον."
peMA.Lauds4.incipit = oc.m6.d1_gr_GR_cog.ocMA.Lauds4.incipit
peMA.Lauds4.text = oc.m6.d1_gr_GR_cog.ocMA.Lauds4.text

peMA.Lauds5.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Lauds5.greekmelody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.greekname
peMA.Lauds5.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
peMA.Lauds5.incipit = "Ὕδωρ τὸ τῆς Πηγῆς, σωτήριον…"
peMA.Lauds5.text = "Ὕδωρ τὸ τῆς Πηγῆς, σωτήριον ὑπάρχει, πᾶσι τοῖς ἀσθενοῦσι· προσέλθωμεν οὖν πίστει, καὶ χάριν ἀρυσώμεθα."

peMA.Lauds6.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Lauds6.greekmelody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.greekname
peMA.Lauds6.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
peMA.Lauds6.incipit = "Φρέαρ τὸ ζωηρόν, Πηγῆς τῆς…"
peMA.Lauds6.text = "Φρέαρ τὸ ζωηρόν, Πηγῆς τῆς ἀθανάτου τοῖς προσιοῦσι πόθῳ, ἰάσεων παρέχει, πλημμυραν ἀνεξάντλητον."

peMA.Lauds7.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Lauds7.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
peMA.Lauds7.incipit = "Ῥώννυσι τὰς ψυχάς, τὸ ὕδωρ…"
peMA.Lauds7.text = "Ῥώννυσι τὰς ψυχάς, τὸ ὕδωρ τῆς Παρθένου, οἱ τῶν παθῶν ἐν ῥύποις, προσδράμωμεν τῇ Κόρῃ, καὶ τούτους ἀποπλύνωμεν."

peMA.Lauds8.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Lauds8.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
peMA.Lauds8.incipit = "Στάμνος ἡ ἱερά, τὸ μάννα…"
peMA.Lauds8.text = "Στάμνος ἡ ἱερά, τὸ μάννα νῦν ἀφθόνως, Πηγῆς ἐξ ἀενάου, προχέει τοῖς αἰτοῦσι, τὴν χρείαν πᾶς ἀντλήσωμεν."

peMA.MM.Lauds12as12.text = properties_gr_GR_cog.media.key
peMA.MM.Lauds1234as1234.text = properties_gr_GR_cog.media.key
peMA.MM.Lauds5678as5678.text = properties_gr_GR_cog.media.key

peLI.Megalynarion.rubric = "Εἰς τὰ δίπτυχα εἴθισται νὰ ψάλλεται τὸ ἑξῆς Μεγαλυνάριον·"
peLI.Megalynarion.text = "Ὕδωρ τὸ ζωήῤῥυτον τῆς Πηγῆς, μάννα τὸ προχέον τὸν ἀθάνατον δροσισμόν, τὸ νέκταρ τὸ θεῖον, τὴν ξένην ἀμβροσίαν, τὸ μέλι τὸ ἐκ πέτρας, πίστει τιμήσωμεν."
