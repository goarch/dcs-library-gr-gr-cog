peVE.Stichera07.mode = miscellanea_gr_GR_cog.misc.Mode6
peVE.Stichera07.greekmelody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.greekname
peVE.Stichera07.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
peVE.Stichera07.incipit = "Ξένα καὶ παράδοξα, τῶν οὐρανῶν…"
peVE.Stichera07.text = "Ξένα καὶ παράδοξα, τῶν οὐρανῶν ὁ Δεσπότης, ἐπὶ σοὶ τετέλεκε, καταρχὰς Πανάμωμε· καὶ γὰρ ἄνωθεν, ἐμφανῶς ἔσταξεν, ὑετὸς καθάπερ, ἐν τῇ μήτρᾳ σου Θεόνυμφε, Πηγὴν δεικνύων σε, σύμπαν ἀγαθὸν ἀναβλύζουσαν, πλημμύραν τε ἰάσεων, τὰς εὐεργεσίας προῤῥέουσαν ἅπασιν ἀφθόνως, τοῖς χρῄζουσι τὴν ῥῶσιν τῶν ψυχῶν, καὶ τὴν ὑγείαν τοῦ σώματος, ὕδατι τῆς χάριτος."

peVE.Stichera08.mode = miscellanea_gr_GR_cog.misc.Mode6
peVE.Stichera08.greekmelody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.greekname
peVE.Stichera08.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
peVE.Stichera08.incipit = "Μάννα σε οὐράνιον, καὶ Παραδείσου…"
peVE.Stichera08.text = "Μάννα σε οὐράνιον, καὶ Παραδείσου Παρθένε, τὴν Πηγὴν τὴν ἔνθεον, ὀνομάζω Δέσποινα προσφυέστατα· τῆς γὰρ γῆς ἔδραμεν, ἡ ῥοὴ καὶ χάρις, τῆς Πηγῆς σου τετραμέρειαν αὐτῆς καλύπτουσα, ξένοις τεραστίοις ἑκάστοτε, καὶ πᾶσι τὸ αἰτούμενον γίνεται τὸ ὕδωρ πινόμενον· ὅθεν γεγηθότες, Χριστώνυμοι προστρέχομεν πιστῶς, ἁγιασμόν ἀρυόμενοι, πάντοτε γλυκύῤῥοον."

peVE.Stichera09.mode = miscellanea_gr_GR_cog.misc.Mode6
peVE.Stichera09.melody = he.a.m6_gr_GR_cog.heAU.OlinApothemenoi.name
peVE.Stichera09.incipit = "Ῥεῖθρα τῶν ἰάσεων, ἀναβλυστάνεις Παρθένε…"
peVE.Stichera09.text = "Ῥεῖθρα τῶν ἰάσεων, ἀναβλυστάνεις Παρθένε, τοῖς πιστῶς προστρέχουσι, τῇ Πηγῇ σου πάντοτε, θεονύμφευτε· δωρεὰν ῥέεις γάρ, δαψιλῆ καὶ χύδην τοῖς νοσοῦσι τὰ Ἰάματα, τυφλοὺς ἐμβλέποντας, φαίνεις ἐναργῶς προσιόντας σοι, χωλοὺς πολλοὺς ἀνώρθωσας καὶ τοὺς παρειμένους συνέσφιγξας, τὸν δὲ νεκρωθέντα, ἐζώωσας προσχύσει τῇ τριττῇ, ὑδρωπικῶν καὶ δυσπνόων τε, πάθη ἐθεράπευσας."

peVE.SticGlory.mode = miscellanea_gr_GR_cog.misc.Mode8
peVE.SticGlory.melody = ""
peVE.SticGlory.incipit = "Τίς λαλήσει τὰς δυναστείας σου…"
peVE.SticGlory.text = "Τίς λαλήσει τὰς δυναστείας σου Πηγή; ἥτις ἐξ ἀκενώτων θαυμάτων πλημμυροῦσα, πολλὰ καὶ ὑπὲρ φύσιν ἐνεργεῖς διὰ ἰάσεων. Βαβαὶ τῶν μεγαλείων, ὧν τοῖς πάσιν ἐπιῤῥέεις! οὐ μόνον γὰρ νοσήματα χαλεπὰ ἀπήλασας, τῶν προσιόντων μετὰ πόθου, ἀλλὰ καὶ τὰ τῶν ψυχῶν πάθη ἐκπλύνεις καθαρίζουσα πανάσπιλε, σὺν πᾶσι βραβεύουσα καὶ μέγα ἔλεος."

peVE.SticBoth.mode = miscellanea_gr_GR_cog.misc.Mode6
peVE.SticBoth.melody = ""
peVE.SticBoth.incipit = oc.m6.d1_gr_GR_cog.ocVE.SticTheotokion.incipit
peVE.SticBoth.text = oc.m6.d1_gr_GR_cog.ocVE.SticTheotokion.text

peVE.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode6
peVE.Aposticha1.melody = ""
peVE.Aposticha1.incipit = oc.m6.d1_gr_GR_cog.ocVE.Aposticha1.incipit
peVE.Aposticha1.text = oc.m6.d1_gr_GR_cog.ocVE.Aposticha1.text

peVE.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode5
peVE.Aposticha2.greekmelody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.greekname
peVE.Aposticha2.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
peVE.Aposticha2.incipit = "Χαίροις ἡ ζωηφόρος Πηγή, κατὰ…"
peVE.Aposticha2.text = "Χαίροις ἡ ζωηφόρος Πηγή, κατὰ θαλάσσας πελαγίζουσα θαύματα, πρὸς πᾶσαν τὴν οἰκουμένην Ὠκεανὲ νοητέ, τὰ Νειλῷα ῥεῖθρα ὑπερβαίνουσα, τῇ χύσει τῆς χάριτος, Σιλωὰμ ἐκ πέτρας ἄλλος δεύτερος, ὕδωρ πηγάζων, ὡς παράδοξον, Ἰορδάνου τε δεξαμένη ἐνέργειαν, μάννα σωτηριῶδές τε ἐναργῶς τὸ γινόμενον πρὸς τοῦ ζητοῦντος τὴν χρείαν· πλούσιον ὄντως καὶ ἄφθονον, Χριστοῦ Μῆτερ Κόρη ἡ προχέουσα τῷ κόσμῳ τὸ μέγα ἔλεος."

peVE.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode5
peVE.Aposticha3.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
peVE.Aposticha3.incipit = "Ὕμνοις ἐν ἐξαισίοις, Πιστοὶ, τὴν…"
peVE.Aposticha3.text = "Ὕμνοις ἐν ἐξαισίοις, Πιστοὶ, τὴν ἐπουράνιον νεφέλην ὑμνήσωμεν, σταγόνα τὴν οὐρανίαν, τὸν ζωοδότην Χριστόν, ἐπὶ γῆς ἀῤῥεύστως ὑετίζουσαν, τὸ ζῶν, τὸ ἁλλόμενον, καὶ πηγάζον ἀθάνατα, ὕδωρ τὸ θεῖον, τὴν ἀμβροσίαν τοῦ νέκταρος τοῦ μηδέποτε μετὰ πόσιν ἐκρέοντος, δίψαν δὲ τὴν συντήκουσαν ψυχὰς ἀπελαύνοντος, οὗπερ πιόντες ἐμφρόνως, ῥεύματα θεῖα προβάλλονται, κοιλίας ἐκ νόου, ἑπομβρίζοντα τοῖς πᾶσι, χάριν τὴν ἄφθονον."

peVE.Aposticha4.mode = miscellanea_gr_GR_cog.misc.Mode5
peVE.Aposticha4.melody = he.a.m5_gr_GR_cog.heAU.ChairoisAskitikon.name
peVE.Aposticha4.incipit = "Χαίροις ἡ ζωοδόχος Πηγή, ἡ…"
peVE.Aposticha4.text = "Χαίροις ἡ ζωοδόχος Πηγή, ἡ ἀενάως ἀναβλύζουσα χάριτας, ἡ βρύσις τῶν ἰαμάτων ἡ πᾶσαν νόσων ἰσχύν, ἀσθενῆ καὶ φαύλην ἀπελέγχουσα· τυφλῶν ἡ ἀνάβλεψις, καὶ λεπρῶν θεία κάθαρσις· σθένος ἀῤῥώστον, παρειμένων ἀνόρθωσις, ἡ πηγάζουσα, νοσημάτων πᾶν φάρμακον, ἅπασι τοῖς προστρέχουσι, πιστῶς τῷ τεμένει σου, μέγα κοινὸν ἰατρεῖον ἄμισθον ὄντως καὶ ἕτοιμον, Χριστοῦ Μῆτερ Λόγου, τοῦ πηγάζοντος τῷ κόσμῳ τὸ μέγα ἔλεος."

peVE.AposGlory.mode = miscellanea_gr_GR_cog.misc.Mode5
peVE.AposGlory.melody = ""
peVE.AposGlory.incipit = "Σαλπίσωμεν φιλέορτοι ἐν ὕμνοις, σκιρτήσωμεν…"
peVE.AposGlory.text = "Σαλπίσωμεν φιλέορτοι ἐν ὕμνοις, σκιρτήσωμεν ἐν ὕδασι καὶ χορεύσωμεν εὐφραινόμενοι, τοῖς ἀενάως πλημμυροῦσι τῆς ζωηφόρου Πηγῆς. Βασιλεῖς καὶ ἄρχοντες συντρεχέτωσαν, καὶ Πηγῆς τὴν χάριν προχείτωσαν ἀφθόνως· Βασιλεῖς γὰρ ἔσωσε, τοὺς ἐν κλίνῃ συσχεθέντας δέ, τῇ προσψαύσει ἐξανέστησε. Ποιμένες τε καὶ σύμπαντες, τὴν ὀμβροφόρον νεφέλην, τὸ σωτήριον συνελθόντες ἀρυσώμεθα, οἱ ἐν νόσοις ἀπαλλαγήν, οἱ ἐν κινδύνοις τὴν ῥῶσιν, τὴν ἀναψυχὴν οἱ ἐν δίψει· τὰ ὄμματά τε οἱ τυφλοί, οἱ κωφεύοντες τὴν εὐηκοΐαν, τὴν ἰατρείαν οἱ καχεκτοῦντες, οἱ ἐν θανάτοις τὴν ζωηφόρον, οἱ πάντες τὴν πανταχοῦ πιστοῖς προῤῥέουσαν, ὕδατα σωτηρίας, ἀνακροτήσαντες, οὕτω κράξωμεν· Ἀείζωα προχέουσα νάματα, ἐκ Πηγῆς ἁγνή, μὴ διαλίπῃς Παρθένε πρεσβεύουσα πάντοτε ὑπὲρ τῶν δούλων σου."

peVE.Apolytikion1.mode = miscellanea_gr_GR_cog.misc.Mode1
peVE.Apolytikion1.melody = ""
peVE.Apolytikion1.incipit = "Ὁ ναός σου, Θεοτόκε, ἀνεδείχθη…"
peVE.Apolytikion1.text = "Ὁ ναός σου, Θεοτόκε, ἀνεδείχθη παράδεισος, ὡς ποταμοὺς ἀειζώους, ἀναβλύζων ἰάματα· ᾧ προσερχόμενοι πιστῶς, ὡς ζωοδόχου ἐκ Πηγῆς, ῥῶσιν ἀντλοῦμεν, καὶ ζωὴν τὴν αἰώνιον· πρεσβεύεις γὰρ σύ, τῷ ἐκ σοῦ τεχθέντι Σωτῆρι Χριστῷ, σωθῆναι τὰς ψυχὰς ἡμῶν."

peMA.C1.title = titles_gr_GR_cog.ti.CanonTheotokos
peMA.C1.verse = prayers_gr_GR_cog.pr.verse_Theotokos.text

peMA.Ode1C11.ode = miscellanea_gr_GR_cog.misc.Ode1
peMA.Ode1C11.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode1C11.greekmelody = he.h.m1_gr_GR_cog.heHE.AnastaseosImera.greekname
peMA.Ode1C11.melody = he.h.m1_gr_GR_cog.heHE.AnastaseosImera.name
peMA.Ode1C11.incipit = "Νῦν πηγάσαις μοι Παρθένε, Θεοτόκε…"
peMA.Ode1C11.text = "Νῦν πηγάσαις μοι Παρθένε, Θεοτόκε Πηγή, χάριν διδοῦσα λόγου, ὡς ἀνυμνήσω σου πηγήν, τὴν βλυστάνουσαν ζωήν, καὶ χάριν πιστοῖς· σὺ γὰρ ἐνυπόστατον Λόγον ἐπήγασας."

peMA.Ode1C12.ode = miscellanea_gr_GR_cog.misc.Ode1
peMA.Ode1C12.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode1C12.melody = he.h.m1_gr_GR_cog.heHE.AnastaseosImera.name
peMA.Ode1C12.incipit = "Ἰατρεῖον ὑπὲρ φύσιν, ὁ ναός…"
peMA.Ode1C12.text = "Ἰατρεῖον ὑπὲρ φύσιν, ὁ ναός σου σεμνή, δείκνυται πᾶσι Κόρη· ἐκ γὰρ θανάτου προφανοῦς τοὺς προστρέχοντας πιστούς, σαφῶς ἀνιστᾷ, καὶ πᾶσι τὴν ἄφθονον, ἀναβλύζει γλυκύτητα."

peMA.Ode1C13.ode = miscellanea_gr_GR_cog.misc.Ode1
peMA.Ode1C13.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode1C13.melody = he.h.m1_gr_GR_cog.heHE.AnastaseosImera.name
peMA.Ode1C13.incipit = "Καταῤῥέεις οὐρανόθεν ἀκενώτως ἡμῖν, χάριτας…"
peMA.Ode1C13.text = "Καταῤῥέεις οὐρανόθεν ἀκενώτως ἡμῖν, χάριτας ὄντως μόνη· τὸν γὰρ τυφλώττοντα ποιεῖς, ἀναβλέπειν πρὸς τὸ φῶς, βορβόρῳ καινῷ, φωνήσασα ἄνωθεν, ὑπὲρ ἔννοιαν τῷ Λέοντι."

peMA.Ode1C14.ode = miscellanea_gr_GR_cog.misc.Ode1
peMA.Ode1C14.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode1C14.melody = he.h.m1_gr_GR_cog.heHE.AnastaseosImera.name
peMA.Ode1C14.incipit = "Ἡ κοινὴ φιλοτιμία, τοῦ βροτείου…"
peMA.Ode1C14.text = "Ἡ κοινὴ φιλοτιμία, τοῦ βροτείου σεμνή, Χαῖρε Μαρία, Χαῖρε· ὁ γὰρ τῶν ὅλων ποιητής, ἐπὶ σοὶ ὥς περ σταγών, κατέβη σαφῶς, Πηγήν σε ἀθάνατον, ἀναδείξας Θεόνυμφε."

peMA.Ode3C11.ode = miscellanea_gr_GR_cog.misc.Ode3
peMA.Ode3C11.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode3C11.greekmelody = he.h.m1_gr_GR_cog.heHE.DeftePomaPiomen.greekname
peMA.Ode3C11.melody = he.h.m1_gr_GR_cog.heHE.DeftePomaPiomen.name
peMA.Ode3C11.incipit = "Φωτεινόν σε ἅγιον ναόν, τοῦ…"
peMA.Ode3C11.text = "Φωτεινόν σε ἅγιον ναόν, τοῦ Δεσπότου τῶν ὅλων Κόρη ἐπίσταμαι, καὶ ἀφθαρσίας πηγήν, τὸ ὕδωρ προῤῥέουσαν Χριστόν, ἐξ οὗ ποτιζόμεθα."

peMA.Ode3C12.ode = miscellanea_gr_GR_cog.misc.Ode3
peMA.Ode3C12.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode3C12.melody = he.h.m1_gr_GR_cog.heHE.DeftePomaPiomen.name
peMA.Ode3C12.incipit = "Ὅσην χάριν Δέσποινα Πηγή, Αὐτοκράτορι…"
peMA.Ode3C12.text = "Ὅσην χάριν Δέσποινα Πηγή, Αὐτοκράτορι δίδως οὔρων τὴν πρόοδον ἐπεχομένην δεινῶς, τοῦ λίθου ὑπόστασιν φρικτήν, τῷ ὕδατι λύσασαν."

peMA.Ode3C13.ode = miscellanea_gr_GR_cog.misc.Ode3
peMA.Ode3C13.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode3C13.melody = he.h.m1_gr_GR_cog.heHE.DeftePomaPiomen.name
peMA.Ode3C13.incipit = "Ῥέει χάρις ἄφθονος ἐκ σοῦ…"
peMA.Ode3C13.text = "Ῥέει χάρις ἄφθονος ἐκ σοῦ, Θεοτόκε Παρθένε χύδην πηγάζουσα· χωλοὶ σκιρτῶσιν ἐν σοί, λεπρῶν καθαρίζεται πληθύς, καὶ Δαίμονες πνίγονται."

peMA.Ode3C14.ode = miscellanea_gr_GR_cog.misc.Ode3
peMA.Ode3C14.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode3C14.melody = he.h.m1_gr_GR_cog.heHE.DeftePomaPiomen.name
peMA.Ode3C14.incipit = "Ὅλοις νέμεις ἴασιν πιστοῖς, βασιλεῦσι…"
peMA.Ode3C14.text = "Ὅλοις νέμεις ἴασιν πιστοῖς, βασιλεῦσι, δημόταις, καὶ πένησιν, ἄρχουσι, πτωχοῖς, πλουσίοις κοινῶς, τὸ ὕδωρ προχέουσα Πηγή, ἀποίκιλον φάρμακον."

peMA.Ode3Kathisma1.mode = miscellanea_gr_GR_cog.misc.Mode8
peMA.Ode3Kathisma1.greekmelody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.greekname
peMA.Ode3Kathisma1.melody = he.a.m8_gr_GR_cog.heAU.TinSofianKaiLogon.name
peMA.Ode3Kathisma1.incipit = "Τὴν ἀέναον κρήνην καὶ ζωηράν…"
peMA.Ode3Kathisma1.text = "Τὴν ἀέναον κρήνην καὶ ζωηράν, τὴν πηγάζουσαν ῥεῖθρα θείαν Πηγήν, συμφώνως αἰνέσωμεν, οἱ τὴν χάριν αἰτούμενοι· καθʼ ἑκάστην βρύει, καὶ γὰρ τὰ ἰάματα, ὡς ποταμῶν τὰ ῥεύματα, δεικνῦσα ἐλάχιστα. Ὅθεν κατὰ χρέος προσιόντες ἐν πόθῳ, πιστῶς ἀρυσώμεθα, ἐκ Πηγῆς ἀνεξάντλητον, ῥῶσιν ὄντως ἀθάνατον, δροσίζουσαν σαφῶς τῶν εὐσεβῶν, τὰς καρδίας, καὶ χείλεσιν ἐκβοήσωμεν. Σὺ εἶ τῶν πιστῶν τὸ παραμύθιον."

peMA.Ode4C11.ode = miscellanea_gr_GR_cog.misc.Ode4
peMA.Ode4C11.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode4C11.greekmelody = he.h.m1_gr_GR_cog.heHE.EpiTisTheiasFylakis.greekname
peMA.Ode4C11.melody = he.h.m1_gr_GR_cog.heHE.EpiTisTheiasFylakis.name
peMA.Ode4C11.incipit = "Ὑπὲρ τὴν ψάμμον ἀληθῶς, καὶ…"
peMA.Ode4C11.text = "Ὑπὲρ τὴν ψάμμον ἀληθῶς, καὶ τὰς σταγόνας ὑετῶν, πέφυκε Παρθένε τὰ πλήθη τῆς Πηγῆς τῶν ἔργων σου, ἀκαταπαύστως ῥέοντα, ἅπασαν ἐπὶ χθόνα πλουσίως πάντα νοσοῦντα δεινῶς, τάχος ἰώμενα."

peMA.Ode4C12.ode = miscellanea_gr_GR_cog.misc.Ode4
peMA.Ode4C12.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode4C12.melody = he.h.m1_gr_GR_cog.heHE.EpiTisTheiasFylakis.name
peMA.Ode4C12.incipit = "Κατασχεθέντα γυναικός, ὑπὸ καρκίνου τὸν…"
peMA.Ode4C12.text = "Κατασχεθέντα γυναικός, ὑπὸ καρκίνου τὸν μαζόν, ὕδωρ ἐπιχεῖται Παρθένε, τῆς Πηγῆς σου Δέσποινα, καὶ παραυτίκα πέπαυται, πάθη θανατηφόρα τῷ ῥείθρῳ, καὶ ὁ καρκίνος ὀρθὰ βαίνειν ἐγνώρισεν."

peMA.Ode4C13.ode = miscellanea_gr_GR_cog.misc.Ode4
peMA.Ode4C13.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode4C13.melody = he.h.m1_gr_GR_cog.heHE.EpiTisTheiasFylakis.name
peMA.Ode4C13.incipit = "Ἀκατανόητον ἐν σοί, καὶ ὑπὲρ…"
peMA.Ode4C13.text = "Ἀκατανόητον ἐν σοί, καὶ ὑπὲρ φύσιν τὸ πραχθέν, ἔνεστι σαφῶς Θεοτόκε· τὸ γὰρ ὕδωρ γίνεται, τὸ τῆς Πηγῆς σου ἴαμα, νόσων θανατηφόρων ἐναντίον, ὅπερ ἡ φύσις, σαφῶς οἶδεν οὐδέποτε."

peMA.Ode4C14.ode = miscellanea_gr_GR_cog.misc.Ode4
peMA.Ode4C14.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode4C14.melody = he.h.m1_gr_GR_cog.heHE.EpiTisTheiasFylakis.name
peMA.Ode4C14.incipit = "Ἀεὶ θανατοῖ με ὁ ἐχθρός…"
peMA.Ode4C14.text = "Ἀεὶ θανατοῖ με ὁ ἐχθρός, ταῖς ἐνηδόνοις προσβολαῖς, Δέσποινα Πηγὴ Θεοτόκε· μὴ παρίδῃς, πρόφθασον, ἡ ταχινὴ βοήθεια, τούτου δὲ τῶν παγίδων με λύτρου, ἵνα ὑμνῶ σε ἀεὶ τὴν πολυύμνητον."

peMA.Ode5C11.ode = miscellanea_gr_GR_cog.misc.Ode5
peMA.Ode5C11.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode5C11.greekmelody = he.h.m1_gr_GR_cog.heHE.OrthrisomenOrthrouVatheos.greekname
peMA.Ode5C11.melody = he.h.m1_gr_GR_cog.heHE.OrthrisomenOrthrouVatheos.name
peMA.Ode5C11.incipit = "Λαλούμενα Κόρη Παρθένε, τὰ τῆς…"
peMA.Ode5C11.text = "Λαλούμενα Κόρη Παρθένε, τὰ τῆς Πηγῆς σου τῷ ὄντι τεράστια, καταπλήττει τῶν βροτῶν διάνοιαν· ὑπὲρ γὰρ φύσιν πέφυκε, πάντας πιστοὺς ἁγιάζοντα."

peMA.Ode5C12.ode = miscellanea_gr_GR_cog.misc.Ode5
peMA.Ode5C12.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode5C12.melody = he.h.m1_gr_GR_cog.heHE.OrthrisomenOrthrouVatheos.name
peMA.Ode5C12.incipit = "Ἱστόρησε πόκος τὸ Μάννα, καὶ…"
peMA.Ode5C12.text = "Ἱστόρησε πόκος τὸ Μάννα, καὶ Σιλωὰμ καὶ ἡ πέτρα πηγάζουσα, Σολομῶντος ἡ στοὰ τὴν χάριν σου, τὰ Ἰορδάνεια νάματα, καὶ ἡ πηγὴ Σαμαρείτιδος."

peMA.Ode5C13.ode = miscellanea_gr_GR_cog.misc.Ode5
peMA.Ode5C13.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode5C13.melody = he.h.m1_gr_GR_cog.heHE.OrthrisomenOrthrouVatheos.name
peMA.Ode5C13.incipit = "Σταγόνες σου Κόρη Παρθένε, αἱ…"
peMA.Ode5C13.text = "Σταγόνες σου Κόρη Παρθένε, αἱ τῆς Πηγῆς καὶ νεκρὸν ἀνεζώωσαν, ὑπὲρ λόγον τὸ πραχθὲν καὶ ἔννοιαν! τὰ σὰ γὰρ πάντα πάναγνε, λόγον νικᾷ τὸν ἀνθρώπινον."

peMA.Ode5C14.ode = miscellanea_gr_GR_cog.misc.Ode5
peMA.Ode5C14.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode5C14.melody = he.h.m1_gr_GR_cog.heHE.OrthrisomenOrthrouVatheos.name
peMA.Ode5C14.incipit = "Τὰ πάθη μου Κόρη ἰάσαις…"
peMA.Ode5C14.text = "Τὰ πάθη μου Κόρη ἰάσαις, τῆς αἱμοῤῥοίας πηγὴν ἡ ξηράνασα, καὶ τὸ ῥῖγος, τῆς φλογὸς τὴν ἄναψιν, καὶ ἑκτικὴν διάθεσιν, οὔρων δεσμὰ καὶ γαστρόῤῥοιαν."

peMA.Ode6C11.ode = miscellanea_gr_GR_cog.misc.Ode6
peMA.Ode6C11.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode6C11.greekmelody = he.h.m1_gr_GR_cog.heHE.KatilthesEnToisKatotatois.greekname
peMA.Ode6C11.melody = he.h.m1_gr_GR_cog.heHE.KatilthesEnToisKatotatois.name
peMA.Ode6C11.incipit = "Οἱ λόγοι τοῦ λόγου ὡς…"
peMA.Ode6C11.text = "Οἱ λόγοι τοῦ λόγου ὡς ὄντως πηγήν, ἀνυμνοῦσί σε Ἁγνή· τῆς σοφίας βυθὸν γάρ, ὡς ὑπὲρ λόγον γεννᾷς, τὸν κρεμάσαντα, ἐν αἰθέρι τὰς ῥοάς, καὶ τὴν γῆν ἐπὶ ὕδωρ."

peMA.Ode6C12.ode = miscellanea_gr_GR_cog.misc.Ode6
peMA.Ode6C12.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode6C12.melody = he.h.m1_gr_GR_cog.heHE.KatilthesEnToisKatotatois.name
peMA.Ode6C12.incipit = "Ὑπῆλθες τὴν τῶν κλιμάκων φοράν…"
peMA.Ode6C12.text = "Ὑπῆλθες τὴν τῶν κλιμάκων φοράν, ἀπειλοῦσαν συντριβήν, τοὺς ἐκεῖσε ζωγράφους, ὦ παναγία Πηγή, διασώσασα, καὶ λαὸν ὑπὸ σεισμοῦ, πεπτωκότος τοῦ δόμου."

peMA.Ode6C13.ode = miscellanea_gr_GR_cog.misc.Ode6
peMA.Ode6C13.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode6C13.melody = he.h.m1_gr_GR_cog.heHE.KatilthesEnToisKatotatois.name
peMA.Ode6C13.incipit = "Τὰς μήτρας ἀγόνους στειρώσει τὸ…"
peMA.Ode6C13.text = "Τὰς μήτρας ἀγόνους στειρώσει τὸ πρίν, διαλύεις ἐμφανῶς, τῆς Πηγῆς σου τῷ ῥείθρῳ· καὶ γὰρ ὡς τέξασα σὺ παρθενεύουσα, τὸν Δεσπότην τοῦ παντός, καὶ τοὺς τόκους βραβεύεις."

peMA.Ode6C14.ode = miscellanea_gr_GR_cog.misc.Ode6
peMA.Ode6C14.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode6C14.melody = he.h.m1_gr_GR_cog.heHE.KatilthesEnToisKatotatois.name
peMA.Ode6C14.incipit = "Οὐ λόγος, οὐ νοῦς, οὐδὲ…"
peMA.Ode6C14.text = "Οὐ λόγος, οὐ νοῦς, οὐδὲ γλῶττα τὸν σὸν ἐξισχύουσιν Ἁγνή, τοκετὸν εὐφημῆσαι· ἀλλʼ ἀσθενοῦσιν ἐν σοί, καὶ ἐλέγχεται, φιλοσόφων τὸ σεμνὸν καὶ ῥητόρων κομψότης."

peMA.Kontakion1.mode = miscellanea_gr_GR_cog.misc.Mode8
peMA.Kontakion1.melody = he.a.m8_gr_GR_cog.heAU.TiYpermacho.name
peMA.Kontakion1.incipit = "Ἐξ ἀκενώτου σου Πηγῆς θεοχαρίτωτε…"
peMA.Kontakion1.text = "Ἐξ ἀκενώτου σου Πηγῆς θεοχαρίτωτε ἐπιβραβεύεις μοι πηγάζουσα τὰ νάματα, ἀενάως τῆς σῆς χάριτος ὑπὲρ λόγον· τὸν γὰρ Λόγον ὡς τεκοῦσαν ὑπὲρ ἔννοιαν, ἱκετεύω σε δροσίζειν με σῇ χάριτι, ἵνα κράζω σοι· Χαῖρε ὕδωρ σωτήριον."

peMA.Oikos1.text = "Ἄχραντε Θεοτόκε, ἡ τεκοῦσα ἀῤῥήτως, Πατρὸς τὸν προαιώνιον Λόγον πλάτυνόν μου τὸ στόμα σεμνή, συνεισφέρουσά με πρὸς τὸν σὸν ἔπαινον, ὡς ἂν ἀνευφημήσω σε, κραυγάζων τῇ πηγῇ σου ταῦτα."
peMA.Oikos12.text = "Χαῖρε πηγή, χαρμονῆς ἀλλήκτου, χαῖρε ῥοή, καλλονῆς ἀῤῥήτου."
peMA.Oikos13.text = "Χαῖρε, νοσημάτων παντοίων κατάλυσις, χαῖρε, παθημάτων ποικίλων κατάκλυσις."
peMA.Oikos14.text = "Χαῖρε ῥεῖθρον διειδέστατον, ὑγιάζον τοὺς πιστούς, χαῖρε ὕδωρ χαριέστατον τοῖς νοσοῦσι πολλαπλῶς."
peMA.Oikos15.text = "Χαῖρε νᾶμα σοφίας, ἀγνωσίαν ἐξαῖρον, χαῖρε κρᾶμα καρδίας, ἀμβροσίαν προῤῥέον."
peMA.Oikos16.text = "Χαῖρε κρατὴρ τοῦ μάννα ζωήῤῥυτε, χαῖρε λουτὴρ καὶ νέκταρ θεόῤῥευστε."
peMA.Oikos17.text = "Χαῖρε, πορθμὸν ἀσθενείας δεικνῦσα·χαῖρε, φλογμὸν ἀῤῥωστίας σβεννῦσα."
peMA.Oikos18.text = "Χαῖρε ὕδωρ σωτήριον."

peSY.commemoration.text = "Τῇ Παρασκευῇ τῆς Διακαινησίμου, ἑορτάζομεν τὰ ἐγκαίνια τοῦ ναοῦ τῆς ὑπεραγίας Δεσποίνης ἡμῶν καὶ θεομήτορος, τῆς Ζωηφόρου Πηγῆς, ἔτι δὲ καὶ μνείαν ποιούμεθα τῶν ἐν τούτῳ τελεσθέντων ὑπερφυῶν θαυμάτων παρὰ τῆς Θεομήτορος."
peSY.commemoration.couplet1.verse1 = "Μάννα Σιλωάμ, καὶ Στοὰν Σολομῶντος"
peSY.commemoration.couplet1.verse2 = "Πηγὴν Κόρη σὴν ἐμφανῶς πᾶς τις βλέπει."
peSY.commemoration.narration.p01 = "[paragraph 01]"
peSY.commemoration.narration.p02 = "[paragraph 02]"
peSY.commemoration.narration.p03 = "[paragraph 03]"
peSY.commemoration.narration.p04 = "[paragraph 04]"
peSY.commemoration.narration.p05 = "[paragraph 05]"
peSY.commemoration.narration.p06 = "[paragraph 06]"
peSY.commemoration.narration.p07 = "[paragraph 07]"
peSY.lastline = "Ταῖς τῆς σῆς Μητρὸς πρεσβείαις, Χριστὲ ὁ Θεός, ἐλέησον ἡμᾶς. Ἀμήν."

peMA.Ode7C11.ode = miscellanea_gr_GR_cog.misc.Ode7
peMA.Ode7C11.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode7C11.greekmelody = he.h.m1_gr_GR_cog.heHE.OPaidasEkKaminou.greekname
peMA.Ode7C11.melody = he.h.m1_gr_GR_cog.heHE.OPaidasEkKaminou.name
peMA.Ode7C11.incipit = "Ὑδρεύσασθε νοσοῦντες ἰάματα· ἡ πάναγνος…"
peMA.Ode7C11.text = "Ὑδρεύσασθε νοσοῦντες ἰάματα· ἡ πάναγνος ῥέει γάρ, θείας ἐκ πηγῆς, τὸν γλυκασμὸν τὸν ἀληθῆ, τὸν χειμάῤῥουν τρυφῆς ὄντως βλύζουσα· διὸ καὶ πίστει κρουνούς, τοὺς ἀφθόνους ἀρυσώμεθα σύμπαντες."

peMA.Ode7C12.ode = miscellanea_gr_GR_cog.misc.Ode7
peMA.Ode7C12.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode7C12.melody = he.h.m1_gr_GR_cog.heHE.OPaidasEkKaminou.name
peMA.Ode7C12.incipit = "Ξενίζει τοὺς ἀκούοντας Δέσποινα, τὰ…"
peMA.Ode7C12.text = "Ξενίζει τοὺς ἀκούοντας Δέσποινα, τὰ ξένα σου τέρατα, πάντας τοὺς πιστούς· τοὺς γὰρ ἀλάλους καὶ κωφούς, ὡς εὐλάλους δεικνύει τὸ ὕδωρ σου, τοὺς πάσχοντάς τε δεινῶς θεραπεύει, καὶ ἴασιν χαρίζεται."

peMA.Ode7C13.ode = miscellanea_gr_GR_cog.misc.Ode7
peMA.Ode7C13.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode7C13.melody = he.h.m1_gr_GR_cog.heHE.OPaidasEkKaminou.name
peMA.Ode7C13.incipit = "Ἀνάγεις ἐκ καμίνου τῶν θλίψεων…"
peMA.Ode7C13.text = "Ἀνάγεις ἐκ καμίνου τῶν θλίψεων, δροσίζουσα νάμασι, ξένης ἐκ Πηγῆς, τοὺς προσιόντάς σοι Σεμνή· φαγεδαίνης λυτροῦται γὰρ ἄνθρωπος, καὶ λώβης, τὸν δὲ λεπρόν θεραπεύεις καὶ ἄνθρακας κατέσβεσας."

peMA.Ode7C14.ode = miscellanea_gr_GR_cog.misc.Ode7
peMA.Ode7C14.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode7C14.melody = he.h.m1_gr_GR_cog.heHE.OPaidasEkKaminou.name
peMA.Ode7C14.incipit = "Νεάνιδες καὶ κόραι τὴν Δέσποιναν…"
peMA.Ode7C14.text = "Νεάνιδες καὶ κόραι τὴν Δέσποιναν καὶ σύμπαντες ἄνθρωποι, πίστει ἐκ ψυχῆς ἀνευφημήσωμεν λαμπρῶς· διατρήσεις γὰρ ἥλων, ὑέλωπας, καὶ ἕλκη τὰ πονηρὰ καὶ ὀγκώσεις, καὶ παράλυτον ἰάσατο."

peMA.Ode8C11.ode = miscellanea_gr_GR_cog.misc.Ode8
peMA.Ode8C11.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode8C11.greekmelody = he.h.m1_gr_GR_cog.heHE.AftiIKliti.greekname
peMA.Ode8C11.melody = he.h.m1_gr_GR_cog.heHE.AftiIKliti.name
peMA.Ode8C11.incipit = "Θεῖον ἡ Πηγὴ καὶ σεβάσμιον…"
peMA.Ode8C11.text = "Θεῖον ἡ Πηγὴ καὶ σεβάσμιον ὕδωρ, προῤῥέει σου Παρθένε· ὑδρωπικῶν γὰρ τὸ ῥεῦμα, ἀναχαιτίζει σφοδρῶς, ἐπικλήσει τῇ θείᾳ τῆς χάριτος· διό σε τιμῶμεν, Πηγὴ εἰς τοὺς αἰῶνας."

peMA.Ode8C12.ode = miscellanea_gr_GR_cog.misc.Ode8
peMA.Ode8C12.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode8C12.melody = he.h.m1_gr_GR_cog.heHE.AftiIKliti.name
peMA.Ode8C12.incipit = "Πάντες τὸ σεπτὸν καὶ ζωήῤῥυτον…"
peMA.Ode8C12.text = "Πάντες τὸ σεπτὸν καὶ ζωήῤῥυτον ὕδωρ, ὑμνήσωμεν προφρόνως· τῆς γὰρ δυσπνοίας τὸ ῥεῦμα κατὰ χώραν ἱστᾷ, καὶ ἐλεύθερον ποιεῖ πρὸς διέξοδον. Βαβαὶ σῶν θαυμασίων! ἁγνὴ Θεοκυῆτορ."

peMA.Ode8C13.ode = miscellanea_gr_GR_cog.misc.Ode8
peMA.Ode8C13.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode8C13.melody = he.h.m1_gr_GR_cog.heHE.AftiIKliti.name
peMA.Ode8C13.incipit = "Ποῖον εὐφημήσει Πανύμνητε στόμα, τοῦ…"
peMA.Ode8C13.text = "Ποῖον εὐφημήσει Πανύμνητε στόμα, τοῦ τόκου σου τὸ ξένον, ἀλλὰ καὶ νοῦς ὁποῖος, τῶν θαυμάτων πηγὴν περιβλέψαιτο, καὶ λόγοις κροτήσειεν, οὐκ ἔστι τῇ φύσει ἰσχύς, τὰ σὰ θαυμάζειν."

peMA.Ode8C14.ode = miscellanea_gr_GR_cog.misc.Ode8
peMA.Ode8C14.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode8C14.melody = he.h.m1_gr_GR_cog.heHE.AftiIKliti.name
peMA.Ode8C14.incipit = "Ὅλον ἐπὶ σοὶ τοῦ θανάτου…"
peMA.Ode8C14.text = "Ὅλον ἐπὶ σοὶ τοῦ θανάτου τὸ κράτος, ἠφάνισται ἀθρόον, ὦ Βασιλὶς καὶ Κυρία· Βασιλέα καὶ γάρ, τὴν ἀθάνατον ζωὴν σὺ ἐπήγασας, τὸ ὕδωρ τὸ μάννα, Χριστὸν εἰς τοὺς αἰῶνας."

peMA.Ode9C11.ode = miscellanea_gr_GR_cog.misc.Ode9
peMA.Ode9C11.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode9C11.greekmelody = he.h.m1_gr_GR_cog.heHE.FotizouFotizou.greekname
peMA.Ode9C11.melody = he.h.m1_gr_GR_cog.heHE.FotizouFotizou.name
peMA.Ode9C11.incipit = "Ὑδάτων ἁπάντων, Κόρη ὑπέρκειται ἁγνή…"
peMA.Ode9C11.text = "Ὑδάτων ἁπάντων, Κόρη ὑπέρκειται ἁγνή, τῆς Πηγῆς σου τὸ ὕδωρ, ἐμφανῶς δωρούμενον, ἀπαλλαγὴν νοσημάτων δεινῶν, καὶ ταῖς ψυχαῖς, ἅπασαν τὴν ῥῶσιν, ὡς ὑπὲρ φύσιν χεόμενον."

peMA.Ode9C12.ode = miscellanea_gr_GR_cog.misc.Ode9
peMA.Ode9C12.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode9C12.melody = he.h.m1_gr_GR_cog.heHE.FotizouFotizou.name
peMA.Ode9C12.incipit = "Λυτῆρα τῶν νόσων, τὸν νέον…"
peMA.Ode9C12.text = "Λυτῆρα τῶν νόσων, τὸν νέον ἰδοὺ Σιλωάμ, τῆς Πηγῆς σου Παρθένε, καθορῶμεν ἅπαντες· ὄμματα γὰρ προσλαμβάνει πηρός, ἅπαντες δέ, ῥῶσιν ἀενάως, πρὸς τῇ ζωῇ ποριζόμεθα!"

peMA.Ode9C13.ode = miscellanea_gr_GR_cog.misc.Ode9
peMA.Ode9C13.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode9C13.melody = he.h.m1_gr_GR_cog.heHE.FotizouFotizou.name
peMA.Ode9C13.incipit = "Οἱ ῥῶσιν ζητοῦντες, προσδράμετε ἐν…"
peMA.Ode9C13.text = "Οἱ ῥῶσιν ζητοῦντες, προσδράμετε ἐν τῇ Πηγῇ· ἡ γὰρ Κόρη Παρθένος, ἐνοικεῖ τῷ ὕδατι. Σκίρτα πιστῶν, καὶ εὐφραίνου πληθύς, οὕτω ὡς χρή, ἕξεις τῷ τεμένει, τὴν ἀμοιβὴν τῶν αἰτήσεων."

peMA.Ode9C14.ode = miscellanea_gr_GR_cog.misc.Ode9
peMA.Ode9C14.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode9C14.melody = he.h.m1_gr_GR_cog.heHE.FotizouFotizou.name
peMA.Ode9C14.incipit = "Ὑψώθη Πηγῆς σου, τὸ ὕδωρ…"
peMA.Ode9C14.text = "Ὑψώθη Πηγῆς σου, τὸ ὕδωρ ὑπὲρ οὐρανούς, καὶ τῆς γῆς τὰς ἀβύσσους, ταῖς ῥοαῖς διέδραμε, τοῦτο ἐστὶν ἀμβροσία ψυχῆς, νέκταρ πιστῶν, μέλι τὸ ἐκ πέτρας, καὶ ἡ τοῦ μάννα διάδοσις."

peMA.Ode9C15.ode = miscellanea_gr_GR_cog.misc.Ode9
peMA.Ode9C15.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Ode9C15.melody = he.h.m1_gr_GR_cog.heHE.FotizouFotizou.name
peMA.Ode9C15.incipit = "Εὐφραίνεις Παρθένε, τὸν Ἄνακτα ὑπερφυῶς…"
peMA.Ode9C15.text = "Εὐφραίνεις Παρθένε, τὸν Ἄνακτα ὑπερφυῶς, ἀναβλύζουσα χάριν, ἐκ Πηγῆς ἀέναον, τούτῳ διδοῦσα, κατʼ ἐχθρῶν τὴν ἰσχύν, νίκας ἀεί, ῥῶσιν καὶ εἰρήνην, καὶ αἰτημάτων ἐκπλήρωσιν."

peMA.Exaposteilarion1.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Exaposteilarion1.melody = he.a.m2_gr_GR_cog.heAU.SarkiYpnosas.melody
peMA.Exaposteilarion1.incipit = he.a.m2_gr_GR_cog.heAU.SarkiYpnosas.incipit
peMA.Exaposteilarion1.text = he.a.m2_gr_GR_cog.heAU.SarkiYpnosas.text

peMA.Exaposteilarion2.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Exaposteilarion2.greekmelody = he.a.m2_gr_GR_cog.heAU.SarkiYpnosas.greekname
peMA.Exaposteilarion2.melody = he.a.m2_gr_GR_cog.heAU.SarkiYpnosas.name
peMA.Exaposteilarion2.incipit = "Πηγὴ ὑπάρχεις ἀληθῶς, ὕδατος ζῶντος…"
peMA.Exaposteilarion2.text = "Πηγὴ ὑπάρχεις ἀληθῶς, ὕδατος ζῶντος Δέσποινα· ἐκπλύνεις οὖν νοσήματα, ψυχῶν σωμάτων χαλεπά, ἐν τῇ προσψαύσει μόνη σου ὕδωρ τῆς σωτηρίας, Χριστὸν ἡ προχέουσα."

