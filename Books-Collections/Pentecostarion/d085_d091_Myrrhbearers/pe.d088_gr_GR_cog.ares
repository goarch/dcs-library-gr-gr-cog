peMA.Kathisma21.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Kathisma21.greekmelody = he.a.m2_gr_GR_cog.heAU.EfsplagchniasYparchousa.greekname
peMA.Kathisma21.melody = he.a.m2_gr_GR_cog.heAU.EfsplagchniasYparchousa.name
peMA.Kathisma21.incipit = "Πρὸς τὸ μνῆμά σου Σῶτερ…"
peMA.Kathisma21.text = "Πρὸς τὸ μνῆμά σου Σῶτερ, αἱ σεπταὶ Μυροφόροι ἐλθοῦσαι, τὸν Δεσπότην ἀλείψασθαι μύροις, ὡς βροτόν σε κατηπείγοντο. Ἄγγελος δὲ αὐταῖς χαρὰν ἐμήνυσεν· Ἀνέστη ὁ Κύριος· διὸ κηρύξατε Ἀποστόλοις τὴν ἐκ τάφου ὄντως φρικτὴν τούτου ἐξανάστασιν."

