peVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode2
peVE.Stichera01.greekmelody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.greekname
peVE.Stichera01.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
peVE.Stichera01.incipit = "Χαίρουσι Μαθήτριαι Χριστοῦ, τῶν ἐκ…"
peVE.Stichera01.text = "Χαίρουσι Μαθήτριαι Χριστοῦ, τῶν ἐκ τοῦ Ἀγγέλου ῥημάτων, ἐπακροώμεναι, διʼ ὧν τὴν Ἀνάστασιν, τοῦ διʼ ἡμᾶς ἐν νεκροῖς λογισθέντος πιστούμεναι, κἂν πρὶν Μυροφόροι, τάφῳ παρειστήκεισαν, καὶ ἐθρηνῴδουν αὐτόν, λίθον ἀναβλέπουσι τούτου, ἀποκυλισθέντα ἀθρόον οὗ διηποροῦντο τὴν μετάθεσιν."

peVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode2
peVE.Stichera02.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
peVE.Stichera02.incipit = "Ἄληκτον καὶ θείαν χαρμονήν, ἐπιχορηγοῦσαι…"
peVE.Stichera02.text = "Ἄληκτον καὶ θείαν χαρμονήν, ἐπιχορηγοῦσαι τοῖς θείοις, καὶ ἱεροῖς Μαθηταῖς, ὤφθησαν Μαθήτριαι αἱ Μυροφόροι Χριστοῦ, ἐκπληροῦσαι τὸ κέλευσμα, τοῦ θείου Ἀγγέλου, οὗ ἐξεθαμβήθησαν, τὴν λευκοφόρον στολήν, λέγουσαι· Ἐσκύλευται ᾍδης τῇ πανσωστικῇ Ἀναστάσει, τοῦ ὑπὲρ ἡμῶν θανόντος Ἄνακτος."

peVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode2
peVE.Stichera03.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
peVE.Stichera03.incipit = "Ῥεῖθρα δακρυῤῥόου ἐκ πηγῆς, θρήνων…"
peVE.Stichera03.text = "Ῥεῖθρα δακρυῤῥόου ἐκ πηγῆς, θρήνων ἀναστείλασαι θεῖαι, Χριστοῦ Μαθήτριαι ῥήματα χαρμόσυνα, διαπορθμεύουσαι νῦν, τοῖς αὐτόπταις τῆς χάριτος, μηνύουσαι τούτοις, τὴν τοῦ Λόγου Ἔγερσιν, καὶ τὴν ἐκ τάφου χαράν· ὅθεν, τὴν ἀντίθετον λύπης, ἤκουον φωνὴν παραδόξως ταύταις τὴν τὸ Χαίρετε, προστάττουσαν."

