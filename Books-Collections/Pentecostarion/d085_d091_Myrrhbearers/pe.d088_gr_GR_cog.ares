peMA.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Aposticha1.greekmelody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.greekname
peMA.Aposticha1.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
peMA.Aposticha1.incipit = "Ἆρα, ἐν νεκροῖς ὁ λυτρωτής…"
peMA.Aposticha1.text = "Ἆρα, ἐν νεκροῖς ὁ λυτρωτής; θρήνοις Μυροφόροι ἐβόων, Χριστοῦ μαθήτριαι· Ἥλιος δʼ ὁ μέγιστος, μέχρι καὶ νῦν ὑπὸ γῆν, ἢ ἀνέστη ὡς ἔφησε; Καὶ οὕτω κλαιούσαις, ἐκ τοῦ τάφου Ἄγγελος, τὴν θείαν ὄντως χαράν, ἔφη· Ὁ Χριστὸς ἐξανέστη· δράμετε, κηρύξατε πᾶσι, τούτου τὴν ἐκ τάφου θείαν Ἔγερσιν."

peMA.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Aposticha2.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
peMA.Aposticha2.incipit = "Μύρα, ἑτοιμάσασαι σεπτά, ἔτι τῆς…"
peMA.Aposticha2.text = "Μύρα, ἑτοιμάσασαι σεπτά, ἔτι τῆς σκοτίας ἑνούσης, τῇ τῶν Σαββάτων μιᾷ, ἦλθον πρὸς τὸ μνῆμά σου, αἱ Μυροφόροι Χριστέ, τοῦ μυρίσαι τὸ ἄχραντον, καὶ θεῖόν σου Σῶμα· ὅθεν τὴν Ἀνάστασιν, καταμαθοῦσαι τὴν σήν, ἔσπευδον μηνῦσαι τοῖς Μύσταις· αἷς προϋπαντήσας ἐκ τάφου, Χαίρετε, βοᾷς φιλανθρωπότερον."

peMA.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Aposticha3.melody = he.a.m2_gr_GR_cog.heAU.OteEkTouXylou.name
peMA.Aposticha3.incipit = "Ὕψιστον Θεὸν ἐπὶ τῆς γῆς…"
peMA.Aposticha3.text = "Ὕψιστον Θεὸν ἐπὶ τῆς γῆς, ἐνταφιασθέντα ὡς νέκυν, μυρίσαι σπεύδουσι, τούτου αἱ Μαθήτριαι, διʼ ἀρωμάτων σεπτῶν· καὶ ἐν τάφῳ καθήμενον, καινὸν νεανίαν, βλέψασαι ἐξέστησαν, ἐν ἀστραπτούσῃ μορφῇ· ὅθεν, τὴν ἐκ τάφου τοῦ Λόγου, Ἔγερσιν τριήμερον γνοῦσαι, ταύτην Ἀποστόλοις κατεμήνυον."

