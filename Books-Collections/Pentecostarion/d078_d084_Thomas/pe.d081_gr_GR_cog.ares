peVE.Stichera01.mode = miscellanea_gr_GR_cog.misc.Mode1
peVE.Stichera01.greekmelody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.greekname
peVE.Stichera01.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
peVE.Stichera01.incipit = "Ψηλάφησον λέγει τῷ Θωμᾷ, ἐκ…"
peVE.Stichera01.text = "Ψηλάφησον λέγει τῷ Θωμᾷ, ἐκ νεκρῶν τριήμερος, ἐξαναστὰς ὁ Φιλάνθρωπος· καὶ ἴδε χεῖράς μου, καὶ ποδῶν τὰς τρήσεις, καὶ πλευρᾶς τὴν πώρωσιν, καὶ γνῶθί με Θεὸν ἀναλλοίωτον, γεῶδες φύραμα, κατʼ οὐσίαν μορφωσάμενον, καὶ τὸ πάθος ἐν αὐτῷ δεξάμενον."

peVE.Stichera02.mode = miscellanea_gr_GR_cog.misc.Mode1
peVE.Stichera02.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
peVE.Stichera02.incipit = "Ἠπόρει τὰς τρήσεις ἐνορῶν, τῶν…"
peVE.Stichera02.text = "Ἠπόρει τὰς τρήσεις ἐνορῶν, τῶν ποδῶν ὁ Δίδυμος, καὶ τῶν χειρῶν τὰ τυλώματα, καὶ ἦν θαμβούμενος, τὸ φρικῶδες θαῦμα, καὶ χειρὶ τὴν ἄχραντον, πλευρὰν καὶ ψηλαφῶν καὶ θεώμενος, ἐξ ὧν ὑπέδειξεν, ἀναμφίβολον τοῖς ἔθνεσι, τὴν ἐκ τάφου τριήμερον Ἔγερσιν."

peVE.Stichera03.mode = miscellanea_gr_GR_cog.misc.Mode1
peVE.Stichera03.melody = he.a.m1_gr_GR_cog.heAU.PaneffimoiMartyres.name
peVE.Stichera03.incipit = "Λαμβάνω μεγίστην χαρμονήν, σὴν Σωτήρ…"
peVE.Stichera03.text = "Λαμβάνω μεγίστην χαρμονήν, σὴν Σωτήρ μου Ἔγερσιν, βεβαιουμένην θεώμενος, ἐξ ὧν ἠξίωται, τολμηρῶν πραγμάτων, ὁ Θωμᾶς ἐφάψασθαι· διό σε τὸν ἁπλοῦν δογματίζομεν, Θεὸν καὶ ἄνθρωπον, ἐνεργείας δύο φέροντα, οὐσιώδεις, τῶν ἐξ ὧν συντέθεισαι."

