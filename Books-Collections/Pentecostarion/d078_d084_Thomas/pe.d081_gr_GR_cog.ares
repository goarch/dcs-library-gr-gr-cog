peMA.Kathisma12.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Kathisma12.melody = ""
peMA.Kathisma12.incipit = "Ὁ Ἰσαὰκ ἐν τῷ βουνῷ…"
peMA.Kathisma12.text = "Ὁ Ἰσαὰκ ἐν τῷ βουνῷ ἀνηνέχθη, ὁ Ἰωνᾶς ἐν τῷ βυθῷ κατηνέχθη καὶ ἀμφότεροι τὸ πάθος σου Σωτὴρ ἐξεικόνιζον, ὁ μὲν τὰ δεσμὰ καὶ τὴν σφαγὴν ὁ δὲ τὴν ταφὴν καὶ τὴν ζωήν, τῆς παραδόξου Ἐγέρσεώς σου, Κύριε, δόξα σοι."

