peMA.Aposticha1.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Aposticha1.greekmelody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.greekname
peMA.Aposticha1.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
peMA.Aposticha1.incipit = "Κατήφεια παθῶν, καὶ λογισμῶν ἡ…"
peMA.Aposticha1.text = "Κατήφεια παθῶν, καὶ λογισμῶν ἡ ζάλη, μακρὰν ἐξοριζέσθω, καὶ οὕτως ἐξανθήσει τὸ ἔαρ τὸ τῆς πίστεως."

peMA.Aposticha2.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Aposticha2.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
peMA.Aposticha2.incipit = "Ὤφθης τοῖς ἱεροῖς, σοῦ Σῶτερ…"
peMA.Aposticha2.text = "Ὤφθης τοῖς ἱεροῖς, σοῦ Σῶτερ Ἀποστόλοις, τῶν θυρῶν κεκλεισμένων, διʼ αὐτῶν ἐγκαινίζων, τὸ θεῖον Πνεῦμα σήμερον."

peMA.Aposticha3.mode = miscellanea_gr_GR_cog.misc.Mode2
peMA.Aposticha3.melody = he.a.m2_gr_GR_cog.heAU.OikosTouEfratha.name
peMA.Aposticha3.incipit = "Νῦν σε Παμβασιλεῦ, ἰδόντες οὐ…"
peMA.Aposticha3.text = "Νῦν σε Παμβασιλεῦ, ἰδόντες οὐ βλεφάροις ἀλλὰ καρδίας πόθῳ, Θεὸν πεπιστευκότες, ἐν ὕμνοις μεγαλύνομεν."

