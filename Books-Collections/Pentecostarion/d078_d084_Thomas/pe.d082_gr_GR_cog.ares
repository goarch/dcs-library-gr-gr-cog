peMA.Kathisma1T.mode = miscellanea_gr_GR_cog.misc.Mode1
peMA.Kathisma1T.melody = he.a.m1_gr_GR_cog.heAU.TonTafonSouSotir.name
peMA.Kathisma1T.incipit = "Προφῆταί σε τρανῶς, προκατήγγειλαν Κόρη…"
peMA.Kathisma1T.text = "Προφῆταί σε τρανῶς, προκατήγγειλαν Κόρη, Μητέρα τοῦ Θεοῦ, καὶ Ἀπόστολοι θεῖοι, ἐν κόσμῳ ἐκήρυξαν, καὶ ἡμεῖς ἐπιστεύσαμεν· ὅθεν ἅπαντες, εὐσεβοφρόνως τιμῶντες, ἀνυμνοῦμέν σε, καὶ Θεοτόκον κυρίως, ἀεὶ ὀνομάζομεν."

