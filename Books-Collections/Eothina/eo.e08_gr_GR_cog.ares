A_Resource_Whose_Name = eo.e08_gr_GR_cog

eo.Exaposteilarion.mode = miscellanea_gr_GR_cog.misc.Mode2
eo.Exaposteilarion.melody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.name
eo.Exaposteilarion.greekmelody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.greekname
eo.Exaposteilarion.incipit = "Δύο Ἀγγέλους βλέψασα…"
eo.Exaposteilarion.text = "Δύο Ἀγγέλους βλέψασα, ἔνδοθεν τοῦ μνημείου, Μαρία ἐξεπλήττετο, καὶ Χριστὸν ἀγνοοῦσα, ὡς κηπουρὸν ἐπηρώτα· Κύριε ποῦ τὸ σῶμα, τοῦ Ἰησοῦ μου τέθεικας; κλήσει δὲ τοῦτον γνοῦσα, εἶναι αὐτόν, τὸν Σωτῆρα ἤκουσε· Μή μου ἅπτου, πρὸς τὸν Πατέρα ἄπειμι, εἰπὲ τοῖς ἀδελφοῖς μου."
eo.Theotokion.mode = miscellanea_gr_GR_cog.misc.Mode2
eo.Theotokion.melody = he.a.m2_gr_GR_cog.heAU.ToisMathitaisSynelthomen.name
eo.Theotokion.incipit = "Τριάδος Κόρη τέτοκας…"
eo.Theotokion.text = "Τριάδος Κόρη τέτοκας, ἀποῤῥήτως τὸν ἕνα, διπλοῦν τῇ φύσει πέλοντα, καὶ διπλοῦν ἐνεργείᾳ, καὶ ἕνα τῇ ὑποστάσει· τοῦτον οὖν ἐκδυσώπει, ἀεὶ ὑπὲρ τῶν πίστει σε, προσκυνούντων, ἐκ πάσης ἐπιβουλῆς, τοῦ ἐχθροῦ λυτρώσασθαι, ὅτι πάντες, πρὸς σὲ νῦν καταφεύγομεν, Δέσποινα Θεοτόκε."
eo.title = "Τὸ Ηʹ Ἑωθινόν."
eo.Doxasticon.mode = miscellanea_gr_GR_cog.misc.Mode8
eo.Doxasticon.incipit = "Τὰ τῆς Μαρίας δάκρυα…"
eo.Doxasticon.text = "Τὰ τῆς Μαρίας δάκρυα οὐ μάτην χεῖνται θερμῶς· ἰδοὺ γὰρ κατηξίωται, καὶ διδασκόντων Ἀγγέλων, καὶ τῆς ὄψεως τῆς σῆς, ὦ Ἰησοῦ· ἀλλʼ ἔτι πρόσγεια φρονεῖ, οἷα γυνὴ ἀσθενής· διὸ καὶ ἀποπέμπεται, μὴ προσψαῦσαί σοι Χριστέ. Ἀλλʼ ὅμως κήρυξ πέμπεται τοῖς σοῖς Μαθηταῖς, οἷς εὐαγγέλια ἔφησε, τὴν πρὸς τὸν πατρῷον κλῆρον ἄνοδον ἀπαγγέλλουσα. Μεθʼ ἧς ἀξίωσον καὶ ἡμᾶς, τῆς ἐμφανείας σου, Δέσποτα Κύριε."
